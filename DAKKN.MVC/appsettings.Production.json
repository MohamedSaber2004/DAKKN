{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Auth": {
      "PermitLimit": 5,
      "WindowSeconds": 10,
      "QueueLimit": 0
    }
  },
  "UploadPaths": {
    "Root": "uploads",
    "Products": "products",
    "Categories": "categories",
    "Users": "users",
    "Invoices": "invoices",
    "Reviews": "reviews"
  }
}