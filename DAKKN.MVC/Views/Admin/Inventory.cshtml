@model DAKKN.MVC.ViewModels.Admin.InventoryViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_inventory"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<div class="space-y-6 pb-12">
    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="premium-card p-4 sm:p-6 flex items-center gap-4">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                <span class="material-symbols-outlined text-xl sm:text-2xl">inventory_2</span>
            </div>
            <div class="min-w-0">
                <p class="text-xs sm:text-sm font-semibold text-admin-secondary truncate">@Localizer["admin_inventory_total"]</p>
                <h3 class="text-lg sm:text-2xl font-black text-admin-primary">@Model.TotalProducts</h3>
            </div>
        </div>
    </div>

    <!-- Search + Add -->
    <div class="flex flex-col sm:flex-row gap-4">
        <form method="get" class="flex-1 flex flex-col sm:flex-row gap-4">
            <div class="relative flex-1">
                <input type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="@Localizer["admin_inventory_search_ph"]"
                       class="w-full bg-admin-card border border-admin-border rounded-xl px-4 py-2.5 ltr:pl-10 rtl:pr-10 outline-none focus:ring-2 focus:ring-primary/40 text-admin-primary text-sm transition-all" />
                <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-admin-secondary text-lg">search</span>
            </div>
            <button type="submit" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all whitespace-nowrap">
                <span class="material-symbols-outlined text-lg">search</span>
                @Localizer["admin_search"]
            </button>
        </form>
        <a asp-action="AddProduct" class="flex items-center justify-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all whitespace-nowrap">
            <span class="material-symbols-outlined text-lg">add</span>
            @Localizer["admin_add_product"]
        </a>
    </div>

    <!-- Category Filter Pills -->
    <div class="flex items-center gap-2 overflow-x-auto pb-2 no-scrollbar">
        <a href="@Url.Action("Inventory")" class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(Model.SelectedCategoryId == null ? "bg-primary text-on-primary" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
            @Localizer["admin_cat_all"]
        </a>
        @foreach (var cat in Model.Categories)
        {
            <a href="@Url.Action("Inventory", new { categoryId = cat.Id, searchTerm = Model.SearchTerm })"
               class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(Model.SelectedCategoryId == cat.Id ? "bg-primary text-on-primary" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
                @(isArabic ? cat.ArName : cat.CategoryName)
            </a>
        }
    </div>

    <!-- Stock Status Filter Pills -->
    <div class="flex items-center gap-2 overflow-x-auto pb-2 no-scrollbar">
        <a href="@Url.Action("Inventory", new { searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId })" 
           class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(string.IsNullOrEmpty(Model.StockFilter) ? "bg-primary text-on-primary" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
            @Localizer["admin_cat_all"]
        </a>
        <a href="@Url.Action("Inventory", new { stockFilter = "inStock", searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId })" 
           class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(Model.StockFilter == "inStock" ? "bg-green-500 text-white" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
            <span class="material-symbols-outlined text-sm align-text-bottom">check_circle</span>
            @Localizer["admin_in_stock"]
        </a>
        <a href="@Url.Action("Inventory", new { stockFilter = "lowStock", searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId })" 
           class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(Model.StockFilter == "lowStock" ? "bg-amber-500 text-white" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
            <span class="material-symbols-outlined text-sm align-text-bottom">warning</span>
            @Localizer["admin_low_stock"]
        </a>
        <a href="@Url.Action("Inventory", new { stockFilter = "outOfStock", searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId })" 
           class="px-4 py-2 rounded-full text-xs sm:text-sm font-bold whitespace-nowrap transition-all @(Model.StockFilter == "outOfStock" ? "bg-red-500 text-white" : "bg-admin-card border border-admin-border text-admin-secondary hover:border-primary/50")">
            <span class="material-symbols-outlined text-sm align-text-bottom">block</span>
            @Localizer["inventory_out_of_stock"]
        </a>
    </div>

    <!-- Sort Controls -->
    <div class="flex items-center gap-2">
        <select name="sortBy" onchange="window.location.href=this.value" class="bg-admin-card border border-admin-border rounded-xl px-3 py-2 text-xs text-admin-secondary outline-none focus:ring-1 focus:ring-primary">
            <option value="@Url.Action("Inventory", new { searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, stockFilter = Model.StockFilter })">@Localizer["admin_sort_default"]</option>
            <option value="@Url.Action("Inventory", new { sortBy = "lowest", searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, stockFilter = Model.StockFilter })" selected="@(Model.SortBy == "lowest")">@Localizer["Sort: Low to High"]</option>
            <option value="@Url.Action("Inventory", new { sortBy = "highest", searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, stockFilter = Model.StockFilter })" selected="@(Model.SortBy == "highest")">@Localizer["Sort: High to Low"]</option>
        </select>
    </div>

    <!-- Product Grid -->
    @if (!Model.Products.Any())
    {
        <div class="premium-card p-12 text-center">
            <span class="material-symbols-outlined text-5xl text-admin-secondary/40 block mb-4">inventory_2</span>
            <h4 class="text-xl font-black text-admin-primary mb-2">@Localizer["admin_inventory_empty_title"]</h4>
            <p class="text-admin-secondary text-sm mb-6">@Localizer["admin_inventory_empty_desc"]</p>
            <a asp-action="AddProduct" class="inline-flex items-center gap-2 px-6 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                <span class="material-symbols-outlined text-lg">add</span>
                @Localizer["admin_add_product"]
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 sm:gap-6">
            @foreach (var product in Model.Products)
            {
                <div class="premium-card group flex flex-col overflow-hidden h-full">
                    <!-- Image -->
                    <div class="relative aspect-square bg-surface-container overflow-hidden">
                        <img src="@product.ImageUrl" alt="@(isArabic ? product.ArName : product.Name)" loading="lazy"
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                             onerror="this.src='https://placehold.co/400x400/e2e8f0/64748b?text=No+Image'" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center pb-4 gap-2">
                            <a asp-action="EditProduct" asp-route-id="@product.Id"
                               class="w-9 h-9 rounded-full bg-white/90 text-admin-primary flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                                <span class="material-symbols-outlined text-lg">edit</span>
                            </a>
                            <a asp-action="ProductDetails" asp-route-id="@product.Id"
                               class="w-9 h-9 rounded-full bg-white/90 text-admin-primary flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </a>
                            <button type="button" onclick="openDeleteProductModal('@product.Id', '@(isArabic ? product.ArName : product.Name)')"
                                    class="w-9 h-9 rounded-full bg-white/90 text-red-500 flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                                <span class="material-symbols-outlined text-lg">delete</span>
                            </button>
                        </div>
                    </div>
                    <!-- Info -->
                    <div class="p-4 sm:p-5 flex-1 flex flex-col">
                        <div class="space-y-1 mb-2">
                            <span class="text-[10px] font-bold text-primary uppercase tracking-wider block truncate">@(isArabic ? product.CategoryArName : product.CategoryName)</span>
                            <h4 class="text-sm font-bold text-admin-primary group-hover:text-primary transition-colors truncate">@(isArabic ? product.ArName : product.Name)</h4>
                        </div>
                        <!-- Stock Status Badge -->
                        @if (product.QuantityInStock == 0)
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-red-100 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-[10px] font-bold mb-2 w-fit">
                                <span class="material-symbols-outlined text-xs">block</span>
                                @Localizer["inventory_out_of_stock"]
                            </span>
                        }
                        else if (product.QuantityInStock <= product.DangerQuantity)
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-amber-100 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 text-[10px] font-bold mb-2 w-fit">
                                <span class="material-symbols-outlined text-xs">warning</span>
                                @Localizer["admin_low_stock"] (@product.QuantityInStock)
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-green-100 dark:bg-green-900/20 text-green-600 dark:text-green-400 text-[10px] font-bold mb-2 w-fit">
                                <span class="material-symbols-outlined text-xs">check_circle</span>
                                @Localizer["admin_in_stock"] (@product.QuantityInStock)
                            </span>
                        }
                        <div class="flex items-center justify-between pt-2.5 border-t border-admin-border mt-auto">
                            <span class="text-sm font-black text-admin-primary">@product.Price.ToString("N2") @Localizer["egp"]</span>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm text-amber-500">star</span>
                                <span class="text-[11px] font-bold text-admin-secondary">@product.AverageRating.ToString("F1")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        if (Model.TotalPages > 1)
        {
            <div class="flex justify-center mt-8">
                <nav class="flex items-center gap-1 sm:gap-2 bg-admin-card p-1.5 rounded-xl border border-admin-border shadow-sm">
                    <a href="@Url.Action("Inventory", new { searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, pageNumber = Model.PageNumber - 1 })"
                       class="w-9 h-9 rounded-lg flex items-center justify-center text-admin-secondary hover:bg-primary/5 transition-all @(!Model.HasPreviousPage ? "pointer-events-none opacity-30" : "")">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a href="@Url.Action("Inventory", new { searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, pageNumber = i })"
                           class="w-9 h-9 rounded-lg flex items-center justify-center text-xs sm:text-sm font-bold transition-all @(i == Model.PageNumber ? "bg-primary text-on-primary" : "text-admin-secondary hover:bg-primary/5")">@i</a>
                    }
                    <a href="@Url.Action("Inventory", new { searchTerm = Model.SearchTerm, categoryId = Model.SelectedCategoryId, pageNumber = Model.PageNumber + 1 })"
                       class="w-9 h-9 rounded-lg flex items-center justify-center text-admin-secondary hover:bg-primary/5 transition-all @(!Model.HasNextPage ? "pointer-events-none opacity-30" : "")">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                </nav>
            </div>
        }
    }
</div>

<!-- Delete Product Modal -->
<div id="deleteProductModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" onclick="closeDeleteProductModal()"></div>
    <div class="relative bg-white dark:bg-[#161d27] rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4 border border-admin-border z-10">
        <div class="text-center">
            <div class="mx-auto w-14 h-14 rounded-full bg-red-100 dark:bg-red-900/20 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-3xl text-red-500">delete_forever</span>
            </div>
            <h3 class="text-xl font-bold text-admin-primary mb-2">@Localizer["admin_product_delete_confirm_title"]</h3>
            <p class="text-admin-secondary text-sm mb-1">@Localizer["admin_product_delete_confirm_message"]</p>
            <p class="text-admin-primary font-semibold text-base mb-6" id="deleteProductModalName"></p>
        </div>
        <form id="deleteProductForm" method="post" class="flex gap-3">
            @Html.AntiForgeryToken()
            <button type="button" onclick="closeDeleteProductModal()" class="flex-1 px-4 py-2.5 rounded-xl border border-admin-border text-admin-primary font-medium text-sm hover:bg-admin-page transition-all">
                @Localizer["admin_cancel"]
            </button>
            <button type="submit" class="flex-1 px-4 py-2.5 rounded-xl bg-red-500 text-white font-medium text-sm hover:bg-red-600 transition-all">
                @Localizer["admin_categories_actions"]
            </button>
        </form>
    </div>
</div>

<script>
    var deleteProductModal = document.getElementById('deleteProductModal');
    var deleteProductForm = document.getElementById('deleteProductForm');
    var deleteProductModalName = document.getElementById('deleteProductModalName');

    function openDeleteProductModal(id, name) {
        deleteProductForm.action = '/admin/delete-product/' + id;
        deleteProductModalName.textContent = '"' + name + '"';
        deleteProductModal.classList.remove('hidden');
    }

    function closeDeleteProductModal() {
        deleteProductModal.classList.add('hidden');
    }

    deleteProductModal.addEventListener('click', function(e) {
        if (e.target === deleteProductModal) {
            closeDeleteProductModal();
        }
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteProductModal();
        }
    });
</script>
