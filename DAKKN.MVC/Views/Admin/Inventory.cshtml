@model DAKKN.MVC.ViewModels.Admin.InventoryViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_inventory"];
}

<div class="space-y-8 pb-12">
    <!-- 1. Inventory Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-2xl">inventory_2</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_inventory_total"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.TotalProducts</h3>
            </div>
        </div>
    </div>

    <!-- 2. Search and Filters -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-4 w-full md:w-auto">
            <div class="relative flex-grow md:w-64">
                <input type="text" placeholder="@Localizer["admin_inventory_search_ph"]" class="w-full bg-admin-card border border-admin-border rounded-xl px-4 py-2.5 ltr:pl-10 rtl:pr-10 outline-none focus:ring-1 focus:ring-primary text-admin-primary text-sm shadow-sm transition-all" />
                <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-admin-secondary">search</span>
            </div>
            <a asp-action="AddProduct" class="flex items-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all whitespace-nowrap">
                <span class="material-symbols-outlined text-lg">add</span>
                @Localizer["admin_add_product"]
            </a>
        </div>
    </div>

    <!-- 3. Product Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var product in Model.Products)
        {
            <div class="premium-card group flex flex-col overflow-hidden">
                <div class="relative aspect-square bg-surface-container overflow-hidden">
                    <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                        <a asp-action="EditProduct" asp-route-id="@product.Id" class="w-10 h-10 rounded-full bg-white text-admin-primary flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                            <span class="material-symbols-outlined">edit</span>
                        </a>
                        <button class="w-10 h-10 rounded-full bg-white text-red-500 flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                </div>
                <div class="p-5 space-y-3">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="text-[10px] font-bold text-primary uppercase tracking-wider">@product.CategoryName</span>
                            <h4 class="text-sm font-bold text-admin-primary group-hover:text-primary transition-colors">@product.Name</h4>
                        </div>
                        <span class="text-sm font-black text-admin-primary">@product.Price @Localizer["egp"]</span>
                    </div>
                    <div class="flex items-center justify-between pt-2 border-t border-admin-border">
                        <div class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-sm text-amber-500">star</span>
                            <span class="text-[11px] font-bold text-admin-secondary">@product.AverageRating.ToString("F1") (@product.ReviewCount)</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
