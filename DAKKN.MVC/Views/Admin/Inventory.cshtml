@model DAKKN.MVC.ViewModels.Admin.InventoryViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_inventory"];
}

<div class="space-y-8 pb-12">
    <!-- 1. Inventory Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-2xl">inventory_2</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_inventory_total"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.TotalProducts</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center text-red-600">
                <span class="material-symbols-outlined text-2xl">error</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_inventory_low_stock"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.LowStockAlerts</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-2xl">category</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_inventory_categories"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.CategoriesCount</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-2xl">account_balance_wallet</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_inventory_value"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.TotalStockValue</h3>
            </div>
        </div>
    </div>

    <!-- 2. Search and Filters -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 no-scrollbar w-full md:w-auto">
            <button class="px-5 py-2.5 rounded-xl bg-primary text-on-primary text-sm font-bold shadow-small transition-all whitespace-nowrap">@Localizer["admin_cat_all"]</button>
            <button class="px-5 py-2.5 rounded-xl bg-admin-page border border-admin-border text-admin-secondary text-sm font-bold hover:bg-surface-container transition-all whitespace-nowrap">@Localizer["cat_Gaming"]</button>
            <button class="px-5 py-2.5 rounded-xl bg-admin-page border border-admin-border text-admin-secondary text-sm font-bold hover:bg-surface-container transition-all whitespace-nowrap">@Localizer["cat_Anime"]</button>
            <button class="px-5 py-2.5 rounded-xl bg-admin-page border border-admin-border text-admin-secondary text-sm font-bold hover:bg-surface-container transition-all whitespace-nowrap">@Localizer["cat_Memes"]</button>
        </div>

        <div class="flex items-center gap-4 w-full md:w-auto">
            <div class="relative flex-grow md:w-64">
                <input type="text" placeholder="@Localizer["admin_inventory_search_ph"]" class="w-full bg-admin-card border border-admin-border rounded-xl px-4 py-2.5 ltr:pl-10 rtl:pr-10 outline-none focus:ring-1 focus:ring-primary text-admin-primary text-sm shadow-sm transition-all" />
                <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-admin-secondary">search</span>
            </div>
            <a asp-action="AddProduct" class="flex items-center gap-2 px-5 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all whitespace-nowrap">
                <span class="material-symbols-outlined text-lg">add</span>
                @Localizer["admin_add_product"]
            </a>
        </div>
    </div>

    <!-- 3. Product Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var product in Model.Products)
        {
            <div class="admin-card group flex flex-col overflow-hidden">
                <div class="relative aspect-square bg-surface-container overflow-hidden">
                    <img src="@product.ImageUrl" alt="@product.Name" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                    <div class="absolute top-4 ltr:right-4 rtl:left-4">
                        @if (product.IsLowStock)
                        {
                            <span class="bg-red-500 text-white text-[10px] font-bold px-2 py-1 rounded-lg shadow-lg">@Localizer["admin_low_stock"]</span>
                        }
                    </div>
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                        <a asp-action="EditProduct" asp-route-id="@product.Id" class="w-10 h-10 rounded-full bg-white text-admin-primary flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                            <span class="material-symbols-outlined">edit</span>
                        </a>
                        <button class="w-10 h-10 rounded-full bg-white text-red-500 flex items-center justify-center hover:scale-110 transition-transform shadow-lg">
                            <span class="material-symbols-outlined">delete</span>
                        </button>
                    </div>
                </div>
                <div class="p-5 space-y-3">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="text-[10px] font-bold text-primary uppercase tracking-wider">@Localizer[$"cat_{product.Category}"]</span>
                            <h4 class="text-sm font-bold text-admin-primary group-hover:text-primary transition-colors">@product.Name</h4>
                        </div>
                        <span class="text-sm font-black text-admin-primary">@product.Price @Localizer["egp"]</span>
                    </div>
                    <div class="flex items-center justify-between pt-2 border-t border-admin-border">
                        <div class="flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 rounded-full @(product.StockLevel > 20 ? "bg-green-500" : product.StockLevel > 0 ? "bg-amber-500" : "bg-red-500")"></span>
                            <span class="text-[11px] font-bold text-admin-secondary">@product.StockLevel @Localizer["admin_in_stock"]</span>
                        </div>
                        <span class="text-[11px] font-medium text-admin-secondary">@product.Sku</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- 4. Pagination -->
    <div class="flex justify-center pt-8">
        <div class="flex items-center gap-2">
            <button class="w-10 h-10 rounded-xl border border-admin-border text-admin-secondary flex items-center justify-center hover:bg-admin-page transition-all">
                <span class="material-symbols-outlined text-lg">chevron_right</span>
            </button>
            <button class="w-10 h-10 rounded-xl bg-primary text-on-primary text-sm font-bold shadow-small">1</button>
            <button class="w-10 h-10 rounded-xl border border-admin-border text-admin-secondary text-sm font-bold hover:bg-admin-page transition-all">2</button>
            <button class="w-10 h-10 rounded-xl border border-admin-border text-admin-secondary text-sm font-bold hover:bg-admin-page transition-all">3</button>
            <button class="w-10 h-10 rounded-xl border border-admin-border text-admin-secondary flex items-center justify-center hover:bg-admin-page transition-all">
                <span class="material-symbols-outlined text-lg">chevron_left</span>
            </button>
        </div>
    </div>
</div>
