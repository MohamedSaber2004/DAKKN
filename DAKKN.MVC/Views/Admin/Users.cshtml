@model DAKKN.MVC.ViewModels.Admin.UserManagementViewModel
@using DAKKN.MVC.ViewModels.Admin
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_users"];
}

<div id="statsGridContainer" class="pb-6 sm:pb-8">
    @await Html.PartialAsync("_UserStatsPartial", Model)
</div>

<!-- 2. Table and Filters -->
<div class="premium-card relative overflow-hidden">
    <!-- Table Loader Overlay -->
    <div id="tableLoader" class="hidden absolute inset-0 bg-surface/60 dark:bg-admin-page/60 z-20 flex items-center justify-center backdrop-blur-[2px] transition-all">
        <div class="flex flex-col items-center gap-3">
            <div class="w-10 h-10 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
            <p class="text-sm font-bold text-admin-primary">@Localizer["loading_data"]</p>
        </div>
    </div>

    <form id="usersFilterForm" class="p-4 sm:p-8 border-b border-admin-border space-y-4 sm:space-y-6">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
            <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_users_list"]</h3>
            <div class="flex flex-wrap gap-2 sm:gap-3 w-full lg:w-auto">
                <button type="button" onclick="downloadExportCsv()" class="flex-1 lg:flex-none flex items-center justify-center gap-2 px-4 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-sm font-bold hover:bg-surface-container dark:hover:bg-slate-800 transition-all">
                    <span class="material-symbols-outlined text-lg">download</span>
                    @Localizer["admin_export_csv"]
                </button>
                <button type="button" onclick="openUserModal()" class="flex-1 lg:flex-none flex items-center justify-center gap-2 px-4 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                    <span class="material-symbols-outlined text-lg">person_add</span>
                    @Localizer["admin_add_user"]
                </button>
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-3 sm:gap-4">
            <div class="relative flex-grow group">
                <input type="text" name="searchTerm" id="searchTermSearch" value="@Context.Request.Query["searchTerm"]" onkeyup="handleSearchKeyUp(event)" placeholder="@Localizer["admin_users_search_ph"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-2.5 ltr:pl-10 rtl:pr-10 ltr:pr-10 rtl:pl-10 outline-none focus:ring-1 focus:ring-primary text-admin-primary text-sm transition-all" />
                <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-admin-secondary">search</span>
                
                <button type="button" id="clearSearchBtn" onclick="clearSearch()" class="hidden absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 text-admin-secondary hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined text-lg">close</span>
                </button>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
                <div class="relative flex-1 sm:flex-none">
                    <select name="role" id="roleFilter" onchange="refreshUserList(1)" class="w-full appearance-none bg-none bg-admin-page border border-admin-border text-admin-primary text-sm rounded-xl px-4 py-2.5 ltr:pr-12 rtl:pl-12 outline-none focus:ring-1 focus:ring-primary cursor-pointer sm:min-w-[140px]">
                        <option value="">@Localizer["admin_filter_role"]</option>
                        <option value="Admin">@Localizer["role_Admin"]</option>
                        <option value="User">@Localizer["role_Customer"]</option>
                    </select>
                    <span class="material-symbols-outlined absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 pointer-events-none text-admin-secondary">expand_more</span>
                </div>
                
                <div class="relative flex-1 sm:flex-none">
                    <select name="status" id="statusFilter" onchange="refreshUserList(1)" class="w-full appearance-none bg-none bg-admin-page border border-admin-border text-admin-primary text-sm rounded-xl px-4 py-2.5 ltr:pr-12 rtl:pl-12 outline-none focus:ring-1 focus:ring-primary cursor-pointer sm:min-w-[140px]">
                        <option value="">@Localizer["admin_filter_status"]</option>
                        <option value="Active">@Localizer["status_Active"]</option>
                        <option value="Deleted">@Localizer["status_Deleted"]</option>
                    </select>
                    <span class="material-symbols-outlined absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 pointer-events-none text-admin-secondary">expand_more</span>
                </div>
            </div>
        </div>
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
    </form>

    <div id="dynamicListContainer">
        @await Html.PartialAsync("_UserTablePartial", Model)
    </div>
</div>

<!-- Modals -->

<!-- User Modal -->
<div id="userModal" class="hidden fixed inset-0 bg-black/60 dark:bg-black/80 z-[100] flex items-center justify-center p-4 backdrop-blur-sm transition-all duration-300">
    <div class="bg-surface dark:bg-[#161d27] w-full max-w-lg rounded-[2rem] shadow-2xl overflow-hidden scale-95 opacity-0 transition-all duration-300 border border-transparent dark:border-white/5" id="userModalContent">
        <!-- Modal Header -->
        <div class="p-6 border-b border-border dark:border-outline/10 flex justify-between items-center bg-primary/5 dark:bg-primary/10">
            <h3 id="modalTitle" class="text-xl font-black text-primary">@Localizer["admin_add_user"]</h3>
            <button onclick="closeUserModal()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:bg-surface-container dark:hover:bg-white/5 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <!-- Modal Body -->
        <form id="userForm" class="p-6 space-y-4 max-h-[70vh] overflow-y-auto custom-scrollbar">
            <input type="hidden" id="userId" name="id" />
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_full_name"]</label>
                    <input type="text" id="userFullName" name="fullName" required class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition-all text-admin-primary" />
                </div>
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_email"]</label>
                    <input type="email" id="userEmail" name="email" required class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition-all text-admin-primary" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div id="passwordFieldContainer" class="space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_password"]</label>
                    <input type="password" id="userPassword" name="password" class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition-all text-admin-primary" />
                    <p id="passwordHint" class="hidden text-[10px] text-text-secondary px-1">@Localizer["admin_user_password_hint"]</p>
                </div>
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_phone"]</label>
                    <input type="text" id="userPhone" name="phoneNumber" class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition-all text-admin-primary" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_role"]</label>
                    <div class="relative">
                        <select id="userRole" name="role" required class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition-all appearance-none cursor-pointer bg-none text-admin-primary">
                            <option value="Admin">@Localizer["role_Admin"]</option>
                            <option value="User">@Localizer["role_Customer"]</option>
                        </select>
                        <span class="material-symbols-outlined absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 pointer-events-none text-text-secondary">expand_more</span>
                    </div>
                </div>
                <div id="joinDateField" class="hidden space-y-1.5">
                    <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_th_join_date"]</label>
                    <input type="date" id="userJoinDate" disabled class="w-full bg-surface-container/50 dark:bg-[#1a2535]/50 border-none rounded-2xl px-4 py-3 text-sm outline-none cursor-not-allowed text-admin-primary" />
                </div>
            </div>

            <div id="statusField" class="hidden space-y-1.5">
                <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_user_status"]</label>
                <div class="flex items-center gap-4 py-2 px-1">
                    <label class="inline-flex items-center cursor-pointer">
                        <input type="checkbox" id="userIsActive" name="isActive" class="sr-only peer" checked>
                        <div class="relative w-11 h-6 bg-border peer-focus:outline-none rounded-full peer dark:bg-outline/20 peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:ltr:left-[2px] after:rtl:right-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-primary"></div>
                        <span class="ltr:ml-3 rtl:mr-3 text-sm font-medium text-admin-primary">@Localizer["admin_active"]</span>
                    </label>
                </div>
            </div>
        </form>
        
        <!-- Modal Footer -->
        <div class="p-6 border-t border-border dark:border-outline/10 flex gap-3 bg-surface-container/30 dark:bg-black/20">
            <button onclick="closeUserModal()" class="flex-1 px-6 py-3 border border-border dark:border-outline/20 text-text-secondary hover:bg-surface-container dark:hover:bg-white/5 rounded-2xl text-sm font-bold transition-all">
                @Localizer["admin_user_cancel"]
            </button>
            <button onclick="saveUser()" class="flex-1 px-6 py-3 bg-primary text-on-primary rounded-2xl text-sm font-bold shadow-medium hover:scale-102 active:scale-98 transition-all flex items-center justify-center gap-2">
                <span id="saveBtnText">@Localizer["admin_user_save"]</span>
                <div id="saveLoader" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
            </button>
        </div>
    </div>
</div>

<!-- Change Password Modal -->
<div id="changePasswordModal" class="hidden fixed inset-0 bg-black/60 dark:bg-black/80 z-[110] flex items-center justify-center p-4 backdrop-blur-sm transition-all duration-300">
    <div class="bg-surface dark:bg-[#161d27] w-full max-w-sm rounded-[2rem] shadow-2xl overflow-hidden scale-95 opacity-0 transition-all duration-300 border border-transparent dark:border-white/5" id="changePasswordModalContent">
        <!-- Modal Header -->
        <div class="p-6 border-b border-border dark:border-outline/10 flex justify-between items-center bg-amber-500/5 dark:bg-amber-500/10">
            <h3 class="text-xl font-black text-amber-600">@Localizer["admin_change_password"]</h3>
            <button onclick="closeChangePasswordModal()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:bg-surface-container dark:hover:bg-white/5 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        
        <!-- Modal Body -->
        <div class="p-6 space-y-4">
            <input type="hidden" id="changePasswordUserId" />
            <div class="space-y-1.5">
                <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_new_password"]</label>
                <input type="password" id="newPassword" class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-amber-500 outline-none transition-all text-admin-primary" />
            </div>
            <div class="space-y-1.5">
                <label class="text-xs font-bold text-text-secondary dark:text-admin-text-secondary px-1">@Localizer["admin_confirm_password"]</label>
                <input type="password" id="confirmPassword" class="w-full bg-surface-container dark:bg-[#1a2535] border-none rounded-2xl px-4 py-3 text-sm focus:ring-2 focus:ring-amber-500 outline-none transition-all text-admin-primary" />
            </div>
        </div>
        
        <!-- Modal Footer -->
        <div class="p-6 border-t border-border dark:border-outline/10 flex gap-3 bg-amber-500/5 dark:bg-black/20">
            <button onclick="closeChangePasswordModal()" class="flex-1 px-6 py-3 border border-border dark:border-outline/20 text-text-secondary hover:bg-surface-container dark:hover:bg-white/5 rounded-2xl text-sm font-bold transition-all">
                @Localizer["admin_user_cancel"]
            </button>
            <button onclick="confirmChangePassword()" class="flex-1 px-6 py-3 bg-amber-500 text-white rounded-2xl text-sm font-bold shadow-medium hover:bg-amber-600 transition-all flex items-center justify-center gap-2">
                <span id="changePassBtnText">@Localizer["admin_update_password"]</span>
                <div id="changePassLoader" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
            </button>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 bg-black/60 dark:bg-black/80 z-[110] flex items-center justify-center p-4 backdrop-blur-sm transition-all duration-300">
    <div class="bg-surface dark:bg-[#161d27] w-full max-w-sm rounded-[2rem] shadow-2xl overflow-hidden scale-95 opacity-0 transition-all duration-300 border border-transparent dark:border-white/5" id="deleteModalContent">
        <div class="p-8 text-center space-y-4">
            <div class="w-20 h-20 bg-red-50 dark:bg-red-900/10 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4 animate-bounce">
                <span class="material-symbols-outlined text-4xl">delete_forever</span>
            </div>
            <h3 class="text-xl font-black text-admin-primary">@Localizer["admin_delete_user"]</h3>
            <p class="text-sm text-admin-secondary leading-relaxed px-2">@Localizer["admin_delete_user_confirm"]</p>
        </div>
        <div class="p-6 border-t border-border dark:border-outline/10 flex gap-3 bg-red-50/30 dark:bg-black/20">
            <button onclick="closeDeleteModal()" class="flex-1 px-6 py-3 border border-border dark:border-outline/20 text-text-secondary hover:bg-surface-container dark:hover:bg-white/5 rounded-2xl text-sm font-bold transition-all">
                @Localizer["admin_user_cancel"]
            </button>
            <button onclick="confirmDeleteUser()" class="flex-1 px-6 py-3 bg-red-500 text-white rounded-2xl text-sm font-bold shadow-medium hover:bg-red-600 transition-all flex items-center justify-center gap-2">
                <span id="deleteBtnText">@Localizer["admin_user_delete"]</span>
                <div id="deleteLoader" class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
            </button>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="toastContainer" class="fixed bottom-8 ltr:right-8 rtl:left-8 z-[200] flex flex-col gap-3"></div>

<script>
    let currentDeleteUserId = null;
    let searchTimer = null;

    function handleSearchKeyUp(event) {
        const clearBtn = document.getElementById('clearSearchBtn');
        clearBtn.classList.toggle('hidden', event.target.value === '');
        
        clearTimeout(searchTimer);
        searchTimer = setTimeout(() => {
            refreshUserList(1);
        }, 500);
    }

    function clearSearch() {
        document.getElementById('searchTermSearch').value = '';
        document.getElementById('clearSearchBtn').classList.add('hidden');
        refreshUserList(1);
    }

    async function refreshUserList(pageNumber = 1) {
        const statsContainer = document.getElementById('statsGridContainer');
        const listContainer = document.getElementById('dynamicListContainer');
        const loader = document.getElementById('tableLoader');
        
        if (loader) loader.classList.remove('hidden');
        
        const searchTerm = document.getElementById('searchTermSearch').value;
        const role = document.getElementById('roleFilter').value;
        const status = document.getElementById('statusFilter').value;
        const pageSize = document.querySelector('input[name="pageSize"]')?.value || 10;
        
        const url = new URL(window.location.origin + '@Url.Action("Users")');
        url.searchParams.set('searchTerm', searchTerm);
        url.searchParams.set('role', role);
        url.searchParams.set('status', status);
        url.searchParams.set('pageNumber', pageNumber);
        url.searchParams.set('pageSize', pageSize);
        url.searchParams.set('_', Date.now()); // Cache buster

        // Update URL in browser without reload
        window.history.pushState({}, '', url);

        try {
            const response = await fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                },
                cache: 'no-store'
            });

            if (response.ok) {
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                const statsPart = doc.getElementById('statsPart');
                const tablePart = doc.getElementById('tablePart');
                
                if (statsPart && statsContainer) {
                    statsContainer.innerHTML = statsPart.innerHTML;
                }
                if (tablePart && listContainer) {
                    listContainer.innerHTML = tablePart.innerHTML;
                }
            } else {
                showToast('@Localizer["admin_list_refresh_error"]', 'error');
            }
        } catch (error) {
            console.error('Refresh error:', error);
            showToast('@Localizer["admin_connection_error"]', 'error');
        } finally {
            if (loader) loader.classList.add('hidden');
        }
    }

    function loadPage(pageNumber) {
        refreshUserList(pageNumber);
    }

    function downloadExportCsv() {
        const searchTerm = document.getElementById('searchTermSearch').value;
        const role = document.getElementById('roleFilter').value;
        const status = document.getElementById('statusFilter').value;
        
        const url = new URL(window.location.origin + '@Url.Action("ExportUsers")');
        url.searchParams.set('searchTerm', searchTerm);
        url.searchParams.set('role', role);
        url.searchParams.set('status', status);
        
        window.location.href = url.toString();
    }

    /* ── User Modal Logic ──────────────────────────── */

    function openUserModal(userId = null) {
        const modal = document.getElementById('userModal');
        const content = document.getElementById('userModalContent');
        const form = document.getElementById('userForm');
        const title = document.getElementById('modalTitle');
        const passHint = document.getElementById('passwordHint');
        const statusField = document.getElementById('statusField');
        const joinDateField = document.getElementById('joinDateField');
        const passInput = document.getElementById('userPassword');
        const passwordFieldContainer = document.getElementById('passwordFieldContainer');
        
        form.reset();
        document.getElementById('userId').value = userId || '';
        
        if (userId) {
            title.textContent = "@Localizer["admin_edit_user"]";
            passHint.classList.remove('hidden');
            statusField.classList.remove('hidden');
            joinDateField.classList.remove('hidden');
            passwordFieldContainer.classList.add('hidden');
            passInput.required = false;
            fetchUserDetails(userId);
        } else {
            title.textContent = "@Localizer["admin_add_user"]";
            passHint.classList.add('hidden');
            statusField.classList.add('hidden');
            joinDateField.classList.add('hidden');
            passwordFieldContainer.classList.remove('hidden');
            passInput.required = true;
        }

        modal.classList.remove('hidden');
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeUserModal() {
        const modal = document.getElementById('userModal');
        const content = document.getElementById('userModalContent');
        content.classList.add('scale-95', 'opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    async function fetchUserDetails(userId) {
        try {
            const response = await fetch(`/api/v1/users/${userId}?_=${Date.now()}`);
            const result = await response.json();
            
            if (result.success) {
                const user = result.data;
                document.getElementById('userFullName').value = user.fullName;
                document.getElementById('userEmail').value = user.email;
                document.getElementById('userPhone').value = user.phoneNumber || '';
                // Inactive is Deleted in our business
                document.getElementById('userIsActive').checked = user.isActive && !user.isDeleted;

                if (user.joinDate) {
                    document.getElementById('userJoinDate').value = user.joinDate.split('T')[0];
                }
                
                // Handle Role (assuming first role for simplicity)
                if (user.roles && user.roles.length > 0) {
                    document.getElementById('userRole').value = user.roles[0];
                }
            } else {
                showToast(result.message || '@Localizer["admin_fetch_error"]', 'error');
            }
        } catch (error) {
            console.error('Fetch user details error:', error);
            showToast('@Localizer["admin_connection_error"]', 'error');
        }
    }

    async function saveUser() {
        const userId = document.getElementById('userId').value;
        const form = document.getElementById('userForm');
        
        if (!form.reportValidity()) return;

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        data.isActive = document.getElementById('userIsActive').checked;
        
        // MediatR command expectations
        if (userId) data.id = userId;

        const method = userId ? 'PUT' : 'POST';
        const url = userId ? `/api/v1/users/${userId}` : '/api/v1/users';

        setSaveLoading(true);
        // Show table loader to indicate refresh
        const tableLoader = document.getElementById('tableLoader');
        if (tableLoader) tableLoader.classList.remove('hidden');

        try {
            const response = await fetch(url, {
                method: method,
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify(data)
            });

            const result = await response.json();

            if (response.ok && result.success) {
                showToast(userId ? "@Localizer["admin_user_updated_success"]" : "@Localizer["admin_user_created_success"]", 'success');
                closeUserModal();
                // Get current page from URL
                const currentPage = new URLSearchParams(window.location.search).get('pageNumber') || 1;
                await refreshUserList(currentPage); 
            } else {
                let errorMsg = result.message || 'Validation error';
                if (result.errors) {
                    errorMsg = Object.values(result.errors).flat().join('<br>');
                }
                showToast(errorMsg, 'error');
                if (tableLoader) tableLoader.classList.add('hidden');
            }
        } catch (error) {
            showToast('@Localizer["admin_server_connection_error"]', 'error');
            if (tableLoader) tableLoader.classList.add('hidden');
        } finally {
            setSaveLoading(false);
        }
    }

    function setSaveLoading(loading) {
        document.getElementById('saveBtnText').classList.toggle('hidden', loading);
        document.getElementById('saveLoader').classList.toggle('hidden', !loading);
        document.querySelector('button[onclick="saveUser()"]').disabled = loading;
    }

    /* ── Change Password Logic ─────────────────────── */

    function openChangePasswordModal(userId) {
        document.getElementById('changePasswordUserId').value = userId;
        document.getElementById('newPassword').value = '';
        document.getElementById('confirmPassword').value = '';
        
        const modal = document.getElementById('changePasswordModal');
        const content = document.getElementById('changePasswordModalContent');
        
        modal.classList.remove('hidden');
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeChangePasswordModal() {
        const modal = document.getElementById('changePasswordModal');
        const content = document.getElementById('changePasswordModalContent');
        content.classList.add('scale-95', 'opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    async function confirmChangePassword() {
        const userId = document.getElementById('changePasswordUserId').value;
        const newPassword = document.getElementById('newPassword').value;
        const confirmPassword = document.getElementById('confirmPassword').value;

        if (!newPassword || newPassword.length < 6) {
            showToast("@Localizer["admin_password_min_length"]", 'error');
            return;
        }

        if (newPassword !== confirmPassword) {
            showToast("@Localizer["admin_password_mismatch"]", 'error');
            return;
        }

        setChangePassLoading(true);
        const tableLoader = document.getElementById('tableLoader');
        if (tableLoader) tableLoader.classList.remove('hidden');

        try {
            const response = await fetch(`/api/v1/users/${userId}/change-password`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify({ password: newPassword })
            });

            const result = await response.json();

            if (response.ok && result.success) {
                showToast("@Localizer["admin_password_updated_success"]", 'success');
                closeChangePasswordModal();
                await refreshUserList(); 
            } else {
                showToast(result.message || '@Localizer["admin_password_update_error"]', 'error');
                if (tableLoader) tableLoader.classList.add('hidden');
            }
        } catch (error) {
            showToast('@Localizer["admin_connection_error"]', 'error');
            if (tableLoader) tableLoader.classList.add('hidden');
        } finally {
            setChangePassLoading(false);
        }
    }

    function setChangePassLoading(loading) {
        document.getElementById('changePassBtnText').classList.toggle('hidden', loading);
        document.getElementById('changePassLoader').classList.toggle('hidden', !loading);
        document.querySelector('button[onclick="confirmChangePassword()"]').disabled = loading;
    }

    /* ── Delete Logic ──────────────────────────────── */

    function openDeleteModal(userId) {
        currentDeleteUserId = userId;
        const modal = document.getElementById('deleteModal');
        const content = document.getElementById('deleteModalContent');
        
        modal.classList.remove('hidden');
        setTimeout(() => {
            content.classList.remove('scale-95', 'opacity-0');
            content.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        const content = document.getElementById('deleteModalContent');
        content.classList.add('scale-95', 'opacity-0');
        content.classList.remove('scale-100', 'opacity-100');
        setTimeout(() => {
            modal.classList.add('hidden');
            currentDeleteUserId = null;
        }, 300);
    }

    async function confirmDeleteUser() {
        if (!currentDeleteUserId) return;

        setDeleteLoading(true);
        const tableLoader = document.getElementById('tableLoader');
        if (tableLoader) tableLoader.classList.remove('hidden');

        try {
            const response = await fetch(`/api/v1/users/${currentDeleteUserId}`, {
                method: 'DELETE',
                headers: {
                    'RequestVerificationToken': window.csrfToken
                }
            });

            const result = await response.json();

            if (response.ok && result.success) {
                showToast("@Localizer["admin_user_deleted_success"]", 'success');
                closeDeleteModal();
                const currentPage = new URLSearchParams(window.location.search).get('pageNumber') || 1;
                await refreshUserList(currentPage); 
            } else {
                showToast(result.message || '@Localizer["admin_delete_error"]', 'error');
                if (tableLoader) tableLoader.classList.add('hidden');
            }
        } catch (error) {
            showToast('@Localizer["admin_connection_error"]', 'error');
            if (tableLoader) tableLoader.classList.add('hidden');
        } finally {
            setDeleteLoading(false);
        }
    }

    function setDeleteLoading(loading) {
        document.getElementById('deleteBtnText').classList.toggle('hidden', loading);
        document.getElementById('deleteLoader').classList.toggle('hidden', !loading);
        document.querySelector('button[onclick="confirmDeleteUser()"]').disabled = loading;
    }

    /* ── Toast Logic ────────────────────────────────── */

    function showToast(message, type = 'success') {
        const container = document.getElementById('toastContainer');
        const toast = document.createElement('div');
        
        const bgColor = type === 'success' ? 'bg-primary' : 'bg-red-500';
        const icon = type === 'success' ? 'check_circle' : 'error';
        
        toast.className = `${bgColor} text-white px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-slide-in opacity-0 translate-y-4 transition-all duration-300`;
        toast.innerHTML = `
            <span class="material-symbols-outlined">${icon}</span>
            <span class="text-sm font-bold">${message}</span>
        `;
        
        container.appendChild(toast);
        
        // Trigger animation
        setTimeout(() => {
            toast.classList.remove('opacity-0', 'translate-y-4');
            toast.classList.add('opacity-100', 'translate-y-0');
        }, 10);
        
        // Auto-remove
        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-y--4');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    }
</script>

