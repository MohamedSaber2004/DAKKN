@model DAKKN.MVC.ViewModels.Admin.UserManagementViewModel
@using DAKKN.MVC.ViewModels.Admin
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_users"];
}

<div class="space-y-8 pb-12">
    <!-- 1. Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-2xl">group</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_users_total"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.TotalUsers</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center text-green-600">
                <span class="material-symbols-outlined text-2xl">person_check</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_users_active"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.ActiveUsers</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-2xl">palette</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_users_designers"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.DesignersCount</h3>
            </div>
        </div>

        <div class="admin-card p-6 flex flex-col gap-4">
            <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center text-red-600">
                <span class="material-symbols-outlined text-2xl">block</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_users_blocked"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.BlockedUsers</h3>
            </div>
        </div>
    </div>

    <!-- 2. Table and Filters -->
    <div class="admin-card">
        <div class="p-8 border-b border-admin-border space-y-6">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_users_list"]</h3>
                <div class="flex gap-3">
                    <button class="flex items-center gap-2 px-4 py-2 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-sm font-bold hover:bg-surface-container transition-all">
                        <span class="material-symbols-outlined text-lg">download</span>
                        @Localizer["admin_export_csv"]
                    </button>
                    <button class="flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                        <span class="material-symbols-outlined text-lg">person_add</span>
                        @Localizer["admin_add_user"]
                    </button>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
                <div class="relative flex-grow">
                    <input type="text" placeholder="@Localizer["admin_users_search_ph"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-2.5 ltr:pl-10 rtl:pr-10 outline-none focus:ring-1 focus:ring-primary text-admin-primary text-sm transition-all" />
                    <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-admin-secondary">search</span>
                </div>
                <div class="flex gap-4">
                    <select class="bg-admin-page border border-admin-border text-admin-primary text-sm rounded-xl px-4 py-2.5 outline-none focus:ring-1 focus:ring-primary cursor-pointer min-w-[140px]">
                        <option value="">@Localizer["admin_filter_role"]</option>
                        <option value="Admin">@Localizer["role_Admin"]</option>
                        <option value="Designer">@Localizer["role_Designer"]</option>
                        <option value="Customer">@Localizer["role_Customer"]</option>
                    </select>
                    <select class="bg-admin-page border border-admin-border text-admin-primary text-sm rounded-xl px-4 py-2.5 outline-none focus:ring-1 focus:ring-primary cursor-pointer min-w-[140px]">
                        <option value="">@Localizer["admin_filter_status"]</option>
                        <option value="Active">@Localizer["status_Active"]</option>
                        <option value="Blocked">@Localizer["status_Blocked"]</option>
                        <option value="UnderReview">@Localizer["status_UnderReview"]</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left rtl:text-right users-table">
                <thead class="bg-admin-page/30 text-admin-secondary uppercase text-[11px] font-bold tracking-wider">
                    <tr>
                        <th class="px-8 py-4"><input type="checkbox" class="rounded border-admin-border text-primary focus:ring-primary" /></th>
                        <th class="px-8 py-4">@Localizer["admin_th_user"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_contact"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_join_date"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_role"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_status"]</th>
                        <th class="px-8 py-4 text-center">@Localizer["admin_th_action"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-admin-border">
                    @foreach (var user in Model.Users)
                    {
                        <tr class="hover:bg-admin-page/50 transition-colors group">
                            <td class="px-8 py-5"><input type="checkbox" class="rounded border-admin-border text-primary focus:ring-primary" /></td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-surface-container overflow-hidden shadow-small">
                                        <img src="@user.AvatarUrl" alt="@user.Name" class="w-full h-full object-cover" />
                                    </div>
                                    <span class="font-bold text-admin-primary">@user.Name</span>
                                </div>
                            </td>
                            <td class="px-8 py-5">
                                <div class="flex flex-col text-xs">
                                    <span class="text-admin-primary font-medium">@user.Email</span>
                                    <span class="text-admin-secondary">@user.Phone</span>
                                </div>
                            </td>
                            <td class="px-8 py-5 text-admin-secondary">@user.JoinDate.ToString("yyyy-MM-dd")</td>
                            <td class="px-8 py-5">
                                <span class="px-3 py-1 rounded-full text-[11px] font-bold border @(user.Role == UserRole.Admin ? "bg-primary/5 border-primary/20 text-primary" : user.Role == UserRole.Designer ? "bg-secondary/5 border-secondary/20 text-secondary" : "bg-admin-page border-admin-border text-admin-secondary")">
                                    @Localizer[$"role_{user.Role}"]
                                </span>
                            </td>
                            <td class="px-8 py-5">
                                <span class="status-badge @(user.Status == UserStatus.Active ? "status-done" : user.Status == UserStatus.Blocked ? "status-cancelled" : "status-pending")">
                                    @Localizer[$"status_{user.Status}"]
                                </span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <button class="w-9 h-9 rounded-xl hover:bg-admin-page flex items-center justify-center text-admin-secondary hover:text-primary transition-all">
                                    <span class="material-symbols-outlined text-lg">more_vert</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="px-8 py-6 border-t border-admin-border flex flex-col sm:flex-row justify-between items-center gap-4">
            <span class="text-xs font-medium text-admin-secondary">
                @string.Format(Localizer["admin_pagination_showing"].Value, 1, Model.Users.Count, Model.TotalUsers)
            </span>
            <div class="flex items-center gap-2">
                <button class="p-2 rounded-lg border border-admin-border text-admin-secondary hover:bg-admin-page disabled:opacity-50" disabled>
                    <span class="material-symbols-outlined text-lg">chevron_right</span>
                </button>
                <div class="flex items-center gap-1">
                    <button class="w-9 h-9 rounded-lg bg-primary text-on-primary text-xs font-bold">1</button>
                    <button class="w-9 h-9 rounded-lg border border-admin-border text-admin-secondary text-xs font-bold hover:bg-admin-page">2</button>
                    <button class="w-9 h-9 rounded-lg border border-admin-border text-admin-secondary text-xs font-bold hover:bg-admin-page">3</button>
                    <span class="mx-1 text-admin-secondary">...</span>
                    <button class="w-9 h-9 rounded-lg border border-admin-border text-admin-secondary text-xs font-bold hover:bg-admin-page">30</button>
                </div>
                <button class="p-2 rounded-lg border border-admin-border text-admin-secondary hover:bg-admin-page">
                    <span class="material-symbols-outlined text-lg">chevron_left</span>
                </button>
            </div>
        </div>
    </div>
</div>
