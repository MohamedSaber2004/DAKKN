@using DAKKN.MVC.ViewModels.Admin
@using DAKKN.Domain.Enums
@using System.Text.Json
@model DashboardStatsViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_overview"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
    var recentOrders = ViewData["RecentOrders"] as List<RecentOrderWidgetViewModel> ?? new();
    var analytics7d = ViewData["Analytics7d"] as DAKKN.Application.DTOs.DashboardAnalyticsDto;
    var analytics30d = ViewData["Analytics30d"] as DAKKN.Application.DTOs.DashboardAnalyticsDto;
    var recentRatings = ViewData["RecentProductRatings"] as List<DAKKN.Application.Features.Dashboard.Queries.GetRecentProductRatings.RecentProductRatingDto> ?? new();
}

<div class="space-y-8 pb-12">
    <!-- 1. Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-2xl">shopping_cart</span>
                </div>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_dashboard_orders_today"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.OrdersToday</h3>
            </div>
        </div>
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary">
                    <span class="material-symbols-outlined text-2xl">payments</span>
                </div>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_dashboard_revenue_today"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.RevenueToday.ToString("N0") @Localizer["egp"]</h3>
            </div>
        </div>
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                    <span class="material-symbols-outlined text-2xl">group</span>
                </div>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_dashboard_users"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@Model.TotalUsers</h3>
            </div>
        </div>
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                    <span class="material-symbols-outlined text-2xl">inventory_2</span>
                </div>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_dashboard_products"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@ViewData["TotalProducts"]</h3>
            </div>
        </div>
    </div>

    <!-- Stock Warning Widgets -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <a asp-action="Inventory" asp-route-stockFilter="lowStock" class="premium-card p-6 flex items-center gap-4 hover:shadow-lg transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500 group-hover:bg-amber-500 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-2xl">warning</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["inventory_dashboard_low_stock_title"]</p>
                <h3 class="text-xl font-black text-admin-primary group-hover:text-amber-500 transition-colors">@ViewData["LowStockCount"] @Localizer["admin_products"]</h3>
            </div>
        </a>
        <a asp-action="Inventory" asp-route-stockFilter="outOfStock" class="premium-card p-6 flex items-center gap-4 hover:shadow-lg transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-red-500/10 flex items-center justify-center text-red-500 group-hover:bg-red-500 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-2xl">block</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["inventory_dashboard_out_of_stock_title"]</p>
                <h3 class="text-xl font-black text-admin-primary group-hover:text-red-500 transition-colors">@ViewData["OutOfStockCount"] @Localizer["admin_products"]</h3>
            </div>
        </a>
        <a asp-action="BrandReviews" asp-route-statusFilter="pending" class="premium-card p-6 flex items-center gap-4 hover:shadow-lg transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-500 group-hover:bg-purple-500 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-2xl">rate_review</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["brand_reviews_filter_pending"]</p>
                <h3 class="text-xl font-black text-admin-primary group-hover:text-purple-500 transition-colors">@(ViewData["PendingReviewCount"] ?? 0) @Localizer["brand_reviews_title"]</h3>
            </div>
        </a>
    </div>

    <!-- Recent Product Ratings -->
    <div class="premium-card p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">star</span>
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_recent_ratings"]</h3>
            </div>
            <a asp-action="Inventory" class="text-xs font-bold text-primary hover:underline flex items-center gap-1">
                @Localizer["admin_view_all"] <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
        <div class="space-y-3">
            @if (recentRatings.Count > 0)
            {
                @foreach (var rating in recentRatings)
                {
                    <div class="flex items-center gap-4 p-3 rounded-xl hover:bg-admin-page/50 transition-colors">
                        <div class="w-10 h-10 rounded-xl overflow-hidden bg-surface-container flex-shrink-0">
                            <img src="@(rating.ProductImageFullUrl ?? (string.IsNullOrEmpty(rating.ProductImageUrl) ? "https://ui-avatars.com/api/?name=P&background=6366f1&color=fff&size=40" : rating.ProductImageUrl))" class="w-full h-full object-cover" alt="@rating.ProductName" loading="lazy">
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-bold text-admin-primary truncate">@rating.ProductName</p>
                            <p class="text-xs text-admin-secondary truncate">@rating.CustomerName</p>
                        </div>
                        <div class="flex gap-0.5 items-center">
                            @for (int s = 0; s < 5; s++)
                            {
                                <span class="material-symbols-outlined text-sm @(s < rating.Stars ? "text-yellow-500 fill-icon" : "text-outline/20")">star</span>
                            }
                        </div>
                        <span class="text-[10px] text-admin-secondary font-medium whitespace-nowrap">@rating.CreatedAt.ToString("MMM dd")</span>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-8 text-admin-secondary">
                    <span class="material-symbols-outlined text-4xl mb-2">star_border</span>
                    <p class="text-sm font-bold">@Localizer["admin_no_ratings_yet"]</p>
                </div>
            }
        </div>
    </div>

    <!-- Order Status Summary -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        <div class="premium-card p-4 text-center">
            <p class="text-xs font-semibold text-admin-secondary">@Localizer["admin_dashboard_pending"]</p>
            <h4 class="text-xl font-black text-admin-primary mt-1">@Model.PendingOrders</h4>
        </div>
        <div class="premium-card p-4 text-center">
            <p class="text-xs font-semibold text-admin-secondary">@Localizer["admin_dashboard_delivered"]</p>
            <h4 class="text-xl font-black text-admin-primary mt-1">@Model.DeliveredOrders</h4>
        </div>
        <div class="premium-card p-4 text-center">
            <p class="text-xs font-semibold text-admin-secondary">@Localizer["admin_dashboard_cancelled"]</p>
            <h4 class="text-xl font-black text-admin-primary mt-1">@Model.CancelledOrders</h4>
        </div>
        <div class="premium-card p-4 text-center">
            <p class="text-xs font-semibold text-admin-secondary">@Localizer["admin_dashboard_orders_24h"]</p>
            <h4 class="text-xl font-black text-admin-primary mt-1">@Model.OrdersLast24Hours</h4>
        </div>
        <div class="premium-card p-4 text-center">
            <p class="text-xs font-semibold text-admin-secondary">@Localizer["admin_dashboard_revenue_24h"]</p>
            <h4 class="text-xl font-black text-admin-primary mt-1">@Model.RevenueLast24Hours.ToString("N0")</h4>
        </div>
    </div>

    <!-- 2. Charts and Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 premium-card p-6 space-y-6">
            <div class="flex justify-between items-center">
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_sales_chart"]</h3>
                <div class="flex gap-2">
                    <select class="chart-period-select bg-admin-page border border-admin-border text-admin-secondary text-[11px] font-bold uppercase tracking-wider rounded-lg px-3 py-1.5 outline-none focus:ring-1 focus:ring-primary cursor-pointer">
                        <option value="7">@Localizer["admin_chart_7d"]</option>
                        <option value="30">@Localizer["admin_chart_30d"]</option>
                    </select>
                </div>
            </div>
            <div class="relative h-[280px]">
                <canvas id="salesChart" class="@((analytics7d?.DailyData?.Count ?? 0) == 0 && (analytics30d?.DailyData?.Count ?? 0) == 0 ? "hidden" : "")"></canvas>
                <div id="chart-empty-state" class="@((analytics7d?.DailyData?.Count ?? 0) == 0 && (analytics30d?.DailyData?.Count ?? 0) == 0 ? "flex" : "hidden") flex-col items-center justify-center h-full text-admin-secondary">
                    <span class="material-symbols-outlined text-5xl mb-3">bar_chart</span>
                    <p class="font-bold">@Localizer["admin_chart_no_data"]</p>
                </div>
            </div>
        </div>

        <div class="premium-card p-6 space-y-6 flex flex-col">
            <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_quick_actions"]</h3>
            <div class="grid grid-cols-1 gap-4 flex-grow">
                <a asp-action="AddProduct" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-primary group-hover:text-white transition-all"><span class="material-symbols-outlined">add_box</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-primary transition-colors">@Localizer["admin_add_product"]</span>
                </a>
                <a asp-action="Orders" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-secondary group-hover:text-white transition-all"><span class="material-symbols-outlined">shopping_cart_checkout</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-secondary transition-colors">@Localizer["admin_orders"]</span>
                </a>
                <a asp-action="Support" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-tertiary group-hover:text-white transition-all"><span class="material-symbols-outlined">support_agent</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-tertiary transition-colors">@Localizer["admin_support"]</span>
                </a>
                <a asp-action="Inventory" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-red-500 group-hover:text-white transition-all"><span class="material-symbols-outlined">inventory_2</span></div>
                    <div class="flex flex-col">
                        <span class="text-sm font-bold text-admin-primary group-hover:text-red-500 transition-colors">@Localizer["admin_inventory"]</span>
                        <span class="text-[10px] font-bold text-red-500">@Localizer["admin_inventory_low_stock"]</span>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- 3. Recent Orders Table -->
    <div class="premium-card overflow-hidden">
        <div class="px-8 py-6 flex justify-between items-center border-b border-admin-border bg-admin-page/30">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">history</span>
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_recent_orders"]</h3>
            </div>
            <a asp-action="Orders" class="text-xs font-bold text-primary hover:underline flex items-center gap-1">
                @Localizer["admin_view_all"]
                <span class="material-symbols-outlined text-sm">@(isArabic ? "arrow_back" : "arrow_forward")</span>
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left rtl:text-right orders-table">
                <thead>
                    <tr>
                        <th class="px-8 py-4">@Localizer["admin_th_id"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_customer"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_amount"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_status"]</th>
                        <th class="px-8 py-4 text-center">@Localizer["admin_th_action"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-admin-border">
                    @foreach (var order in recentOrders)
                    {
                        var statusBadge = order.Status switch
                        {
                            OrderStatus.Pending => "status-pending",
                            OrderStatus.Delivered => "status-done",
                            OrderStatus.Cancelled => "status-cancelled",
                            OrderStatus.Shipped => "status-shipped",
                            _ => "status-pending"
                        };
                        <tr>
                            <td class="px-8 py-5 font-bold text-admin-primary">@order.OrderNumber</td>
                            <td class="px-8 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[11px] font-bold text-primary uppercase">@order.CustomerName[0]</div>
                                    <span>@order.CustomerName</span>
                                </div>
                            </td>
                            <td class="px-8 py-5 font-bold text-admin-primary">@order.TotalAmount.ToString("N0") @Localizer["egp"]</td>
                            <td class="px-8 py-5">
                                <span class="status-badge @statusBadge">@Localizer[$"order_status_{order.Status.ToString()}"]</span>
                            </td>
                            <td class="px-8 py-5 text-center">
                                <a asp-action="OrderDetails" asp-route-id="@order.Id" class="w-9 h-9 rounded-xl hover:bg-primary/10 hover:text-primary flex items-center justify-center transition-all">
                                    <span class="material-symbols-outlined text-lg">visibility</span>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (recentOrders.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-8 py-5 text-center text-admin-secondary">@Localizer["admin_orders_no_orders"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"
            onerror="document.getElementById('salesChart')?.classList.add('hidden');
                     document.getElementById('chart-empty-state')?.classList.remove('hidden');
                     document.getElementById('chart-empty-state') && (document.getElementById('chart-empty-state').querySelector('p').textContent = 'Chart library failed to load.')"></script>
    <script>
        @{
            var camelCase = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
        }
        const analytics7d = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics7d?.DailyData ?? new List<DAKKN.Application.DTOs.DailyAnalytics>(), camelCase));
        const analytics30d = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(analytics30d?.DailyData ?? new List<DAKKN.Application.DTOs.DailyAnalytics>(), camelCase));

        document.addEventListener('DOMContentLoaded', () => {
            if (typeof Chart === 'undefined') return;
            const canvas = document.getElementById('salesChart');
            if (!canvas || canvas.classList.contains('hidden')) return;
            const ctx = canvas.getContext('2d');
            if (!ctx) return;
            const isDark = document.documentElement.classList.contains('dark');
            const periodSelect = document.querySelector('.chart-period-select');

            const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';
            const textColor = isDark ? '#7d93ae' : '#94a3b8';
            const primaryColor = '#0e908c';
            const secondaryColor = '#00b4d8';

            function buildChartData(days) {
                const data = days === 30 ? analytics30d : analytics7d;
                const items = data || [];
                return {
                    labels: items.map(function(d) { return d.label || ''; }),
                    datasets: [
                        {
                            label: '@Localizer["admin_stat_revenue"]',
                            data: items.map(function(d) { return d.revenue ?? 0; }),
                            borderColor: primaryColor,
                            backgroundColor: 'rgba(14, 144, 140, 0.06)',
                            fill: true,
                            tension: 0.4,
                            borderWidth: 3,
                            pointRadius: 4,
                            pointBackgroundColor: primaryColor
                        },
                        {
                            label: '@Localizer["admin_stat_orders"]',
                            data: items.map(function(d) { return d.ordersCount ?? 0; }),
                            borderColor: secondaryColor,
                            borderWidth: 2,
                            borderDash: [5, 5],
                            pointRadius: 0,
                            tension: 0.4,
                            fill: false
                        }
                    ]
                };
            }

            var chart;
            try {
                chart = new Chart(ctx, {
                    type: 'line',
                    data: buildChartData(7),
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: isDark ? '#1e2a38' : '#ffffff',
                                titleColor: isDark ? '#7d93ae' : '#475569',
                                bodyColor: isDark ? '#e8edf4' : '#0f172a',
                                borderColor: isDark ? '#253245' : '#e2e8f0',
                                borderWidth: 1,
                                padding: 12,
                                cornerRadius: 12,
                                displayColors: false
                            }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: textColor, font: { size: 11, weight: '600' } }
                            },
                            y: {
                                grid: { color: gridColor },
                                ticks: {
                                    color: textColor,
                                    font: { size: 11, weight: '600' },
                                    callback: function(value) { return value >= 1000 ? (value/1000) + 'k' : value; }
                                },
                                border: { display: false }
                            }
                        }
                    }
                });
            } catch (e) {
                console.error('Chart init error:', e);
                canvas.classList.add('hidden');
                var emptyState = document.getElementById('chart-empty-state');
                if (emptyState) {
                    emptyState.classList.remove('hidden');
                    emptyState.classList.add('flex');
                }
                return;
            }

            if (periodSelect) {
                periodSelect.addEventListener('change', function(e) {
                    var days = parseInt(e.target.value, 10);
                    if (chart) {
                        chart.data = buildChartData(days);
                        chart.update();
                    }
                });
            }
        });
    </script>
}
