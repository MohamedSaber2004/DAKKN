@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_overview"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<div class="space-y-8 pb-12">
    <!-- 1. Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Stat Card 1 -->
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined text-2xl">payments</span>
                </div>
                <span class="flex items-center gap-1 text-[11px] font-bold px-2.5 py-1.5 rounded-lg bg-green-500/10 text-green-600 dark:text-green-500">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    +22%
                </span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_stat_revenue"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">12,450 ج.م</h3>
            </div>
        </div>

        <!-- Stat Card 2 -->
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary">
                    <span class="material-symbols-outlined text-2xl">shopping_cart</span>
                </div>
                <span class="flex items-center gap-1 text-[11px] font-bold px-2.5 py-1.5 rounded-lg bg-red-500/10 text-red-600 dark:text-red-500">
                    <span class="material-symbols-outlined text-sm">trending_down</span>
                    -2%
                </span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_stat_orders"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">142</h3>
            </div>
        </div>

        <!-- Stat Card 3 -->
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                    <span class="material-symbols-outlined text-2xl">group</span>
                </div>
                <span class="flex items-center gap-1 text-[11px] font-bold px-2.5 py-1.5 rounded-lg bg-green-500/10 text-green-600 dark:text-green-500">
                    <span class="material-symbols-outlined text-sm">trending_up</span>
                    +15%
                </span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_stat_customers"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">1,280</h3>
            </div>
        </div>

        <!-- Stat Card 4 -->
        <div class="premium-card p-6 flex flex-col gap-4">
            <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                    <span class="material-symbols-outlined text-2xl">inventory_2</span>
                </div>
                <span class="flex items-center gap-1 text-[11px] font-bold px-2.5 py-1.5 rounded-lg bg-green-500/10 text-green-600 dark:text-green-500">
                    <span class="material-symbols-outlined text-sm">check</span>
                    @Localizer["admin_stat_stock_ok"]
                </span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["admin_stat_products"]</p>
                <h3 class="text-2xl font-black text-admin-primary mt-1">@ViewData["TotalProducts"]</h3>
            </div>
        </div>
    </div>

    <!-- Stock Warning Widgets -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <a asp-action="Inventory" asp-route-stockFilter="lowStock" class="premium-card p-6 flex items-center gap-4 hover:shadow-lg transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-amber-500/10 flex items-center justify-center text-amber-500 group-hover:bg-amber-500 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-2xl">warning</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["inventory_dashboard_low_stock_title"]</p>
                <h3 class="text-xl font-black text-admin-primary group-hover:text-amber-500 transition-colors" id="lowStockCount">@ViewData["LowStockCount"] @Localizer["admin_products"]</h3>
            </div>
        </a>
        <a asp-action="Inventory" asp-route-stockFilter="outOfStock" class="premium-card p-6 flex items-center gap-4 hover:shadow-lg transition-all group">
            <div class="w-14 h-14 rounded-2xl bg-red-500/10 flex items-center justify-center text-red-500 group-hover:bg-red-500 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-2xl">block</span>
            </div>
            <div>
                <p class="text-sm font-semibold text-admin-secondary">@Localizer["inventory_dashboard_out_of_stock_title"]</p>
                <h3 class="text-xl font-black text-admin-primary group-hover:text-red-500 transition-colors" id="outOfStockCount">@ViewData["OutOfStockCount"] @Localizer["admin_products"]</h3>
            </div>
        </a>
    </div>

    <!-- 2. Charts and Quick Actions -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Chart Column -->
        <div class="lg:col-span-2 premium-card p-6 space-y-6">
            <div class="flex justify-between items-center">
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_sales_chart"]</h3>
                <div class="flex gap-2">
                    <select class="bg-admin-page border border-admin-border text-admin-secondary text-[11px] font-bold uppercase tracking-wider rounded-lg px-3 py-1.5 outline-none focus:ring-1 focus:ring-primary cursor-pointer">
                        <option>@Localizer["admin_chart_7d"]</option>
                        <option>@Localizer["admin_chart_30d"]</option>
                    </select>
                </div>
            </div>
            <div class="relative h-[280px]">
                <canvas id="salesChart"></canvas>
            </div>
        </div>

        <!-- Quick Actions Column -->
        <div class="premium-card p-6 space-y-6 flex flex-col">
            <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_quick_actions"]</h3>
            <div class="grid grid-cols-1 gap-4 flex-grow">
                <a asp-action="AddProduct" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-primary group-hover:text-white transition-all"><span class="material-symbols-outlined">add_box</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-primary transition-colors">@Localizer["admin_add_product"]</span>
                </a>
                <a asp-action="Orders" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-secondary group-hover:text-white transition-all"><span class="material-symbols-outlined">shopping_cart_checkout</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-secondary transition-colors">@Localizer["admin_orders"]</span>
                </a>
                <a asp-action="Support" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-tertiary group-hover:text-white transition-all"><span class="material-symbols-outlined">support_agent</span></div>
                    <span class="text-sm font-bold text-admin-primary group-hover:text-tertiary transition-colors">@Localizer["admin_support"]</span>
                </a>
                <a asp-action="Inventory" class="action-tile flex items-center gap-4 group cursor-pointer">
                    <div class="icon group-hover:bg-red-500 group-hover:text-white transition-all"><span class="material-symbols-outlined">inventory_2</span></div>
                    <div class="flex flex-col">
                        <span class="text-sm font-bold text-admin-primary group-hover:text-red-500 transition-colors">@Localizer["admin_inventory"]</span>
                        <span class="text-[10px] font-bold text-red-500">@Localizer["admin_inventory_low_stock"]</span>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- 3. Recent Orders Table -->
    <div class="premium-card overflow-hidden">
        <div class="px-8 py-6 flex justify-between items-center border-b border-admin-border bg-admin-page/30">
            <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">history</span>
                <h3 class="text-lg font-bold text-admin-primary">@Localizer["admin_recent_orders"]</h3>
            </div>
            <a href="#" class="text-xs font-bold text-primary hover:underline flex items-center gap-1">
                @Localizer["admin_view_all"]
                <span class="material-symbols-outlined text-sm">@(isArabic ? "arrow_back" : "arrow_forward")</span>
            </a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left rtl:text-right orders-table">
                <thead>
                    <tr>
                        <th class="px-8 py-4">@Localizer["admin_th_id"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_customer"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_amount"]</th>
                        <th class="px-8 py-4">@Localizer["admin_th_status"]</th>
                        <th class="px-8 py-4 text-center">@Localizer["admin_th_action"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-admin-border">
                    <!-- Mock Row 1 -->
                    <tr>
                        <td class="px-8 py-5 font-bold text-admin-primary">#4582</td>
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-[11px] font-bold text-primary">MA</div>
                                <span>محمد علي</span>
                            </div>
                        </td>
                        <td class="px-8 py-5 font-bold text-admin-primary">240 ج.م</td>
                        <td class="px-8 py-5">
                            <span class="status-badge status-pending">@Localizer["status_pending"]</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <button class="w-9 h-9 rounded-xl hover:bg-primary/10 hover:text-primary flex items-center justify-center transition-all">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </button>
                        </td>
                    </tr>
                    <!-- Mock Row 2 -->
                    <tr>
                        <td class="px-8 py-5 font-bold text-admin-primary">#4581</td>
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-secondary/10 flex items-center justify-center text-[11px] font-bold text-secondary">SA</div>
                                <span>سارة أحمد</span>
                            </div>
                        </td>
                        <td class="px-8 py-5 font-bold text-admin-primary">120 ج.م</td>
                        <td class="px-8 py-5">
                            <span class="status-badge status-done">@Localizer["status_done"]</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <button class="w-9 h-9 rounded-xl hover:bg-primary/10 hover:text-primary flex items-center justify-center transition-all">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </button>
                        </td>
                    </tr>
                    <!-- Mock Row 3 -->
                    <tr>
                        <td class="px-8 py-5 font-bold text-admin-primary">#4580</td>
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-tertiary/10 flex items-center justify-center text-[11px] font-bold text-tertiary">OK</div>
                                <span>عمر خالد</span>
                            </div>
                        </td>
                        <td class="px-8 py-5 font-bold text-admin-primary">450 ج.م</td>
                        <td class="px-8 py-5">
                            <span class="status-badge status-shipped">@Localizer["status_shipped"]</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <button class="w-9 h-9 rounded-xl hover:bg-primary/10 hover:text-primary flex items-center justify-center transition-all">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </button>
                        </td>
                    </tr>
                    <!-- Mock Row 4 -->
                    <tr>
                        <td class="px-8 py-5 font-bold text-admin-primary">#4579</td>
                        <td class="px-8 py-5">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center text-[11px] font-bold text-red-500">LM</div>
                                <span>ليلى محمود</span>
                            </div>
                        </td>
                        <td class="px-8 py-5 font-bold text-admin-primary">85 ج.م</td>
                        <td class="px-8 py-5">
                            <span class="status-badge status-cancelled">@Localizer["status_cancelled"]</span>
                        </td>
                        <td class="px-8 py-5 text-center">
                            <button class="w-9 h-9 rounded-xl hover:bg-primary/10 hover:text-primary flex items-center justify-center transition-all">
                                <span class="material-symbols-outlined text-lg">visibility</span>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const ctx = document.getElementById('salesChart').getContext('2d');
            const isDark = document.documentElement.classList.contains('dark');
            
            // Theme-aware colors
            const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';
            const textColor = isDark ? '#7d93ae' : '#94a3b8';
            const primaryColor = '#0e908c';
            const secondaryColor = '#00b4d8';

            const data = {
                labels: ['@Localizer["admin_sat"]', '@Localizer["admin_sun"]', '@Localizer["admin_mon"]', '@Localizer["admin_tue"]', '@Localizer["admin_wed"]', '@Localizer["admin_thu"]', '@Localizer["admin_fri"]'],
                datasets: [
                    {
                        label: '@Localizer["admin_stat_revenue"]',
                        data: [4200, 3800, 5100, 4900, 6200, 5800, 7500],
                        borderColor: primaryColor,
                        backgroundColor: primaryColor + '10',
                        fill: true,
                        tension: 0.4,
                        borderWidth: 3,
                        pointRadius: 4,
                        pointBackgroundColor: primaryColor
                    },
                    {
                        label: '@Localizer["admin_stat_orders"]',
                        data: [120, 95, 145, 130, 160, 155, 190],
                        borderColor: secondaryColor,
                        borderWidth: 2,
                        borderDash: [5, 5],
                        pointRadius: 0,
                        tension: 0.4,
                        fill: false
                    }
                ]
            };

            new Chart(ctx, {
                type: 'line',
                data: data,
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: isDark ? '#1e2a38' : '#ffffff',
                            titleColor: isDark ? '#7d93ae' : '#475569',
                            bodyColor: isDark ? '#e8edf4' : '#0f172a',
                            borderColor: isDark ? '#253245' : '#e2e8f0',
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 12,
                            displayColors: false
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false },
                            ticks: { color: textColor, font: { size: 11, weight: '600' } }
                        },
                        y: {
                            grid: { color: gridColor },
                            ticks: { 
                                color: textColor, 
                                font: { size: 11, weight: '600' },
                                callback: value => value >= 1000 ? (value/1000) + 'k' : value
                            },
                            border: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
