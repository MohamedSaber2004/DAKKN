@using DAKKN.MVC.ViewModels.Admin
@using DAKKN.Domain.Enums
@model AdminOrderDetailsViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_order_details"];
}

<!-- Order Header -->
<div class="mb-lg flex flex-col lg:flex-row justify-between items-start lg:items-center gap-md">
    <div>
        <div class="flex flex-wrap items-center gap-sm mb-xs">
            <span class="text-caption text-text-secondary dark:text-outline">@Localizer["admin_order_id"]</span>
            <h2 class="text-h2 text-text-primary dark:text-inverse-on-surface">@Model.OrderNumber</h2>
            @{
                var statusClass = Model.Status switch
                {
                    OrderStatus.Delivered => "bg-primary-container/20 text-primary",
                    OrderStatus.Processing => "bg-secondary-container/20 text-secondary",
                    OrderStatus.Shipped => "bg-tertiary-container/20 text-tertiary",
                    OrderStatus.Cancelled => "bg-error-container/20 text-error",
                    _ => "bg-surface-container-highest text-text-secondary"
                };
            }
            <span class="@statusClass px-sm py-xs rounded-full text-caption font-bold">@Localizer[$"order_status_{Model.Status.ToString()}"]</span>
        </div>
        <p class="text-body text-text-secondary dark:text-outline-variant">
            @Localizer["admin_order_date"]: @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy - HH:mm")
        </p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
    <!-- Left Column -->
    <div class="lg:col-span-2 space-y-lg">
        <!-- Order Items -->
        <section class="bg-surface dark:bg-surface-container rounded-2xl border border-border dark:border-outline/20 overflow-hidden shadow-sm transition-colors">
            <div class="p-lg border-b border-border dark:border-outline/10 bg-surface-bright dark:bg-surface-container-high">
                <h3 class="text-h4 flex items-center gap-sm text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">list_alt</span>
                    @Localizer["admin_order_items"] (@Model.Items.Count)
                </h3>
            </div>
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-left rtl:text-right border-collapse">
                    <thead class="bg-surface-container-low dark:bg-surface-container-highest/20 text-caption text-text-secondary dark:text-outline border-b border-border dark:border-outline/10">
                        <tr>
                            <th class="p-md">@Localizer["admin_order_product"]</th>
                            <th class="p-md">@Localizer["admin_order_qty"]</th>
                            <th class="p-md">@Localizer["admin_order_price"]</th>
                            <th class="p-md">Total</th>
                        </tr>
                    </thead>
                    <tbody class="text-body text-text-primary dark:text-inverse-on-surface divide-y divide-border dark:divide-outline/10">
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-surface-container-lowest dark:hover:bg-surface-container-high/30 transition-colors">
                                <td class="p-md">
                                    <div class="flex items-center gap-md">
                                        @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                        {
                                            <div class="w-12 h-12 rounded-lg border border-border dark:border-outline/20 overflow-hidden bg-surface-container-low flex-shrink-0">
                                                <img src="@item.ProductImageUrl" alt="@item.ProductName" class="w-full h-full object-cover">
                                            </div>
                                        }
                                        <p class="font-bold">@item.ProductName</p>
                                    </div>
                                </td>
                                <td class="p-md">@item.Quantity</td>
                                <td class="p-md whitespace-nowrap">@item.UnitPrice.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                                <td class="p-md whitespace-nowrap font-bold">@item.TotalPrice.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-surface-container-low dark:bg-surface-container-highest/20">
                        <tr>
                            <td colspan="3" class="p-md text-right rtl:text-left font-bold">@Localizer["order_subtotal"]</td>
                            <td class="p-md font-bold">@Model.Subtotal.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                        </tr>
                        <tr>
                            <td colspan="3" class="p-md text-right rtl:text-left">@Localizer["order_shipping"]</td>
                            <td class="p-md">@Model.ShippingCost.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                        </tr>
                        <tr class="text-primary">
                            <td colspan="3" class="p-md text-right rtl:text-left font-bold text-h4">@Localizer["order_total"]</td>
                            <td class="p-md font-bold text-h4">@Model.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>

        <!-- Status History -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            @* <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">history</span>
                @Localizer["admin_orders_status_history"]
            </h3> *@
            <div class="space-y-md relative ltr:before:left-2 rtl:before:right-2 before:content-[''] before:absolute before:top-2 before:bottom-2 before:w-px before:bg-border dark:before:bg-outline/10">
                @foreach (var log in Model.StatusHistory)
                {
                    <div class="relative ltr:pl-8 rtl:pr-8">
                        <div class="absolute ltr:left-0 rtl:right-0 top-1 w-4 h-4 rounded-full bg-primary border-4 border-surface dark:border-surface-container"></div>
                        <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">
                            @Localizer[$"order_status_{log.NewStatus.ToString()}"]
                        </p>
                        <p class="text-caption text-text-secondary dark:text-outline">
                            @log.ChangedAt.ToLocalTime().ToString("dd MMM yyyy - HH:mm")
                            @if (!string.IsNullOrEmpty(log.Notes))
                            {
                                <span> - @log.Notes</span>
                            }
                        </p>
                    </div>
                }
            </div>
        </section>
    </div>

    <!-- Right Column -->
    <div class="space-y-lg">
        <!-- Shipping Info -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">local_shipping</span>
                @Localizer["admin_orders_shipping_info"]
            </h3>
            <div class="space-y-sm">
                <div>
                    <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_shipping_address"]</p>
                    <p class="text-body font-bold">@Model.ShippingAddress</p>
                </div>
                <div>
                    <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_governorate"]</p>
                    <p class="text-body font-bold">@Model.ShippingGovernorateName</p>
                </div>
                <div>
                    <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_phone"]</p>
                    <p class="text-body font-bold" dir="ltr">@Model.CustomerPhone</p>
                </div>
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div>
                        <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_notes"]</p>
                        <p class="text-body">@Model.Notes</p>
                    </div>
                }
            </div>
        </section>

        <!-- Customer Info -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">account_circle</span>
                @Localizer["admin_orders_customer_info"]
            </h3>
            <div class="flex items-center gap-md mb-lg">
                <div class="h-12 w-12 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary text-h3 font-bold">@Model.CustomerName[0]</div>
                <div>
                    <h4 class="text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@Model.CustomerName</h4>
                    <p class="text-caption text-text-secondary dark:text-outline">@Model.CustomerEmail</p>
                </div>
            </div>
        </section>

        <!-- Payment Info -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">payments</span>
                @Localizer["admin_orders_payment_info"]
            </h3>
            <div>
                <p class="text-caption text-text-secondary dark:text-outline">@Localizer["admin_orders_payment_info"]</p>
                <p class="text-body font-bold">@Localizer["admin_orders_cod"]</p>
            </div>
            <div class="mt-sm">
                <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_tracking"]</p>
                <p class="text-body font-bold" dir="ltr">@Model.TrackingNumber</p>
            </div>
        </section>

        <!-- Status Update -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">sync_alt</span>
                @Localizer["admin_order_update_status"]
            </h3>
            <form asp-action="UpdateOrderStatus" asp-route-id="@Model.Id" method="post" class="space-y-sm">
                @Html.AntiForgeryToken()
                <select name="newStatus" class="w-full bg-surface-container-low dark:bg-surface-container-highest border border-border dark:border-outline/20 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-primary transition-all appearance-none cursor-pointer">
                    @foreach (var s in Enum.GetValues<OrderStatus>())
                    {
                        <option value="@((int)s)" selected="@(s == Model.Status)">@Localizer[$"order_status_{s.ToString()}"]</option>
                    }
                </select>
                <input type="text" name="statusNotes" class="w-full bg-surface-container-low dark:bg-surface-container-highest border border-border dark:border-outline/20 rounded-xl px-4 py-2 outline-none focus:ring-2 focus:ring-primary transition-all text-sm" placeholder="@Localizer["order_cancel_reason_ph"]" />
                <button type="submit" class="w-full bg-primary text-on-primary py-3 rounded-xl font-bold hover:brightness-110 transition-all">
                    @Localizer["admin_order_update_status"]
                </button>
            </form>
        </section>

        <!-- Delete -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-error/20 shadow-sm transition-colors">
            <form asp-action="DeleteOrder" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@Localizer["admin_order_delete_confirm"]')">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full bg-error/10 text-error py-3 rounded-xl font-bold hover:bg-error hover:text-on-primary transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">delete_forever</span>
                    @Localizer["admin_order_delete"]
                </button>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <style>
        .filled-icon {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
}
