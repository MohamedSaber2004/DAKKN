@using DAKKN.MVC.ViewModels.Admin
@model OrderDetailsViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_order_details"];
}

<!-- Order Header -->
<div class="mb-lg flex flex-col lg:flex-row justify-between items-start lg:items-center gap-md">
    <div>
        <div class="flex flex-wrap items-center gap-sm mb-xs">
            <span class="text-caption text-text-secondary dark:text-outline">@Localizer["admin_order_id"]</span>
            <h2 class="text-h2 text-text-primary dark:text-inverse-on-surface">#@Model.OrderId</h2>
            @{
                var statusClass = Model.Status switch
                {
                    OrderStatus.TechnicalReview => "bg-secondary-container/20 text-secondary",
                    OrderStatus.Delivered => "bg-primary-container/20 text-primary",
                    OrderStatus.Cancelled => "bg-error-container/20 text-error",
                    _ => "bg-surface-container-highest text-text-secondary"
                };
            }
            <span class="@statusClass px-sm py-xs rounded-full text-caption font-bold">@Localizer[$"status_{Model.Status.ToString().ToLower()}"]</span>
        </div>
        <p class="text-body text-text-secondary dark:text-outline-variant">
            @Localizer["admin_order_date"]: @Model.OrderDate.ToString("dd MMM yyyy - HH:mm") | 
            @Localizer["admin_order_deadline"]: @Model.DeadlineDate.ToString("dd MMM yyyy")
        </p>
    </div>
    <div class="flex flex-wrap gap-md w-full lg:w-auto">
        <button class="flex-1 lg:flex-none flex items-center justify-center gap-xs bg-surface dark:bg-surface-container border border-border dark:border-outline/20 px-md py-sm rounded-xl text-body font-bold hover:bg-surface-container-low transition-colors shadow-sm">
            <span class="material-symbols-outlined text-[20px]">download</span>
            @Localizer["admin_order_download_files"]
        </button>
        <button class="flex-1 lg:flex-none flex items-center justify-center gap-xs bg-surface dark:bg-surface-container border border-border dark:border-outline/20 px-md py-sm rounded-xl text-body font-bold hover:bg-surface-container-low transition-colors shadow-sm">
            <span class="material-symbols-outlined text-[20px]">print</span>
            @Localizer["admin_order_print_work"]
        </button>
        <button class="flex-1 lg:flex-none flex items-center justify-center gap-xs bg-error text-on-primary px-md py-sm rounded-xl text-body font-bold hover:brightness-110 transition-all shadow-sm">
            <span class="material-symbols-outlined text-[20px]">cancel</span>
            @Localizer["admin_order_cancel"]
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
    <!-- Left Column: Details -->
    <div class="lg:col-span-2 space-y-lg">
        <!-- Technical Specs -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <div class="flex items-center justify-between mb-md">
                <h3 class="text-h4 flex items-center gap-sm text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">precision_manufacturing</span>
                    @Localizer["admin_order_tech_specs"]
                </h3>
                <button class="text-primary dark:text-primary-light text-body font-bold hover:underline">Edit Specs</button>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-md">
                <div class="p-md bg-surface-container-low dark:bg-surface-container-high rounded-xl transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_material"]</p>
                    <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.Material</p>
                </div>
                <div class="p-md bg-surface-container-low dark:bg-surface-container-high rounded-xl transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_finish"]</p>
                    <p class="text-body font-bold flex items-center gap-xs text-text-primary dark:text-inverse-on-surface">
                        <span class="material-symbols-outlined text-accent-purple text-sm filled-icon">stars</span>
                        @Model.Finish
                    </p>
                </div>
                <div class="p-md bg-surface-container-low dark:bg-surface-container-high rounded-xl transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_cut_type"]</p>
                    <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.CutType</p>
                </div>
                <div class="p-md bg-surface-container-low dark:bg-surface-container-high rounded-xl transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_resolution"]</p>
                    <p class="text-body font-bold text-primary dark:text-primary-light flex items-center gap-xs">
                        <span class="material-symbols-outlined text-sm">check_circle</span>
                        @Model.Resolution
                    </p>
                </div>
            </div>
        </section>

        <!-- Order Items -->
        <section class="bg-surface dark:bg-surface-container rounded-2xl border border-border dark:border-outline/20 overflow-hidden shadow-sm transition-colors">
            <div class="p-lg border-b border-border dark:border-outline/10 bg-surface-bright dark:bg-surface-container-high">
                <h3 class="text-h4 flex items-center gap-sm text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">list_alt</span>
                    @Localizer["admin_order_items"] (@Model.Items.Count)
                </h3>
            </div>
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-start border-collapse">
                    <thead class="bg-surface-container-low dark:bg-surface-container-highest/20 text-caption text-text-secondary dark:text-outline border-b border-border dark:border-outline/10">
                        <tr>
                            <th class="p-md text-start">Image</th>
                            <th class="p-md text-start">@Localizer["admin_order_product"]</th>
                            <th class="p-md text-start">@Localizer["admin_order_size"]</th>
                            <th class="p-md text-start">@Localizer["admin_order_qty"]</th>
                            <th class="p-md text-start">@Localizer["admin_order_price"]</th>
                            <th class="p-md text-center">@Localizer["admin_order_file_status"]</th>
                        </tr>
                    </thead>
                    <tbody class="text-body text-text-primary dark:text-inverse-on-surface divide-y divide-border dark:divide-outline/10">
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-surface-container-lowest dark:hover:bg-surface-container-high/30 transition-colors">
                                <td class="p-md">
                                    <div class="w-12 h-12 rounded-lg border border-border dark:border-outline/20 overflow-hidden bg-surface-container-low">
                                        <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover">
                                    </div>
                                </td>
                                <td class="p-md">
                                    <p class="font-bold">@item.ProductName</p>
                                    <p class="text-caption text-text-secondary dark:text-outline truncate max-w-[150px]">SKU: @item.Sku</p>
                                </td>
                                <td class="p-md whitespace-nowrap">@item.Dimensions</td>
                                <td class="p-md">@item.Quantity</td>
                                <td class="p-md whitespace-nowrap">
                                    <p>@item.UnitPrice.ToString("N2") @Localizer["egp"]</p>
                                    <p class="text-caption text-text-secondary dark:text-outline">Total: @item.TotalPrice.ToString("N2")</p>
                                </td>
                                <td class="p-md text-center">
                                    @if (item.FileStatusOk)
                                    {
                                        <span class="material-symbols-outlined text-primary filled-icon">check_circle</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-accent-orange filled-icon">warning</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Internal Notes -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">edit_note</span>
                @Localizer["admin_order_internal_notes"]
            </h3>
            <textarea placeholder="Add internal notes for the team..." class="w-full h-24 p-md bg-surface-container-low dark:bg-surface-container-high border border-border dark:border-outline/20 rounded-xl text-body focus:ring-1 focus:ring-primary focus:border-primary outline-none mb-md transition-all dark:text-inverse-on-surface">@Model.InternalNotes</textarea>
            <div class="flex flex-col sm:flex-row justify-between items-center gap-md">
                <p class="text-caption text-text-secondary dark:text-outline text-center sm:text-start">These notes are visible to the team only.</p>
                <button class="w-full sm:w-auto bg-primary text-on-primary px-lg py-sm rounded-xl text-body font-bold hover:brightness-110 transition-all shadow-sm">Save Note</button>
            </div>
        </section>
    </div>

    <!-- Right Column: Customer & History -->
    <div class="space-y-lg">
        <!-- System History -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-text-primary dark:text-inverse-on-surface">
                <span class="material-symbols-outlined text-primary">history</span>
                @Localizer["admin_order_system_log"]
            </h3>
            <div class="space-y-md relative ltr:before:left-2 rtl:before:right-2 before:content-[''] before:absolute before:top-2 before:bottom-2 before:w-px before:bg-border dark:before:bg-outline/10">
                @foreach (var log in Model.Logs)
                {
                    var dotColor = log.IsSystem ? "bg-primary" : "bg-border dark:bg-outline/30";
                    <div class="relative ltr:pl-8 rtl:pr-8">
                        <div class="absolute ltr:left-0 rtl:right-0 top-1 w-4 h-4 rounded-full @dotColor border-4 border-surface dark:border-surface-container"></div>
                        <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@log.Message</p>
                        <p class="text-caption text-text-secondary dark:text-outline">@log.Timestamp - @log.Actor</p>
                    </div>
                }
            </div>
        </section>

        <!-- Customer Info -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <div class="flex items-center justify-between mb-md">
                <h3 class="text-h4 flex items-center gap-sm text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">account_circle</span>
                    @Localizer["admin_order_customer_info"]
                </h3>
                <button class="text-text-secondary dark:text-outline hover:text-primary transition-colors"><span class="material-symbols-outlined">open_in_new</span></button>
            </div>
            <div class="flex items-center gap-md mb-lg">
                <div class="h-12 w-12 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary text-h3 font-bold">@Model.Customer.Name[0]</div>
                <div>
                    <h4 class="text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@Model.Customer.Name</h4>
                    <p class="text-caption text-text-secondary dark:text-outline">@Model.Customer.Email</p>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-md mb-lg">
                <div class="p-sm bg-surface-container-low dark:bg-surface-container-high rounded-xl text-center transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_total_spent"]</p>
                    <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.Customer.TotalSpent</p>
                </div>
                <div class="p-sm bg-surface-container-low dark:bg-surface-container-high rounded-xl text-center transition-colors">
                    <p class="text-caption text-text-secondary dark:text-outline mb-xs">@Localizer["admin_order_total_count"]</p>
                    <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.Customer.TotalOrdersCount orders</p>
                </div>
            </div>
            <div class="space-y-sm">
                <p class="text-caption text-text-secondary dark:text-outline font-bold">@Localizer["admin_order_recent_orders"] (3)</p>
                @foreach (var recent in Model.Customer.RecentOrders)
                {
                    <div class="flex items-center justify-between p-sm border border-border dark:border-outline/10 rounded-xl transition-colors">
                        <span class="text-body font-bold text-text-primary dark:text-inverse-on-surface">#@recent.OrderId</span>
                        @{
                            var rStatusClass = recent.Status == OrderStatus.Delivered ? "text-primary bg-primary-container/10" : "text-error bg-error-container/10";
                        }
                        <span class="text-caption @rStatusClass px-sm py-xs rounded-lg">@Localizer[$"status_{recent.Status.ToString().ToLower()}"]</span>
                    </div>
                }
            </div>
        </section>

        <!-- Quick Actions -->
        <section class="bg-surface dark:bg-surface-container p-lg rounded-2xl border border-border dark:border-outline/20 shadow-sm transition-colors">
            <h3 class="text-h4 mb-md text-text-primary dark:text-inverse-on-surface">Quick Actions</h3>
            <div class="space-y-sm">
                <button class="w-full flex items-center gap-sm p-sm border border-border dark:border-outline/20 rounded-xl hover:bg-surface-container-low dark:hover:bg-surface-container-high text-body transition-colors text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">inventory</span>
                    @Localizer["admin_order_action_inventory"]
                </button>
                <button class="w-full flex items-center gap-sm p-sm border border-border dark:border-outline/20 rounded-xl hover:bg-surface-container-low dark:hover:bg-surface-container-high text-body transition-colors text-text-primary dark:text-inverse-on-surface">
                    <span class="material-symbols-outlined text-primary">mail</span>
                    @Localizer["admin_order_action_mail"]
                </button>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <style>
        .filled-icon {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
}
