@model DAKKN.MVC.ViewModels.Admin.UserManagementViewModel
@inject IStringLocalizer<Messages> Localizer

<div id="statsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
    <div class="admin-card p-5 sm:p-6 flex flex-row sm:flex-col items-center sm:items-start gap-4">
        <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
            <span class="material-symbols-outlined text-2xl">group</span>
        </div>
        <div>
            <p class="text-xs sm:text-sm font-semibold text-admin-secondary">@Localizer["admin_users_total"]</p>
            <h3 class="text-xl sm:text-2xl font-black text-admin-primary mt-1">@Model.TotalUsers</h3>
        </div>
    </div>

    <div class="admin-card p-5 sm:p-6 flex flex-row sm:flex-col items-center sm:items-start gap-4">
        <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center text-green-600 shrink-0">
            <span class="material-symbols-outlined text-2xl">person_check</span>
        </div>
        <div>
            <p class="text-xs sm:text-sm font-semibold text-admin-secondary">@Localizer["admin_users_active"]</p>
            <h3 class="text-xl sm:text-2xl font-black text-admin-primary mt-1">@Model.ActiveUsers</h3>
        </div>
    </div>

    <div class="admin-card p-5 sm:p-6 flex flex-row sm:flex-col items-center sm:items-start gap-4 sm:col-span-2 lg:col-span-1">
        <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center text-red-600 shrink-0">
            <span class="material-symbols-outlined text-2xl">delete</span>
        </div>
        <div>
            <p class="text-xs sm:text-sm font-semibold text-admin-secondary">@Localizer["admin_users_deleted"]</p>
            <h3 class="text-xl sm:text-2xl font-black text-admin-primary mt-1">@Model.DeletedUsers</h3>
        </div>
    </div>
</div>
