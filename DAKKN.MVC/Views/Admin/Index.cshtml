@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");
}

<!-- Page Header -->
<div class="mb-lg">
    <h2 class="font-h2-mobile md:font-h2 text-h2-mobile md:text-h2 text-text-primary mb-xs">@Localizer["admin_welcome"]</h2>
    <p class="font-body text-body text-text-secondary">@Localizer["admin_stats_overview"]</p>
</div>

<!-- Metrics Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-md mb-xl">
    <!-- Metric 1 -->
    <div class="bg-surface rounded-2xl p-md shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 ltr:right-0 rtl:left-0 w-16 h-16 bg-primary-light/20 rounded-bl-full -z-0"></div>
        <div class="flex justify-between items-start mb-md relative z-10">
            <div class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">payments</span>
            </div>
            <span class="bg-surface-container text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+15%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-xs">@Localizer["admin_total_sales"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">@Localizer["egp"] 24,500</h3>
        </div>
    </div>
    <!-- Metric 2 -->
    <div class="bg-surface rounded-2xl p-md shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 ltr:right-0 rtl:left-0 w-16 h-16 bg-accent-orange/20 rounded-bl-full -z-0"></div>
        <div class="flex justify-between items-start mb-md relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-orange/20 text-accent-orange flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">shopping_bag</span>
            </div>
            <span class="bg-surface-container text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+8%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-xs">@Localizer["admin_new_orders"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">142</h3>
        </div>
    </div>
    <!-- Metric 3 -->
    <div class="bg-surface rounded-2xl p-md shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 ltr:right-0 rtl:left-0 w-16 h-16 bg-accent-purple/20 rounded-bl-full -z-0"></div>
        <div class="flex justify-between items-start mb-md relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-purple/20 text-accent-purple flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">sell</span>
            </div>
            <span class="bg-surface-container text-text-secondary font-caption text-caption px-2 py-1 rounded-full">-2%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-xs">@Localizer["admin_stickers_sold"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">850</h3>
        </div>
    </div>
    <!-- Metric 4 -->
    <div class="bg-surface rounded-2xl p-md shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 ltr:right-0 rtl:left-0 w-16 h-16 bg-accent-pink/20 rounded-bl-full -z-0"></div>
        <div class="flex justify-between items-start mb-md relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-pink/20 text-accent-pink flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">group_add</span>
            </div>
            <span class="bg-surface-container text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+22%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-xs">@Localizer["admin_new_customers"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">64</h3>
        </div>
    </div>
</div>

<!-- Complex Layout Area -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
    <!-- Chart Area (Bento Grid Style) -->
    <div class="lg:col-span-2 bg-surface rounded-[24px] p-lg shadow-medium">
        <div class="flex justify-between items-center mb-md">
            <h4 class="font-h4 text-h4 text-text-primary">@Localizer["admin_sales_analysis"]</h4>
            <select class="bg-surface-container border-none rounded-full font-body text-body px-4 py-1 focus:ring-2 focus:ring-primary outline-none">
                <option>@Localizer["admin_week"]</option>
                <option>@Localizer["admin_month"]</option>
            </select>
        </div>
        <!-- Faux Chart Representation -->
        <div class="h-64 flex items-end justify-between gap-2 mt-lg relative">
            <!-- Y-axis labels -->
            <div class="absolute ltr:right-0 rtl:left-0 top-0 h-full flex flex-col justify-between text-caption text-text-secondary pb-8">
                <span>500</span>
                <span>250</span>
                <span>0</span>
            </div>
            <!-- Grid lines -->
            <div class="absolute inset-0 border-b border-surface-container mb-8"></div>
            <div class="absolute inset-0 border-b border-surface-container mt-28 mb-8"></div>
            <!-- Bars -->
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[40%] hover:bg-primary transition-colors cursor-pointer relative group ltr:mr-8 rtl:ml-8 z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">120</div>
            </div>
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[60%] hover:bg-primary transition-colors cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">250</div>
            </div>
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[30%] hover:bg-primary transition-colors cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">90</div>
            </div>
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[80%] hover:bg-primary transition-colors cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">400</div>
            </div>
            <div class="w-1/12 bg-primary rounded-t-lg h-[100%] cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">500</div>
            </div>
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[50%] hover:bg-primary transition-colors cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">210</div>
            </div>
            <div class="w-1/12 bg-primary-container rounded-t-lg h-[70%] hover:bg-primary transition-colors cursor-pointer relative group z-10">
                <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface text-surface text-xs py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity">350</div>
            </div>
        </div>
        <!-- X-axis labels -->
        <div class="flex justify-between mt-2 ltr:mr-8 rtl:ml-8 text-caption text-text-secondary">
            <span>@Localizer["admin_sat"]</span>
            <span>@Localizer["admin_sun"]</span>
            <span>@Localizer["admin_mon"]</span>
            <span>@Localizer["admin_tue"]</span>
            <span class="text-primary font-bold">@Localizer["admin_today"]</span>
            <span>@Localizer["admin_thu"]</span>
            <span>@Localizer["admin_fri"]</span>
        </div>
    </div>
    <!-- Right Column: Quick Actions & Recent -->
    <div class="flex flex-col gap-md">
        <!-- Quick Actions -->
        <div class="bg-surface rounded-[24px] p-lg shadow-medium">
            <h4 class="font-h4 text-h4 text-text-primary mb-md">@Localizer["admin_quick_actions"]</h4>
            <div class="grid grid-cols-2 gap-sm">
                <button class="bg-surface-container hover:bg-primary-container text-on-surface hover:text-on-primary-container rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">add_photo_alternate</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_add_product"]</span>
                </button>
                <button class="bg-surface-container hover:bg-accent-orange/20 text-on-surface hover:text-accent-orange rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">local_shipping</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_ship_orders"]</span>
                </button>
                <button class="bg-surface-container hover:bg-accent-purple/20 text-on-surface hover:text-accent-purple rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">campaign</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_marketing"]</span>
                </button>
                <button class="bg-surface-container hover:bg-accent-pink/20 text-on-surface hover:text-accent-pink rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">diamond</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_coupons"]</span>
                </button>
            </div>
        </div>
        <!-- Recent Activity -->
        <div class="bg-surface rounded-[24px] p-md shadow-medium flex-1">
            <div class="flex justify-between items-center mb-md">
                <h4 class="font-h4 text-h4 text-text-primary">@Localizer["admin_recent_orders"]</h4>
                <a asp-controller="Admin" asp-action="Orders" class="text-primary font-body text-body hover:underline">@Localizer["admin_view_all"]</a>
            </div>
            <div class="flex flex-col gap-sm">
                <!-- Order Item -->
                <div class="flex items-center gap-sm p-sm rounded-lg hover:bg-surface-container transition-colors">
                    <div class="w-10 h-10 rounded-full bg-accent-orange/20 flex items-center justify-center text-accent-orange shrink-0">
                        <span class="material-symbols-outlined">inventory_2</span>
                    </div>
                    <div class="flex-1">
                        <p class="font-body-lg text-body-lg text-text-primary leading-tight">@Localizer["admin_order_no"]1024</p>
                        <p class="font-caption text-caption text-text-secondary">@Localizer["admin_time_ago", "15m"]</p>
                    </div>
                    <span class="font-body text-body font-bold text-primary">@Localizer["egp"] 120</span>
                </div>
                <!-- Order Item -->
                <div class="flex items-center gap-sm p-sm rounded-lg hover:bg-surface-container transition-colors">
                    <div class="w-10 h-10 rounded-full bg-accent-purple/20 flex items-center justify-center text-accent-purple shrink-0">
                        <span class="material-symbols-outlined">inventory_2</span>
                    </div>
                    <div class="flex-1">
                        <p class="font-body-lg text-body-lg text-text-primary leading-tight">@Localizer["admin_order_no"]1023</p>
                        <p class="font-caption text-caption text-text-secondary">@Localizer["admin_time_ago", "2h"]</p>
                    </div>
                    <span class="font-body text-body font-bold text-primary">@Localizer["egp"] 350</span>
                </div>
            </div>
        </div>
    </div>
</div>
