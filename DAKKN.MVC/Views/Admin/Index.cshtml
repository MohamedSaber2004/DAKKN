@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isRtl = culture.StartsWith("ar");
}

<!-- Page Header -->
<div class="mb-lg">
    <h2 class="font-h2-mobile md:font-h2 text-h2-mobile md:text-h2 text-text-primary mb-xs">@Localizer["admin_welcome"]
    </h2>
    <p class="font-body text-body text-text-secondary">@Localizer["admin_stats_overview"]</p>
</div>

<!-- Metrics Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12 p-2">
    <!-- Metric 1 -->
    <div class="bg-surface dark:bg-inverse-surface rounded-2xl p-6 shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 start-0 w-16 h-16 bg-primary-light/20 rounded-ee-full -z-0"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div
                class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">payments</span>
            </div>
            <span
            class="bg-surface dark:bg-surface-container-high text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+15%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-1">@Localizer["admin_total_sales"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">@Localizer["egp"] 24,500</h3>
        </div>
    </div>
    <!-- Metric 2 -->
    <div class="bg-surface dark:bg-inverse-surface rounded-2xl p-6 shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 start-0 w-16 h-16 bg-accent-orange/20 rounded-ee-full -z-0"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-orange/20 text-accent-orange flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">shopping_bag</span>
            </div>
            <span
            class="bg-surface dark:bg-surface-container-high text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+8%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-1">@Localizer["admin_new_orders"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">142</h3>
        </div>
    </div>
    <!-- Metric 3 -->
    <div class="bg-surface dark:bg-inverse-surface rounded-2xl p-6 shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 start-0 w-16 h-16 bg-accent-purple/20 rounded-ee-full -z-0"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-purple/20 text-accent-purple flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">sell</span>
            </div>
            <span
            class="bg-surface dark:bg-surface-container-high text-text-secondary font-caption text-caption px-2 py-1 rounded-full">-2%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-1">@Localizer["admin_stickers_sold"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">850</h3>
        </div>
    </div>
    <!-- Metric 4 -->
    <div class="bg-surface dark:bg-inverse-surface rounded-2xl p-6 shadow-medium hover:shadow-large transition-shadow duration-300 relative overflow-hidden group">
        <div class="absolute top-0 start-0 w-16 h-16 bg-accent-pink/20 rounded-ee-full -z-0"></div>
        <div class="flex justify-between items-start mb-4 relative z-10">
            <div class="w-12 h-12 rounded-full bg-accent-pink/20 text-accent-pink flex items-center justify-center">
                <span class="material-symbols-outlined filled-icon">group_add</span>
            </div>
            <span
            class="bg-surface dark:bg-surface-container-high text-text-secondary font-caption text-caption px-2 py-1 rounded-full">+22%</span>
        </div>
        <div class="relative z-10">
            <p class="font-body text-body text-text-secondary mb-1">@Localizer["admin_new_customers"]</p>
            <h3 class="font-h3 text-h3 text-text-primary">64</h3>
        </div>
    </div>
</div>

<!-- Complex Layout Area -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
    <!-- Chart Area (Bento Grid Style) -->
    <div class="lg:col-span-2 bg-surface dark:bg-inverse-surface rounded-[24px] p-lg shadow-medium">
        <div class="flex justify-between items-center mb-md">
            <h4 class="font-h4 text-h4 text-text-primary">@Localizer["admin_sales_analysis"]</h4>
            <select
                class="bg-surface dark:bg-surface-container-high border-none rounded-full font-body text-body px-4 py-1 focus:ring-2 focus:ring-primary outline-none">
                <option>@Localizer["admin_week"]</option>
                <option>@Localizer["admin_month"]</option>
            </select>
        </div>
        <!-- Sales Chart -->
        <div class="h-64 flex flex-col mt-lg relative">
            <div class="flex-1 flex items-end justify-between px-10 relative">
                <!-- Y-axis labels -->
                <div class="absolute ltr:left-0 rtl:right-0 top-0 h-full flex flex-col justify-between text-[10px] font-bold text-text-secondary pb-8">
                    <span>500</span>
                    <span>250</span>
                    <span>0</span>
                </div>
                
                <!-- Grid lines -->
                <div class="absolute inset-x-0 bottom-8 border-b border-surface-container-high/50"></div>
                <div class="absolute inset-x-0 top-1/2 -translate-y-4 border-b border-surface-container-high/30 border-dashed"></div>

                <!-- Bars container -->
                <div id="chart-bars" class="flex-1 flex items-end justify-around h-full pb-8">
                    <!-- Weekly/Monthly bars will be injected here by JS -->
                </div>
            </div>
            
            <!-- X-axis labels -->
            <div id="chart-labels" class="flex justify-around px-10 text-caption font-bold text-text-secondary mt-2">
                <!-- Labels will be injected here by JS -->
            </div>
        </div>

        <script>
            const i18n = {
                admin_sat: "@Localizer["admin_sat"]",
                admin_sun: "@Localizer["admin_sun"]",
                admin_mon: "@Localizer["admin_mon"]",
                admin_tue: "@Localizer["admin_tue"]",
                admin_wed: "@Localizer["admin_wed"]",
                admin_thu: "@Localizer["admin_thu"]",
                admin_fri: "@Localizer["admin_fri"]",
                admin_week: "@Localizer["admin_week"]"
            };

            const salesData = {
                weekly: {
                    labels: ["admin_sat", "admin_sun", "admin_mon", "admin_tue", "admin_wed", "admin_thu", "admin_fri"],
                    values: [120, 250, 90, 400, 500, 210, 350]
                },
                monthly: {
                    labels: ["admin_week", "admin_week", "admin_week", "admin_week"],
                    values: [1500, 2200, 1800, 3100]
                }
            };

            function renderChart(type) {
                const container = document.getElementById('chart-bars');
                const labelContainer = document.getElementById('chart-labels');
                container.innerHTML = '';
                labelContainer.innerHTML = '';
                
                const data = salesData[type];
                const maxVal = Math.max(...data.values);

                data.values.forEach((val, i) => {
                    const height = (val / maxVal) * 100;
                    container.innerHTML += `
                        <div class="w-8 bg-primary-container dark:bg-primary rounded-t-lg transition-all duration-500 hover:scale-x-110 cursor-pointer relative group" style="height: ${height}%">
                             <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-inverse-surface dark:bg-surface-container-high text-surface dark:text-inverse-on-surface text-[10px] py-1 px-2 rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap z-20">${val}</div>
                        </div>`;
                    labelContainer.innerHTML += `<span class="text-text-secondary dark:text-outline-variant font-caption">${i18n[data.labels[i]] || ''}</span>`;
                });
            }

            document.querySelector('select').addEventListener('change', (e) => {
                renderChart(e.target.value === '@Localizer["admin_month"]' ? 'monthly' : 'weekly');
            });
            renderChart('weekly');
        </script>
    </div>

    <!-- Right Column: Quick Actions & Recent -->
    <div class="flex flex-col gap-md">
        <!-- Quick Actions -->
        <div class="bg-surface dark:bg-inverse-surface rounded-[24px] p-lg shadow-medium">
            <h4 class="font-h4 text-h4 text-text-primary mb-md">@Localizer["admin_quick_actions"]</h4>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-sm">
                <button
                    class="bg-surface dark:bg-surface-container-high hover:bg-primary-container text-on-surface hover:text-on-primary-container rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">add_photo_alternate</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_add_product"]</span>
                </button>
                <button
                    class="bg-surface dark:bg-surface-container-high hover:bg-accent-orange/20 text-on-surface hover:text-accent-orange rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">orders</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_orders_mgmt"]</span>
                </button>
                <button
                    class="bg-surface dark:bg-surface-container-high hover:bg-accent-purple/20 text-on-surface hover:text-accent-purple rounded-xl p-md flex flex-col items-center justify-center gap-2 transition-colors duration-200 shadow-small hover:shadow-medium">
                    <span class="material-symbols-outlined text-3xl">manage_accounts</span>
                    <span class="font-body-lg text-body text-center">@Localizer["admin_users_mgmt"]</span>
                </button>
            </div>
        </div>
        <!-- Recent Activity -->
        <div class="bg-surface dark:bg-inverse-surface rounded-[24px] p-md shadow-medium flex-1">
            <div class="flex justify-between items-center mb-md">
                <h4 class="font-h4 text-h4 text-text-primary">@Localizer["admin_recent_orders"]</h4>
                <a asp-controller="Admin" asp-action="Orders"
                   class="text-primary font-body text-body hover:underline">@Localizer["admin_view_all"]</a>
            </div>
            <div class="flex flex-col gap-sm">
                <!-- Order Item -->
                <div class="flex items-center gap-sm p-sm rounded-lg hover:bg-surface dark:bg-surface-container-high transition-colors">
                    <div
                        class="w-10 h-10 rounded-full bg-accent-orange/20 flex items-center justify-center text-accent-orange shrink-0">
                        <span class="material-symbols-outlined">inventory_2</span>
                    </div>
                    <div class="flex-1">
                        <p class="font-body-lg text-body-lg text-text-primary leading-tight">
                            @Localizer["admin_order_no"]1024</p>
                            <p class="font-caption text-caption text-text-secondary">@Localizer["admin_time_ago", "15m"]</p>
                        </div>
                        <span class="font-body text-body font-bold text-primary">@Localizer["egp"] 120</span>
                    </div>
                    <!-- Order Item -->
                    <div class="flex items-center gap-sm p-sm rounded-lg hover:bg-surface dark:bg-surface-container-high transition-colors">
                        <div
                            class="w-10 h-10 rounded-full bg-accent-purple/20 flex items-center justify-center text-accent-purple shrink-0">
                            <span class="material-symbols-outlined">inventory_2</span>
                        </div>
                        <div class="flex-1">
                            <p class="font-body-lg text-body-lg text-text-primary leading-tight">
                                @Localizer["admin_order_no"]1023</p>
                                <p class="font-caption text-caption text-text-secondary">@Localizer["admin_time_ago", "2h"]</p>
                            </div>
                            <span class="font-body text-body font-bold text-primary">@Localizer["egp"] 350</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>

