@model DAKKN.MVC.ViewModels.Admin.ContentManagementViewModel
@using DAKKN.Application.Features.BrandReviews.DTOs
@using System.Globalization
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_content_mgmt"];
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="flex flex-col lg:flex-row gap-4 lg:gap-lg">
    <!-- Sub-sidebar: Content Modules -->
    <aside class="w-full lg:w-64 xl:w-72 flex-shrink-0">
        <div class="bg-admin-card border border-admin-border rounded-2xl shadow-small p-4 lg:sticky lg:top-0">
            <h3 class="text-lg font-black text-admin-primary mb-4 px-2">@Localizer["admin_content_mgmt"]</h3>
            <nav class="flex flex-col gap-xs">
                <button onclick="switchTab('section-order')" id="tab-section-order" class="content-tab-btn active flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">reorder</span>
                    <span class="font-body-lg">@Localizer["admin_section_order"]</span>
                </button>
                <button onclick="switchTab('hero-banner')" id="tab-hero-banner" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">branding_watermark</span>
                    <span class="font-body-lg">@Localizer["admin_hero_settings"]</span>
                </button>
                <button onclick="switchTab('customer-stories')" id="tab-customer-stories" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">forum</span>
                    <span class="font-body-lg">@Localizer["section_testimonials"]</span>
                </button>
                <button onclick="switchTab('faq')" id="tab-faq" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">help_center</span>
                    <span class="font-body-lg">@Localizer["section_faq"]</span>
                </button>
                <button onclick="switchTab('contact-info')" id="tab-contact-info" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">contact_support</span>
                    <span class="font-body-lg">@Localizer["section_contact"]</span>
                </button>
            </nav>
        </div>
    </aside>

    <!-- Main Editor Area -->
    <div class="flex-1 min-w-0">
        <!-- Toast Container -->
        <div id="toastCms" class="fixed bottom-24 lg:bottom-16 ltr:right-4 lg:ltr:right-8 rtl:left-4 lg:rtl:left-8 z-[200] flex flex-col gap-3 max-w-[calc(100vw-2rem)] lg:max-w-md"></div>
    <!-- Global Save All Button -->
    <button onclick="saveAllChanges()" id="cms-global-save" class="fixed bottom-20 lg:bottom-8 ltr:right-4 lg:ltr:right-8 rtl:left-4 lg:rtl:left-8 z-50 bg-primary text-on-primary w-14 h-14 lg:w-auto lg:h-auto lg:px-2xl lg:py-lg rounded-2xl lg:rounded-full font-bold shadow-xl hover:scale-105 transition-all flex items-center justify-center lg:gap-md" title="@Localizer["admin_save_all_changes"]">
        <span class="material-symbols-outlined">save</span>
        <span class="hidden lg:inline">@Localizer["admin_save_all_changes"]</span>
    </button>
        <!-- Section: Order Management -->
        <div id="panel-section-order" class="content-panel bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-medium border border-admin-border dark:border-white/5 p-xl transition-all duration-300">
            <div class="flex justify-between items-center mb-xl">
                <div>
                    <h2 class="font-h2 text-h2 font-bold text-admin-primary dark:text-white">@Localizer["admin_section_order"]</h2>
                    <p class="text-admin-secondary dark:text-admin-muted-variant mt-xs">@Localizer["admin_section_order_desc"]</p>
                </div>
                <button onclick="saveLayout()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-105 transition-all">
                    @Localizer["admin_save_layout"]
                </button>
            </div>

            <div id="sortable-sections" class="flex flex-col gap-md">
                @foreach (var item in Model.SectionOrder.Sections.OrderBy(s => s.DisplayOrder))
                {
                    <div class="section-card group p-lg rounded-2xl border border-admin-border dark:border-white/5 flex items-center gap-lg hover:border-primary/50 transition-all cursor-grab active:cursor-grabbing" style="background-color:var(--admin-page-bg)" data-id="@item.Id">
                        <span class="material-symbols-outlined drag_indicator text-admin-muted group-hover:text-primary transition-colors">drag_indicator</span>
                        <div class="flex-1">
                            <h4 class="font-h3 text-h3 font-bold text-admin-primary dark:text-white">@Localizer["section_" + item.Id.Replace("-", "_")]</h4>
                            <span class="text-xs uppercase tracking-wider text-admin-muted font-bold">@item.Id</span>
                        </div>
                        <div class="flex items-center gap-xl">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" @(item.IsVisible ? "checked" : "")>
                                <div class="w-11 h-6 bg-outline/20 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:ltr:left-[2px] after:rtl:right-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                <span class="ltr:ml-3 rtl:mr-3 text-sm font-medium text-admin-secondary dark:text-admin-muted-variant">@Localizer["admin_visibility_toggle"]</span>
                            </label>
                            <button onclick="goToEditor('@item.Id')" class="w-10 h-10 rounded-full flex items-center justify-center bg-surface dark:bg-[#1E293B] border border-admin-border dark:border-white/5 text-primary hover:bg-primary hover:text-on-primary transition-all" title="@Localizer["admin_edit"]">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Section: Hero Settings -->
        <div id="panel-hero-banner" class="content-panel hidden bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-medium border border-admin-border dark:border-white/5 p-xl">
            <h2 class="font-h2 text-h2 font-bold mb-xl">@Localizer["admin_hero_settings"]</h2>

            <!-- Language Tabs -->
            <div class="flex gap-sm mb-xl border-b border-admin-border dark:border-white/5 pb-sm">
                <button onclick="switchHeroLang('ar')" id="hero-lang-ar" class="hero-lang-tab active px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_ar"]</button>
                <button onclick="switchHeroLang('en')" id="hero-lang-en" class="hero-lang-tab px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_en"]</button>
            </div>

            <div class="space-y-lg">
                    <!-- Arabic Fields -->
                    <div id="hero-fields-ar" class="hero-lang-fields">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_hero_title_segments"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_ar_marker"]</span></label>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
                                <input id="hero-title-a-ar" type="text" value="@Model.Hero.TitleAAr" placeholder="@Localizer["admin_content_ph_hero_title_a_ar"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-b-ar" type="text" value="@Model.Hero.TitleBAr" placeholder="@Localizer["admin_content_ph_hero_title_b_ar"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md text-primary font-bold focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-c-ar" type="text" value="@Model.Hero.TitleCAr" placeholder="@Localizer["admin_content_ph_hero_title_c_ar"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-d-ar" type="text" value="@Model.Hero.TitleDAr" placeholder="@Localizer["admin_content_ph_hero_title_d_ar"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md text-secondary font-bold focus:ring-primary focus:border-primary transition-all">
                            </div>
                        </div>
                        @* <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_hero_btn_text"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_ar_marker"]</span></label>
                             <input id="hero-btn-text-ar" type="text" value="@Model.Hero.ButtonTextAr" placeholder="@Localizer["admin_hero_btn_text"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">
                        </div> *@
                    </div>

                    <!-- English Fields -->
                    <div id="hero-fields-en" class="hero-lang-fields hidden">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_hero_title_segments"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_en_marker"]</span></label>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-sm">
                                <input id="hero-title-a-en" type="text" value="@Model.Hero.TitleAEn" placeholder="@Localizer["admin_content_ph_hero_title_a_en"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-b-en" type="text" value="@Model.Hero.TitleBEn" placeholder="@Localizer["admin_content_ph_hero_title_b_en"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md text-primary font-bold focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-c-en" type="text" value="@Model.Hero.TitleCEn" placeholder="@Localizer["admin_content_ph_hero_title_c_en"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                                <input id="hero-title-d-en" type="text" value="@Model.Hero.TitleDEn" placeholder="@Localizer["admin_content_ph_hero_title_d_en"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md text-secondary font-bold focus:ring-primary focus:border-primary transition-all">
                            </div>
                        </div>
                        @* <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_hero_btn_text"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_en_marker"]</span></label>
                            <input id="hero-btn-text-en" type="text" value="@Model.Hero.ButtonTextEn" placeholder="@Localizer["btn_shop"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">
                        </div> *@
                    </div>
                </div>

        </div>

        <!-- Section: Customer Stories (Testimonials) -->
        <div id="panel-customer-stories" class="content-panel hidden bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-medium border border-admin-border dark:border-white/5 p-xl">
            <div class="flex justify-between items-center mb-xl">
                <div>
                    <h2 class="font-h2 text-h2 font-bold">@Localizer["section_testimonials"]</h2>
                    <p class="text-admin-secondary">@Localizer["admin_testimonials_desc"]</p>
                </div>
                <button onclick="saveTestimonialsSection()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg mb-xl">
                <div class="flex flex-col gap-xs">
                    <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_testi_title"]</label>
                    <input id="testi-title" type="text" value="@Model.Testimonials.Title" placeholder="@Localizer["admin_content_ph_testi_title"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_testi_desc"]</label>
                    <textarea id="testi-desc" rows="2" placeholder="@Localizer["admin_content_ph_testi_desc"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">@Model.Testimonials.Description</textarea>
                </div>
            </div>

            <!-- Dynamic Brand Reviews from Database -->
            <div class="flex items-center justify-between mb-md">
                <h3 class="font-bold text-admin-primary">@Localizer["brand_reviews_admin_title"]</h3>
                <a href="/admin/brand-reviews" class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                    <span class="material-symbols-outlined text-lg">open_in_new</span>
                    @Localizer["admin_manage_reviews"]
                </a>
            </div>

            @if (Model.BrandReviews.Count == 0)
            {
                <div class="text-center py-lg px-lg text-admin-muted bg-surface-container/50 rounded-2xl border border-admin-border/50">
                    <span class="material-symbols-outlined text-4xl block mb-2">rate_review</span>
                    <p class="text-sm">@Localizer["admin_testimonials_empty"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto rounded-2xl border border-admin-border/50">
                    <table class="w-full text-left rtl:text-right">
                        <thead style="background-color:var(--admin-page-bg)">
                            <tr>
                                <th class="py-md px-lg font-bold text-admin-muted uppercase text-xs">@Localizer["admin_th_customer"]</th>
                                <th class="py-md px-lg font-bold text-admin-muted uppercase text-xs">@Localizer["admin_th_quote"]</th>
                                <th class="py-md px-lg font-bold text-admin-muted uppercase text-xs">@Localizer["admin_th_rating"]</th>
                                <th class="py-md px-lg font-bold text-admin-muted uppercase text-xs">@Localizer["admin_th_status"]</th>
                                <th class="py-md px-lg font-bold text-admin-muted uppercase text-xs">@Localizer["admin_th_display"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model.BrandReviews)
                            {
                                <tr class="border-b border-admin-border/50 hover:bg-surface-container/50 transition-colors">
                                    <td class="py-md px-lg">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 bg-gradient-to-br from-primary/20 to-primary/5">
                                                @if (!string.IsNullOrEmpty(review.ProfilePictureUrl))
                                                {
                                                    <img src="@review.ProfilePictureUrl" alt="@review.CustomerName" class="w-full h-full object-cover" onerror="this.onerror=null; this.style.display='none'; this.parentElement.innerHTML='<span class=\'flex items-center justify-center w-full h-full text-sm font-bold text-primary\'>@review.CustomerName[0]</span>'" />
                                                }
                                                else
                                                {
                                                    <span class="flex items-center justify-center w-full h-full text-sm font-bold text-primary">@review.CustomerName[0]</span>
                                                }
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-admin-primary">@review.CustomerName</p>
                                                <p class="text-xs text-admin-muted">@review.CustomerEmail</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-md px-lg max-w-xs">
                                        <p class="text-sm text-admin-secondary line-clamp-2">&ldquo;@review.ReviewText&rdquo;</p>
                                    </td>
                                    <td class="py-md px-lg">
                                        <div class="flex gap-0.5" aria-label="@string.Format(Localizer["admin_review_rating_aria"].Value, review.Rating)">
                                            @for (int j = 0; j < 5; j++)
                                            {
                                                <span class="material-symbols-outlined text-sm @(j < review.Rating ? "text-yellow-500 fill-icon" : "text-admin-muted/20")">star</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="py-md px-lg">
                                        @if (review.IsApproved)
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-bold text-success bg-success/10 px-2.5 py-1 rounded-full">@Localizer["admin_approved"]</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-bold text-admin-muted bg-outline/10 px-2.5 py-1 rounded-full">@Localizer["admin_pending"]</span>
                                        }
                                    </td>
                                    <td class="py-md px-lg">
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" class="sr-only peer brand-review-display" data-review-id="@review.Id" @(review.IsDisplayed ? "checked" : "") onchange="toggleBrandReviewDisplay('@review.Id', this.checked)">
                                            <div class="w-10 h-5 bg-outline/20 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:ltr:left-[2px] after:rtl:right-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
                                            <span class="ltr:ml-2 rtl:mr-2 text-xs font-medium @(review.IsDisplayed ? "text-primary" : "text-admin-muted")">@(review.IsDisplayed ? Localizer["admin_displayed"] : Localizer["admin_hidden"])</span>
                                        </label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <p class="text-xs text-admin-muted mt-md flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">info</span>
                @Localizer["admin_testimonials_dynamic_hint"]
            </p>
        </div>

        <!-- Section: FAQ -->
        <div id="panel-faq" class="content-panel hidden bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-medium border border-admin-border dark:border-white/5 p-xl">
            <div class="flex justify-between items-center mb-xl">
                <div>
                    <h2 class="font-h2 text-h2 font-bold">@Localizer["section_faq"]</h2>
                    <p class="text-admin-secondary">@Localizer["admin_faq_desc"]</p>
                </div>
                <button onclick="saveFaqSection()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
            </div>

            <!-- Language Tabs -->
            <div class="flex gap-sm mb-xl border-b border-admin-border dark:border-white/5 pb-sm">
                <button onclick="switchFaqLang('ar')" id="faq-lang-ar" class="faq-lang-tab active px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_ar"]</button>
                <button onclick="switchFaqLang('en')" id="faq-lang-en" class="faq-lang-tab px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_en"]</button>
            </div>

            <div class="space-y-xl">
                <!-- Arabic Fields -->
                <div id="faq-fields-ar" class="faq-lang-fields">
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_title"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_ar_marker"]</span></label>
                        <input id="faq-title-ar" type="text" value="@Model.Faq.TitleAr" placeholder="@Localizer["admin_faq_title_ph"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_description"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_ar_marker"]</span></label>
                        <textarea id="faq-desc-ar" rows="3" placeholder="@Localizer["admin_faq_description_ph"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">@Model.Faq.DescriptionAr</textarea>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_display_limit"]</label>
                            <input id="faq-display-limit" type="number" min="1" max="20" value="@Model.Faq.DisplayLimit" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all max-w-xs">
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="faq-auto-fetch" class="w-5 h-5 rounded border-admin-border dark:border-white/10 text-primary focus:ring-primary" @(Model.Faq.AutoFetchFromSupport ? "checked" : "")>
                            <label for="faq-auto-fetch" class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["admin_faq_auto_fetch"]</label>
                        </div>
                    </div>
                </div>

                <!-- English Fields -->
                <div id="faq-fields-en" class="faq-lang-fields hidden">
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_title"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_en_marker"]</span></label>
                        <input id="faq-title-en" type="text" value="@Model.Faq.TitleEn" placeholder="@Localizer["admin_faq_title_ph"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_description"] <span class="text-xs text-admin-muted">@Localizer["admin_lang_en_marker"]</span></label>
                        <textarea id="faq-desc-en" rows="3" placeholder="@Localizer["admin_faq_description_ph"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">@Model.Faq.DescriptionEn</textarea>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_faq_display_limit"]</label>
                            <input id="faq-display-limit-en" type="number" min="1" max="20" value="@Model.Faq.DisplayLimit" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all max-w-xs">
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="faq-auto-fetch-en" class="w-5 h-5 rounded border-admin-border dark:border-white/10 text-primary focus:ring-primary" @(Model.Faq.AutoFetchFromSupport ? "checked" : "")>
                            <label for="faq-auto-fetch-en" class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["admin_faq_auto_fetch"]</label>
                        </div>
                    </div>
                </div>
            </div>

            <button onclick="saveFaqSection()" class="mt-xl bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
        </div>

        <!-- Section: Contact Info -->
        <div id="panel-contact-info" class="content-panel hidden bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-medium border border-admin-border dark:border-white/5 p-xl">
            <h2 class="font-h2 text-h2 font-bold mb-xl">@Localizer["section_contact"]</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
                <div class="space-y-lg">
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_contact_phone"]</label>
                        <input id="contact-phone" type="text" value="@Model.Contact.Phone" placeholder="@Localizer["admin_content_ph_contact_phone"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-admin-muted px-1 uppercase">@Localizer["admin_contact_address"]</label>
                        <textarea id="contact-address" rows="3" placeholder="@Localizer["admin_content_ph_contact_address"]" class="bg-admin-input dark:bg-[#1E293B] border-admin-border rounded-xl p-md">@Model.Contact.Address</textarea>
                    </div>
                </div>
                <div class="bg-primary/5 rounded-3xl p-xl flex flex-col items-center justify-center text-center border border-primary/10">
                    <span class="material-symbols-outlined text-6xl text-primary mb-md">location_on</span>
                    <h3 class="font-bold text-xl mb-sm">@Localizer["admin_map_integration_h"]</h3>
                    <p class="text-admin-secondary text-sm">@Localizer["admin_map_integration_p"]</p>
                </div>
            </div>
            <button onclick="saveContactSection()" class="mt-xl bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
        </div>

    </div>
</div>

<style>
    .content-tab-btn {
        color: var(--admin-text-secondary, #475569);
    }
    .dark .content-tab-btn {
        color: #94a3b8;
    }
    .content-tab-btn:hover {
        background-color: rgba(var(--primary-rgb, 14, 144, 140), 0.08);
        color: var(--primary-color, #0E908C);
    }
    .dark .content-tab-btn:hover {
        background-color: rgba(255, 255, 255, 0.06);
        color: #ffffff;
    }
    .content-tab-btn.active {
        background: var(--primary-color, #0E908C) !important;
        color: #ffffff !important;
        font-weight: 700;
    }

    .sortable-ghost {
        opacity: 0.4;
        border: 2px dashed var(--primary-color, #0E908C) !important;
        background-color: rgba(var(--primary-rgb, 14, 144, 140), 0.1) !important;
    }

    .sortable-drag {
        cursor: grabbing !important;
    }

    .filled-icon {
        font-variation-settings: 'FILL' 1;
    }

    .hero-lang-tab, .faq-lang-tab {
        color: var(--admin-text-secondary, #475569);
        border: 1px solid transparent;
    }
    .dark .hero-lang-tab, .dark .faq-lang-tab {
        color: #94a3b8;
    }
    .hero-lang-tab:hover, .faq-lang-tab:hover {
        background-color: rgba(var(--primary-rgb, 14, 144, 140), 0.08);
        color: var(--primary-color, #0E908C);
    }
    .dark .hero-lang-tab:hover, .dark .faq-lang-tab:hover {
        background-color: rgba(255, 255, 255, 0.06);
        color: #ffffff;
    }
    .hero-lang-tab.active, .faq-lang-tab.active {
        background-color: var(--primary-color, #0E908C) !important;
        color: #ffffff !important;
        border-color: var(--primary-color, #0E908C) !important;
    }

    /* Content panel transitions */
    .content-panel {
        transition: opacity 0.25s ease, transform 0.25s ease;
    }
    .content-panel.hidden {
        display: none;
    }

    /* Mobile: reduce panel padding */
    @@media (max-width: 767px) {
        .content-panel {
            padding: 1rem !important;
            border-radius: 1.25rem !important;
        }
        .content-panel h2 {
            font-size: 1.25rem !important;
        }
        .content-panel h3 {
            font-size: 1rem !important;
        }
        .content-panel input,
        .content-panel textarea,
        .content-panel select {
            font-size: 16px !important; /* Prevent iOS zoom */
            padding: 0.625rem 0.875rem !important;
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        // Mapping of section IDs to tab IDs
        const sectionToTabMap = {
            'hero': 'hero-banner',
            'categories': 'section-order',
            'shop': 'section-order',
            'all-products': 'section-order',
            'testimonials': 'customer-stories',
            'faq': 'faq',
            'contact': 'contact-info'
        };

        function goToEditor(sectionId) {
            const tabId = sectionToTabMap[sectionId] || 'section-order';
            switchTab(tabId);
        }

        function switchTab(tabId) {
            // Update Buttons
            document.querySelectorAll('.content-tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const activeTab = document.getElementById('tab-' + tabId);
            if (activeTab) activeTab.classList.add('active');

            // Update Panels
            document.querySelectorAll('.content-panel').forEach(panel => {
                panel.classList.add('hidden');
            });
            const activePanel = document.getElementById('panel-' + tabId);
            if (activePanel) activePanel.classList.remove('hidden');
            
            // Re-init sortable if it's the section-order tab
            if (tabId === 'section-order') {
                initSortable();
            }
        }

        function initSortable() {
            const el = document.getElementById('sortable-sections');
            if (el && !el.dataset.sortable) {
                new Sortable(el, {
                    animation: 250,
                    ghostClass: 'sortable-ghost',
                    dragClass: 'sortable-drag',
                    handle: '.drag_indicator',
                    onEnd: function (evt) {
                        console.log('New order:', Array.from(el.children).map(c => c.dataset.id));
                    }
                });
                el.dataset.sortable = "true";
            }
        }

        function saveLayout() {
            const el = document.getElementById('sortable-sections');
            const sections = Array.from(el.children).map((c, index) => ({
                id: c.dataset.id,
                displayOrder: index,
                isVisible: c.querySelector('input[type="checkbox"]').checked
            }));

            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify({ sectionOrder: { sections: sections } })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('@Localizer["admin_save_success"]', 'success');
                } else {
                    showToast(data.message || '@Localizer["admin_save_error"]', 'error');
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function uploadHeroImage(file) {
            const formData = new FormData();
            formData.append('file', file);

            fetch('/admin/content/upload-image', {
                method: 'POST',
                headers: { 'RequestVerificationToken': window.csrfToken },
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('hero-image-preview').src = data.imageUrl;
                    document.getElementById('hero-image-preview').classList.remove('opacity-30');
                    document.getElementById('hero-image-url-input').value = data.imageUrl;
                } else {
                    alert(data.message);
                }
            })
            .catch(e => console.error('Upload error:', e));
        }

        function switchHeroLang(lang) {
            document.querySelectorAll('.hero-lang-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('hero-lang-' + lang).classList.add('active');
            document.querySelectorAll('.hero-lang-fields').forEach(f => f.classList.add('hidden'));
            document.getElementById('hero-fields-' + lang).classList.remove('hidden');
        }

        function switchFaqLang(lang) {
            document.querySelectorAll('.faq-lang-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('faq-lang-' + lang).classList.add('active');
            document.querySelectorAll('.faq-lang-fields').forEach(f => f.classList.add('hidden'));
            document.getElementById('faq-fields-' + lang).classList.remove('hidden');
        }

        function collectHeroData() {
            return {
                titleAAr: document.getElementById('hero-title-a-ar')?.value || '',
                titleBAr: document.getElementById('hero-title-b-ar')?.value || '',
                titleCAr: document.getElementById('hero-title-c-ar')?.value || '',
                titleDAr: document.getElementById('hero-title-d-ar')?.value || '',
                buttonTextAr: document.getElementById('hero-btn-text-ar')?.value || '',
                titleAEn: document.getElementById('hero-title-a-en')?.value || '',
                titleBEn: document.getElementById('hero-title-b-en')?.value || '',
                titleCEn: document.getElementById('hero-title-c-en')?.value || '',
                titleDEn: document.getElementById('hero-title-d-en')?.value || '',
                buttonTextEn: document.getElementById('hero-btn-text-en')?.value || '',
                imageUrl: document.getElementById('hero-image-url-input')?.value || ''
            };
        }

        function saveHeroSection() {
            const data = { hero: collectHeroData() };

            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(d => { if (d.success) showToast('@Localizer["admin_save_success"]', 'success'); else showToast(d.message || '@Localizer["admin_save_error"]', 'error'); })
            .catch(e => showToast('@Localizer["admin_save_error"]', 'error'));
        }

        function toggleBrandReviewDisplay(reviewId, isDisplayed) {
            fetch('/admin/brand-reviews/toggle-display/' + reviewId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': window.csrfToken
                },
                body: 'returnUrl=/admin/content',
                redirect: 'manual'
            })
            .then(() => {
                const checkbox = document.querySelector(`input[data-review-id="${reviewId}"]`);
                const label = checkbox.closest('label').querySelector('span:last-child');
                if (isDisplayed) {
                    label.textContent = '@Localizer["admin_displayed"]';
                    label.className = 'ltr:ml-2 rtl:mr-2 text-xs font-medium text-primary';
                } else {
                    label.textContent = '@Localizer["admin_hidden"]';
                    label.className = 'ltr:ml-2 rtl:mr-2 text-xs font-medium text-admin-muted';
                }
                showToast(isDisplayed ? '@Localizer["admin_review_displayed"]' : '@Localizer["admin_review_hidden"]', 'success');
            })
            .catch(() => {
                document.querySelector(`input[data-review-id="${reviewId}"]`).checked = !isDisplayed;
                showToast('@Localizer["admin_save_error"]', 'error');
            });
        }

        function saveTestimonialsSection() {
            postCmsData({ testimonials: { title: document.getElementById('testi-title')?.value || '', description: document.getElementById('testi-desc')?.value || '', reviews: [] } });
        }

        function saveContactSection() {
            const data = {
                contact: {
                    phone: document.getElementById('contact-phone')?.value || '',
                    address: document.getElementById('contact-address')?.value || ''
                }
            };
            postCmsData(data);
        }

        function saveFaqSection() {
            const data = {
                faq: {
                    titleAr: document.getElementById('faq-title-ar')?.value || '',
                    titleEn: document.getElementById('faq-title-en')?.value || '',
                    descriptionAr: document.getElementById('faq-desc-ar')?.value || '',
                    descriptionEn: document.getElementById('faq-desc-en')?.value || '',
                    displayLimit: parseInt(document.getElementById('faq-display-limit')?.value) || 6,
                    autoFetchFromSupport: document.getElementById('faq-auto-fetch')?.checked || false
                }
            };
            postCmsData(data);
        }

        function saveAllChanges() {
            // Collect section order
            const el = document.getElementById('sortable-sections');
            let sectionOrder = null;
            if (el) {
                const sections = Array.from(el.children).map((c, index) => ({
                    id: c.dataset.id,
                    displayOrder: index,
                    isVisible: c.querySelector('input[type="checkbox"]').checked
                }));
                sectionOrder = { sections: sections };
            }

            // Collect hero (bilingual)
            const hero = collectHeroData();

            // Collect contact
            const contact = {
                phone: document.getElementById('contact-phone')?.value || '',
                address: document.getElementById('contact-address')?.value || ''
            };

            const payload = {};
            if (sectionOrder) payload.sectionOrder = sectionOrder;
            payload.hero = hero;
            payload.testimonials = { title: document.getElementById('testi-title')?.value || '', description: document.getElementById('testi-desc')?.value || '', reviews: [] };
            payload.contact = contact;

            postCmsData(payload);
        }

        function postCmsData(data) {
            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(d => { if (d.success) showToast('@Localizer["admin_save_success"]', 'success'); else showToast(d.message || '@Localizer["admin_save_error"]', 'error'); })
            .catch(e => showToast('@Localizer["admin_save_error"]', 'error'));
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastCms');
            const toast = document.createElement('div');
            const bgColor = type === 'success' ? 'bg-primary' : 'bg-red-500';
            const icon = type === 'success' ? 'check_circle' : 'error';
            toast.className = `${bgColor} text-white px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-slide-in opacity-0 translate-y-4 transition-all duration-300`;
            toast.innerHTML = '<span class="material-symbols-outlined">' + icon + '</span><span class="text-sm font-bold">' + message + '</span>';
            container.appendChild(toast);
            setTimeout(() => { toast.classList.remove('opacity-0', 'translate-y-4'); toast.classList.add('opacity-100', 'translate-y-0'); }, 10);
            setTimeout(() => { toast.classList.add('opacity-0', 'translate-y--4'); setTimeout(() => toast.remove(), 300); }, 4000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSortable();

            const heroInput = document.getElementById('hero-image-input');
            if (heroInput) {
                heroInput.addEventListener('change', (e) => {
                    if (e.target.files && e.target.files[0]) {
                        uploadHeroImage(e.target.files[0]);
                    }
                });
            }
        });
    </script>
}
