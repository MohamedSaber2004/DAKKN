@model DAKKN.MVC.ViewModels.Admin.ContentManagementViewModel
@using DAKKN.Application.Features.BrandReviews.DTOs
@using System.Globalization
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_content_mgmt"];
    var isArabic = CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="flex flex-col lg:flex-row gap-lg h-full">
    <!-- Sub-sidebar: Content Modules -->
    <aside class="w-full lg:w-72 flex-shrink-0">
        <div class="bg-surface dark:bg-inverse-surface rounded-[24px] shadow-small p-md border border-border dark:border-outline/10 sticky top-0">
            <h3 class="font-h3 text-h3 font-bold mb-md px-2 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_content_mgmt"]</h3>
            <nav class="flex flex-col gap-xs">
                <button onclick="switchTab('section-order')" id="tab-section-order" class="content-tab-btn active flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">reorder</span>
                    <span class="font-body-lg">@Localizer["admin_section_order"]</span>
                </button>
                <button onclick="switchTab('hero-banner')" id="tab-hero-banner" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">branding_watermark</span>
                    <span class="font-body-lg">@Localizer["admin_hero_settings"]</span>
                </button>
                <button onclick="switchTab('about-us')" id="tab-about-us" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">info</span>
                    <span class="font-body-lg">@Localizer["section_about"]</span>
                </button>
                <button onclick="switchTab('customer-stories')" id="tab-customer-stories" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">forum</span>
                    <span class="font-body-lg">@Localizer["section_testimonials"]</span>
                </button>
                <button onclick="switchTab('contact-info')" id="tab-contact-info" class="content-tab-btn flex items-center gap-md p-3 rounded-xl transition-all duration-200 text-left rtl:text-right w-full">
                    <span class="material-symbols-outlined">contact_support</span>
                    <span class="font-body-lg">@Localizer["section_contact"]</span>
                </button>
            </nav>
        </div>
    </aside>

    <!-- Main Editor Area -->
    <div class="flex-1 min-w-0">
        <!-- Toast Container -->
        <div id="toastCms" class="fixed bottom-8 ltr:right-8 rtl:left-8 z-[200] flex flex-col gap-3"></div>
        <!-- Global Save All Button -->
        <button onclick="saveAllChanges()" class="fixed bottom-8 right-8 z-50 bg-primary text-on-primary px-2xl py-lg rounded-full font-bold shadow-xl hover:scale-105 transition-all flex items-center gap-md">
            <span class="material-symbols-outlined">save</span>
            @Localizer["admin_save_all_changes"]
        </button>
        <!-- Section: Order Management -->
        <div id="panel-section-order" class="content-panel bg-surface dark:bg-inverse-surface rounded-[32px] shadow-medium border border-border dark:border-outline/10 p-xl transition-all duration-300">
            <div class="flex justify-between items-center mb-xl">
                <div>
                    <h2 class="font-h2 text-h2 font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_section_order"]</h2>
                    <p class="text-text-secondary dark:text-outline-variant mt-xs">@Localizer["admin_section_order_desc"]</p>
                </div>
                <button onclick="saveLayout()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-105 transition-all">
                    @Localizer["admin_save_layout"]
                </button>
            </div>

            <div id="sortable-sections" class="flex flex-col gap-md">
                @foreach (var item in Model.SectionOrder.Sections.OrderBy(s => s.DisplayOrder))
                {
                    <div class="section-card group bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border dark:border-outline/10 flex items-center gap-lg hover:border-primary/50 transition-all cursor-grab active:cursor-grabbing" data-id="@item.Id">
                        <span class="material-symbols-outlined drag_indicator text-outline group-hover:text-primary transition-colors">drag_indicator</span>
                        <div class="flex-1">
                            <h4 class="font-h3 text-h3 font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["section_" + item.Id.Replace("-", "_")]</h4>
                            <span class="text-xs uppercase tracking-wider text-outline font-bold">@item.Id</span>
                        </div>
                        <div class="flex items-center gap-xl">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" class="sr-only peer" @(item.IsVisible ? "checked" : "")>
                                <div class="w-11 h-6 bg-outline/20 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:ltr:left-[2px] after:rtl:right-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                                <span class="ltr:ml-3 rtl:mr-3 text-sm font-medium text-text-secondary dark:text-outline-variant">@Localizer["admin_visibility_toggle"]</span>
                            </label>
                            <button onclick="goToEditor('@item.Id')" class="w-10 h-10 rounded-full flex items-center justify-center bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 text-primary hover:bg-primary hover:text-on-primary transition-all" title="@Localizer["admin_edit"]">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Section: Hero Settings -->
        <div id="panel-hero-banner" class="content-panel hidden bg-surface dark:bg-inverse-surface rounded-[32px] shadow-medium border border-border dark:border-outline/10 p-xl">
            <h2 class="font-h2 text-h2 font-bold mb-xl">@Localizer["admin_hero_settings"]</h2>

            <!-- Language Tabs -->
            <div class="flex gap-sm mb-xl border-b border-border dark:border-outline/10 pb-sm">
                <button onclick="switchHeroLang('ar')" id="hero-lang-ar" class="hero-lang-tab active px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_ar"]</button>
                <button onclick="switchHeroLang('en')" id="hero-lang-en" class="hero-lang-tab px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_en"]</button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
                <!-- Language-Specific Fields -->
                <div class="space-y-lg">
                    <!-- Arabic Fields -->
                    <div id="hero-fields-ar" class="hero-lang-fields">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_badge"] <span class="text-xs text-outline">(Ar)</span></label>
                            <input id="hero-badge-ar" type="text" value="@Model.Hero.BadgeAr" placeholder="@Localizer["admin_content_ph_badge_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_title_segments"] <span class="text-xs text-outline">(Ar)</span></label>
                            <div class="grid grid-cols-2 gap-sm">
                                <input id="hero-title-a-ar" type="text" value="@Model.Hero.TitleAAr" placeholder="@Localizer["admin_content_ph_hero_title_a_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                                <input id="hero-title-b-ar" type="text" value="@Model.Hero.TitleBAr" placeholder="@Localizer["admin_content_ph_hero_title_b_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md text-primary font-bold">
                                <input id="hero-title-c-ar" type="text" value="@Model.Hero.TitleCAr" placeholder="@Localizer["admin_content_ph_hero_title_c_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                                <input id="hero-title-d-ar" type="text" value="@Model.Hero.TitleDAr" placeholder="@Localizer["admin_content_ph_hero_title_d_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md text-secondary font-bold">
                            </div>
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_desc"] <span class="text-xs text-outline">(Ar)</span></label>
                            <textarea id="hero-desc-ar" rows="4" placeholder="@Localizer["admin_content_ph_hero_desc_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.Hero.DescriptionAr</textarea>
                        </div>
                        @* <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_btn_text"] <span class="text-xs text-outline">(Ar)</span></label>
                            <input id="hero-btn-text-ar" type="text" value="@Model.Hero.ButtonTextAr" placeholder="نص الزر" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                        </div> *@
                    </div>

                    <!-- English Fields -->
                    <div id="hero-fields-en" class="hero-lang-fields hidden">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_badge"] <span class="text-xs text-outline">(En)</span></label>
                            <input id="hero-badge-en" type="text" value="@Model.Hero.BadgeEn" placeholder="@Localizer["admin_content_ph_badge_en"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md focus:ring-primary focus:border-primary transition-all">
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_title_segments"] <span class="text-xs text-outline">(En)</span></label>
                            <div class="grid grid-cols-2 gap-sm">
                                <input id="hero-title-a-en" type="text" value="@Model.Hero.TitleAEn" placeholder="@Localizer["admin_content_ph_hero_title_a_en"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                                <input id="hero-title-b-en" type="text" value="@Model.Hero.TitleBEn" placeholder="@Localizer["admin_content_ph_hero_title_b_en"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md text-primary font-bold">
                                <input id="hero-title-c-en" type="text" value="@Model.Hero.TitleCEn" placeholder="@Localizer["admin_content_ph_hero_title_c_en"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                                <input id="hero-title-d-en" type="text" value="@Model.Hero.TitleDEn" placeholder="@Localizer["admin_content_ph_hero_title_d_en"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md text-secondary font-bold">
                            </div>
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_desc"] <span class="text-xs text-outline">(En)</span></label>
                            <textarea id="hero-desc-en" rows="4" placeholder="@Localizer["admin_hero_desc_ph"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.Hero.DescriptionEn</textarea>
                        </div>
                        @* <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_hero_btn_text"] <span class="text-xs text-outline">(En)</span></label>
                            <input id="hero-btn-text-en" type="text" value="@Model.Hero.ButtonTextEn" placeholder="@Localizer["btn_shop"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                        </div> *@
                    </div>
                </div>

                <!-- Image Upload (Shared) -->
                <div class="flex flex-col gap-lg">
                    <div class="aspect-video rounded-3xl bg-surface-container dark:bg-surface-container-high border-2 border-dashed border-border dark:border-outline/20 flex flex-col items-center justify-center p-xl relative group overflow-hidden">
                        <img id="hero-image-preview" src="@Model.Hero.ImageUrl" class="absolute inset-0 w-full h-full object-cover opacity-30 group-hover:opacity-10 transition-opacity">
                        <span class="material-symbols-outlined text-4xl text-outline mb-sm">image</span>
                        <span class="font-bold text-text-secondary">@Localizer["admin_hero_image_update"]</span>
                        <input id="hero-image-input" type="file" accept="image/*" class="absolute inset-0 opacity-0 cursor-pointer">
                    </div>
                    <input id="hero-image-url-input" type="hidden" value="@Model.Hero.ImageUrl">
                    <button class="bg-primary text-on-primary py-md rounded-full font-bold shadow-medium hover:scale-103 transition-all" onclick="saveHeroSection()">@Localizer["admin_save_changes"]</button>
                </div>
            </div>
        </div>

        <!-- Section: About Us -->
        <div id="panel-about-us" class="content-panel hidden bg-surface dark:bg-inverse-surface rounded-[32px] shadow-medium border border-border dark:border-outline/10 p-xl">
            <h2 class="font-h2 text-h2 font-bold mb-xl">@Localizer["section_about"]</h2>

            <!-- Language Tabs -->
            <div class="flex gap-sm mb-xl border-b border-border dark:border-outline/10 pb-sm">
                <button onclick="switchAboutLang('ar')" id="about-lang-ar" class="about-lang-tab active px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_ar"]</button>
                <button onclick="switchAboutLang('en')" id="about-lang-en" class="about-lang-tab px-lg py-md rounded-xl font-bold text-sm transition-all">@Localizer["admin_hero_lang_en"]</button>
            </div>

            <div class="space-y-xl">
                <!-- Arabic Fields -->
                <div id="about-fields-ar" class="about-lang-fields">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg mb-2">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_about_title"] <span class="text-xs text-outline">(Ar)</span></label>
                            <input id="about-title-ar" type="text" value="@Model.About.TitleAr" placeholder="@Localizer["admin_content_ph_about_title_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_about_desc"] <span class="text-xs text-outline">(Ar)</span></label>
                            <textarea id="about-desc-ar" rows="2" placeholder="@Localizer["admin_content_ph_about_desc_ar"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.About.DescriptionAr</textarea>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">1</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 1) <span class="text-xs text-outline">(Ar)</span></h4>
                            </div>
                            <input id="about-feat1-title-ar" type="text" value="@Model.About.Feature1TitleAr" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat1-desc-ar" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature1DescAr</textarea>
                        </div>
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">2</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 2) <span class="text-xs text-outline">(Ar)</span></h4>
                            </div>
                            <input id="about-feat2-title-ar" type="text" value="@Model.About.Feature2TitleAr" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat2-desc-ar" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature2DescAr</textarea>
                        </div>
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">3</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 3) <span class="text-xs text-outline">(Ar)</span></h4>
                            </div>
                            <input id="about-feat3-title-ar" type="text" value="@Model.About.Feature3TitleAr" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat3-desc-ar" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature3DescAr</textarea>
                        </div>
                    </div>
                </div>

                <!-- English Fields -->
                <div id="about-fields-en" class="about-lang-fields hidden">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-lg mb-2">
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_about_title"] <span class="text-xs text-outline">(En)</span></label>
                            <input id="about-title-en" type="text" value="@Model.About.TitleEn" placeholder="@Localizer["admin_about_title_ph"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                        </div>
                        <div class="flex flex-col gap-xs">
                            <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_about_desc"] <span class="text-xs text-outline">(En)</span></label>
                            <textarea id="about-desc-en" rows="2" placeholder="@Localizer["admin_about_desc_ph"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.About.DescriptionEn</textarea>
                        </div>
                    </div>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">1</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 1) <span class="text-xs text-outline">(En)</span></h4>
                            </div>
                            <input id="about-feat1-title-en" type="text" value="@Model.About.Feature1TitleEn" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat1-desc-en" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature1DescEn</textarea>
                        </div>
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">2</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 2) <span class="text-xs text-outline">(En)</span></h4>
                            </div>
                            <input id="about-feat2-title-en" type="text" value="@Model.About.Feature2TitleEn" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat2-desc-en" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature2DescEn</textarea>
                        </div>
                        <div class="bg-surface-container dark:bg-surface-container-high p-lg rounded-2xl border border-border">
                            <div class="flex items-center gap-md mb-md">
                                <span class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold">3</span>
                                <h4 class="font-bold">@string.Format(Localizer["admin_feature_h"].Value, 3) <span class="text-xs text-outline">(En)</span></h4>
                            </div>
                            <input id="about-feat3-title-en" type="text" value="@Model.About.Feature3TitleEn" placeholder="@Localizer["admin_feature_title_ph"]" class="w-full bg-surface border-border rounded-lg p-md mb-sm">
                            <textarea id="about-feat3-desc-en" rows="3" placeholder="@Localizer["admin_feature_desc_ph"]" class="w-full bg-surface border-border rounded-lg p-md text-sm">@Model.About.Feature3DescEn</textarea>
                        </div>
                    </div>
                </div>

                <button onclick="saveAboutSection()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
            </div>
        </div>

        <!-- Section: Customer Stories (Testimonials) -->
        <div id="panel-customer-stories" class="content-panel hidden bg-surface dark:bg-inverse-surface rounded-[32px] shadow-medium border border-border dark:border-outline/10 p-xl">
            <div class="flex justify-between items-center mb-xl">
                <div>
                    <h2 class="font-h2 text-h2 font-bold">@Localizer["section_testimonials"]</h2>
                    <p class="text-text-secondary">@Localizer["admin_testimonials_desc"]</p>
                </div>
                <button onclick="saveTestimonialsSection()" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg mb-xl">
                <div class="flex flex-col gap-xs">
                    <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_testi_title"]</label>
                    <input id="testi-title" type="text" value="@Model.Testimonials.Title" placeholder="@Localizer["admin_content_ph_testi_title"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                </div>
                <div class="flex flex-col gap-xs">
                    <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_testi_desc"]</label>
                    <textarea id="testi-desc" rows="2" placeholder="@Localizer["admin_content_ph_testi_desc"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.Testimonials.Description</textarea>
                </div>
            </div>

            <!-- Dynamic Brand Reviews from Database -->
            <div class="flex items-center justify-between mb-md">
                <h3 class="font-bold text-text-primary">@Localizer["brand_reviews_admin_title"]</h3>
                <a href="/admin/brand-reviews" class="text-sm font-bold text-primary hover:underline flex items-center gap-1">
                    <span class="material-symbols-outlined text-lg">open_in_new</span>
                    @Localizer["admin_manage_reviews"]
                </a>
            </div>

            @if (Model.BrandReviews.Count == 0)
            {
                <div class="text-center py-lg px-lg text-outline bg-surface-container/50 rounded-2xl border border-border/50">
                    <span class="material-symbols-outlined text-4xl block mb-2">rate_review</span>
                    <p class="text-sm">@Localizer["admin_testimonials_empty"]</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto rounded-2xl border border-border/50">
                    <table class="w-full text-left rtl:text-right">
                        <thead class="bg-surface-container">
                            <tr>
                                <th class="py-md px-lg font-bold text-outline uppercase text-xs">@Localizer["admin_th_customer"]</th>
                                <th class="py-md px-lg font-bold text-outline uppercase text-xs">@Localizer["admin_th_quote"]</th>
                                <th class="py-md px-lg font-bold text-outline uppercase text-xs">@Localizer["admin_th_rating"]</th>
                                <th class="py-md px-lg font-bold text-outline uppercase text-xs">@Localizer["admin_th_status"]</th>
                                <th class="py-md px-lg font-bold text-outline uppercase text-xs">@Localizer["admin_th_display"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model.BrandReviews)
                            {
                                <tr class="border-b border-border/50 hover:bg-surface-container/50 transition-colors">
                                    <td class="py-md px-lg">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 bg-gradient-to-br from-primary/20 to-primary/5">
                                                @if (!string.IsNullOrEmpty(review.ProfilePictureUrl))
                                                {
                                                    <img src="@review.ProfilePictureUrl" alt="@review.CustomerName" class="w-full h-full object-cover" onerror="this.onerror=null; this.style.display='none'; this.parentElement.innerHTML='<span class=\'flex items-center justify-center w-full h-full text-sm font-bold text-primary\'>@review.CustomerName[0]</span>'" />
                                                }
                                                else
                                                {
                                                    <span class="flex items-center justify-center w-full h-full text-sm font-bold text-primary">@review.CustomerName[0]</span>
                                                }
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-text-primary">@review.CustomerName</p>
                                                <p class="text-xs text-outline">@review.CustomerEmail</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-md px-lg max-w-xs">
                                        <p class="text-sm text-text-secondary line-clamp-2">&ldquo;@review.ReviewText&rdquo;</p>
                                    </td>
                                    <td class="py-md px-lg">
                                        <div class="flex gap-0.5" aria-label="@string.Format(Localizer["admin_review_rating_aria"].Value, review.Rating)">
                                            @for (int j = 0; j < 5; j++)
                                            {
                                                <span class="material-symbols-outlined text-sm @(j < review.Rating ? "text-yellow-500 fill-icon" : "text-outline/20")">star</span>
                                            }
                                        </div>
                                    </td>
                                    <td class="py-md px-lg">
                                        @if (review.IsApproved)
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-bold text-success bg-success/10 px-2.5 py-1 rounded-full">@Localizer["admin_approved"]</span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1 text-xs font-bold text-outline bg-outline/10 px-2.5 py-1 rounded-full">@Localizer["admin_pending"]</span>
                                        }
                                    </td>
                                    <td class="py-md px-lg">
                                        <label class="relative inline-flex items-center cursor-pointer">
                                            <input type="checkbox" class="sr-only peer brand-review-display" data-review-id="@review.Id" @(review.IsDisplayed ? "checked" : "") onchange="toggleBrandReviewDisplay('@review.Id', this.checked)">
                                            <div class="w-10 h-5 bg-outline/20 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:ltr:left-[2px] after:rtl:right-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary"></div>
                                            <span class="ltr:ml-2 rtl:mr-2 text-xs font-medium @(review.IsDisplayed ? "text-primary" : "text-outline")">@(review.IsDisplayed ? Localizer["admin_displayed"] : Localizer["admin_hidden"])</span>
                                        </label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <p class="text-xs text-outline mt-md flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">info</span>
                @Localizer["admin_testimonials_dynamic_hint"]
            </p>
        </div>

        <!-- Section: Contact Info -->
        <div id="panel-contact-info" class="content-panel hidden bg-surface dark:bg-inverse-surface rounded-[32px] shadow-medium border border-border dark:border-outline/10 p-xl">
            <h2 class="font-h2 text-h2 font-bold mb-xl">@Localizer["section_contact"]</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
                <div class="space-y-lg">
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_contact_email"]</label>
                        <input id="contact-email" type="email" value="@Model.Contact.Email" placeholder="@Localizer["admin_content_ph_contact_email"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_contact_phone"]</label>
                        <input id="contact-phone" type="text" value="@Model.Contact.Phone" placeholder="@Localizer["admin_content_ph_contact_phone"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["admin_contact_address"]</label>
                        <textarea id="contact-address" rows="3" placeholder="@Localizer["admin_content_ph_contact_address"]" class="bg-surface-container dark:bg-surface-container-high border-border rounded-xl p-md">@Model.Contact.Address</textarea>
                    </div>
                </div>
                <div class="bg-primary/5 rounded-3xl p-xl flex flex-col items-center justify-center text-center border border-primary/10">
                    <span class="material-symbols-outlined text-6xl text-primary mb-md">location_on</span>
                    <h3 class="font-bold text-xl mb-sm">@Localizer["admin_map_integration_h"]</h3>
                    <p class="text-text-secondary text-sm">@Localizer["admin_map_integration_p"]</p>
                </div>
            </div>
            <button onclick="saveContactSection()" class="mt-xl bg-primary text-on-primary px-xl py-md rounded-full font-bold">@Localizer["admin_save_changes"]</button>
        </div>

    </div>
</div>

<style>
    .content-tab-btn {
        color: var(--md-sys-color-text-secondary);
    }
    .content-tab-btn:hover {
        background-color: var(--md-sys-color-surface-container-high);
        color: var(--md-sys-color-primary);
    }
    .content-tab-btn.active {
        background-color: var(--md-sys-color-primary-container);
        color: var(--md-sys-color-on-primary-container);
        font-weight: 700;
    }
    
    .sortable-ghost {
        opacity: 0.4;
        border: 2px dashed var(--md-sys-color-primary) !important;
        background-color: var(--md-sys-color-primary-container) !important;
    }
    
    .sortable-drag {
        cursor: grabbing !important;
    }

    .filled-icon {
        font-variation-settings: 'FILL' 1;
    }

    .hero-lang-tab, .about-lang-tab {
        color: var(--md-sys-color-text-secondary);
        border: 1px solid transparent;
    }
    .hero-lang-tab:hover, .about-lang-tab:hover {
        background-color: var(--md-sys-color-surface-container-high);
        color: var(--md-sys-color-primary);
    }
    .hero-lang-tab.active, .about-lang-tab.active {
        background-color: var(--md-sys-color-primary-container);
        color: var(--md-sys-color-on-primary-container);
        border-color: var(--md-sys-color-primary);
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        // Mapping of section IDs to tab IDs
        const sectionToTabMap = {
            'hero': 'hero-banner',
            'about': 'about-us',
            'categories': 'section-order',
            'shop': 'section-order',
            'all-products': 'section-order',
            'testimonials': 'customer-stories',
            'contact': 'contact-info'
        };

        function goToEditor(sectionId) {
            const tabId = sectionToTabMap[sectionId] || 'section-order';
            switchTab(tabId);
        }

        function switchTab(tabId) {
            // Update Buttons
            document.querySelectorAll('.content-tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            const activeTab = document.getElementById('tab-' + tabId);
            if (activeTab) activeTab.classList.add('active');

            // Update Panels
            document.querySelectorAll('.content-panel').forEach(panel => {
                panel.classList.add('hidden');
            });
            const activePanel = document.getElementById('panel-' + tabId);
            if (activePanel) activePanel.classList.remove('hidden');
            
            // Re-init sortable if it's the section-order tab
            if (tabId === 'section-order') {
                initSortable();
            }
        }

        function initSortable() {
            const el = document.getElementById('sortable-sections');
            if (el && !el.dataset.sortable) {
                new Sortable(el, {
                    animation: 250,
                    ghostClass: 'sortable-ghost',
                    dragClass: 'sortable-drag',
                    handle: '.drag_indicator',
                    onEnd: function (evt) {
                        console.log('New order:', Array.from(el.children).map(c => c.dataset.id));
                    }
                });
                el.dataset.sortable = "true";
            }
        }

        function saveLayout() {
            const el = document.getElementById('sortable-sections');
            const sections = Array.from(el.children).map((c, index) => ({
                id: c.dataset.id,
                displayOrder: index,
                isVisible: c.querySelector('input[type="checkbox"]').checked
            }));

            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify({ sectionOrder: { sections: sections } })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showToast('@Localizer["admin_save_success"]', 'success');
                } else {
                    showToast(data.message || '@Localizer["admin_save_error"]', 'error');
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function uploadHeroImage(file) {
            const formData = new FormData();
            formData.append('file', file);

            fetch('/admin/content/upload-image', {
                method: 'POST',
                headers: { 'RequestVerificationToken': window.csrfToken },
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('hero-image-preview').src = data.imageUrl;
                    document.getElementById('hero-image-preview').classList.remove('opacity-30');
                    document.getElementById('hero-image-url-input').value = data.imageUrl;
                } else {
                    alert(data.message);
                }
            })
            .catch(e => console.error('Upload error:', e));
        }

        function switchHeroLang(lang) {
            document.querySelectorAll('.hero-lang-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('hero-lang-' + lang).classList.add('active');
            document.querySelectorAll('.hero-lang-fields').forEach(f => f.classList.add('hidden'));
            document.getElementById('hero-fields-' + lang).classList.remove('hidden');
        }

        function collectHeroData() {
            return {
                badgeAr: document.getElementById('hero-badge-ar')?.value || '',
                titleAAr: document.getElementById('hero-title-a-ar')?.value || '',
                titleBAr: document.getElementById('hero-title-b-ar')?.value || '',
                titleCAr: document.getElementById('hero-title-c-ar')?.value || '',
                titleDAr: document.getElementById('hero-title-d-ar')?.value || '',
                descriptionAr: document.getElementById('hero-desc-ar')?.value || '',
                buttonTextAr: document.getElementById('hero-btn-text-ar')?.value || '',
                badgeEn: document.getElementById('hero-badge-en')?.value || '',
                titleAEn: document.getElementById('hero-title-a-en')?.value || '',
                titleBEn: document.getElementById('hero-title-b-en')?.value || '',
                titleCEn: document.getElementById('hero-title-c-en')?.value || '',
                titleDEn: document.getElementById('hero-title-d-en')?.value || '',
                descriptionEn: document.getElementById('hero-desc-en')?.value || '',
                buttonTextEn: document.getElementById('hero-btn-text-en')?.value || '',
                imageUrl: document.getElementById('hero-image-url-input')?.value || ''
            };
        }

        function saveHeroSection() {
            const data = { hero: collectHeroData() };

            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(d => { if (d.success) showToast('@Localizer["admin_save_success"]', 'success'); else showToast(d.message || '@Localizer["admin_save_error"]', 'error'); })
            .catch(e => showToast('@Localizer["admin_save_error"]', 'error'));
        }

        function toggleBrandReviewDisplay(reviewId, isDisplayed) {
            fetch('/admin/brand-reviews/toggle-display/' + reviewId, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': window.csrfToken
                },
                body: 'returnUrl=/admin/content',
                redirect: 'manual'
            })
            .then(() => {
                const checkbox = document.querySelector(`input[data-review-id="${reviewId}"]`);
                const label = checkbox.closest('label').querySelector('span:last-child');
                if (isDisplayed) {
                    label.textContent = '@Localizer["admin_displayed"]';
                    label.className = 'ltr:ml-2 rtl:mr-2 text-xs font-medium text-primary';
                } else {
                    label.textContent = '@Localizer["admin_hidden"]';
                    label.className = 'ltr:ml-2 rtl:mr-2 text-xs font-medium text-outline';
                }
                showToast(isDisplayed ? '@Localizer["admin_review_displayed"]' : '@Localizer["admin_review_hidden"]', 'success');
            })
            .catch(() => {
                document.querySelector(`input[data-review-id="${reviewId}"]`).checked = !isDisplayed;
                showToast('@Localizer["admin_save_error"]', 'error');
            });
        }

        function switchAboutLang(lang) {
            document.querySelectorAll('.about-lang-tab').forEach(t => t.classList.remove('active'));
            document.getElementById('about-lang-' + lang).classList.add('active');
            document.querySelectorAll('.about-lang-fields').forEach(f => f.classList.add('hidden'));
            document.getElementById('about-fields-' + lang).classList.remove('hidden');
        }

        function collectAboutData() {
            return {
                titleAr: document.getElementById('about-title-ar')?.value || '',
                titleEn: document.getElementById('about-title-en')?.value || '',
                descriptionAr: document.getElementById('about-desc-ar')?.value || '',
                descriptionEn: document.getElementById('about-desc-en')?.value || '',
                feature1TitleAr: document.getElementById('about-feat1-title-ar')?.value || '',
                feature1TitleEn: document.getElementById('about-feat1-title-en')?.value || '',
                feature1DescAr: document.getElementById('about-feat1-desc-ar')?.value || '',
                feature1DescEn: document.getElementById('about-feat1-desc-en')?.value || '',
                feature2TitleAr: document.getElementById('about-feat2-title-ar')?.value || '',
                feature2TitleEn: document.getElementById('about-feat2-title-en')?.value || '',
                feature2DescAr: document.getElementById('about-feat2-desc-ar')?.value || '',
                feature2DescEn: document.getElementById('about-feat2-desc-en')?.value || '',
                feature3TitleAr: document.getElementById('about-feat3-title-ar')?.value || '',
                feature3TitleEn: document.getElementById('about-feat3-title-en')?.value || '',
                feature3DescAr: document.getElementById('about-feat3-desc-ar')?.value || '',
                feature3DescEn: document.getElementById('about-feat3-desc-en')?.value || ''
            };
        }

        function saveAboutSection() {
            const data = { about: collectAboutData() };
            postCmsData(data);
        }

        function saveTestimonialsSection() {
            postCmsData({ testimonials: { title: document.getElementById('testi-title')?.value || '', description: document.getElementById('testi-desc')?.value || '', reviews: [] } });
        }

        function saveContactSection() {
            const data = {
                contact: {
                    email: document.getElementById('contact-email')?.value || '',
                    phone: document.getElementById('contact-phone')?.value || '',
                    address: document.getElementById('contact-address')?.value || ''
                }
            };
            postCmsData(data);
        }

        function saveAllChanges() {
            // Collect section order
            const el = document.getElementById('sortable-sections');
            let sectionOrder = null;
            if (el) {
                const sections = Array.from(el.children).map((c, index) => ({
                    id: c.dataset.id,
                    displayOrder: index,
                    isVisible: c.querySelector('input[type="checkbox"]').checked
                }));
                sectionOrder = { sections: sections };
            }

            // Collect hero (bilingual)
            const hero = collectHeroData();

            // Collect about (bilingual)
            const about = collectAboutData();

            // Collect contact
            const contact = {
                email: document.getElementById('contact-email')?.value || '',
                phone: document.getElementById('contact-phone')?.value || '',
                address: document.getElementById('contact-address')?.value || ''
            };

            const payload = {};
            if (sectionOrder) payload.sectionOrder = sectionOrder;
            payload.hero = hero;
            payload.about = about;
            payload.testimonials = { title: document.getElementById('testi-title')?.value || '', description: document.getElementById('testi-desc')?.value || '', reviews: [] };
            payload.contact = contact;

            postCmsData(payload);
        }

        function postCmsData(data) {
            fetch('/admin/content/update', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': window.csrfToken
                },
                body: JSON.stringify(data)
            })
            .then(r => r.json())
            .then(d => { if (d.success) showToast('@Localizer["admin_save_success"]', 'success'); else showToast(d.message || '@Localizer["admin_save_error"]', 'error'); })
            .catch(e => showToast('@Localizer["admin_save_error"]', 'error'));
        }

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastCms');
            const toast = document.createElement('div');
            const bgColor = type === 'success' ? 'bg-primary' : 'bg-red-500';
            const icon = type === 'success' ? 'check_circle' : 'error';
            toast.className = `${bgColor} text-white px-6 py-4 rounded-2xl shadow-xl flex items-center gap-3 animate-slide-in opacity-0 translate-y-4 transition-all duration-300`;
            toast.innerHTML = '<span class="material-symbols-outlined">' + icon + '</span><span class="text-sm font-bold">' + message + '</span>';
            container.appendChild(toast);
            setTimeout(() => { toast.classList.remove('opacity-0', 'translate-y-4'); toast.classList.add('opacity-100', 'translate-y-0'); }, 10);
            setTimeout(() => { toast.classList.add('opacity-0', 'translate-y--4'); setTimeout(() => toast.remove(), 300); }, 4000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            initSortable();

            const heroInput = document.getElementById('hero-image-input');
            if (heroInput) {
                heroInput.addEventListener('change', (e) => {
                    if (e.target.files && e.target.files[0]) {
                        uploadHeroImage(e.target.files[0]);
                    }
                });
            }
        });
    </script>
}
