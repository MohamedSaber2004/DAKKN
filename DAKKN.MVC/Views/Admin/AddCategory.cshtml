@model DAKKN.MVC.ViewModels.Admin.CategoryFormViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.IsEdit ? Localizer["admin_categories_edit"] : Localizer["admin_categories_add_new"];
}

<div class="max-w-3xl mx-auto pb-12">
    <form asp-action="@(Model.IsEdit ? "EditCategory" : "CreateCategory")" asp-route-id="@Model.Id" method="post" class="space-y-8">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h3 class="text-2xl font-black text-admin-primary">
                    @(Model.IsEdit ? Localizer["admin_categories_edit"] : Localizer["admin_categories_add_new"])
                </h3>
                <p class="text-sm text-admin-secondary">
                    @(Model.IsEdit ? Localizer["admin_categories_edit_subtitle"] : Localizer["admin_categories_new_subtitle"])
                </p>
            </div>
            <div class="flex gap-3 w-full md:w-auto">
                <a asp-action="Categories" class="flex-1 md:flex-none px-6 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-center text-sm font-bold hover:bg-surface-container transition-all">
                    @Localizer["admin_cancel"]
                </a>
                <button type="submit" class="flex-1 md:flex-none px-6 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                    @(Model.IsEdit ? Localizer["admin_product_update_btn"] : Localizer["admin_product_save"])
                </button>
            </div>
        </div>

        <div class="premium-card p-8 space-y-6">
            <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">category</span>
                @Localizer["admin_categories_add_new"]
            </h4>

            <div class="space-y-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_category_name"] (@Localizer["admin_lang_en"])</label>
                    <input asp-for="CategoryName" type="text" placeholder="e.g. Gaming" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                    <span asp-validation-for="CategoryName" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_category_arname"] (@Localizer["admin_lang_ar"])</label>
                    <input asp-for="ArName" type="text" placeholder="مثال: جيمنج" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                    <span asp-validation-for="ArName" class="text-xs text-red-500"></span>
                </div>
            </div>
        </div>
    </form>
</div>
