@model DAKKN.MVC.ViewModels.Admin.CategoryFormViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.IsEdit ? Localizer["admin_categories_edit"] : Localizer["admin_categories_add_new"];
}

<div class="max-w-3xl mx-auto pb-12">
    <form asp-action="@(Model.IsEdit ? "EditCategory" : "CreateCategory")" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="space-y-8">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h3 class="text-2xl font-black text-admin-primary">
                    @(Model.IsEdit ? Localizer["admin_categories_edit"] : Localizer["admin_categories_add_new"])
                </h3>
                <p class="text-sm text-admin-secondary">
                    @(Model.IsEdit ? Localizer["admin_categories_edit_subtitle"] : Localizer["admin_categories_new_subtitle"])
                </p>
            </div>
            <div class="flex gap-3 w-full md:w-auto">
                <a asp-action="Categories" class="flex-1 md:flex-none px-6 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-center text-sm font-bold hover:bg-surface-container transition-all">
                    @Localizer["admin_cancel"]
                </a>
                <button type="submit" class="flex-1 md:flex-none px-6 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                    @(Model.IsEdit ? Localizer["admin_product_update_btn"] : Localizer["admin_product_save"])
                </button>
            </div>
        </div>

        <div class="premium-card p-8 space-y-6">
            <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">category</span>
                @Localizer["admin_categories_add_new"]
            </h4>

            <div class="space-y-4">
                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_category_name"] (@Localizer["admin_lang_en"])</label>
                    <input asp-for="CategoryName" type="text" placeholder="@Localizer["admin_content_ph_cat_name_en"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                    <span asp-validation-for="CategoryName" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_category_arname"] (@Localizer["admin_lang_ar"])</label>
                    <input asp-for="ArName" type="text" placeholder="@Localizer["admin_content_ph_cat_name_ar"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                    <span asp-validation-for="ArName" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_category_image"]</label>
                    @if (Model.IsEdit && !string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <div class="relative w-32 h-32 rounded-2xl overflow-hidden border border-admin-border group mb-3">
                            <img src="@Model.ExistingImageUrl" alt="Current Category" class="w-full h-full object-cover" onerror="this.onerror=null; this.src='/images/placeholders/category-placeholder.svg'" />
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <span class="text-white text-xs font-bold">@Localizer["admin_product_image_current"]</span>
                            </div>
                        </div>
                    }
                    <label class="flex items-center gap-3 bg-admin-page border border-dashed border-admin-border rounded-xl px-4 py-6 cursor-pointer hover:border-primary transition-all">
                        <span class="material-symbols-outlined text-admin-secondary">upload</span>
                        <span class="text-sm text-admin-secondary">@Localizer["admin_product_media_subtitle"]</span>
                        <input asp-for="ImageFile" type="file" accept="image/*" class="hidden" onchange="this.closest('label').querySelector('.file-name').textContent = this.files[0]?.name || ''" />
                        <span class="file-name text-xs text-primary font-medium ml-auto"></span>
                    </label>
                    <input type="hidden" asp-for="ExistingImageUrl" />
                </div>
            </div>
        </div>
    </form>
</div>
