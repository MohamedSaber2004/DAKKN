@using DAKKN.MVC.ViewModels.Admin
@model SupportDashboardViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_support_title"];
}

<div class="mb-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-md">
    <div>
        <h2 class="font-h2 text-h2 text-text-primary dark:text-inverse-on-surface mb-sm">@Localizer["admin_support_title"]</h2>
        <p class="font-body text-body text-text-secondary dark:text-outline-variant">@Localizer["admin_support_avg_time"]: @Model.AverageResolutionTime</p>
    </div>
</div>

<!-- Stats Row -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-lg mb-lg">
    <div class="bg-surface dark:bg-surface-container rounded-2xl p-lg shadow-sm border border-border dark:border-outline/20 flex items-center justify-between transition-colors">
        <div>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant mb-xs">@Localizer["admin_support_open"]</p>
            <p class="font-h2 text-h2 text-text-primary dark:text-inverse-on-surface">@Model.TotalOpen</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-error-container/20 text-error flex items-center justify-center">
            <span class="material-symbols-outlined filled-icon">mark_email_unread</span>
        </div>
    </div>
    <div class="bg-surface dark:bg-surface-container rounded-2xl p-lg shadow-sm border border-border dark:border-outline/20 flex items-center justify-between transition-colors">
        <div>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant mb-xs">@Localizer["admin_support_waiting"]</p>
            <p class="font-h2 text-h2 text-text-primary dark:text-inverse-on-surface">@Model.WaitingResponse</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-secondary-container/20 text-secondary flex items-center justify-center">
            <span class="material-symbols-outlined filled-icon">pending_actions</span>
        </div>
    </div>
    <div class="bg-surface dark:bg-surface-container rounded-2xl p-lg shadow-sm border border-border dark:border-outline/20 flex items-center justify-between transition-colors">
        <div>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant mb-xs">@Localizer["admin_support_resolved"]</p>
            <p class="font-h2 text-h2 text-text-primary dark:text-inverse-on-surface">45</p>
        </div>
        <div class="w-12 h-12 rounded-full bg-primary-container/20 text-primary flex items-center justify-center">
            <span class="material-symbols-outlined filled-icon">check_circle</span>
        </div>
    </div>
</div>

<!-- Support Interface -->
<div class="flex flex-col lg:flex-row gap-lg h-auto lg:h-[calc(100vh-320px)]">
    <!-- Ticket List -->
    <div class="w-full lg:w-1/3 bg-surface dark:bg-surface-container rounded-2xl shadow-sm border border-border dark:border-outline/20 flex flex-col overflow-hidden transition-colors">
        <div class="p-md border-b border-border dark:border-outline/20 bg-surface-bright dark:bg-surface-container-high flex gap-sm overflow-x-auto hide-scrollbar">
            <button class="px-md py-1 bg-primary text-on-primary rounded-full font-caption text-caption whitespace-nowrap">@Localizer["admin_support_all"]</button>
            <button class="px-md py-1 bg-surface dark:bg-surface-container-low border border-border dark:border-outline/20 text-text-secondary dark:text-outline-variant rounded-full font-caption text-caption hover:bg-surface-container-low dark:hover:bg-surface-container-high transition-colors whitespace-nowrap">@Localizer["admin_support_open"]</button>
            <button class="px-md py-1 bg-surface dark:bg-surface-container-low border border-border dark:border-outline/20 text-text-secondary dark:text-outline-variant rounded-full font-caption text-caption hover:bg-surface-container-low dark:hover:bg-surface-container-high transition-colors whitespace-nowrap">@Localizer["admin_support_inprogress"]</button>
        </div>
        <div class="flex-1 overflow-y-auto p-sm flex flex-col gap-xs custom-scrollbar">
            @foreach (var ticket in Model.Tickets)
            {
                var priorityClass = ticket.Priority switch
                {
                    TicketPriority.Urgent => "bg-error-container text-error",
                    TicketPriority.High => "bg-tertiary-container text-tertiary",
                    TicketPriority.Medium => "bg-secondary-container text-secondary",
                    _ => "bg-surface-container-highest text-text-secondary"
                };

                var statusBorder = ticket.Status == TicketStatus.Open ? "border-primary" : "border-transparent";
                var bgClass = ticket.Status == TicketStatus.Open ? "bg-primary-container/10 dark:bg-primary-container/5" : "bg-surface dark:bg-surface-container hover:bg-surface-container-low dark:hover:bg-surface-container-high";

                <div class="p-md rounded-xl @bgClass border @statusBorder cursor-pointer transition-all relative group">
                    @if (ticket.Status == TicketStatus.Open)
                    {
                        <div class="absolute ltr:left-0 rtl:right-0 top-0 bottom-0 w-1 bg-primary rounded-full"></div>
                    }
                    <div class="flex justify-between items-start mb-sm">
                        <span class="font-body text-body text-primary dark:text-primary-light font-bold">#@ticket.TicketId</span>
                        <span class="font-caption text-caption text-text-secondary dark:text-outline">@ticket.CreatedAt.ToString("HH:mm")</span>
                    </div>
                    <h4 class="font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface mb-xs truncate font-semibold">@ticket.Subject</h4>
                    <p class="font-body text-body text-text-secondary dark:text-outline-variant mb-md truncate">@ticket.MessageSnippet</p>
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-xs">
                            <div class="w-6 h-6 rounded-full bg-primary-container flex items-center justify-center text-[10px] text-primary font-bold">
                                @ticket.CustomerName[0]
                            </div>
                            <span class="font-caption text-caption text-text-secondary dark:text-outline">@ticket.CustomerName</span>
                        </div>
                        <span class="px-2 py-0.5 @priorityClass rounded-md font-caption text-caption">@Localizer[$"admin_support_priority_{ticket.Priority.ToString().ToLower()}"]</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Ticket Detail Preview (Desktop only or conditional) -->
    <div class="hidden lg:flex flex-1 bg-surface dark:bg-surface-container rounded-2xl shadow-sm border border-border dark:border-outline/20 flex-col overflow-hidden transition-colors">
        @if (Model.Tickets.Any())
        {
            var firstTicket = Model.Tickets[0];
            <div class="p-lg border-b border-border dark:border-outline/20 flex justify-between items-center bg-surface-bright dark:bg-surface-container-high">
                <div>
                    <div class="flex items-center gap-md mb-xs">
                        <h3 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@firstTicket.Subject</h3>
                        <span class="px-2 py-1 bg-error-container text-error rounded-md font-caption text-caption">@Localizer["admin_support_priority_high"]</span>
                    </div>
                    <p class="font-body text-body text-text-secondary dark:text-outline-variant">@Localizer["admin_support_ticket_no"]@firstTicket.TicketId • @firstTicket.CustomerName</p>
                </div>
                <div class="flex gap-sm">
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light transition-colors hover:bg-surface-container dark:hover:bg-surface-container-high">
                        <span class="material-symbols-outlined">more_vert</span>
                    </button>
                </div>
            </div>
            
            <div class="flex-1 overflow-y-auto p-lg flex flex-col gap-lg bg-background/30 dark:bg-dark-page/10 custom-scrollbar">
                <!-- Customer Message -->
                <div class="flex gap-md">
                    <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center shrink-0 shadow-sm text-primary font-bold">
                        @firstTicket.CustomerName[0]
                    </div>
                    <div class="bg-surface dark:bg-surface-container-high p-md rounded-2xl ltr:rounded-tl-none rtl:rounded-tr-none shadow-sm border border-border dark:border-outline/20 max-w-[80%] transition-colors">
                        <div class="flex justify-between items-baseline mb-sm">
                            <span class="font-body-lg text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@firstTicket.CustomerName</span>
                            <span class="font-caption text-caption text-text-secondary dark:text-outline">10:23 AM</span>
                        </div>
                        <p class="font-body text-body text-text-primary dark:text-inverse-on-surface leading-relaxed">
                            @firstTicket.MessageSnippet
                        </p>
                    </div>
                </div>

                <!-- Admin Response (Mock) -->
                <div class="flex gap-md flex-row-reverse">
                    <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center shrink-0 shadow-sm font-bold">
                        AD
                    </div>
                    <div class="bg-primary-container/10 dark:bg-primary/10 p-md rounded-2xl ltr:rounded-tr-none rtl:rounded-tl-none shadow-sm border border-primary/20 max-w-[80%] transition-colors">
                        <div class="flex justify-between items-baseline mb-sm flex-row-reverse">
                            <span class="font-body-lg text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_profile"] (@Localizer["brand"])</span>
                            <span class="font-caption text-caption text-text-secondary dark:text-outline">10:45 AM</span>
                        </div>
                        <p class="font-body text-body text-text-primary dark:text-inverse-on-surface leading-relaxed">
                            @Localizer["supp_mock_response"]
                        </p>
                    </div>
                </div>
            </div>

            <div class="p-lg border-t border-border dark:border-outline/20 bg-surface dark:bg-surface-container transition-colors">
                <div class="flex gap-md items-end">
                    <button class="w-12 h-12 flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light hover:bg-surface-container-low dark:hover:bg-surface-container-high rounded-xl transition-colors">
                        <span class="material-symbols-outlined">attach_file</span>
                    </button>
                    <div class="flex-1 relative">
                        <textarea class="w-full bg-surface-container-low dark:bg-surface-container-high border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary rounded-xl py-3 px-4 font-body text-body text-on-surface dark:text-inverse-on-surface resize-none h-[52px] outline-none transition-all" placeholder="@Localizer["form_msg_ph"]"></textarea>
                    </div>
                    <button class="px-xl h-[52px] bg-primary text-on-primary rounded-xl font-body-lg text-body-lg shadow-sm hover:brightness-110 active:scale-95 transition-all flex items-center gap-sm">
                        @Localizer["btn_send"]
                        <span class="material-symbols-outlined text-[20px] ltr:rotate-0 rtl:rotate-180">send</span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="flex-1 flex flex-col items-center justify-center text-text-secondary p-xl">
                <span class="material-symbols-outlined text-6xl mb-md">support_agent</span>
                <p class="font-body-lg text-body-lg">@Localizer["supp_no_tickets"]</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        .filled-icon {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .hide-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .hide-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
}
