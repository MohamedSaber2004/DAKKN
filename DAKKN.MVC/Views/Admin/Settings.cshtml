@using System.Security.Claims
@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Admin.AdminSettingsViewModel
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_settings"];
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
    
    var fullName = User.FindFirstValue("FullName");
    if (string.IsNullOrWhiteSpace(fullName))
    {
        fullName = User.Identity?.Name ?? "Admin";
    }
}

<div class="max-w-6xl mx-auto space-y-lg pb-32">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
        <div>
            <h1 class="text-3xl font-black text-admin-primary">@Localizer["admin_settings"]</h1>
            <p class="text-sm text-admin-secondary mt-1">@Localizer["admin_settings_subtitle"]</p>
        </div>
    </div>

    <!-- Main Grid Layout -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Sticky Left Navigation -->
        <aside class="lg:col-span-1">
            <nav class="flex lg:flex-col gap-2 p-1.5 bg-surface-container dark:bg-[#1E293B] rounded-2xl lg:bg-transparent lg:dark:bg-transparent lg:p-0 sticky top-24">
                <a href="#section-profile" class="flex-1 lg:flex-none flex items-center justify-center lg:justify-start gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all bg-primary/10 text-primary" id="link-profile">
                    <span class="material-symbols-outlined text-lg">person</span>
                    <span>@Localizer["admin_basic_info"]</span>
                </a>
                <a href="#section-appearance" class="flex-1 lg:flex-none flex items-center justify-center lg:justify-start gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all text-text-secondary dark:text-outline-variant hover:bg-surface-container dark:hover:bg-white/5" id="link-appearance">
                    <span class="material-symbols-outlined text-lg">palette</span>
                    <span>@Localizer["admin_appearance"]</span>
                </a>
                <a href="#section-inventory" class="flex-1 lg:flex-none flex items-center justify-center lg:justify-start gap-3 px-4 py-3 rounded-xl text-sm font-bold transition-all text-text-secondary dark:text-outline-variant hover:bg-surface-container dark:hover:bg-white/5" id="link-inventory">
                    <span class="material-symbols-outlined text-lg">inventory_2</span>
                    <span>@Localizer["admin_inventory_settings"]</span>
                </a>
            </nav>
        </aside>

        <!-- Settings Content Cards -->
        <div class="lg:col-span-3 space-y-8">
            <form id="settings-form" asp-action="Settings" asp-controller="Admin" method="post" class="space-y-8">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Theme" id="hidden-theme" />
                <input type="hidden" asp-for="Language" id="hidden-lang" />
                <input type="hidden" asp-for="IsDarkMode" id="hidden-is-dark" />
                <input type="hidden" asp-for="LayoutMode" id="hidden-layout" />
                <input type="hidden" asp-for="PrimaryColor" id="hidden-color" />

                <!-- Profile Section -->
                <section id="section-profile" class="premium-card p-6 sm:p-8 space-y-6 scroll-mt-24">
                    <div class="flex justify-between items-start border-b border-border dark:border-white/5 pb-4">
                        <div>
                            <h2 class="text-xl font-bold text-admin-primary">@Localizer["admin_basic_info"]</h2>
                            <p class="text-xs text-admin-secondary mt-1">@Localizer["admin_basic_info_desc"]</p>
                        </div>
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-primary-container/20 text-primary dark:bg-primary/20 dark:text-primary-light rounded-full text-xs font-bold">
                            <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
                            @Localizer["admin_active"]
                        </span>
                    </div>

                    @await Html.PartialAsync("Partials/_AuthAlert")

                    <div class="flex flex-col sm:flex-row items-center gap-6 p-4 bg-surface-container-low dark:bg-black/10 rounded-2xl">
                        <div class="relative group">
                            <div class="w-20 h-20 rounded-full overflow-hidden border-4 border-surface dark:border-white/5 shadow-medium flex items-center justify-center bg-surface-container dark:bg-black/20" id="avatar-container">
                                @if (Model.HasProfileImage)
                                {
                                    <img id="profile-image-img" alt="Admin Avatar" class="w-full h-full object-cover" src="@Model.ProfileImageSrc?v=@DateTime.Now.Ticks">
                                }
                                else
                                {
                                    <span id="default-avatar-icon" class="material-symbols-outlined text-4xl text-admin-secondary">person</span>
                                }
                                <div id="avatar-spinner" class="absolute inset-0 hidden items-center justify-center bg-black/40 rounded-full">
                                    <span class="material-symbols-outlined text-white animate-spin">refresh</span>
                                </div>
                            </div>
                            <button id="btn-edit-icon" class="absolute bottom-0 right-0 w-7 h-7 bg-surface dark:bg-inverse-surface rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-115 transition-transform border border-border dark:border-white/10" type="button">
                                <span class="material-symbols-outlined text-base">edit</span>
                            </button>
                            <input id="profile-image-input" type="file" accept=".jpg,.jpeg,.png,.webp" class="hidden">
                        </div>
                        <div class="text-center sm:text-left rtl:sm:text-right space-y-2">
                            <h4 class="font-bold text-admin-primary">@Localizer["admin_profile_pic"]</h4>
                            <p class="text-xs text-admin-secondary">@Localizer["admin_profile_pic_format"]</p>
                            <div class="flex justify-center sm:justify-start gap-2">
                                <button id="btn-change-photo" class="px-4 py-1.5 bg-surface dark:bg-white/5 border border-primary text-primary dark:border-primary-light dark:text-primary-light rounded-xl text-xs font-bold hover:bg-primary/5 transition-colors" type="button">@Localizer["admin_change"]</button>
                                <button id="btn-remove-photo" class="px-4 py-1.5 text-error dark:text-error-light text-xs font-bold hover:bg-error/5 rounded-xl transition-colors" type="button">@Localizer["admin_remove"]</button>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1.5 md:col-span-2">
                            <label asp-for="FullName" class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_user_full_name"]</label>
                            <input asp-for="FullName" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-transparent dark:border-white/5 focus:ring-2 focus:ring-primary/20 outline-none font-bold text-sm text-admin-primary transition-all placeholder:text-text-secondary dark:placeholder:text-outline" type="text" placeholder="@Localizer["admin_user_full_name"]">
                            <span asp-validation-for="FullName" class="text-xs text-error font-bold block mt-1"></span>
                        </div>
                        <div class="space-y-1.5 md:col-span-2">
                            <label asp-for="Email" class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["auth.login.email"]</label>
                            <input asp-for="Email" class="w-full px-4 py-3 bg-surface-container/40 dark:bg-black/40 rounded-2xl border border-transparent dark:border-white/5 text-admin-secondary cursor-not-allowed opacity-60 font-semibold text-sm transition-all" type="email" readonly>
                        </div>
                    </div>
                </section>

                <!-- Appearance Section -->
                <section id="section-appearance" class="premium-card p-6 sm:p-8 space-y-6 scroll-mt-24">
                    <div class="border-b border-border dark:border-white/5 pb-4">
                        <h2 class="text-xl font-bold text-admin-primary">@Localizer["admin_appearance"]</h2>
                        <p class="text-xs text-admin-secondary mt-1">@Localizer["admin_appearance_desc"]</p>
                    </div>

                    <div class="space-y-6">
                        <!-- Theme Selection -->
                        <div class="space-y-3">
                            <h4 class="text-sm font-bold text-admin-primary">@Localizer["admin_theme_select"]</h4>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <button type="button" onclick="setTheme('light')" class="theme-card group p-5 rounded-2xl border-2 transition-all text-left rtl:text-right bg-white dark:bg-black/20 border-border dark:border-white/5 hover:border-primary/40" id="theme-card-light">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="material-symbols-outlined text-4xl text-amber-500 group-[.active]:filled-icon">light_mode</span>
                                        <div class="w-6 h-6 rounded-full border-2 border-border dark:border-white/20 group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center transition-all">
                                            <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                                        </div>
                                    </div>
                                    <h5 class="font-bold text-sm text-admin-primary">@Localizer["admin_theme_light"]</h5>
                                    <p class="text-xs text-admin-secondary mt-1">@Localizer["admin_theme_light_desc"]</p>
                                </button>
                                <button type="button" onclick="setTheme('dark')" class="theme-card group p-5 rounded-2xl border-2 transition-all text-left rtl:text-right bg-white dark:bg-black/20 border-border dark:border-white/5 hover:border-primary/40" id="theme-card-dark">
                                    <div class="flex items-center justify-between mb-4">
                                        <span class="material-symbols-outlined text-4xl text-primary-light group-[.active]:filled-icon">dark_mode</span>
                                        <div class="w-6 h-6 rounded-full border-2 border-border dark:border-white/20 group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center transition-all">
                                            <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                                        </div>
                                    </div>
                                    <h5 class="font-bold text-sm text-admin-primary">@Localizer["admin_theme_dark"]</h5>
                                    <p class="text-xs text-admin-secondary mt-1">@Localizer["admin_theme_dark_desc"]</p>
                                </button>
                            </div>
                        </div>

                        <!-- Primary Color -->
                        <div class="space-y-3 pt-6 border-t border-border dark:border-white/5">
                            <h4 class="text-sm font-bold text-admin-primary">@Localizer["admin_primary_color"]</h4>
                            <div class="flex flex-wrap gap-3">
                                @{
                                    var colors = new[] { 
                                        new { Name = Localizer["color_teal"].Value, Hex = "#0E908C" },
                                        new { Name = Localizer["color_blue"].Value, Hex = "#3B82F6" },
                                        new { Name = Localizer["color_purple"].Value, Hex = "#8B5CF6" },
                                        new { Name = Localizer["color_pink"].Value, Hex = "#EC4899" },
                                        new { Name = Localizer["color_orange"].Value, Hex = "#F59E0B" },
                                        new { Name = Localizer["color_slate"].Value, Hex = "#475569" }
                                    };
                                }
                                @foreach (var color in colors)
                                {
                                    <button type="button" onclick="setPrimaryColor('@color.Hex')" 
                                            class="w-10 h-10 rounded-full border-4 border-transparent hover:scale-105 active:scale-95 transition-all shadow-sm focus-ring"
                                            style="background-color: @color.Hex;"
                                            title="@color.Name"
                                            data-color-btn="@color.Hex">
                                    </button>
                                }
                            </div>
                        </div>

                        <!-- Language -->
                        <div class="space-y-3 pt-6 border-t border-border dark:border-white/5">
                            <h4 class="text-sm font-bold text-admin-primary">@Localizer["admin_lang_select"]</h4>
                            <div class="flex flex-wrap gap-4">
                                <button type="button" onclick="setLanguage('en')" class="lang-btn px-6 py-4 rounded-2xl border-2 transition-all flex items-center gap-4 text-start @(Model.Language == "en" ? "border-primary bg-primary/5 text-primary" : "border-border dark:border-white/5 text-admin-secondary hover:border-primary/30")" id="lang-en">
                                    <span class="text-3xl">🇺🇸</span>
                                    <div>
                                        <div class="font-bold text-sm text-admin-primary">@Localizer["admin_lang_en"]</div>
                                        <div class="text-[9px] uppercase tracking-wider text-admin-secondary mt-0.5">@Localizer["admin_lang_en_sub"]</div>
                                    </div>
                                </button>
                                <button type="button" onclick="setLanguage('ar')" class="lang-btn px-6 py-4 rounded-2xl border-2 transition-all flex items-center gap-4 text-start @(Model.Language == "ar" ? "border-primary bg-primary/5 text-primary" : "border-border dark:border-white/5 text-admin-secondary hover:border-primary/30")" id="lang-ar">
                                    <span class="text-3xl">🇪🇬</span>
                                    <div>
                                        <div class="font-bold text-sm text-admin-primary">@Localizer["admin_lang_ar"]</div>
                                        <div class="text-[9px] uppercase tracking-wider text-admin-secondary mt-0.5">@Localizer["admin_lang_ar_sub"]</div>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Inventory Settings Section -->
                <section id="section-inventory" class="premium-card p-6 sm:p-8 space-y-6 scroll-mt-24">
                    <div class="border-b border-border dark:border-white/5 pb-4">
                        <h2 class="text-xl font-bold text-admin-primary">@Localizer["admin_inventory_settings"]</h2>
                        <p class="text-xs text-admin-secondary mt-1">@Localizer["admin_inventory_settings_desc"]</p>
                    </div>
                    <div class="space-y-3">
                        <h4 class="text-sm font-bold text-admin-primary">@Localizer["admin_global_danger_quantity"]</h4>
                        <div class="max-w-xs">
                            <input type="number" name="GlobalDangerQuantity" id="globalDangerQuantity" min="0"
                                   class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all"
                                   value="@ViewData["GlobalDangerQuantity"]" />
                        </div>
                        <p class="text-xs text-admin-secondary">@Localizer["admin_global_danger_quantity_desc"]</p>
                    </div>
                </section>
            </form>
        </div>
    </div>
</div>

<!-- Floating Glass Save Changes Bar -->
<div id="settings-save-bar" class="fixed bottom-6 ltr:right-6 rtl:left-6 md:ltr:right-12 md:rtl:left-12 z-50">
    <button type="submit" form="settings-form" class="h-[56px] px-8 bg-primary text-on-primary rounded-2xl font-bold shadow-large flex items-center gap-3 hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 focus-ring">
        <span class="material-symbols-outlined">save</span>
        @Localizer["admin_save_changes"]
    </button>
</div>

<div id="toast-container" class="fixed top-4 ltr:right-4 rtl:left-4 z-[100] flex flex-col gap-2 hidden"></div>

<style>
    .theme-card.active { 
        border-color: var(--primary-color) !important; 
        box-shadow: 0 0 0 2px rgba(var(--primary-rgb), 0.1);
        background-color: rgba(var(--primary-rgb), 0.02);
    }
    .theme-card.active .w-6.h-6 { 
        border-color: var(--primary-color) !important; 
        background-color: var(--primary-color) !important; 
    }
    .theme-card.active .w-6.h-6 span { 
        opacity: 1 !important; 
    }

    #toast-container { display: flex; }
    .toast-item {
        min-width: 280px;
        max-width: 400px;
        padding: 12px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        box-shadow: 0 4px 24px rgba(0,0,0,0.12);
        display: flex;
        align-items: center;
        gap: 8px;
        animation: toast-in 0.3s ease-out;
    }
    .toast-item.toast-success { background: #059669; color: #fff; }
    .toast-item.toast-error { background: #DC2626; color: #fff; }
    .toast-item.toast-out { animation: toast-out 0.3s ease-in forwards; }
    @@keyframes toast-in {
        from { opacity: 0; transform: translateX(40px); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes toast-out {
        from { opacity: 1; transform: translateX(0); }
        to { opacity: 0; transform: translateX(40px); }
    }
    .animate-spin { animation: spin 1s linear infinite; }
    @@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>

@section Scripts {
    <script>
        function setTheme(theme) {
            const isDark = theme === 'dark';
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            
            // Update hidden inputs for form submission
            document.getElementById('hidden-theme').value = theme;
            document.getElementById('hidden-is-dark').value = isDark ? 'true' : 'false';
            
            localStorage.setItem('dakkn_theme', theme);
            updateThemeCards(theme);
        }

        function updateThemeCards(activeTheme) {
            document.querySelectorAll('.theme-card').forEach(card => {
                card.classList.remove('active');
            });
            const activeCard = document.getElementById('theme-card-' + activeTheme);
            if (activeCard) activeCard.classList.add('active');
        }

        function setLanguage(lang) {
            // Update hidden input for form submission
            document.getElementById('hidden-lang').value = lang;
            
            localStorage.setItem('dakkn_lang', lang);
            
            // Highlight the selected language button
            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('border-primary', 'bg-primary/5', 'text-primary');
                btn.classList.add('border-border', 'dark:border-white/5', 'text-admin-secondary');
            });
            const activeBtn = document.getElementById('lang-' + lang);
            if (activeBtn) {
                activeBtn.classList.add('border-primary', 'bg-primary/5', 'text-primary');
            }
        }

        function setPrimaryColor(color) {
            document.getElementById('hidden-color').value = color;
            document.documentElement.style.setProperty('--primary-color', color);
            
            document.querySelectorAll('[data-color-btn]').forEach(btn => {
                btn.classList.remove('border-primary', 'scale-110', 'shadow-lg');
                btn.classList.add('border-transparent');
            });
            
            const activeBtn = document.querySelector(`[data-color-btn="${color}"]`);
            if (activeBtn) {
                activeBtn.classList.remove('border-transparent');
                activeBtn.classList.add('border-primary', 'scale-110', 'shadow-lg');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Sync localStorage with server-side model values on load
            const modelTheme = '@Model.Theme';
            const modelLang = '@Model.Language';
            
            if (modelTheme) {
                localStorage.setItem('dakkn_theme', modelTheme);
                setTheme(modelTheme);
            }
            
            if (modelLang) {
                localStorage.setItem('dakkn_lang', modelLang);
            }

            // Scrollspy implementation for left navigation
            const sections = document.querySelectorAll('section[id]');
            const links = {
                'section-profile': document.getElementById('link-profile'),
                'section-appearance': document.getElementById('link-appearance'),
                'section-inventory': document.getElementById('link-inventory')
            };

            const scrollContainer = document.getElementById('admin-canvas') || document.querySelector('main > .overflow-y-auto') || window;

            function updateActiveLink() {
                let activeId = 'section-profile';
                // Fallback to top=0 if scrollContainer doesn't have getBoundingClientRect (e.g. window)
                const containerRect = scrollContainer.getBoundingClientRect ? scrollContainer.getBoundingClientRect() : { top: 0 };
                
                sections.forEach(sec => {
                    const rect = sec.getBoundingClientRect();
                    const relativeTop = rect.top - containerRect.top;
                    // Trigger highlighting when section top is close to the top of viewport (e.g. <= 140px)
                    if (relativeTop <= 140) {
                        activeId = sec.getAttribute('id');
                    }
                });

                Object.keys(links).forEach(key => {
                    const link = links[key];
                    if (!link) return;
                    if (key === activeId) {
                        link.classList.add('bg-primary/10', 'text-primary');
                        link.classList.remove('text-text-secondary', 'dark:text-outline-variant', 'hover:bg-surface-container', 'dark:hover:bg-white/5');
                    } else {
                        link.classList.remove('bg-primary/10', 'text-primary');
                        link.classList.add('text-text-secondary', 'dark:text-outline-variant', 'hover:bg-surface-container', 'dark:hover:bg-white/5');
                    }
                });
            }

            if (scrollContainer) {
                scrollContainer.addEventListener('scroll', updateActiveLink, { passive: true });
            }
            updateActiveLink(); // Run initially to highlight current active section

            // Smooth scroll for nav links
            Object.keys(links).forEach(key => {
                const link = links[key];
                if (!link) return;
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetSection = document.getElementById(key);
                    if (targetSection) {
                        targetSection.scrollIntoView({ behavior: 'smooth' });
                        // Update history state without jumping the page
                        history.pushState(null, null, '#' + key);
                    }
                });
            });

            // --- Profile Image Upload / Remove ---
            const fileInput = document.getElementById('profile-image-input');
            const changeBtn = document.getElementById('btn-change-photo');
            const editIcon = document.getElementById('btn-edit-icon');
            const removeBtn = document.getElementById('btn-remove-photo');
            const avatarContainer = document.getElementById('avatar-container');
            const defaultIcon = document.getElementById('default-avatar-icon');
            const spinner = document.getElementById('avatar-spinner');
            const toastContainer = document.getElementById('toast-container');

            function getToken() {
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            function showToast(message, type) {
                const toast = document.createElement('div');
                toast.className = 'toast-item toast-' + type;
                const icon = type === 'success' ? 'check_circle' : 'error';
                toast.innerHTML = '<span class="material-symbols-outlined text-lg">' + icon + '</span><span>' + message + '</span>';
                toastContainer.appendChild(toast);
                setTimeout(() => {
                    toast.classList.add('toast-out');
                    setTimeout(() => toast.remove(), 300);
                }, 3500);
            }

            function showSpinner(show) {
                spinner.classList.toggle('hidden', !show);
            }

            function updateAvatar(imageUrl) {
                const imgEl = document.getElementById('profile-image-img');
                if (!imageUrl) {
                    if (imgEl) { imgEl.remove(); }
                    if (defaultIcon) { defaultIcon.classList.remove('hidden'); }
                    return;
                }
                if (imgEl) {
                    imgEl.src = imageUrl + '?v=' + Date.now();
                } else {
                    const img = document.createElement('img');
                    img.id = 'profile-image-img';
                    img.alt = 'Admin Avatar';
                    img.className = 'w-full h-full object-cover';
                    img.src = imageUrl + '?v=' + Date.now();
                    avatarContainer.insertBefore(img, spinner);
                }
                if (defaultIcon) { defaultIcon.classList.add('hidden'); }
            }

            function triggerFilePicker() { fileInput.click(); }
            if (changeBtn) { changeBtn.addEventListener('click', triggerFilePicker); }
            if (editIcon) { editIcon.addEventListener('click', triggerFilePicker); }

            if (fileInput) {
                fileInput.addEventListener('change', async function () {
                    const file = this.files[0];
                    if (!file) return;

                    const allowedExtensions = ['.jpg', '.jpeg', '.png', '.webp'];
                    const ext = '.' + file.name.split('.').pop().toLowerCase();
                    if (!allowedExtensions.includes(ext)) {
                        showToast('@Localizer["admin_settings_invalid_file_type"]', 'error');
                        this.value = '';
                        return;
                    }
                    if (file.size > 5 * 1024 * 1024) {
                        showToast('@Localizer["admin_settings_file_too_large"]', 'error');
                        this.value = '';
                        return;
                    }

                    showSpinner(true);
                    const formData = new FormData();
                    formData.append('profileImage', file);
                    formData.append('__RequestVerificationToken', getToken());

                    try {
                        const response = await fetch('/admin/settings/update-profile-image', { method: 'POST', body: formData });
                        const data = await response.json();
                        if (data.success) {
                            updateAvatar(data.imageUrl);
                            showToast(data.message || '@Localizer["admin_settings_upload_success"]', 'success');
                        } else {
                            showToast(data.message || '@Localizer["admin_settings_upload_failed"]', 'error');
                        }
                    } catch {
                        showToast('@Localizer["admin_settings_upload_retry"]', 'error');
                    } finally {
                        showSpinner(false);
                        this.value = '';
                    }
                });
            }

            if (removeBtn) {
                removeBtn.addEventListener('click', async function () {
                    showSpinner(true);
                    const formData = new FormData();
                    formData.append('__RequestVerificationToken', getToken());

                    try {
                        const response = await fetch('/admin/settings/remove-profile-image', { method: 'POST', body: formData });
                        const data = await response.json();
                        if (data.success) {
                            updateAvatar(null);
                            showToast(data.message || '@Localizer["admin_settings_remove_success"]', 'success');
                        } else {
                            showToast(data.message || '@Localizer["admin_settings_remove_failed"]', 'error');
                        }
                    } catch {
                        showToast('@Localizer["admin_settings_remove_retry"]', 'error');
                    } finally {
                        showSpinner(false);
                    }
                });
            }
        });

        });
    </script>
}
