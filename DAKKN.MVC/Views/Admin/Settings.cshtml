@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_settings"];
}

<div class="flex flex-col md:flex-row gap-lg">
    <!-- Internal Settings Nav -->
    <div class="w-full md:w-64 flex-shrink-0">
        <h3 class="font-h4 text-h4 mb-md text-text-primary dark:text-inverse-on-surface">@Localizer["admin_settings"]</h3>
        <nav class="flex flex-row md:flex-col gap-xs overflow-x-auto pb-4 md:pb-0">
            <a class="flex items-center gap-sm px-4 py-3 bg-surface dark:bg-inverse-surface rounded-xl shadow-small border-l-4 border-primary text-primary dark:text-primary-light font-body-lg text-body-lg font-bold whitespace-nowrap" href="#">
                <span class="material-symbols-outlined filled-icon">person</span>
                @Localizer["admin_profile"]
            </a>
            <a class="flex items-center gap-sm px-4 py-3 rounded-xl text-text-secondary dark:text-outline-variant hover:bg-surface-container dark:hover:bg-surface-container-high transition-colors font-body-lg text-body-lg whitespace-nowrap" href="#">
                <span class="material-symbols-outlined">security</span>
                @Localizer["admin_security"]
            </a>
        </nav>
    </div>

    <!-- Settings Canvas -->
    <div class="flex-1 bg-surface dark:bg-inverse-surface rounded-2xl p-lg shadow-medium">
        <div class="flex justify-between items-start mb-lg border-b border-border dark:border-outline/20 pb-md">
            <div>
                <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_basic_info"]</h2>
                <p class="font-body text-body text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_basic_info_desc"]</p>
            </div>
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-primary-container/30 text-on-primary-container dark:bg-primary/20 dark:text-primary-light rounded-full font-caption text-caption font-bold">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                @Localizer["admin_active"]
            </span>
        </div>

        <form class="space-y-xl">
            <!-- Avatar Section -->
            <div class="flex items-center gap-lg">
                <div class="relative group">
                    <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface dark:border-inverse-surface shadow-small">
                        <img alt="صورة المشرف الحالية" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=Admin&background=69d2cf&color=005957&size=200">
                    </div>
                    <button class="absolute bottom-0 right-0 w-8 h-8 bg-surface dark:bg-surface-container-high rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-110 transition-transform border border-border dark:border-outline/20" type="button">
                        <span class="material-symbols-outlined text-[18px]">edit</span>
                    </button>
                </div>
                <div>
                    <h4 class="font-body-lg text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_profile_pic"]</h4>
                    <p class="font-caption text-caption text-text-secondary dark:text-outline-variant mb-2">JPG, GIF أو PNG. @Localizer["admin_max_size"] 8MB.</p>
                    <div class="flex gap-sm">
                        <button class="px-4 py-2 bg-surface dark:bg-surface-container-high border-2 border-primary text-primary dark:border-primary-light dark:text-primary-light rounded-xl font-body text-body font-bold hover:bg-primary/5 transition-colors" type="button">@Localizer["admin_change"]</button>
                        <button class="px-4 py-2 text-error dark:text-error-light font-body text-body hover:bg-error/5 rounded-xl transition-colors" type="button">@Localizer["admin_remove"]</button>
                    </div>
                </div>
            </div>

            <!-- Form Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_first_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="text" value="أحمد">
                </div>
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_last_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="text" value="محمود">
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["auth.login.email"]</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-text-secondary dark:text-outline">mail</span>
                        <input class="w-full pr-12 pl-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="email" value="admin@dakkn.com">
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_role"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container-low dark:bg-inverse-surface-container rounded-[18px] border border-border dark:border-outline/20 font-body text-body text-text-secondary dark:text-outline-variant cursor-not-allowed opacity-70" disabled="" type="text" value="مدير النظام">
                </div>
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_timezone"]</label>
                    <select class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors appearance-none">
                        <option>(GMT+03:00) توقيت الرياض</option>
                        <option>(GMT+02:00) توقيت القاهرة</option>
                        <option>(GMT+04:00) توقيت دبي</option>
                    </select>
                </div>
            </div>

            <!-- Bio Section -->
            <div class="space-y-2">
                <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface flex justify-between">
                    <span>@Localizer["admin_bio"]</span>
                    <span class="text-text-secondary dark:text-outline-variant text-caption font-caption">275/500 @Localizer["admin_chars"]</span>
                </label>
                <textarea class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors resize-none" rows="4">مسؤول عن إدارة المحتوى وتجربة المستخدم في منصة دكّن. مهتم بتصميم الواجهات وتحسين أداء المتاجر الإلكترونية.</textarea>
            </div>
        </form>
    </div>
</div>

<!-- Floating Action Button Area (Save) -->
<div class="fixed bottom-lg left-lg z-50">
    <button class="h-[56px] px-8 bg-primary text-on-primary rounded-full font-body-lg text-body-lg font-bold shadow-medium flex items-center gap-2 hover:scale-103 transition-transform duration-200">
        <span class="material-symbols-outlined">save</span>
        حفظ التغييرات
    </button>
</div>
