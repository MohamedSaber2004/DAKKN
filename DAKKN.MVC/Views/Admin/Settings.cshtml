@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_settings"];
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
}

<div class="max-w-5xl mx-auto space-y-lg pb-32">
    <!-- Profile Section -->
    <section id="section-profile" class="settings-card bg-surface dark:bg-inverse-surface rounded-2xl p-lg shadow-medium border border-border dark:border-outline/10">
        <div class="flex justify-between items-start mb-lg border-b border-border dark:border-outline/20 pb-md">
            <div>
                <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_basic_info"]</h2>
                <p class="font-body text-body text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_basic_info_desc"]</p>
            </div>
            <span class="inline-flex items-center gap-1 px-3 py-1 bg-primary-container/30 text-on-primary-container dark:bg-primary/20 dark:text-primary-light rounded-full font-caption text-caption font-bold">
                <span class="w-2 h-2 rounded-full bg-primary"></span>
                @Localizer["admin_active"]
            </span>
        </div>

        <form class="space-y-xl">
            <div class="flex items-center gap-lg">
                <div class="relative group">
                    <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface dark:border-inverse-surface shadow-small">
                        <img alt="Admin Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=Admin&background=69d2cf&color=005957&size=200">
                    </div>
                    <button class="absolute bottom-0 right-0 w-8 h-8 bg-surface dark:bg-surface-container-high rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-110 transition-transform border border-border dark:border-outline/20" type="button">
                        <span class="material-symbols-outlined text-[18px]">edit</span>
                    </button>
                </div>
                <div>
                    <h4 class="font-body-lg text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_profile_pic"]</h4>
                    <p class="font-caption text-caption text-text-secondary dark:text-outline-variant mb-2">JPG, GIF or PNG. Max 8MB.</p>
                    <div class="flex gap-sm">
                        <button class="px-4 py-2 bg-surface dark:bg-surface-container-high border-2 border-primary text-primary dark:border-primary-light dark:text-primary-light rounded-xl font-body text-body font-bold hover:bg-primary/5 transition-colors" type="button">@Localizer["admin_change"]</button>
                        <button class="px-4 py-2 text-error dark:text-error-light font-body text-body hover:bg-error/5 rounded-xl transition-colors" type="button">@Localizer["admin_remove"]</button>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_first_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="text" value="أحمد">
                </div>
                <div class="space-y-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["admin_last_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="text" value="محمود">
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="block font-body-lg text-body-lg text-text-primary dark:text-inverse-on-surface">@Localizer["auth.login.email"]</label>
                    <input class="w-full px-4 py-3 bg-surface dark:bg-surface-container-high rounded-[18px] border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary font-body text-body text-text-primary dark:text-inverse-on-surface transition-colors" type="email" value="admin@dakkn.com">
                </div>
            </div>
        </form>
    </section>

    <!-- Security Section -->
    <section id="section-security" class="settings-card bg-surface dark:bg-inverse-surface rounded-2xl p-lg shadow-medium border border-border dark:border-outline/10">
        <div class="mb-lg border-b border-border dark:border-outline/20 pb-md">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_security"]</h2>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_security_desc"]</p>
        </div>
        
        <div class="p-xl text-center">
            <span class="material-symbols-outlined text-6xl text-outline mb-md">lock_reset</span>
            <p class="text-text-secondary">Password management and security options will appear here.</p>
        </div>
    </section>

    <!-- Appearance Section -->
    <section id="section-appearance" class="settings-card bg-surface dark:bg-inverse-surface rounded-2xl p-lg shadow-medium border border-border dark:border-outline/10">
        <div class="mb-lg border-b border-border dark:border-outline/20 pb-md">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_appearance"]</h2>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_appearance_desc"]</p>
        </div>

        <div class="space-y-xl">
            <div class="space-y-md">
                <h4 class="font-bold text-lg">@Localizer["admin_theme_select"]</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-lg">
                    <button onclick="setTheme('light')" class="theme-card group p-lg rounded-2xl border-2 transition-all text-left rtl:text-right bg-white border-border hover:border-primary/50" id="theme-card-light">
                        <div class="flex items-center justify-between mb-md">
                            <span class="material-symbols-outlined text-4xl text-yellow-500">light_mode</span>
                            <div class="w-6 h-6 rounded-full border-2 border-border group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center transition-colors">
                                <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                            </div>
                        </div>
                        <h5 class="font-bold text-gray-900">@Localizer["admin_theme_light"]</h5>
                        <p class="text-xs text-gray-500">@Localizer["admin_theme_light_desc"]</p>
                    </button>
                    <button onclick="setTheme('dark')" class="theme-card group p-lg rounded-2xl border-2 transition-all text-left rtl:text-right bg-[#1A1C1E] border-border dark:border-outline/20 hover:border-primary/50" id="theme-card-dark">
                        <div class="flex items-center justify-between mb-md">
                            <span class="material-symbols-outlined text-4xl text-white">dark_mode</span>
                            <div class="w-6 h-6 rounded-full border-2 border-border dark:border-outline group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center transition-colors">
                                <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                            </div>
                        </div>
                        <h5 class="font-bold text-white">@Localizer["admin_theme_dark"]</h5>
                        <p class="text-xs text-white/70">@Localizer["admin_theme_dark_desc"]</p>
                    </button>
                </div>
            </div>

            <div class="space-y-md pt-lg border-t border-border dark:border-outline/20">
                <h4 class="font-bold text-lg">@Localizer["admin_lang_select"]</h4>
                <div class="flex flex-wrap gap-md">
                    <button onclick="setLanguage('en')" class="lang-btn px-xl py-md rounded-2xl border-2 transition-all flex items-center gap-md @(currentCulture.StartsWith("en") ? "border-primary bg-primary/5 text-primary" : "border-border hover:border-primary/30")" id="lang-en">
                        <span class="text-2xl">🇺🇸</span>
                        <div class="text-left rtl:text-right">
                            <div class="font-bold">@Localizer["admin_lang_en"]</div>
                            <div class="text-[10px] uppercase opacity-60">@Localizer["admin_lang_en_sub"]</div>
                        </div>
                    </button>
                    <button onclick="setLanguage('ar')" class="lang-btn px-xl py-md rounded-2xl border-2 transition-all flex items-center gap-md @(currentCulture.StartsWith("ar") ? "border-primary bg-primary/5 text-primary" : "border-border hover:border-primary/30")" id="lang-ar">
                        <span class="text-2xl">🇪🇬</span>
                        <div class="text-left rtl:text-right">
                            <div class="font-bold">@Localizer["admin_lang_ar"]</div>
                            <div class="text-[10px] uppercase opacity-60">@Localizer["admin_lang_ar_sub"]</div>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Floating Save Button -->
<div id="settings-save-bar" class="fixed bottom-lg left-lg z-50">
    <button class="h-[56px] px-8 bg-primary text-on-primary rounded-full font-body-lg text-body-lg font-bold shadow-medium flex items-center gap-2 hover:scale-103 transition-transform duration-200">
        <span class="material-symbols-outlined">save</span>
        @Localizer["admin_save_changes"]
    </button>
</div>

<style>
    .theme-card.active { border-color: var(--md-sys-color-primary); background-color: rgba(var(--md-sys-color-primary-rgb), 0.05); }
</style>

@section Scripts {
    <script>
        function setTheme(theme) {
            const isDark = theme === 'dark';
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
            localStorage.setItem('dakkn_theme', theme);
            updateThemeCards(theme);
        }

        function updateThemeCards(activeTheme) {
            document.querySelectorAll('.theme-card').forEach(card => {
                card.classList.remove('active');
            });
            const activeCard = document.getElementById('theme-card-' + activeTheme);
            if (activeCard) activeCard.classList.add('active');
        }

        function setLanguage(lang) {
            localStorage.setItem('dakkn_lang', lang);
            window.location.href = '/Translation/SetLanguage?culture=' + lang + '&returnUrl=' + encodeURIComponent(window.location.pathname);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('dakkn_theme');
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const themeToApply = savedTheme === 'dark' || (savedTheme !== 'light' && systemPrefersDark) ? 'dark' : 'light';
            
            updateThemeCards(themeToApply);
        });
    </script>
}
