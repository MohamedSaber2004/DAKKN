@model ShippingGovernorateFormViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.IsEdit ? Localizer[LocalizationKeys.AdminShipping.Edit.Key] : Localizer[LocalizationKeys.AdminShipping.AddNew.Key];
}

<div class="max-w-3xl mx-auto pb-12">
    <form asp-action="@(Model.IsEdit ? "EditShipping" : "CreateShipping")" asp-route-id="@Model.Id" method="post" class="space-y-8 has-sticky-bar">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="mb-4">
            <h3 class="text-2xl font-black text-admin-primary">
                @(Model.IsEdit ? Localizer[LocalizationKeys.AdminShipping.Edit.Key] : Localizer[LocalizationKeys.AdminShipping.AddNew.Key])
            </h3>
            <p class="text-sm text-admin-secondary">@Localizer[LocalizationKeys.AdminShipping.Subtitle.Key]</p>
        </div>

        <!-- Mobile Sticky Save Bar -->
        <div class="mobile-form-sticky-bar">
            <a asp-action="Shipping" class="btn-sticky btn-sticky-cancel">
                @Localizer[LocalizationKeys.AdminShipping.Cancel.Key]
            </a>
            <button type="submit" class="btn-sticky btn-sticky-save">
                @Localizer[LocalizationKeys.AdminShipping.Save.Key]
            </button>
        </div>

        <div class="premium-card p-8 space-y-6">
            <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">local_shipping</span>
                @(Model.IsEdit ? Localizer[LocalizationKeys.AdminShipping.Edit.Key] : Localizer[LocalizationKeys.AdminShipping.AddNew.Key])
            </h4>

            <div class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer[LocalizationKeys.AdminShipping.Name.Key]</label>
                        <input asp-for="Name" type="text" placeholder="@Localizer["admin_content_ph_gov_name_en"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        <span asp-validation-for="Name" class="text-xs text-red-500"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer[LocalizationKeys.AdminShipping.ArName.Key]</label>
                        <input asp-for="ArName" type="text" placeholder="@Localizer["admin_content_ph_gov_name_ar"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        <span asp-validation-for="ArName" class="text-xs text-red-500"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer[LocalizationKeys.AdminShipping.Price.Key]</label>
                        <input asp-for="ShippingPrice" type="number" step="0.01" min="0" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        <span asp-validation-for="ShippingPrice" class="text-xs text-red-500"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer[LocalizationKeys.AdminShipping.DisplayOrder.Key]</label>
                        <input asp-for="DisplayOrder" type="number" min="0" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        <span asp-validation-for="DisplayOrder" class="text-xs text-red-500"></span>
                    </div>
                </div>

                @if (Model.IsEdit)
                {
                    <div class="flex items-center gap-3 pt-4">
                        <input asp-for="IsActive" type="checkbox" class="w-5 h-5 rounded border-admin-border text-primary focus:ring-primary" />
                        <label class="text-sm font-medium text-admin-primary">@Localizer[LocalizationKeys.AdminShipping.Active.Key]</label>
                    </div>
                }
            </div>
        </div>

        <!-- Desktop Bottom Action Bar -->
        <div class="hidden md:flex justify-end gap-3 mt-8 pt-6 border-t border-admin-border">
            <a asp-action="Shipping" class="px-6 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-center text-sm font-bold hover:bg-surface-container transition-all">
                @Localizer[LocalizationKeys.AdminShipping.Cancel.Key]
            </a>
            <button type="submit" class="px-8 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-medium hover:scale-103 active:scale-95 transition-all">
                @Localizer[LocalizationKeys.AdminShipping.Save.Key]
            </button>
        </div>
    </form>
</div>

