@model DAKKN.Application.DTOs.ProductDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_product_details_title"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<div class="max-w-5xl mx-auto pb-12">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h3 class="text-2xl font-black text-admin-primary">@(isArabic ? Model.ArName : Model.Name)</h3>
            <p class="text-sm text-admin-secondary">@Localizer["admin_product_details_subtitle"]</p>
        </div>
        <div class="flex gap-3 w-full md:w-auto">
            <a asp-action="EditProduct" asp-route-id="@Model.Id"
               class="flex-1 md:flex-none px-6 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all inline-flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-lg">edit</span>
                @Localizer["admin_product_details_edit"]
            </a>
            <button type="button" onclick="openDeleteProductModal('@Model.Id', '@(isArabic ? Model.ArName : Model.Name)')"
                    class="flex-1 md:flex-none px-6 py-2.5 bg-red-500 text-white rounded-xl text-sm font-bold shadow-small hover:bg-red-600 active:scale-95 transition-all inline-flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-lg">delete</span>
                @Localizer["admin_product_details_delete"]
            </button>
            <a asp-action="Inventory"
               class="flex-1 md:flex-none px-6 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-sm font-bold hover:bg-surface-container transition-all inline-flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-lg">arrow_back</span>
                @Localizer["admin_product_details_back"]
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Left: Product Image -->
        <div class="lg:col-span-1">
            <div class="premium-card p-6">
                <div class="aspect-square rounded-2xl overflow-hidden bg-surface-container">
                    <img src="@Model.ImageUrl" alt="@(isArabic ? Model.ArName : Model.Name)"
                         class="w-full h-full object-cover"
                         onerror="this.src='https://placehold.co/600x600/e2e8f0/64748b?text=No+Image'" />
                </div>
            </div>
        </div>

        <!-- Right: Product Details -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Information Card -->
            <div class="premium-card p-8 space-y-6">
                <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">info</span>
                    @Localizer["admin_product_details_information"]
                </h4>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_name"] (@Localizer["admin_lang_en"])</label>
                            <p class="text-admin-primary font-medium">@Model.Name</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_name"] (@Localizer["admin_lang_ar"])</label>
                            <p class="text-admin-primary font-medium" dir="rtl">@Model.ArName</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_category"]</label>
                            <p class="text-admin-primary font-medium">@(isArabic ? Model.CategoryArName : Model.CategoryName)</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_price"]</label>
                            <p class="text-admin-primary font-bold text-lg">@Model.Price.ToString("N2") @Localizer["egp"]</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["Quantity In Stock"]</label>
                            <p class="text-admin-primary font-bold text-lg">@Model.QuantityInStock</p>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["Danger Quantity"]</label>
                            <p class="text-admin-primary font-medium">@Model.DangerQuantity</p>
                        </div>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_details_status"]</label>
                            @if (Model.IsDeleted)
                            {
                                <span class="status-badge status-cancelled">@Localizer["admin_product_details_status_deleted"]</span>
                            }
                            else if (Model.IsActive)
                            {
                                <span class="status-badge status-done">@Localizer["admin_product_details_status_active"]</span>
                            }
                            else
                            {
                                <span class="status-badge status-pending">@Localizer["admin_product_details_status_inactive"]</span>
                            }
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["Stock Status"]</label>
                            @if (Model.QuantityInStock == 0)
                            {
                                <span class="status-badge status-cancelled">@Localizer["inventory_out_of_stock"]</span>
                            }
                            else if (Model.QuantityInStock <= Model.DangerQuantity)
                            {
                                <span class="px-3 py-1 rounded-lg bg-amber-100 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400 text-xs font-bold">@Localizer["admin_low_stock"] (@Model.QuantityInStock @Localizer["inventory_quantity"])</span>
                            }
                            else
                            {
                                <span class="status-badge status-done">@Localizer["admin_in_stock"]</span>
                            }
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_details_rating"]</label>
                            <div class="flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm text-amber-500">star</span>
                                <span class="text-admin-primary font-bold">@Model.AverageRating.ToString("F1")</span>
                                <span class="text-admin-secondary text-sm">(@Model.ReviewCount @Localizer["Product_Reviews"])</span>
                            </div>
                        </div>
                        <div>
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_details_created_at"]</label>
                            <p class="text-admin-primary font-medium">@Model.CreatedAt.ToString("dd MMM yyyy")</p>
                        </div>
                        @if (Model.UpdatedAt.HasValue)
                        {
                            <div>
                                <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_product_details_updated_at"]</label>
                                <p class="text-admin-primary font-medium">@Model.UpdatedAt.Value.ToString("dd MMM yyyy")</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Size Options Card -->
            <div class="premium-card p-8 space-y-6">
                <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">straighten</span>
                    @Localizer["admin_product_sec_size"]
                </h4>
                @if (Model.SizeOptions.Any())
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var size in Model.SizeOptions)
                        {
                            <span class="px-4 py-2 bg-admin-page border border-admin-border rounded-xl text-sm font-medium text-admin-primary">@size.Trim('"')</span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-admin-secondary text-sm">—</p>
                }
            </div>

            <!-- Description Card -->
            <div class="premium-card p-8 space-y-6">
                <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">description</span>
                    @Localizer["admin_product_desc"]
                </h4>
                <div class="space-y-4">
                    <div>
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_lang_en"]</label>
                        <p class="text-admin-primary text-sm leading-relaxed">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</p>
                    </div>
                    <div>
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider block mb-1">@Localizer["admin_lang_ar"]</label>
                        <p class="text-admin-primary text-sm leading-relaxed" dir="rtl">@(string.IsNullOrEmpty(Model.ArDescription) ? "—" : Model.ArDescription)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Product Modal -->
<div id="deleteProductModal" class="fixed inset-0 z-50 hidden flex items-center justify-center">
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" onclick="closeDeleteProductModal()"></div>
    <div class="relative bg-white dark:bg-[#161d27] rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4 border border-admin-border z-10">
        <div class="text-center">
            <div class="mx-auto w-14 h-14 rounded-full bg-red-100 dark:bg-red-900/20 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-3xl text-red-500">delete_forever</span>
            </div>
            <h3 class="text-xl font-bold text-admin-primary mb-2">@Localizer["admin_product_delete_confirm_title"]</h3>
            <p class="text-admin-secondary text-sm mb-1">@Localizer["admin_product_delete_confirm_message"]</p>
            <p class="text-admin-primary font-semibold text-base mb-6" id="deleteProductModalName"></p>
        </div>
        <form id="deleteProductForm" method="post" class="flex gap-3">
            @Html.AntiForgeryToken()
            <button type="button" onclick="closeDeleteProductModal()" class="flex-1 px-4 py-2.5 rounded-xl border border-admin-border text-admin-primary font-medium text-sm hover:bg-admin-page transition-all">
                @Localizer["admin_cancel"]
            </button>
            <button type="submit" class="flex-1 px-4 py-2.5 rounded-xl bg-red-500 text-white font-medium text-sm hover:bg-red-600 transition-all">
                @Localizer["admin_categories_actions"]
            </button>
        </form>
    </div>
</div>

<script>
    var deleteProductModal = document.getElementById('deleteProductModal');
    var deleteProductForm = document.getElementById('deleteProductForm');
    var deleteProductModalName = document.getElementById('deleteProductModalName');

    function openDeleteProductModal(id, name) {
        deleteProductForm.action = '/admin/delete-product/' + id;
        deleteProductModalName.textContent = '"' + name + '"';
        deleteProductModal.classList.remove('hidden');
    }

    function closeDeleteProductModal() {
        deleteProductModal.classList.add('hidden');
    }

    deleteProductModal.addEventListener('click', function(e) {
        if (e.target === deleteProductModal) {
            closeDeleteProductModal();
        }
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteProductModal();
        }
    });
</script>
