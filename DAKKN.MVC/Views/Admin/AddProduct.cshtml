@model DAKKN.MVC.ViewModels.Admin.AddProductViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.IsEdit ? Localizer["admin_product_edit_title"] : Localizer["admin_add_product"];
}

<div class="max-w-5xl mx-auto pb-12">
    <form asp-action="@(Model.IsEdit ? "EditProduct" : "AddProduct")" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="space-y-8">
        <input type="hidden" asp-for="Id" />
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h3 class="text-2xl font-black text-admin-primary">
                    @(Model.IsEdit ? Localizer["admin_product_edit_title"] : Localizer["admin_product_new_title"])
                </h3>
                <p class="text-sm text-admin-secondary">
                    @(Model.IsEdit ? Localizer["admin_product_edit_subtitle"] : Localizer["admin_product_new_subtitle"])
                </p>
            </div>
            <div class="flex gap-3 w-full md:w-auto">
                <a asp-action="Inventory" class="flex-1 md:flex-none px-6 py-2.5 bg-admin-page border border-admin-border text-admin-secondary rounded-xl text-center text-sm font-bold hover:bg-surface-container transition-all">
                    @Localizer["admin_cancel"]
                </a>
                <button type="submit" class="flex-1 md:flex-none px-6 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                    @(Model.IsEdit ? Localizer["admin_product_update_btn"] : Localizer["admin_product_save"])
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Main Info -->
            <div class="lg:col-span-2 space-y-8">
                <!-- 1. General Information -->
                <div class="premium-card p-8 space-y-6">
                    <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">info</span>
                        @Localizer["admin_product_sec_general"]
                    </h4>
                    
                    <div class="space-y-4">
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_name"] (@Localizer["admin_lang_en"])</label>
                            <input asp-for="Name" type="text" placeholder="@Localizer["admin_content_ph_product_name_en"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_name"] (@Localizer["admin_lang_ar"])</label>
                            <input asp-for="ArName" type="text" placeholder="@Localizer["admin_content_ph_product_name_ar"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_desc"] (@Localizer["admin_lang_en"])</label>
                            <textarea asp-for="Description" rows="5" placeholder="@Localizer["admin_content_ph_product_desc_en"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all resize-none"></textarea>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_desc"] (@Localizer["admin_lang_ar"])</label>
                            <textarea asp-for="ArDescription" rows="5" placeholder="@Localizer["admin_content_ph_product_desc_ar"]" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all resize-none"></textarea>
                        </div>

                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_category"]</label>
                            <div class="relative">
                                <select asp-for="CategoryId" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 ltr:pr-10 rtl:pl-10 outline-none focus:ring-1 focus:ring-primary text-admin-primary cursor-pointer appearance-none">
                                    <option value="">@Localizer["admin_product_cat_select"]</option>
                                    @foreach (var cat in Model.AvailableCategories)
                                    {
                                        <option value="@cat.Id">@cat.CategoryName — @cat.ArName</option>
                                    }
                                </select>
                                <span class="material-symbols-outlined absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 pointer-events-none text-admin-secondary">arrow_drop_down</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Media Upload -->
                <div class="premium-card p-8 space-y-6">
                    <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">image</span>
                        @Localizer["admin_product_sec_media"]
                    </h4>

                    @if (Model.IsEdit && !string.IsNullOrEmpty(Model.ExistingImageUrl))
                    {
                        <div class="relative w-40 h-40 rounded-2xl overflow-hidden border border-admin-border group">
                            <img src="@Model.ExistingImageUrl" alt='@Localizer["admin_content_ph_product_image_alt"]' class="w-full h-full object-cover" onerror="this.onerror=null; this.src='/images/placeholders/product-placeholder.svg'" />
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                <span class="text-white text-xs font-bold">@Localizer["admin_product_image_current"]</span>
                            </div>
                        </div>
                    }

                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_media_title"]</label>
                        <div class="flex items-center gap-4">
                            <label class="flex-1 flex items-center gap-3 bg-admin-page border border-dashed border-admin-border rounded-xl px-4 py-6 cursor-pointer hover:border-primary transition-all">
                                <span class="material-symbols-outlined text-admin-secondary">upload</span>
                                <span class="text-sm text-admin-secondary">@Localizer["admin_product_media_subtitle"]</span>
                                <input asp-for="ImageFile" type="file" accept="image/*" class="hidden" onchange="this.closest('.flex-1').querySelector('.file-name').textContent = this.files[0]?.name || ''" />
                                <span class="file-name text-xs text-primary font-medium ml-auto"></span>
                            </label>
                        </div>
                    </div>
                    <input type="hidden" asp-for="ExistingImageUrl" />
                </div>

                <!-- 3. Pricing -->
                <div class="premium-card p-8 space-y-6">
                    <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">payments</span>
                        @Localizer["admin_product_sec_pricing"]
                    </h4>
                    
                    <div class="space-y-1.5">
                        <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_product_price"]</label>
                        <div class="relative max-w-xs">
                            <input asp-for="Price" type="number" step="0.01" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 ltr:pr-12 rtl:pl-12 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                            <span class="absolute ltr:right-4 rtl:left-4 top-1/2 -translate-y-1/2 text-xs font-bold text-admin-secondary">@Localizer["egp"]</span>
                        </div>
                </div>
            </div>

                <!-- 3b. Inventory -->
                <div class="premium-card p-8 space-y-6">
                    <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">inventory_2</span>
                        @Localizer["admin_inventory"]
                    </h4>
                    
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_quantity_in_stock"]</label>
                            <input asp-for="QuantityInStock" type="number" min="0" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-admin-secondary uppercase tracking-wider">@Localizer["admin_danger_quantity"]</label>
                            <input asp-for="DangerQuantity" type="number" min="0" class="w-full bg-admin-page border border-admin-border rounded-xl px-4 py-3 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                            <p class="text-[10px] text-admin-secondary mt-1">@Localizer["admin_danger_quantity_hint"]</p>
                        </div>
                    </div>
                </div>

                <!-- 4. Size Options -->
                <div class="premium-card p-8 space-y-6">
                    <h4 class="text-lg font-bold text-admin-primary flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">straighten</span>
                        @Localizer["admin_product_sec_size"]
                    </h4>

                    <div id="size-options-container" class="space-y-3">
                        @for (var i = 0; i < Model.SizeOptions.Count; i++)
                        {
                            <div class="size-option flex items-center gap-2">
                                <input type="text" name="SizeOptions" value="@Model.SizeOptions[i]" class="flex-1 bg-admin-page border border-admin-border rounded-xl px-4 py-2.5 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                                <button type="button" onclick="this.closest('.size-option').remove()" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-all">
                                    <span class="material-symbols-outlined text-lg">close</span>
                                </button>
                            </div>
                        }

                        <div class="size-option flex items-center gap-2">
                            <input type="text" placeholder="@Localizer["admin_product_size_add"]" class="flex-1 bg-admin-page border border-admin-border rounded-xl px-4 py-2.5 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />
                            <button type="button" onclick="addSizeOption(this)" class="px-4 py-2.5 bg-primary text-on-primary rounded-xl text-sm font-bold shadow-small hover:scale-103 active:scale-95 transition-all">
                                <span class="material-symbols-outlined text-lg">add</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function addSizeOption(btn) {
        const container = document.getElementById('size-options-container');
        const row = btn.closest('.size-option');
        const input = row.querySelector('input');
        const val = input.value.trim();
        if (!val) return;

        const newRow = document.createElement('div');
        newRow.className = 'size-option flex items-center gap-2';
        newRow.innerHTML = '<input type="text" name="SizeOptions" value="' + val.replace(/"/g, '&quot;') + '" class="flex-1 bg-admin-page border border-admin-border rounded-xl px-4 py-2.5 outline-none focus:ring-1 focus:ring-primary text-admin-primary transition-all" />' +
            '<button type="button" onclick="this.closest(\'.size-option\').remove()" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-all">' +
            '<span class="material-symbols-outlined text-lg">close</span></button>';

        container.insertBefore(newRow, row);
        input.value = '';
        input.focus();
    }
</script>
