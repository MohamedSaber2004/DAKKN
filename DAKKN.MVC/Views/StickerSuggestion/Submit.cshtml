@model DAKKN.Application.Features.StickerSuggestions.Commands.SubmitSuggestion.SubmitSuggestionCommand
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["sticker_suggestion_submit_title"];
}

<div class="max-w-2xl mx-auto px-4 py-6 md:py-8">
    <h1 class="text-xl md:text-2xl font-bold mb-2">@Localizer["sticker_suggestion_submit_heading"]</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6 md:mb-8">@Localizer["sticker_suggestion_submit_subtitle"]</p>

    @if (TempData["Success"] is not null)
    {
        <div class="bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg mb-6">
            @TempData["Success"]
        </div>
    }

    <form asp-action="Submit" method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <div>
            <label asp-for="Title" class="block text-sm font-medium mb-1">@Localizer["sticker_suggestion_form_title"]</label>
            <input asp-for="Title" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition" placeholder="@Localizer["sticker_suggestion_form_title_ph"]" />
            <span asp-validation-for="Title" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Description" class="block text-sm font-medium mb-1">@Localizer["sticker_suggestion_form_desc"]</label>
            <textarea asp-for="Description" rows="5" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition" placeholder="@Localizer["sticker_suggestion_form_desc_ph"]"></textarea>
            <span asp-validation-for="Description" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Tags" class="block text-sm font-medium mb-1">@Localizer["sticker_suggestion_form_tags"]</label>
            <input asp-for="Tags" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition" placeholder="@Localizer["sticker_suggestion_form_tags_ph"]" />
            <p class="text-xs text-gray-400 mt-1">@Localizer["sticker_suggestion_form_tags_hint"]</p>
        </div>

        <div>
            <label asp-for="ReferenceImage" class="block text-sm font-medium mb-1">@Localizer["sticker_suggestion_form_image"]</label>
            <input asp-for="ReferenceImage" type="file" accept="image/*" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 transition" />
            <div id="imagePreview" class="mt-3 hidden">
                <img id="previewImg" src="#" alt="Preview" class="max-w-full h-auto max-h-[200px] rounded-lg border border-gray-300" />
            </div>
        </div>

        <button type="submit" class="w-full bg-primary hover:bg-primary-hover text-on-primary font-medium py-3 px-6 rounded-lg transition duration-200">
            @Localizer["sticker_suggestion_form_submit"]
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelector('input[type="file"]')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                    const preview = document.getElementById('previewImg');
                    preview.src = ev.target.result;
                    document.getElementById('imagePreview').classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
