@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
@{
    var faqs = new[]
    {
        new { Q = Localizer["contact_faq1_q"], A = Localizer["contact_faq1_a"] },
        new { Q = Localizer["contact_faq2_q"], A = Localizer["contact_faq2_a"] },
        new { Q = Localizer["contact_faq3_q"], A = Localizer["contact_faq3_a"] },
        new { Q = Localizer["contact_faq4_q"], A = Localizer["contact_faq4_a"] },
        new { Q = Localizer["contact_faq5_q"], A = Localizer["contact_faq5_a"] },
        new { Q = Localizer["contact_faq6_q"], A = Localizer["contact_faq6_a"] },
    };
}
<section id="faq" class="relative py-12 md:py-24 px-4 overflow-hidden bg-surface dark:bg-[#0F172A]" itemscope itemtype="https://schema.org/FAQPage">
    <div class="max-w-3xl mx-auto">
        <div class="text-center mb-8 md:mb-12 scroll-animate">
            <span class="inline-block text-xs font-bold text-primary bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20 mb-3">@Localizer["f_faqs"]</span>
            <h2 class="text-2xl md:text-4xl font-black text-on-surface dark:text-white">@Localizer["contact_faq_title"]</h2>
            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-400 mt-1 md:mt-2">@Localizer["contact_faq_sub"]</p>
        </div>
        <div class="space-y-3 scroll-animate" id="faq-accordion">
            @for (int i = 0; i < faqs.Length; i++)
            {
                <div class="faq-item bg-surface-container-high dark:bg-[#1E293B] rounded-xl border border-outline-variant/20 dark:border-white/5 overflow-hidden transition-all duration-300" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
                    <button class="faq-trigger w-full flex items-center justify-between gap-4 px-5 md:px-6 py-4 text-start" onclick="toggleFaq(this)" aria-expanded="false" aria-controls="faq-answer-@i" itemprop="name">
                        <span class="text-sm md:text-base font-bold text-on-surface dark:text-white flex-1">@faqs[i].Q</span>
                        <span class="material-symbols-outlined text-primary transition-transform duration-300 faq-icon text-lg flex-shrink-0">add</span>
                    </button>
                    <div id="faq-answer-@i" class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-out" role="region" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
                        <div class="px-5 md:px-6 pb-4 text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed" itemprop="text">@faqs[i].A</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>