@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Landing.LandingPageViewModel
@{
    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var contact = Model.Contact;
}
<section id="contact" class="relative py-16 md:py-24 px-4 overflow-hidden bg-surface dark:bg-[#0F172A]">
    <div class="deco-blob w-[500px] h-[500px] -bottom-40 -start-40 bg-primary/5 animate-blob-3"></div>
    <div class="max-w-6xl mx-auto relative z-10">
        <div class="text-center mb-12 scroll-animate">
            <span class="inline-block text-xs font-bold text-primary bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20 mb-4">@Localizer["contact_badge"]</span>
            <h2 class="text-3xl md:text-4xl font-black text-on-surface dark:text-white">@Localizer["contact_title"]</h2>
            <p class="text-on-surface-variant dark:text-slate-400 mt-2">@Localizer["contact_description"]</p>
        </div>
        <div class="grid lg:grid-cols-5 gap-8 lg:gap-12">
            <div class="lg:col-span-3 scroll-animate">
                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-6 md:p-8 border border-outline-variant/20 dark:border-white/5 shadow-lg">
                    <h3 class="text-lg font-bold text-on-surface dark:text-white mb-1">@Localizer["contact_form_title"]</h3>
                    <p class="text-sm text-on-surface-variant dark:text-slate-400 mb-6">@Localizer["contact_form_sub"]</p>
                    <form id="contact-form" class="space-y-4" novalidate>
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div>
                                <label for="cf-name" class="block text-xs font-bold text-on-surface dark:text-slate-300 mb-1.5">@Localizer["contact_form_name_label"] <span class="text-red-500">*</span></label>
                                <input id="cf-name" type="text" required placeholder="@Localizer["contact_form_name_ph"]" class="w-full px-4 py-3 rounded-xl bg-surface dark:bg-[#0F172A] border border-outline-variant/30 dark:border-white/10 text-sm text-on-surface dark:text-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
                                <span class="cf-error text-xs text-red-500 hidden" data-for="name"></span>
                            </div>
                            <div>
                                <label for="cf-email" class="block text-xs font-bold text-on-surface dark:text-slate-300 mb-1.5">@Localizer["contact_form_email_label"] <span class="text-red-500">*</span></label>
                                <input id="cf-email" type="email" required placeholder="@Localizer["contact_form_email_ph"]" class="w-full px-4 py-3 rounded-xl bg-surface dark:bg-[#0F172A] border border-outline-variant/30 dark:border-white/10 text-sm text-on-surface dark:text-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
                                <span class="cf-error text-xs text-red-500 hidden" data-for="email"></span>
                            </div>
                        </div>
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div>
                                <label for="cf-phone" class="block text-xs font-bold text-on-surface dark:text-slate-300 mb-1.5">@Localizer["contact_form_phone_label"] <span class="text-on-surface-variant text-[10px]">@Localizer["contact_form_phone_opt"]</span></label>
                                <input id="cf-phone" type="tel" placeholder="@Localizer["contact_form_phone_ph"]" class="w-full px-4 py-3 rounded-xl bg-surface dark:bg-[#0F172A] border border-outline-variant/30 dark:border-white/10 text-sm text-on-surface dark:text-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
                            </div>
                            <div>
                                <label for="cf-subject" class="block text-xs font-bold text-on-surface dark:text-slate-300 mb-1.5">@Localizer["contact_form_subject_label"] <span class="text-red-500">*</span></label>
                                <select id="cf-subject" required class="w-full px-4 py-3 rounded-xl bg-surface dark:bg-[#0F172A] border border-outline-variant/30 dark:border-white/10 text-sm text-on-surface dark:text-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all">
                                    <option value="">@Localizer["contact_form_subject_ph"]</option>
                                    <option value="order">@Localizer["contact_form_subj_order"]</option>
                                    <option value="bulk">@Localizer["contact_form_subj_bulk"]</option>
                                    <option value="shipping">@Localizer["contact_form_subj_shipping"]</option>
                                    <option value="return">@Localizer["contact_form_subj_return"]</option>
                                    <option value="design">@Localizer["contact_form_subj_design"]</option>
                                    <option value="other">@Localizer["contact_form_subj_other"]</option>
                                </select>
                                <span class="cf-error text-xs text-red-500 hidden" data-for="subject"></span>
                            </div>
                        </div>
                        <div>
                            <label for="cf-msg" class="block text-xs font-bold text-on-surface dark:text-slate-300 mb-1.5">@Localizer["contact_form_msg_label"] <span class="text-red-500">*</span></label>
                            <textarea id="cf-msg" rows="4" required placeholder="@Localizer["contact_form_msg_ph"]" class="w-full px-4 py-3 rounded-xl bg-surface dark:bg-[#0F172A] border border-outline-variant/30 dark:border-white/10 text-sm text-on-surface dark:text-white placeholder:text-on-surface-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none"></textarea>
                            <span class="cf-error text-xs text-red-500 hidden" data-for="msg"></span>
                        </div>
                        <button type="submit" class="w-full bg-primary hover:bg-primary-container text-on-primary font-bold py-3.5 px-6 rounded-xl transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:scale-95 text-sm flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-lg">send</span>
                            <span>@Localizer["contact_form_submit"]</span>
                        </button>
                        <div id="cf-success" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700/30 rounded-xl p-4 text-center">
                            <span class="material-symbols-outlined text-green-500 text-3xl mb-2">check_circle</span>
                            <p class="font-bold text-green-700 dark:text-green-300">@Localizer["contact_form_success_title"]</p>
                            <p class="text-sm text-green-600 dark:text-green-400 mt-1">@Localizer["contact_form_success_sub"]</p>
                        </div>
                    </form>
                </div>
            </div>
            <div class="lg:col-span-2 space-y-4 scroll-animate delay-200">
                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-5 border border-outline-variant/20 dark:border-white/5 shadow-lg flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-primary">mail</span>
                    </div>
                    <div>
                        <span class="block text-sm font-bold text-on-surface dark:text-white">@Localizer["contact_card_email_title"]</span>
                        <span class="block text-xs text-on-surface-variant dark:text-slate-400">@Localizer["contact_card_email_sub"]</span>
                        <a href="mailto:@contact.Email" class="text-sm font-bold text-primary hover:text-primary-container transition-colors mt-1 block">@contact.Email</a>
                    </div>
                </div>
                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-5 border border-outline-variant/20 dark:border-white/5 shadow-lg flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-primary">phone</span>
                    </div>
                    <div>
                        <span class="block text-sm font-bold text-on-surface dark:text-white">@Localizer["contact_card_whatsapp_title"]</span>
                        <span class="block text-xs text-on-surface-variant dark:text-slate-400">@Localizer["contact_card_whatsapp_sub"]</span>
                        <a href="tel:@contact.Phone" class="text-sm font-bold text-primary hover:text-primary-container transition-colors mt-1 block">@contact.Phone</a>
                    </div>
                </div>
                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-5 border border-outline-variant/20 dark:border-white/5 shadow-lg flex items-start gap-4">
                    <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0">
                        <span class="material-symbols-outlined text-primary">location_on</span>
                    </div>
                    <div>
                        <span class="block text-sm font-bold text-on-surface dark:text-white">@Localizer["contact_card_location_title"]</span>
                        <span class="block text-xs text-on-surface-variant dark:text-slate-400">@contact.Address</span>
                        <span class="block text-[11px] text-on-surface-variant/60 dark:text-slate-500 mt-0.5">@Localizer["contact_card_location_sub"]</span>
                    </div>
                </div>
                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-5 border border-outline-variant/20 dark:border-white/5 shadow-lg">
                    <span class="block text-sm font-bold text-on-surface dark:text-white mb-3">@Localizer["contact_hours_title"]</span>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant dark:text-slate-400">@Localizer["contact_hours_day1"]</span>
                            <span class="font-bold text-on-surface dark:text-white">@Localizer["contact_hours_weekday_time"]</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant dark:text-slate-400">@Localizer["contact_hours_day2"]</span>
                            <span class="font-bold text-red-500">@Localizer["contact_hours_day2_status"]</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant dark:text-slate-400">@Localizer["contact_hours_day3"]</span>
                            <span class="font-bold text-on-surface dark:text-white">@Localizer["contact_hours_friday_time"]</span>
                        </div>
                    </div>
                    <p class="text-[11px] text-on-surface-variant/60 dark:text-slate-500 mt-3">@Localizer["contact_hours_footer"]</p>
                </div>
            </div>
        </div>
    </div>
</section>