    <!-- 7. Feedback / Contact Form -->
    <section id="contact" class="py-16 md:py-24 px-4 md:px-16 bg-cyan-50 border-t border-outline-variant/10">
        <div class="relative z-10 max-w-2xl mx-auto bg-cyan-50/60 backdrop-blur-md border border-primary/20 p-8 md:p-12 rounded-3xl shadow-2xl shadow-primary/5 scroll-animate-scale">
            <h2 data-i18n="form_h2" class="text-3xl font-extrabold text-on-surface mb-3 text-center">@Localizer["form_h2"]</h2>
            <p data-i18n="form_p" class="text-sm text-on-surface-variant text-center mb-8">@Localizer["form_p"]</p>
            <form onsubmit="event.preventDefault(); alert('Message sent successfully! / تم إرسال الرسالة بنجاح!');" class="flex flex-col gap-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label data-i18n="form_name" class="text-xs font-bold text-primary">@Localizer["form_name"]</label>
                        <input data-i18n="form_name_ph" class="bg-white border border-primary/20 rounded-xl p-3.5 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-cyan-50 outline-none transition-all duration-200" placeholder="@Localizer["form_name_ph"]" type="text" required/>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label data-i18n="form_email" class="text-xs font-bold text-primary">@Localizer["form_email"]</label>
                        <input data-i18n="form_email_ph" class="bg-white border border-primary/20 rounded-xl p-3.5 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-cyan-50 outline-none transition-all duration-200" placeholder="@Localizer["form_email_ph"]" type="email" required/>
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <label data-i18n="form_msg" class="text-xs font-bold text-primary">@Localizer["form_msg"]</label>
                    <textarea data-i18n="form_msg_ph" class="bg-white border border-primary/20 rounded-xl p-3.5 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-cyan-50 outline-none transition-all duration-200" placeholder="@Localizer["form_msg_ph"]" rows="4" required></textarea>
                </div>
                <button data-i18n="btn_send" class="bg-primary hover:bg-primary-container text-on-primary font-bold py-4 rounded-xl transition-all shadow-md hover:shadow-lg duration-200 mt-2" type="submit">
                    @Localizer["btn_send"]
                </button>
            </form>
        </div>
    </section>
</main>

