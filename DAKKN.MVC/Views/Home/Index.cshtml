                <h3 class="text-xl font-bold text-on-surface dark:text-slate-100">@HeroText(Model.About.Feature1TitleAr, Model.About.Feature1TitleEn, "feat1_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature1DescAr, Model.About.Feature1DescEn, "feat1_p")</p>
            </div>
            
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-4 hover:-translate-y-1 transition-transform duration-300 shadow-sm scroll-animate delay-200">
                <div class="w-12 h-12 rounded-xl bg-tertiary-container/20 border border-tertiary/30 flex items-center justify-center text-tertiary mb-2">
                    <span class="material-symbols-outlined text-2xl">palette</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface dark:text-slate-100">@HeroText(Model.About.Feature2TitleAr, Model.About.Feature2TitleEn, "feat2_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature2DescAr, Model.About.Feature2DescEn, "feat2_p")</p>
            </div>
            
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-4 hover:-translate-y-1 transition-transform duration-300 shadow-sm scroll-animate delay-300">
                <div class="w-12 h-12 rounded-xl bg-secondary-container/20 border border-secondary/30 flex items-center justify-center text-secondary mb-2">
                    <span class="material-symbols-outlined text-2xl">shield</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface dark:text-white">@HeroText(Model.About.Feature3TitleAr, Model.About.Feature3TitleEn, "feat3_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature3DescAr, Model.About.Feature3DescEn, "feat3_p")</p>
            </div>
        </div>
    </section>
                </text>
                break;
            case "categories":
                <text>
    <section id="categories" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface dark:bg-[#080e1a] border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-shape-square top-24 left-12 rtl:left-auto rtl:right-12 opacity-60"></div>
            <div class="deco-shape-diamond bottom-24 right-12 rtl:right-auto rtl:left-12 opacity-60" style="animation-delay: 2s;"></div>
            <div class="deco-ring-solid w-[400px] h-[400px] -top-48 left-1/3 opacity-30"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center mb-16 scroll-animate">
            <h2 class="text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-4">@Localizer["cat_h2"]</h2>
            <p class="text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@Localizer["cat_p"]</p>
        </div>
        <!-- Category Slider Wrapper -->
        <div class="relative z-10 scroll-animate">
            <div class="overflow-hidden" id="cat-slider-viewport">
                <div id="cat-slider-track" class="flex gap-6 transition-transform duration-500 ease-out"
                     style="will-change: transform;">
                    @if (Model.HasCategories)
                    {
                        @foreach (var cat in Model.Categories)
                        {
                            <a href="/shop/products?categoryId=@cat.Id" data-frozen-action
                               class="group rounded-2xl overflow-hidden relative flex-shrink-0 w-[calc(100%-0px)] sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] lg:w-[calc(25%-18px)] aspect-square glass-panel shadow-sm no-underline block">
                                <img src="@ResolveCategoryImage(cat.ImageFullUrl)" alt="@(isAr ? cat.ArName : cat.CategoryName)" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" onerror="this.src='/images/placeholders/category-placeholder.svg'" />
                                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors z-10"></div>
                                <div class="absolute bottom-0 left-0 right-0 p-6 cat-overlay z-20">
                                    <h3 class="text-xl font-bold text-white">@(isAr ? cat.ArName : cat.CategoryName)</h3>
                                    <p class="text-sm text-white/80">@cat.ProductsCount @Localizer["cat_products_count"]</p>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="flex-shrink-0 w-full text-center py-16">
                            <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">grid_view</span>
                            <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["categories_empty_title"]</h3>
                            <p class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer["categories_empty_msg"]</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="flex items-center justify-center gap-4 mt-8">
                <button onclick="slidePrev()" aria-label="@Localizer["slider_prev_aria"]"
                        class="w-11 h-11 rounded-full bg-surface dark:bg-[#0d1a2a] border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0">
                    <span class="material-symbols-outlined text-xl ltr:block rtl:hidden">chevron_left</span>
                    <span class="material-symbols-outlined text-xl ltr:hidden rtl:block">chevron_right</span>
                </button>

                <div class="flex gap-2.5 items-center" id="cat-dots">
                    <button id="cat-dot-0" onclick="slideGoTo(0)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 1)"
                            class="w-2.5 h-2.5 rounded-full bg-primary transition-all duration-300 hover:scale-125"></button>
                    <button id="cat-dot-1" onclick="slideGoTo(1)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 2)"
                            class="w-2.5 h-2.5 rounded-full bg-primary/30 transition-all duration-300 hover:scale-125"></button>
                    <button id="cat-dot-2" onclick="slideGoTo(2)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 3)"
                            class="w-2.5 h-2.5 rounded-full bg-primary/30 transition-all duration-300 hover:scale-125"></button>
                </div>

                <button onclick="slideNext()" aria-label="@Localizer["slider_next_aria"]"
                        class="w-11 h-11 rounded-full bg-surface dark:bg-[#0d1a2a] border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0">
                    <span class="material-symbols-outlined text-xl ltr:block rtl:hidden">chevron_right</span>
                    <span class="material-symbols-outlined text-xl ltr:hidden rtl:block">chevron_left</span>
                </button>
            </div>
        </div>
    </section>
                </text>
                break;
            case "all-products":
                <text>
    <section id="all-products" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface-container-low dark:bg-dark-page border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-secondary-container/10 w-[300px] h-[300px] -top-12 -left-12 opacity-40"></div>
            <div class="deco-ring-solid w-[300px] h-[300px] bottom-6 right-8 opacity-30"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center mb-12 scroll-animate">
            <h2 class="text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-4">@Localizer["all_products_h2"]</h2>
            <p class="text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@Localizer["all_products_p"]</p>
        </div>

        <!-- Filter Controls -->
        <div class="relative z-10 max-w-5xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 bg-surface/60 dark:bg-[#0a1220]/80 backdrop-blur-md border border-primary/15 dark:border-white/5 p-6 rounded-2xl shadow-sm">
            <!-- Category Filter Pills -->
            <div class="flex flex-col gap-2.5">
                <span class="text-xs font-bold text-primary uppercase tracking-wider">@Localizer["filter_category"]</span>
                <div class="flex flex-wrap gap-2" id="prod-cat-filters">
                    <!-- Rendered dynamically by landing.js -->
                </div>
            </div>

            <!-- Price Filter Slider -->
            <div class="flex flex-col gap-2.5 min-w-[200px]">
                <div class="flex justify-between items-center">
                    <span class="text-xs font-bold text-primary uppercase tracking-wider">@Localizer["filter_price"]</span>
                    <span class="text-xs font-bold text-primary font-sans" id="price-val-display">150 EGP</span>
                </div>
                <input type="range" min="0" max="200" value="200" class="w-full h-1.5 bg-primary/20 rounded-lg appearance-none cursor-pointer accent-primary" id="price-slider" onchange="filterPrice(this.value)"/>
                <div class="flex justify-between text-[10px] text-on-surface-variant/60 dark:text-slate-400/50 font-semibold font-sans">
                    <span>40 EGP</span>
                    <span>150 EGP</span>
                </div>
            </div>
        </div>

        <!-- Dynamic Products Grid -->
        <div class="relative z-10 max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 min-h-[300px]" id="all-prods-grid">
            @if (Model.AllProducts != null && Model.AllProducts.Items.Count > 0)
            {
                @foreach (var product in Model.AllProducts.Items)
                {
                    <div class="product-card glass-panel p-5 rounded-2xl flex flex-col gap-4 scroll-animate visible">
                        <div class="aspect-square rounded-xl overflow-hidden relative">
                            <img class="w-full h-full object-cover" src="@ResolveImage(product.ImageFullUrl)" onerror="this.src='@placeholder'" alt="@(isAr ? product.ArName : product.Name)" loading="lazy" />
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-on-surface dark:text-white">@(isAr ? product.ArName : product.Name)</h3>
                            <p class="text-xs text-on-surface-variant dark:text-slate-400">@(isAr ? product.CategoryArName : product.CategoryName)</p>
                        </div>
                        <!-- Stock Status -->
                        @if (product.QuantityInStock == 0)
                        {
                            <span class="text-[10px] font-bold text-red-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">block</span>
                                @Localizer["inventory_out_of_stock"]
                            </span>
                        }
                        else if (product.QuantityInStock <= product.DangerQuantity)
                        {
                            <span class="text-[10px] font-bold text-amber-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">warning</span>
                                @Localizer["inventory_only_x_left", product.QuantityInStock]
                            </span>
                        }
                        else
                        {
                            <span class="text-[10px] font-bold text-green-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">check_circle</span>
                                @Localizer["inventory_in_stock"]
                            </span>
                        }
                        <div class="flex items-center justify-between mt-auto pt-2">
                            <span class="text-xl font-bold text-primary font-sans">@product.Price.ToString("N0") @Localizer["currency"]</span>
                            <div class="flex gap-2">
                                @if (product.QuantityInStock > 0)
                                {
                                    <button onclick="guestAddToCart(this, '@product.Id','@(isAr ? product.ArName : product.Name)','@product.Price','@(product.ImageFullUrl ?? product.ImageUrl)')" class="px-3 py-2 rounded-lg bg-primary text-on-primary text-[10px] font-bold hover:bg-primary-container hover:text-primary transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                                    </button>
                                }
                                else
                                {
                                    <button disabled class="px-3 py-2 rounded-lg bg-gray-300 text-gray-500 text-[10px] font-bold cursor-not-allowed flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">block</span>
                                    </button>
                                }
                                <a href="/shop/product/@product.Id" class="px-3 py-2 rounded-lg bg-primary/10 text-primary hover:bg-primary hover:text-on-primary text-[10px] font-bold transition-all duration-200">@Localizer["shop_view_details"]</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Pagination Controls -->
        <div class="relative z-10 flex items-center justify-center gap-4 mt-12" id="prods-pagination">
            <button onclick="prevProdsPage()" id="btn-prod-prev" class="w-10 h-10 rounded-full bg-surface dark:bg-[#0d1a2a] border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 disabled:opacity-40 disabled:pointer-events-none">
                <span class="material-symbols-outlined text-lg ltr:block rtl:hidden">chevron_left</span>
                <span class="material-symbols-outlined text-lg ltr:hidden rtl:block">chevron_right</span>
            </button>
            <div class="flex gap-2" id="prods-page-indicators">
                <!-- Indicators rendered dynamically -->
            </div>
            <button onclick="nextProdsPage()" id="btn-prod-next" class="w-10 h-10 rounded-full bg-surface dark:bg-[#0d1a2a] border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 disabled:opacity-40 disabled:pointer-events-none">
                <span class="material-symbols-outlined text-lg ltr:block rtl:hidden">chevron_right</span>
                <span class="material-symbols-outlined text-lg ltr:hidden rtl:block">chevron_left</span>
            </button>
        </div>
    </section>
                </text>
                break;
            case "testimonials":
                <text>
    <section id="testimonials" class="relative overflow-hidden py-16 lg:py-24 px-4 sm:px-6 lg:px-8 bg-surface dark:bg-[#080e1a] border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-3 bg-tertiary-container/15 w-[320px] h-[320px] top-12 left-12 rtl:left-auto rtl:right-12"></div>
            <div class="deco-blob animate-blob-1 bg-primary/10 w-[300px] h-[300px] bottom-12 right-12 rtl:right-auto rtl:left-12"></div>
            <div class="deco-ring w-[240px] h-[240px] top-10 right-1/3 rtl:right-auto rtl:left-1/3 opacity-40"></div>
            <div class="deco-dots-grid top-6 right-8 rtl:right-auto rtl:left-8 opacity-40"></div>
        </div>

        <div class="relative z-20 max-w-7xl mx-auto">
            <!-- Section Header -->
            <div class="max-w-3xl mx-auto text-center mb-12 lg:mb-14 scroll-animate">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-on-surface dark:text-white mb-4">
                    @(Model.HasCmsData && !string.IsNullOrEmpty(Model.Testimonials.Title) ? Model.Testimonials.Title : Localizer["test_h2"].Value)
                </h2>
                @{
                    var testiDesc = Model.HasCmsData && !string.IsNullOrEmpty(Model.Testimonials.Description) ? Model.Testimonials.Description : Localizer["test_p"].Value;
                }
                @if (!string.IsNullOrEmpty(testiDesc))
                {
                    <p class="text-base md:text-lg text-on-surface-variant dark:text-slate-400 leading-relaxed max-w-2xl mx-auto">@testiDesc</p>
                }
            </div>

            <!-- Testimonials Grid -->
            @if (Model.Testimonials.Reviews.Count > 0)
            {
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8" data-stagger>
                    @for (int ri = 0; ri < Model.Testimonials.Reviews.Count; ri++)
                    {
                        var rev = Model.Testimonials.Reviews[ri];
                        <div class="group bg-surface dark:bg-[#0d1a2a] rounded-3xl border border-outline-variant/20 dark:border-white/5 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 p-6 md:p-8 flex flex-col gap-4 scroll-animate relative overflow-hidden">
                            <!-- Top accent gradient -->
                            <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-primary/40 via-primary to-primary/40 dark:from-primary/30 dark:via-primary dark:to-primary/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                            <!-- Rating badge + stars row -->
                            <div class="flex items-center justify-between gap-2">
                                <div class="flex gap-1" aria-label="@string.Format(Localizer["admin_review_rating_aria"].Value, rev.Rating)">
                                    @for (int s = 0; s < 5; s++)
                                    {
                                        <span class="material-symbols-outlined text-sm @(s < rev.Rating ? "text-yellow-500 fill-icon" : "text-outline/20 dark:text-white/10")">star</span>
                                    }
                                </div>
                                <span class="inline-flex items-center gap-1 text-xs font-bold text-on-surface-variant dark:text-slate-400 bg-surface-container dark:bg-[#0f1d30] px-2.5 py-1 rounded-full">
                                    <span class="material-symbols-outlined text-sm text-yellow-500 fill-icon">star</span>
                                    @rev.Rating
                                </span>
                            </div>

                            <!-- Review Text -->
                            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-300 leading-relaxed flex-grow">
                                &ldquo;@rev.Quote&rdquo;
                            </p>

                            <!-- Customer Info -->
                            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-outline-variant/10 dark:border-white/5">
                                <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0 bg-gradient-to-br from-primary/20 to-primary/5 dark:from-primary/30 dark:to-primary/10 shadow-sm">
                                    @if (!string.IsNullOrEmpty(rev.ProfilePictureUrl))
                                    {
                                        <img src="@rev.ProfilePictureUrl" alt="@rev.Name" class="w-full h-full object-cover" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholders/product-placeholder.svg'" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center">
                                            <span class="text-sm font-bold text-primary">@rev.Name[0]</span>
                                        </div>
                                    }
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-bold text-on-surface dark:text-white truncate">@rev.Name</p>
                                    @if (!string.IsNullOrEmpty(rev.Role))
                                    {
                                        <p class="text-xs text-on-surface-variant dark:text-slate-400 truncate">@rev.Role</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="text-center py-16 scroll-animate">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">rate_review</span>
                    <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["testimonials_empty_title"]</h3>
                    <p class="text-sm text-on-surface-variant dark:text-slate-400 max-w-md mx-auto">@Localizer["testimonials_empty_msg"]</p>
                </div>
            }
        </div>
    </section>
                </text>
                break;
            case "contact":
                <text>
    <section id="contact" class="py-16 md:py-24 px-4 md:px-16 bg-surface-container-low dark:bg-dark-page border-t border-outline-variant/10">
        <div class="relative z-10 max-w-2xl mx-auto bg-surface-container-low/60 dark:bg-[#0a1220]/80 backdrop-blur-md border border-primary/20 dark:border-white/5 p-8 md:p-12 rounded-3xl shadow-2xl shadow-primary/5 scroll-animate-scale">
            <h2 class="text-3xl font-extrabold text-on-surface dark:text-white mb-3 text-center">@Localizer["form_h2"]</h2>
            <p class="text-sm text-on-surface-variant dark:text-slate-400 text-center mb-8">@Localizer["form_p"]</p>
            <form data-frozen-action novalidate class="flex flex-col gap-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-primary">@Localizer["form_name"]</label>
                        <input class="bg-surface dark:bg-[#0d1a2a] border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["form_name_ph"]" type="text" required/>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-primary">@Localizer["form_email"]</label>
                        <input class="bg-surface dark:bg-[#0d1a2a] border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["form_email_ph"]" type="email" required/>
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <label class="text-xs font-bold text-primary">@Localizer["form_msg"]</label>
                    <textarea class="bg-surface dark:bg-[#0d1a2a] border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["form_msg_ph"]" rows="4" required></textarea>
                </div>
                <button class="bg-primary hover:bg-primary/90 text-on-primary font-bold py-4 rounded-xl transition-all shadow-md hover:shadow-lg duration-200 mt-2" type="submit">
                    @Localizer["btn_send"]
                </button>
            </form>
        </div>
    </section>
                </text>
                break;
        }
    }
}
</main>

<!-- Cart Toast Container -->
<div id="cart-toast-container" class="fixed bottom-24 md:bottom-8 end-4 md:end-8 z-[90] flex flex-col gap-3 pointer-events-none"></div>

<!-- Sign-in Modal for Frozen Actions -->
<div id="signin-modal" class="fixed inset-0 z-[100] flex items-center justify-center hidden" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white dark:bg-[#0f1d30] rounded-3xl shadow-2xl border border-primary/10 dark:border-white/5 p-8 md:p-10 max-w-md w-[90%] mx-4 text-center">
        <button onclick="hideSignInModal()" class="absolute top-4 end-4 w-10 h-10 rounded-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 flex items-center justify-center text-on-surface-variant dark:text-slate-300 hover:text-primary transition-all" aria-label="@Localizer["close_aria"]">
            <span class="material-symbols-outlined text-xl">close</span>
        </button>
        <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-primary">lock</span>
        </div>
        <h3 class="text-2xl font-extrabold text-on-surface dark:text-white mb-2">@Localizer["signin_modal_title"]</h3>
        <p class="text-sm text-on-surface-variant dark:text-slate-400 mb-8 leading-relaxed">@Localizer["signin_modal_msg"]</p>
        <div class="flex flex-col gap-3">
            <a asp-action="Login" asp-controller="Auth" class="w-full bg-primary hover:bg-primary-container text-on-primary font-bold py-3.5 px-6 rounded-xl transition-all shadow-lg hover:-translate-y-0.5 active:scale-95 text-sm">
                @Localizer["auth.login.submit"]
            </a>
            <a asp-action="Register" asp-controller="Auth" class="w-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 text-on-surface dark:text-slate-200 font-bold py-3.5 px-6 rounded-xl transition-all border border-outline-variant/20 dark:border-white/5 hover:-translate-y-0.5 active:scale-95 text-sm">
                @Localizer["auth.login.register"]
            </a>
            <button onclick="hideSignInModal()" class="text-xs text-on-surface-variant dark:text-slate-400 hover:text-primary mt-2 transition-colors">@Localizer["signin_modal_continue"]</button>
        </div>
    </div>
</div>

