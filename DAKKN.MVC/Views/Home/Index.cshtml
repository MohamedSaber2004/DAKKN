@using DAKKN.MVC.ViewModels.Landing
@using DAKKN.Application.DTOs
@inject IStringLocalizer<Messages> Localizer
@model LandingPageViewModel
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["brand"] + " - " + Localizer["hero_badge"];
    var isAr = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("ar");
    var placeholder = "/images/placeholders/product-placeholder.svg";

    string ResolveImage(string? imageFullUrl)
    {
        if (string.IsNullOrEmpty(imageFullUrl)) return placeholder;
        if (imageFullUrl.StartsWith("http")) return imageFullUrl;
        return Model.BaseUrl + imageFullUrl;
    }

    string ResolveCategoryImage(string? imageFullUrl)
    {
        if (string.IsNullOrEmpty(imageFullUrl)) return "/images/placeholders/category-placeholder.svg";
        if (imageFullUrl.StartsWith("http")) return imageFullUrl;
        return Model.BaseUrl + imageFullUrl;
    }

    string ResolveImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return placeholder;
        if (imageUrl.StartsWith("http")) return imageUrl;
        return Model.BaseUrl + imageUrl;
    }

    string GetHeroButtonText()
    {
        if (!Model.HasCmsData) return Localizer["btn_shop"].Value;
        var text = isAr ? Model.Hero?.ButtonTextAr : Model.Hero?.ButtonTextEn;
        if (string.IsNullOrEmpty(text)) return Localizer["btn_shop"].Value;
        if (text.StartsWith("/")) return Localizer["btn_shop"].Value;
        if (text.StartsWith("http")) return Localizer["btn_shop"].Value;
        return text;
    }

    string HeroText(string arValue, string enValue, string fallbackKey)
    {
        if (!Model.HasCmsData) return Localizer[fallbackKey].Value;
        var val = isAr ? arValue : enValue;
        
        return !string.IsNullOrEmpty(val) ? val : Localizer[fallbackKey].Value;
    }
}


<!-- 1. Header Navigation -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-[#0a1020]/85 backdrop-blur-md border-b border-outline-variant/10 dark:border-white/5 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="#hero" class="logo-glow cursor-pointer" data-section="hero">
            <img src="~/images/logo.png" alt='@Localizer["logo_alt"]' class="h-16 md:h-18" />
        </a>
        <!-- Desktop nav links with icons -->
        <div class="hidden lg:flex items-center gap-1">
            <a href="#shop" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="shop">
                <span class="material-symbols-outlined text-[17px]">local_fire_department</span>
                <span>@Localizer["nav_shop"]</span>
            </a>
            <a href="#categories" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="categories">
                <span class="material-symbols-outlined text-[17px]">grid_view</span>
                <span>@Localizer["nav_categories"]</span>
