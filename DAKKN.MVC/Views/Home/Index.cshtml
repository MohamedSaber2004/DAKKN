@using DAKKN.MVC.ViewModels.Landing
@using DAKKN.Application.DTOs
@inject IStringLocalizer<Messages> Localizer
@model LandingPageViewModel
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["brand"] + " - " + Localizer["hero_badge"];
    var isAr = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("ar");
    var placeholder = "/images/placeholders/product-placeholder.svg";

    string ResolveImage(string? imageFullUrl)
    {
        if (string.IsNullOrEmpty(imageFullUrl)) return placeholder;
        if (imageFullUrl.StartsWith("http")) return imageFullUrl;
        return Model.BaseUrl + imageFullUrl;
    }

    string ResolveCategoryImage(string? imageFullUrl)
    {
        if (string.IsNullOrEmpty(imageFullUrl)) return "/images/placeholders/category-placeholder.svg";
        if (imageFullUrl.StartsWith("http")) return imageFullUrl;
        return Model.BaseUrl + imageFullUrl;
    }

    string ResolveImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return placeholder;
        if (imageUrl.StartsWith("http")) return imageUrl;
        return Model.BaseUrl + imageUrl;
    }

    string GetHeroButtonText()
    {
        if (!Model.HasCmsData) return Localizer["btn_shop"].Value;
        var text = isAr ? Model.Hero?.ButtonTextAr : Model.Hero?.ButtonTextEn;
        if (string.IsNullOrEmpty(text)) return Localizer["btn_shop"].Value;
        if (text.StartsWith("/")) return Localizer["btn_shop"].Value;
        if (text.StartsWith("http")) return Localizer["btn_shop"].Value;
        return text;
    }

    string HeroText(string arValue, string enValue, string fallbackKey)
    {
        if (!Model.HasCmsData) return Localizer[fallbackKey].Value;
        var val = isAr ? arValue : enValue;
        
        return !string.IsNullOrEmpty(val) ? val : Localizer[fallbackKey].Value;
    }
}


<!-- 1. Header Navigation -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-dark-overlay/85 backdrop-blur-md border-b border-outline-variant/10 dark:border-white/5 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="#hero" class="logo-glow cursor-pointer" data-section="hero">
            <img src="~/images/logo.png" alt='@Localizer["logo_alt"]' class="h-16 md:h-18" asp-append-version="true" />
        </a>
        <!-- Desktop nav links with icons -->
        <div class="hidden lg:flex items-center gap-1">
            <a href="#shop" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="shop">
                <span class="material-symbols-outlined text-[17px]">local_fire_department</span>
                <span>@Localizer["nav_shop"]</span>
            </a>
            <a href="#categories" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="categories">
                <span class="material-symbols-outlined text-[17px]">grid_view</span>
                <span>@Localizer["nav_categories"]</span>
            </a>
            <a href="#all-products" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="all-products">
                <span class="material-symbols-outlined text-[17px]">inventory_2</span>
                <span>@Localizer["nav_all_products"]</span>
            </a>
            <a href="#testimonials" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="testimonials">
                <span class="material-symbols-outlined text-[17px]">reviews</span>
                <span>@Localizer["nav_reviews"]</span>
            </a>
            <a href="#contact" class="nav-link-premium nav-icon-link dark:text-slate-300 dark:hover:text-primary" data-section="contact">
                <span class="material-symbols-outlined text-[17px]">support_agent</span>
                <span>@Localizer["nav_support"]</span>
            </a>
        </div>
    </div>
    <div class="flex items-center gap-1 md:gap-3">

        <!-- Auth Group (Desktop) -->
        <div class="hidden lg:flex items-center gap-4 me-3">
            <a asp-action="Login" asp-controller="Auth" class="text-[14px] font-bold text-on-surface-variant dark:text-slate-300 hover:text-primary transition-colors">
                @Localizer["auth.register.login"]
            </a>
            <a asp-action="Register" asp-controller="Auth" class="bg-primary hover:bg-primary-container text-on-primary text-[14px] font-bold px-6 py-2.5 rounded-full transition-all shadow-lg shadow-primary/20 hover:-translate-y-0.5 active:scale-95">
                @Localizer["auth.login.register"]
            </a>
            <a asp-action="Cart" asp-controller="Shop"
               class="relative flex items-center gap-2 bg-primary/10 hover:bg-primary text-primary hover:text-on-primary text-[14px] font-bold px-5 py-2.5 rounded-full transition-all duration-200 shadow-sm hover:shadow-lg hover:-translate-y-0.5 active:scale-95"
               title="@Localizer["nav_cart"]">
                <span class="material-symbols-outlined text-[20px]">shopping_cart</span>
                <span class="absolute -top-1 -end-1 w-5 h-5 bg-primary text-on-primary text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm" id="cart-badge">0</span>
            </a>
        </div>

        <!-- Account Button (Mobile) -->
        <a asp-action="Login" asp-controller="Auth" class="navbar-icon-btn scale-90 md:scale-100 lg:hidden dark:text-slate-300" title="@Localizer["auth.register.login"]">
            <span class="material-symbols-outlined text-[24px]">person</span>
        </a>

        <!-- Cart Button (Mobile) -->
        <a asp-action="Cart" asp-controller="Shop" aria-label="@Localizer["nav_cart"]" class="navbar-icon-btn relative scale-90 md:scale-100 dark:text-slate-300 lg:hidden" title="@Localizer["nav_cart"]">
            <span class="material-symbols-outlined text-[24px]">shopping_cart</span>
            <span class="absolute -top-0.5 -end-0.5 w-4 h-4 bg-primary text-on-primary text-[8px] font-bold rounded-full flex items-center justify-center shadow-sm" id="cart-badge-mobile">0</span>
        </a>

        <!-- Language Switcher -->
        @await Html.PartialAsync("Partials/_LanguageToggle")

        @await Html.PartialAsync("Partials/_ThemeToggle")
    </div>
</nav>

<!-- Mobile Bottom Navigation Bar -->
<nav id="mobile-bottom-nav" class="mobile-bottom-nav lg:hidden dark:bg-black/90 dark:border-white/10">
    <a href="#shop" class="mob-nav-item" id="mobnav-shop" data-section="shop">
        <span class="material-symbols-outlined">local_fire_department</span>
        <span>@Localizer["nav_shop"]</span>
    </a>
    <a href="#categories" class="mob-nav-item" id="mobnav-cats" data-section="categories">
        <span class="material-symbols-outlined">grid_view</span>
        <span>@Localizer["nav_categories"]</span>
    </a>
    <a href="#all-products" class="mob-nav-item" id="mobnav-products" data-section="all-products">
        <span class="material-symbols-outlined">inventory_2</span>
        <span>@Localizer["nav_all_products"]</span>
    </a>
    <a href="#testimonials" class="mob-nav-item" id="mobnav-reviews" data-section="testimonials">
        <span class="material-symbols-outlined">reviews</span>
        <span>@Localizer["nav_reviews"]</span>
    </a>
    <a href="#contact" class="mob-nav-item" id="mobnav-contact" data-section="contact">
        <span class="material-symbols-outlined">support_agent</span>
        <span>@Localizer["nav_support"]</span>
    </a>
</nav>

<main class="flex-grow pt-20">
@{
    foreach (var sectionId in Model.OrderedSectionIds)
    {
        switch (sectionId)
        {
            case "hero":
                <text>
    <section id="hero" class="relative h-[calc(100vh-5rem)] flex flex-col overflow-hidden" style="background:#050505">
        @* ── Static brand background image ── *@
        <div class="absolute inset-0 z-0">
            <img alt="" class="w-full h-full object-cover" src="/images/hero-bg.jpg" onerror="this.style.display='none'" aria-hidden="true" />
        </div>

        @* ── Dark overlay ── *@
        <div class="absolute inset-0 z-[1]" style="background:linear-gradient(135deg, rgba(5,5,5,0.92) 0%, rgba(5,5,5,0.70) 50%, rgba(5,5,5,0.85) 100%)"></div>

        @* ── Teal accent glow ── *@
        <div class="absolute inset-0 z-[2] pointer-events-none">
            <div class="absolute top-1/3 -right-32 w-[600px] h-[600px] rounded-full" style="background: radial-gradient(circle, rgba(24,199,199,0.08) 0%, transparent 70%)"></div>
            <div class="absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(24,199,199,0.05) 0%, transparent 60%)"></div>
        </div>

        @* ── Subtle decorative rings ── *@
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-[2]">
            <div class="absolute w-[420px] h-[420px] -top-28 -start-28 rounded-full border border-white/5 animate-spin-slow"></div>
            <div class="absolute w-[300px] h-[300px] -bottom-16 -end-16 rounded-full border border-white/5 animate-spin-slow-reverse"></div>
        </div>

        @* ── Main Hero Content ── *@
        <div class="relative z-10 w-full max-w-6xl mx-auto px-6 md:px-8 flex-1 flex items-center justify-center pt-8 pb-4 md:pt-12 md:pb-6">
            <div class="grid lg:grid-cols-12 gap-8 md:gap-12 items-center">
                @* ── Left: Text Content (55%) ── *@
                <div class="lg:col-span-7 text-center lg:text-left">
                    @* Brand Badge *@
                    <div class="hero-fade-in inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full mb-6 md:mb-8 bg-white/5 border border-white/10 backdrop-blur-sm" style="animation-delay:0.1s">
                        <span class="w-1.5 h-1.5 rounded-full" style="background:#18C7C7;box-shadow:0 0 8px rgba(24,199,199,0.5)"></span>
                        <span class="text-[11px] md:text-xs font-bold text-white/80 uppercase tracking-[0.15em]">@HeroText(Model.Hero.BadgeAr, Model.Hero.BadgeEn, "hero_badge")</span>
                    </div>

                    @* Headline *@
                    @if (Model.HasCmsData)
                    {
                        <h1 class="hero-fade-in text-[2.5rem] sm:text-[3.2rem] md:text-[4rem] lg:text-[4.5rem] xl:text-[5rem] font-black text-white leading-[1.05] tracking-tight mb-5" style="animation-delay:0.2s">
                            <span class="block">@HeroText(Model.Hero.TitleAAr, Model.Hero.TitleAEn, "hero_h1_a")</span>
                            <span class="block text-[0.85em] text-transparent bg-clip-text animate-text-gradient">@HeroText(Model.Hero.TitleBAr, Model.Hero.TitleBEn, "hero_h1_b")@HeroText(Model.Hero.TitleCAr, Model.Hero.TitleCEn, "hero_h1_c")</span>
                            <span class="block text-white/90">@HeroText(Model.Hero.TitleDAr, Model.Hero.TitleDEn, "hero_h1_d")</span>
                        </h1>
                    }
                    else
                    {
                        <h1 class="hero-fade-in text-[2.5rem] sm:text-[3.2rem] md:text-[4rem] lg:text-[4.5rem] xl:text-[5rem] font-black text-white leading-[1.05] tracking-tight mb-5" style="animation-delay:0.2s">
                            <span class="block">@Localizer["hero_h1_a"]</span>
                            <span class="block text-[0.85em] text-transparent bg-clip-text animate-text-gradient">@Localizer["hero_h1_b"]@Localizer["hero_h1_c"]</span>
                            <span class="block text-white/90">@Localizer["hero_h1_d"]</span>
                        </h1>
                    }

                    @* CTA Button *@
                    <div class="hero-fade-in flex flex-col sm:flex-row items-stretch sm:items-center gap-4 md:gap-6 mb-10 md:mb-12" style="animation-delay:0.5s">
                        <a href="#shop" data-frozen-action class="group relative inline-flex items-center justify-center font-bold text-center text-sm md:text-base overflow-hidden transition-all duration-300 active:scale-[0.97]" style="height:60px;padding:0 36px;border-radius:18px;background:linear-gradient(135deg,#17C5C5,#13AFAF);color:#fff;box-shadow:0 15px 40px rgba(24,199,199,0.35)">
                            <span class="relative z-10 flex items-center justify-center gap-2">
                                @GetHeroButtonText()
                                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </span>
                            <span class="absolute inset-0 rounded-[18px] opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background:linear-gradient(135deg,#26E0DD,#17C5C5)"></span>
                        </a>
                    </div>
                </div>

                @* ── Right: Product Showcase (45%) ── *@
                <div class="hero-fade-in lg:col-span-5 hidden lg:flex items-center justify-center" style="animation-delay:0.4s">
                    <div class="relative w-full max-w-[400px] xl:max-w-[440px]">
                        @* Glow behind product *@
                        <div class="absolute inset-0 -top-8 -bottom-8 -left-8 -right-8 rounded-full" style="background:radial-gradient(circle, rgba(24,199,199,0.12) 0%, transparent 70%)"></div>
                        @* Product card *@
                        <div class="relative rounded-2xl overflow-hidden bg-[rgba(22,24,28,0.95)] border border-white/5 shadow-[0_20px_60px_rgba(0,0,0,0.5)]">
                            @* Subtle reflection line *@
                            <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
                            <div class="aspect-square p-8 md:p-10 flex items-center justify-center">
                                <img src="@(Model.Hero.ImageUrl ?? "~/images/hero-placeholder.svg")" alt='@Localizer["alt_hero_sticker"]' class="w-full h-full object-contain transition-transform duration-700 hover:scale-105" loading="eager" fetchpriority="high" />
                            </div>
                        </div>
                        @* Premium floating badge *@
                        <div class="absolute -top-3 -end-3 flex items-center gap-2 px-3 py-2 rounded-xl bg-[rgba(22,24,28,0.95)] backdrop-blur-xl border border-white/10 shadow-[0_8px_24px_rgba(0,0,0,0.3)]">
                            <span class="material-symbols-outlined text-base text-primary">local_shipping</span>
                            <span class="text-[11px] font-bold text-white/90">@Localizer["hero_delivery_title"]</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Scroll Down Indicator ── *@
        <div class="hero-fade-in relative z-10 flex justify-center pb-1 hidden md:flex" style="animation-delay:1s">
            <a href="#shop" aria-label="@Localizer["hero_scroll_down"]" class="flex flex-col items-center gap-1 text-white/40 hover:text-white/70 transition-colors animate-bounce">
                <span class="text-[10px] font-bold uppercase tracking-[0.2em]">@Localizer["hero_scroll_down"]</span>
                <span class="material-symbols-outlined text-2xl">expand_circle_down</span>
            </a>
        </div>

        @* ── Marquee Ticker Bar at Bottom ── *@
        @{
            var tickerItems = new (string Label, string Icon, string Style)[]
            {
                (Localizer["waterproof"].Value, "water_drop", "background:rgba(6,182,212,0.12);border-color:rgba(6,182,212,0.25);color:#0891B2"),
                (Localizer["uv"].Value, "sunny", "background:rgba(251,146,60,0.12);border-color:rgba(251,146,60,0.25);color:#D97706"),
                (Localizer["hero_ticker_scratch"].Value, "content_cut", "background:rgba(251,113,133,0.12);border-color:rgba(251,113,133,0.25);color:#E11D48"),
                (Localizer["hero_ticker_made_in"].Value, "location_on", "background:rgba(74,222,128,0.12);border-color:rgba(74,222,128,0.25);color:#16A34A"),
                (Localizer["hero_trust_support"].Value, "headset_mic", "background:rgba(251,191,36,0.12);border-color:rgba(251,191,36,0.25);color:#D97706"),
            };
        }
        <div class="relative z-20">
            <div class="marquee-wrapper py-2.5 md:py-3 bg-[rgba(5,5,5,0.85)] backdrop-blur-md border-t border-white/5">
                <div class="marquee-track">
                    @for (int t = 0; t < 2; t++)
                    {
                        @foreach (var (label, icon, style) in tickerItems)
                        {
                            <span class="marquee-item mx-3 md:mx-4 flex-shrink-0">
                                <span class="marquee-chip inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-xs md:text-sm font-semibold tracking-wide whitespace-nowrap" style="@style">
                                    <span class="material-symbols-outlined text-[16px] md:text-[18px]">@icon</span>
                                    @label
                                </span>
                            </span>
                        }
                    }
                </div>
            </div>
        </div>
    </section>
                </text>
                break;
            case "shop":
                <text>
    <section id="shop" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface dark:bg-dark-surface border-t border-outline-variant/10">
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-3 bg-primary/8 w-[280px] h-[280px] -top-16 right-10"></div>
            <div class="deco-shape-diamond top-1/3 left-8 opacity-40" style="animation-delay: 2s;"></div>
            <div class="deco-shape-square bottom-16 right-12 opacity-40" style="animation-delay: 4s;"></div>
        </div>
        <div class="max-w-3xl mx-auto text-center mb-10 md:mb-16 scroll-animate">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-3" data-reveal>@Localizer["prod_h2"]</h2>
            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@Localizer["prod_p"]</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8" id="featured-products-grid" data-stagger>
            @if (Model.HasFeaturedProducts)
            {
                @foreach (var product in Model.FeaturedProducts)
                {
                    <div class="product-card glass-panel p-5 rounded-2xl flex flex-col gap-4 scroll-animate group" data-tilt>
                        <a href="/shop/product/@product.Id" class="no-underline">
                            <div class="aspect-square rounded-xl overflow-hidden relative">
                                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="@ResolveImage(product.ImageFullUrl)" onerror="this.src='@placeholder'" alt="@(isAr ? product.ArName : product.Name)" loading="lazy" />
                            </div>
                            <div>
                                <h3 class="text-lg font-bold text-on-surface dark:text-white">@(isAr ? product.ArName : product.Name)</h3>
                                <p class="text-xs text-on-surface-variant dark:text-slate-400">@(isAr ? product.CategoryArName : product.CategoryName)</p>
                                @if (product.AverageRating > 0)
                                {
                                    <div class="flex items-center gap-1 mt-1.5">
                                        <div class="flex gap-0.5">
                                            @for (int s = 0; s < 5; s++)
                                            {
                                                <span class="material-symbols-outlined text-xs @(s < Math.Round(product.AverageRating) ? "text-yellow-500 fill-icon" : "text-outline/20 dark:text-white/10")">star</span>
                                            }
                                        </div>
                                        <span class="text-[10px] font-medium text-on-surface-variant dark:text-slate-400">(@product.ReviewCount)</span>
                                    </div>
                                }
                            </div>
                        </a>
                        <!-- Stock Status -->
                        @if (product.QuantityInStock == 0)
                        {
                            <span class="text-[10px] font-bold text-red-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">block</span>
                                @Localizer["inventory_out_of_stock"]
                            </span>
                        }
                        else if (product.QuantityInStock <= product.DangerQuantity)
                        {
                            <span class="text-[10px] font-bold text-amber-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">warning</span>
                                @Localizer["inventory_only_x_left", product.QuantityInStock]
                            </span>
                        }
                        else
                        {
                            <span class="text-[10px] font-bold text-green-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">check_circle</span>
                                @Localizer["inventory_in_stock"]
                            </span>
                        }
                        <div class="flex items-center justify-between mt-auto pt-2">
                            <span class="text-xl font-bold text-primary">@product.Price.ToString("N0") @Localizer["currency"]</span>
                            <div class="flex gap-2">
                                @if (product.QuantityInStock > 0)
                                {
                                    <button onclick="guestAddToCart(this, '@product.Id','@(isAr ? product.ArName : product.Name)','@product.Price','@(product.ImageFullUrl ?? product.ImageUrl)')" class="px-3 py-2 rounded-lg bg-primary text-on-primary text-[10px] font-bold hover:bg-primary-container hover:text-primary transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                                    </button>
                                }
                                else
                                {
                                    <button disabled class="px-3 py-2 rounded-lg bg-gray-300 text-gray-500 text-[10px] font-bold cursor-not-allowed flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">block</span>
                                    </button>
                                }
                                <a href="/shop/product/@product.Id" class="px-3 py-2 rounded-lg bg-primary/10 text-primary text-[10px] font-bold hover:bg-primary hover:text-on-primary transition-all no-underline">@Localizer["shop_view_details"]</a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center py-16">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">inventory_2</span>
                    <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["featured_empty_title"]</h3>
                    <p class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer["featured_empty_msg"]</p>
                </div>
            }
        </div>
    </section>
                </text>
                break;
            case "about":
                <text>
    <section id="about" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface-container-low dark:bg-dark-page border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-2 bg-primary/10 w-[300px] h-[300px] -top-12 -right-12 rtl:right-auto rtl:-left-12"></div>
            <div class="deco-blob animate-blob-1 bg-secondary-container/15 w-[350px] h-[350px] -bottom-24 -left-12 rtl:left-auto rtl:-right-12"></div>
            <div class="deco-ring w-[200px] h-[200px] bottom-10 right-1/4 rtl:right-auto rtl:left-1/4 opacity-40"></div>
            <div class="deco-dots-grid bottom-12 left-8 rtl:left-auto rtl:right-8 opacity-40"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center mb-16 scroll-animate">
            <h2 class="text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-4" data-reveal>@HeroText(Model.About.TitleAr, Model.About.TitleEn, "about_h2")</h2>
            <p class="text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@HeroText(Model.About.DescriptionAr, Model.About.DescriptionEn, "about_p")</p>
        </div>
        <div class="relative z-10 grid grid-cols-1 md:grid-cols-3 gap-8" data-stagger>
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-4 hover:-translate-y-1 transition-transform duration-300 shadow-sm scroll-animate delay-100">
                <div class="w-12 h-12 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center text-primary mb-2">
                    <span class="material-symbols-outlined text-2xl">layers</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface dark:text-slate-100">@HeroText(Model.About.Feature1TitleAr, Model.About.Feature1TitleEn, "feat1_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature1DescAr, Model.About.Feature1DescEn, "feat1_p")</p>
            </div>
            
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-4 hover:-translate-y-1 transition-transform duration-300 shadow-sm scroll-animate delay-200">
                <div class="w-12 h-12 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center text-primary mb-2">
                    <span class="material-symbols-outlined text-2xl">palette</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface dark:text-slate-100">@HeroText(Model.About.Feature2TitleAr, Model.About.Feature2TitleEn, "feat2_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature2DescAr, Model.About.Feature2DescEn, "feat2_p")</p>
            </div>
            
            <div class="glass-panel p-8 rounded-2xl flex flex-col gap-4 hover:-translate-y-1 transition-transform duration-300 shadow-sm scroll-animate delay-300">
                <div class="w-12 h-12 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center text-primary mb-2">
                    <span class="material-symbols-outlined text-2xl">shield</span>
                </div>
                <h3 class="text-xl font-bold text-on-surface dark:text-white">@HeroText(Model.About.Feature3TitleAr, Model.About.Feature3TitleEn, "feat3_h")</h3>
                <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed flex-grow">@HeroText(Model.About.Feature3DescAr, Model.About.Feature3DescEn, "feat3_p")</p>
            </div>
        </div>
    </section>
                </text>
                break;
            case "categories":
                <text>
    <section id="categories" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface dark:bg-dark-surface border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-shape-square top-24 left-12 rtl:left-auto rtl:right-12 opacity-60"></div>
            <div class="deco-shape-diamond bottom-24 right-12 rtl:right-auto rtl:left-12 opacity-60" style="animation-delay: 2s;"></div>
            <div class="deco-ring-solid w-[400px] h-[400px] -top-48 left-1/3 opacity-30"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center mb-10 md:mb-16 scroll-animate">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-3" data-reveal>@Localizer["cat_h2"]</h2>
            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@Localizer["cat_p"]</p>
        </div>
        <!-- Category Slider Wrapper -->
        <div class="relative z-10 scroll-animate">
            <div class="overflow-hidden" id="cat-slider-viewport">
                <div id="cat-slider-track" class="flex gap-4 md:gap-6 transition-transform duration-500 ease-out"
                     style="will-change: transform;">
                    @if (Model.HasCategories)
                    {
                        @foreach (var cat in Model.Categories)
                        {
                            <a href="/shop/products?categoryId=@cat.Id" data-frozen-action
                               class="group rounded-2xl overflow-hidden relative flex-shrink-0 w-[85vw] sm:w-[calc(50%-12px)] md:w-[calc(33.333%-16px)] lg:w-[calc(25%-18px)] aspect-square glass-panel shadow-sm no-underline block">
                                <img src="@ResolveCategoryImage(cat.ImageFullUrl)" alt="@(isAr ? cat.ArName : cat.CategoryName)" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" onerror="this.src='/images/placeholders/category-placeholder.svg'" />
                                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors z-10"></div>
                                <div class="absolute bottom-0 left-0 right-0 p-4 md:p-6 cat-overlay z-20">
                                    <h3 class="text-base md:text-xl font-bold text-white">@(isAr ? cat.ArName : cat.CategoryName)</h3>
                                    <p class="text-xs md:text-sm text-white/80">@cat.ProductsCount @Localizer["cat_products_count"]</p>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="flex-shrink-0 w-full text-center py-16">
                            <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">grid_view</span>
                            <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["categories_empty_title"]</h3>
                            <p class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer["categories_empty_msg"]</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Navigation Buttons -->
            <div class="flex items-center justify-center gap-4 mt-8">
                <button onclick="slidePrev()" aria-label="@Localizer["slider_prev_aria"]"
                        class="w-11 h-11 rounded-full bg-surface dark:bg-dark-elevated border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0">
                    <span class="material-symbols-outlined text-xl ltr:block rtl:hidden">chevron_left</span>
                    <span class="material-symbols-outlined text-xl ltr:hidden rtl:block">chevron_right</span>
                </button>

                <div class="flex gap-2.5 items-center" id="cat-dots">
                    <button id="cat-dot-0" onclick="slideGoTo(0)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 1)"
                            class="w-2.5 h-2.5 rounded-full bg-primary transition-all duration-300 hover:scale-125"></button>
                    <button id="cat-dot-1" onclick="slideGoTo(1)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 2)"
                            class="w-2.5 h-2.5 rounded-full bg-primary/30 transition-all duration-300 hover:scale-125"></button>
                    <button id="cat-dot-2" onclick="slideGoTo(2)" aria-label="@string.Format(Localizer["slider_slide_aria"].Value, 3)"
                            class="w-2.5 h-2.5 rounded-full bg-primary/30 transition-all duration-300 hover:scale-125"></button>
                </div>

                <button onclick="slideNext()" aria-label="@Localizer["slider_next_aria"]"
                        class="w-11 h-11 rounded-full bg-surface dark:bg-dark-elevated border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0">
                    <span class="material-symbols-outlined text-xl ltr:block rtl:hidden">chevron_right</span>
                    <span class="material-symbols-outlined text-xl ltr:hidden rtl:block">chevron_left</span>
                </button>
            </div>
        </div>
    </section>
                </text>
                break;
            case "all-products":
                <text>
    <section id="all-products" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface-container-low dark:bg-dark-page border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-secondary-container/10 w-[300px] h-[300px] -top-12 -left-12 opacity-40"></div>
            <div class="deco-ring-solid w-[300px] h-[300px] bottom-6 right-8 opacity-30"></div>
        </div>

        <div class="relative z-10 max-w-3xl mx-auto text-center mb-10 md:mb-12 scroll-animate">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-3">@Localizer["all_products_h2"]</h2>
            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-400 leading-relaxed">@Localizer["all_products_p"]</p>
        </div>

        <!-- Filter Controls -->
        <div class="relative z-10 max-w-5xl mx-auto flex flex-col md:flex-row md:items-center justify-between gap-4 md:gap-6 mb-8 md:mb-10 bg-surface/60 dark:bg-dark-overlay/80 backdrop-blur-md border border-primary/15 dark:border-white/5 p-4 md:p-6 rounded-2xl shadow-sm">
            <!-- Category Filter Pills -->
            <div class="flex flex-col gap-2.5">
                <span class="text-xs font-bold text-primary uppercase tracking-wider">@Localizer["filter_category"]</span>
                <div class="flex flex-wrap gap-2" id="prod-cat-filters">
                    <!-- Rendered dynamically by landing.js -->
                </div>
            </div>

            <!-- Price Filter Slider -->
            <div class="flex flex-col gap-2.5 min-w-[200px]">
                <div class="flex justify-between items-center">
                    <span class="text-xs font-bold text-primary uppercase tracking-wider">@Localizer["filter_price"]</span>
                    <span class="text-xs font-bold text-primary font-sans" id="price-val-display">@Localizer["price_display_val"]</span>
                </div>
                <input type="range" min="0" max="200" value="200" class="w-full h-1.5 bg-primary/20 rounded-lg appearance-none cursor-pointer accent-primary" id="price-slider" onchange="filterPrice(this.value)"/>
                <div class="flex justify-between text-[10px] text-on-surface-variant/60 dark:text-slate-400/50 font-semibold font-sans">
                    <span>@Localizer["price_min_val"]</span>
                    <span>@Localizer["price_max_val"]</span>
                </div>
            </div>
        </div>

        <!-- Dynamic Products Grid -->
        <div class="relative z-10 max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 min-h-[300px]" id="all-prods-grid">
            @if (Model.AllProducts != null && Model.AllProducts.Items.Count > 0)
            {
                @foreach (var product in Model.AllProducts.Items)
                {
                    <div class="product-card glass-panel p-5 rounded-2xl flex flex-col gap-4 scroll-animate visible" data-tilt>
                        <div class="aspect-square rounded-xl overflow-hidden relative">
                            <img class="w-full h-full object-cover" src="@ResolveImage(product.ImageFullUrl)" onerror="this.src='@placeholder'" alt="@(isAr ? product.ArName : product.Name)" loading="lazy" />
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-on-surface dark:text-white">@(isAr ? product.ArName : product.Name)</h3>
                            <p class="text-xs text-on-surface-variant dark:text-slate-400">@(isAr ? product.CategoryArName : product.CategoryName)</p>
                            @if (product.AverageRating > 0)
                            {
                                <div class="flex items-center gap-1 mt-1.5">
                                    <div class="flex gap-0.5">
                                        @for (int s = 0; s < 5; s++)
                                        {
                                            <span class="material-symbols-outlined text-xs @(s < Math.Round(product.AverageRating) ? "text-yellow-500 fill-icon" : "text-outline/20 dark:text-white/10")">star</span>
                                        }
                                    </div>
                                    <span class="text-[10px] font-medium text-on-surface-variant dark:text-slate-400">(@product.ReviewCount)</span>
                                </div>
                            }
                        </div>
                        <!-- Stock Status -->
                        @if (product.QuantityInStock == 0)
                        {
                            <span class="text-[10px] font-bold text-red-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">block</span>
                                @Localizer["inventory_out_of_stock"]
                            </span>
                        }
                        else if (product.QuantityInStock <= product.DangerQuantity)
                        {
                            <span class="text-[10px] font-bold text-amber-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">warning</span>
                                @Localizer["inventory_only_x_left", product.QuantityInStock]
                            </span>
                        }
                        else
                        {
                            <span class="text-[10px] font-bold text-green-500 flex items-center gap-1">
                                <span class="material-symbols-outlined text-xs">check_circle</span>
                                @Localizer["inventory_in_stock"]
                            </span>
                        }
                        <div class="flex items-center justify-between mt-auto pt-2">
                            <span class="text-xl font-bold text-primary font-sans">@product.Price.ToString("N0") @Localizer["currency"]</span>
                            <div class="flex gap-2">
                                @if (product.QuantityInStock > 0)
                                {
                                    <button onclick="guestAddToCart(this, '@product.Id','@(isAr ? product.ArName : product.Name)','@product.Price','@(product.ImageFullUrl ?? product.ImageUrl)')" class="px-3 py-2 rounded-lg bg-primary text-on-primary text-[10px] font-bold hover:bg-primary-container hover:text-primary transition-all flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span>
                                    </button>
                                }
                                else
                                {
                                    <button disabled class="px-3 py-2 rounded-lg bg-gray-300 text-gray-500 text-[10px] font-bold cursor-not-allowed flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">block</span>
                                    </button>
                                }
                                <a href="/shop/product/@product.Id" class="px-3 py-2 rounded-lg bg-primary/10 text-primary hover:bg-primary hover:text-on-primary text-[10px] font-bold transition-all duration-200">@Localizer["shop_view_details"]</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Pagination Controls -->
        <div class="relative z-10 flex items-center justify-center gap-4 mt-12" id="prods-pagination">
            <button onclick="prevProdsPage()" id="btn-prod-prev" class="w-10 h-10 rounded-full bg-surface dark:bg-dark-elevated border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 disabled:opacity-40 disabled:pointer-events-none">
                <span class="material-symbols-outlined text-lg ltr:block rtl:hidden">chevron_left</span>
                <span class="material-symbols-outlined text-lg ltr:hidden rtl:block">chevron_right</span>
            </button>
            <div class="flex gap-2" id="prods-page-indicators">
                <!-- Indicators rendered dynamically -->
            </div>
            <button onclick="nextProdsPage()" id="btn-prod-next" class="w-10 h-10 rounded-full bg-surface dark:bg-dark-elevated border border-primary/20 shadow-md flex items-center justify-center text-primary hover:bg-primary hover:text-white hover:border-primary transition-all duration-200 disabled:opacity-40 disabled:pointer-events-none">
                <span class="material-symbols-outlined text-lg ltr:block rtl:hidden">chevron_right</span>
                <span class="material-symbols-outlined text-lg ltr:hidden rtl:block">chevron_left</span>
            </button>
        </div>
    </section>
                </text>
                break;
            case "testimonials":
                <text>
    <section id="testimonials" class="relative overflow-hidden py-16 lg:py-24 px-4 sm:px-6 lg:px-8 bg-surface dark:bg-dark-surface border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-3 bg-primary/15 w-[320px] h-[320px] top-12 left-12 rtl:left-auto rtl:right-12"></div>
            <div class="deco-blob animate-blob-1 bg-primary/10 w-[300px] h-[300px] bottom-12 right-12 rtl:right-auto rtl:left-12"></div>
            <div class="deco-ring w-[240px] h-[240px] top-10 right-1/3 rtl:right-auto rtl:left-1/3 opacity-40"></div>
            <div class="deco-dots-grid top-6 right-8 rtl:right-auto rtl:left-8 opacity-40"></div>
        </div>

        <div class="relative z-20 max-w-7xl mx-auto px-0">
            <!-- Section Header -->
            <div class="max-w-3xl mx-auto text-center mb-10 md:mb-14 scroll-animate">
                <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-on-surface dark:text-white mb-3">
                    @(Model.HasCmsData && !string.IsNullOrEmpty(Model.Testimonials.Title) ? Model.Testimonials.Title : Localizer["test_h2"].Value)
                </h2>
                @{
                    var testiDesc = Model.HasCmsData && !string.IsNullOrEmpty(Model.Testimonials.Description) ? Model.Testimonials.Description : Localizer["test_p"].Value;
                }
                @if (!string.IsNullOrEmpty(testiDesc))
                {
                    <p class="text-base md:text-lg text-on-surface-variant dark:text-slate-400 leading-relaxed max-w-2xl mx-auto">@testiDesc</p>
                }
            </div>

            <!-- Testimonials Grid -->
            @if (Model.Testimonials.Reviews.Count > 0)
            {
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8" data-stagger>
                    @for (int ri = 0; ri < Model.Testimonials.Reviews.Count; ri++)
                    {
                        var rev = Model.Testimonials.Reviews[ri];
                        <div class="group bg-surface dark:bg-dark-elevated rounded-3xl border border-outline-variant/20 dark:border-white/5 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 p-6 md:p-8 flex flex-col gap-4 scroll-animate relative overflow-hidden">
                            <!-- Top accent gradient -->
                            <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-primary/40 via-primary to-primary/40 dark:from-primary/30 dark:via-primary dark:to-primary/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                            <!-- Rating badge + stars row -->
                            <div class="flex items-center justify-between gap-2">
                                <div class="flex gap-1" aria-label="@string.Format(Localizer["admin_review_rating_aria"].Value, rev.Rating)">
                                    @for (int s = 0; s < 5; s++)
                                    {
                                        <span class="material-symbols-outlined text-sm @(s < rev.Rating ? "text-yellow-500 fill-icon" : "text-outline/20 dark:text-white/10")">star</span>
                                    }
                                </div>
                                <span class="inline-flex items-center gap-1 text-xs font-bold text-on-surface-variant dark:text-slate-400 bg-surface-container dark:bg-dark-elevated px-2.5 py-1 rounded-full">
                                    <span class="material-symbols-outlined text-sm text-yellow-500 fill-icon">star</span>
                                    @rev.Rating
                                </span>
                            </div>

                            <!-- Review Text -->
                            <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-300 leading-relaxed flex-grow">
                                &ldquo;@rev.Quote&rdquo;
                            </p>

                            <!-- Customer Info -->
                            <div class="flex items-center gap-3 mt-auto pt-4 border-t border-outline-variant/10 dark:border-white/5">
                                <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0 bg-gradient-to-br from-primary/20 to-primary/5 dark:from-primary/30 dark:to-primary/10 shadow-sm">
                                    @if (!string.IsNullOrEmpty(rev.ProfilePictureUrl))
                                    {
                                        <img src="@rev.ProfilePictureUrl" alt="@rev.Name" class="w-full h-full object-cover" loading="lazy" onerror="this.onerror=null; this.src='/images/placeholders/product-placeholder.svg'" />
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center">
                                            <span class="text-sm font-bold text-primary">@rev.Name[0]</span>
                                        </div>
                                    }
                                </div>
                                <div class="min-w-0">
                                    <p class="text-sm font-bold text-on-surface dark:text-white truncate">@rev.Name</p>
                                    @if (!string.IsNullOrEmpty(rev.Role))
                                    {
                                        <p class="text-xs text-on-surface-variant dark:text-slate-400 truncate">@rev.Role</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="text-center py-16 scroll-animate">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">rate_review</span>
                    <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["testimonials_empty_title"]</h3>
                    <p class="text-sm text-on-surface-variant dark:text-slate-400 max-w-md mx-auto">@Localizer["testimonials_empty_msg"]</p>
                </div>
            }
        </div>
    </section>
                </text>
                break;
            case "faq":
                <text>
    <section id="faq" class="relative overflow-hidden py-16 lg:py-24 px-4 md:px-16 bg-surface dark:bg-dark-surface border-t border-outline-variant/10">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-3 bg-primary/15 w-[320px] h-[320px] top-12 left-12 rtl:left-auto rtl:right-12"></div>
            <div class="deco-blob animate-blob-1 bg-primary/10 w-[300px] h-[300px] bottom-12 right-12 rtl:right-auto rtl:left-12"></div>
            <div class="deco-ring w-[240px] h-[240px] top-10 right-1/3 rtl:right-auto rtl:left-1/3 opacity-40"></div>
            <div class="deco-dots-grid top-6 right-8 rtl:right-auto rtl:left-8 opacity-40"></div>
        </div>

        <div class="relative z-20 max-w-7xl mx-auto px-0">
            <!-- Section Header -->
            <div class="max-w-3xl mx-auto text-center mb-10 md:mb-14 scroll-animate">
                <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-extrabold text-on-surface dark:text-white mb-3">
                    @(Model.HasCmsData && !string.IsNullOrEmpty(Model.Faq.TitleAr) ? (isAr ? Model.Faq.TitleAr : Model.Faq.TitleEn) : Localizer["section_faq"].Value)
                </h2>
                @{
                    var faqDesc = Model.HasCmsData && !string.IsNullOrEmpty(Model.Faq.DescriptionAr) ? (isAr ? Model.Faq.DescriptionAr : Model.Faq.DescriptionEn) : "";
                }
                @if (!string.IsNullOrEmpty(faqDesc))
                {
                    <p class="text-base md:text-lg text-on-surface-variant dark:text-slate-400 leading-relaxed max-w-2xl mx-auto">@faqDesc</p>
                }
            </div>

            <!-- FAQ Grid -->
            @if (Model.FaqItems != null && Model.FaqItems.Count > 0)
            {
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-stagger>
                    @for (int fi = 0; fi < Model.FaqItems.Count; fi++)
                    {
                        var faq = Model.FaqItems[fi];
                        <div class="group bg-surface dark:bg-dark-elevated rounded-3xl border border-outline-variant/20 dark:border-white/5 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1.5 p-6 md:p-8 flex flex-col gap-4 scroll-animate relative overflow-hidden" style="animation-delay: @(fi * 100)ms;">
                            <div class="flex items-start gap-4">
                                <div class="w-10 h-10 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center text-primary flex-shrink-0">
                                    <span class="material-symbols-outlined text-xl">help_center</span>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-lg font-bold text-on-surface dark:text-slate-100 mb-2">@(isAr ? faq.ArQuestion : faq.Question)</h3>
                                    <p class="text-sm text-on-surface-variant dark:text-slate-400 leading-relaxed">@(isAr ? faq.ArAnswer : faq.Answer)</p>
                                </div>
                            </div>
                            <div class="flex items-center justify-between pt-2 border-t border-outline-variant/10 dark:border-white/5">
                                <span class="inline-flex items-center gap-1 text-xs font-bold text-on-surface-variant dark:text-slate-400 bg-surface-container dark:bg-dark-elevated px-2.5 py-1 rounded-full">
                                    <span class="material-symbols-outlined text-sm text-primary">category</span>
                                    @(isAr ? faq.CategoryArName : faq.CategoryName)
                                </span>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="text-center py-16 scroll-animate">
                    <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 dark:text-slate-500/40 mb-4">help_center</span>
                    <h3 class="text-xl font-bold text-on-surface dark:text-slate-100 mb-2">@Localizer["section_faq"]</h3>
                    <p class="text-sm text-on-surface-variant dark:text-slate-400 max-w-md mx-auto">@Localizer["supp_no_faqs"]</p>
                </div>
            }
        </div>
    </section>
                </text>
                break;
            case "contact":
                <text>
    <section id="contact" class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-surface-container-low dark:bg-dark-page border-t border-outline-variant/10">
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-secondary-container/10 w-[300px] h-[300px] -bottom-20 -right-20"></div>
            <div class="deco-ring w-[200px] h-[200px] top-8 left-8 opacity-30"></div>
            <div class="deco-dots-grid bottom-12 right-12 opacity-30"></div>
        </div>
        <div class="relative z-10 max-w-2xl mx-auto bg-surface-container-low/60 dark:bg-dark-overlay/80 backdrop-blur-md border border-primary/20 dark:border-white/5 p-6 md:p-12 rounded-3xl shadow-2xl shadow-primary/5 scroll-animate-scale">
            <h2 class="text-2xl md:text-3xl font-extrabold text-on-surface dark:text-white mb-2 md:mb-3 text-center">@Localizer["form_h2"]</h2>
            <p class="text-sm text-on-surface-variant dark:text-slate-400 text-center mb-6 md:mb-8">@Localizer["form_p"]</p>
            <form novalidate class="flex flex-col gap-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label for="cf-name" class="text-xs font-bold text-primary">@Localizer["form_name"]</label>
                        <input id="cf-name" class="bg-surface dark:bg-dark-elevated border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["form_name_ph"]" type="text" required/>
                        <span class="cf-error text-xs text-red-500 hidden" data-for="name"></span>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label for="cf-phone" class="text-xs font-bold text-primary">@Localizer["contact_form_phone_label"]</label>
                        <input id="cf-phone" class="bg-surface dark:bg-dark-elevated border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["contact_form_phone_ph"]" type="tel" required/>
                        <span class="cf-error text-xs text-red-500 hidden" data-for="phone"></span>
                    </div>
                    <div class="flex flex-col gap-2 md:col-span-2">
                        <label for="cf-email" class="text-xs font-bold text-primary">@Localizer["contact_form_email_label"]</label>
                        <input id="cf-email" class="bg-surface dark:bg-dark-elevated border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["contact_form_email_ph"]" type="email" />
                        <span class="cf-error text-xs text-red-500 hidden" data-for="email"></span>
                    </div>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="cf-subject" class="text-xs font-bold text-primary">@Localizer["contact_form_subject_label"]</label>
                    <select id="cf-subject" class="w-full bg-surface dark:bg-dark-elevated border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" required>
                        <option value="">@Localizer["contact_form_subject_ph"]</option>
                        @foreach (var cat in Model.SupportCategories.OrderBy(c => c.DisplayOrder))
                        {
                            <option value="@cat.Id">@(isAr ? cat.ArName : cat.Name)</option>
                        }
                    </select>
                    <span class="cf-error text-xs text-red-500 hidden" data-for="subject"></span>
                </div>
                <div class="flex flex-col gap-2">
                    <label for="cf-msg" class="text-xs font-bold text-primary">@Localizer["form_msg"]</label>
                    <textarea id="cf-msg" class="bg-surface dark:bg-dark-elevated border border-primary/20 dark:border-white/5 rounded-xl p-3.5 text-on-surface dark:text-slate-100 focus:ring-2 focus:ring-primary/20 focus:border-primary focus:bg-surface-container-low dark:focus:bg-[#0f1d30] outline-none transition-all duration-200" placeholder="@Localizer["form_msg_ph"]" rows="4" required></textarea>
                    <span class="cf-error text-xs text-red-500 hidden" data-for="msg"></span>
                </div>
                <button class="bg-primary hover:bg-primary/90 text-on-primary font-bold py-4 rounded-xl transition-all shadow-md hover:shadow-lg duration-200 mt-2" type="submit">
                    @Localizer["btn_send"]
                </button>
                <div id="cf-success" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700/30 rounded-xl p-4 text-center">
                    <span class="material-symbols-outlined text-green-500 text-3xl mb-2">check_circle</span>
                    <p class="font-bold text-green-700 dark:text-green-300">@Localizer["contact_form_success_title"]</p>
                    <p class="text-sm text-green-600 dark:text-green-400 mt-1">@Localizer["contact_form_success_sub"]</p>
                </div>
            </form>
        </div>
    </section>
                </text>
                break;
        }
    }
}
</main>

<!-- Cart Toast Container -->
<div id="cart-toast-container" class="fixed bottom-24 md:bottom-8 end-4 md:end-8 z-[90] flex flex-col gap-3 pointer-events-none"></div>

<!-- Sign-in Modal for Frozen Actions -->
<div id="signin-modal" class="fixed inset-0 z-[100] flex items-center justify-center hidden" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="relative bg-white dark:bg-dark-elevated rounded-3xl shadow-2xl border border-primary/10 dark:border-white/5 p-6 md:p-10 max-w-md w-[92%] sm:w-[90%] mx-4 text-center">
        <button onclick="hideSignInModal()" class="absolute top-4 end-4 w-10 h-10 rounded-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 flex items-center justify-center text-on-surface-variant dark:text-slate-300 hover:text-primary transition-all" aria-label="@Localizer["close_aria"]">
            <span class="material-symbols-outlined text-xl">close</span>
        </button>
        <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-primary">lock</span>
        </div>
        <h3 class="text-2xl font-extrabold text-on-surface dark:text-white mb-2">@Localizer["signin_modal_title"]</h3>
        <p class="text-sm text-on-surface-variant dark:text-slate-400 mb-8 leading-relaxed">@Localizer["signin_modal_msg"]</p>
        <div class="flex flex-col gap-3">
            <a asp-action="Login" asp-controller="Auth" class="w-full bg-primary hover:bg-primary-container text-on-primary font-bold py-3.5 px-6 rounded-xl transition-all shadow-lg hover:-translate-y-0.5 active:scale-95 text-sm">
                @Localizer["auth.login.submit"]
            </a>
            <a asp-action="Register" asp-controller="Auth" class="w-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 text-on-surface dark:text-slate-200 font-bold py-3.5 px-6 rounded-xl transition-all border border-outline-variant/20 dark:border-white/5 hover:-translate-y-0.5 active:scale-95 text-sm">
                @Localizer["auth.login.register"]
            </a>
            <button onclick="hideSignInModal()" class="text-xs text-on-surface-variant dark:text-slate-400 hover:text-primary mt-2 transition-colors">@Localizer["signin_modal_continue"]</button>
        </div>
    </div>
</div>

