                <span class="absolute -top-1 -end-1 w-5 h-5 bg-tertiary-container text-on-tertiary-container text-[10px] font-bold rounded-full flex items-center justify-center shadow-sm" id="cart-badge">0</span>
            </a>
        </div>

        <!-- Account Button (Mobile) -->
        <a asp-action="Login" asp-controller="Auth" class="navbar-icon-btn scale-90 md:scale-100 lg:hidden dark:text-slate-300" title="@Localizer["auth.register.login"]">
            <span class="material-symbols-outlined text-[24px]">person</span>
        </a>

        <!-- Cart Button (Mobile) -->
        <a asp-action="Cart" asp-controller="Shop" aria-label="@Localizer["nav_cart"]" class="navbar-icon-btn relative scale-90 md:scale-100 dark:text-slate-300 lg:hidden" title="@Localizer["nav_cart"]">
