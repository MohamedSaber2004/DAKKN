@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "DAKKN - Premium Vinyl Stickers";
}

<!-- 1. Header Navigation -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-surface-container/75 backdrop-blur-md border-b border-outline-variant/10 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="#hero" class="logo-glow cursor-pointer" data-section="hero">
                    <img src="~/images/logo.png" alt="DAKKN Logo" class="h-16 md:h-18" />
                </a>
        <!-- Desktop nav links with icons -->
        <div class="hidden lg:flex items-center gap-1">
            <a href="#shop" class="nav-link-premium nav-icon-link" data-section="shop">
                <span class="material-symbols-outlined text-[17px]">local_fire_department</span>
                <span data-i18n="nav_shop">@Localizer["nav_shop"]</span>
            </a>
            <a href="#categories" class="nav-link-premium nav-icon-link" data-section="categories">
                <span class="material-symbols-outlined text-[17px]">grid_view</span>
                <span data-i18n="nav_categories">@Localizer["nav_categories"]</span>
            </a>
            <a href="#all-products" class="nav-link-premium nav-icon-link" data-section="all-products">
                <span class="material-symbols-outlined text-[17px]">inventory_2</span>
                <span data-i18n="nav_all_products">@Localizer["nav_all_products"]</span>
            </a>
            <a href="#testimonials" class="nav-link-premium nav-icon-link" data-section="testimonials">
                <span class="material-symbols-outlined text-[17px]">reviews</span>
                <span data-i18n="nav_reviews">@Localizer["nav_reviews"]</span>
            </a>
            <a href="#contact" class="nav-link-premium nav-icon-link" data-section="contact">
                <span class="material-symbols-outlined text-[17px]">support_agent</span>
                <span data-i18n="nav_support">@Localizer["nav_support"]</span>
            </a>
        </div>
    </div>
    <div class="flex items-center gap-1 md:gap-3">

        <!-- Account Button -->
        <button aria-label="person" class="navbar-icon-btn scale-90 md:scale-100" title="Account">
            <span class="material-symbols-outlined text-[24px]">person</span>
        </button>

        <!-- Cart Button -->
        <button aria-label="shopping_cart" class="navbar-icon-btn relative scale-90 md:scale-100" title="Cart">
            <span class="material-symbols-outlined text-[24px]">shopping_cart</span>
            <span class="absolute top-1.5 right-1.5 rtl:right-auto rtl:left-1.5 w-2 h-2 bg-tertiary-container rounded-full"></span>
        </button>

        <!-- Language Switcher -->
        <button id="lang-toggle-btn" onclick="toggleLang()" class="lang-pill-premium text-[11px] md:text-[13px] px-3 md:px-4 py-1.5 md:py-2">
            العربية
        </button>
    </div>
</nav>

<!-- Mobile Bottom Navigation Bar -->
<nav id="mobile-bottom-nav" class="mobile-bottom-nav lg:hidden">
    <a href="#shop" class="mob-nav-item" id="mobnav-shop" data-section="shop">
        <span class="material-symbols-outlined">local_fire_department</span>
        <span data-i18n="nav_shop">@Localizer["nav_shop"]</span>
    </a>
    <a href="#categories" class="mob-nav-item" id="mobnav-cats" data-section="categories">
        <span class="material-symbols-outlined">grid_view</span>
        <span data-i18n="nav_categories">@Localizer["nav_categories"]</span>
    </a>
    <a href="#all-products" class="mob-nav-item" id="mobnav-products" data-section="all-products">
        <span class="material-symbols-outlined">inventory_2</span>
        <span data-i18n="nav_all_products">@Localizer["nav_all_products"]</span>
    </a>
    <a href="#testimonials" class="mob-nav-item" id="mobnav-reviews" data-section="testimonials">
        <span class="material-symbols-outlined">reviews</span>
        <span data-i18n="nav_reviews">@Localizer["nav_reviews"]</span>
    </a>
    <a href="#contact" class="mob-nav-item" id="mobnav-contact" data-section="contact">
        <span class="material-symbols-outlined">support_agent</span>
        <span data-i18n="nav_support">@Localizer["nav_support"]</span>
    </a>
</nav>

<main class="flex-grow pt-20">
    <!-- 2. Hero Section -->
    <section id="hero" class="relative min-h-[85vh] flex items-center px-4 md:px-16 py-12 md:py-16 overflow-hidden hero-glow bg-cyan-50">
        <!-- Decorative Ambient Elements -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0 hidden md:block">
            <!-- Floating Blobs -->
            <div class="deco-blob animate-blob-1 bg-primary/20 w-[450px] h-[450px] -top-24 -left-24 rtl:-left-auto rtl:-right-24"></div>
            <div class="deco-blob animate-blob-2 bg-tertiary-container/30 w-[350px] h-[350px] bottom-12 right-12 rtl:right-auto rtl:left-12"></div>
            <div class="deco-blob animate-blob-3 bg-secondary-container/20 w-[400px] h-[400px] top-1/3 left-1/3"></div>

            <!-- Rotating Rings -->
            <div class="deco-ring w-[300px] h-[300px] top-10 right-10 rtl:right-auto rtl:left-10 opacity-70"></div>
            <div class="deco-ring-solid w-[500px] h-[500px] -bottom-36 -left-12 opacity-40"></div>

            <!-- Floating Mini Shapes -->
            <div class="deco-shape-diamond top-1/4 left-10 rtl:left-auto rtl:right-10" style="animation-delay: 1s;"></div>
            <div class="deco-shape-square top-1/2 right-1/4 rtl:right-auto rtl:left-1/4" style="animation-delay: 3s;"></div>
            <div class="deco-shape-diamond bottom-1/4 left-1/2" style="animation-delay: 5s;"></div>
            
            <!-- Dots Grid -->
            <div class="deco-dots-grid top-12 left-1/2 rtl:left-auto rtl:right-1/2 opacity-60"></div>
        </div>

        <!-- Mobile: image top, text bottom. Desktop: text left, image right -->
        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-6 lg:gap-12 w-full z-10 relative">

            <!-- Image: order-1 on mobile (top), order-2 on desktop (right) -->
            <div class="order-1 lg:order-2 lg:col-span-6 relative flex items-center justify-center fade-in-up delay-200 scroll-animate-right">
                <div class="absolute w-[110%] h-[110%] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-primary/10 to-transparent blur-3xl z-0"></div>
                <div class="glass-panel rounded-2xl p-3 md:p-4 relative z-10 w-full max-w-sm md:max-w-lg aspect-square flex items-center justify-center overflow-hidden group shadow-2xl">
                    <img alt="Premium Holographic Sticker" class="w-full h-full object-cover rounded-xl group-hover:scale-105 transition-transform duration-700 ease-out" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA72PkjHVeCPUlIaHJ3_eGqx62IshGNKsZAFOtRfa4qXiqB34wZxI5n0pDgo8HSGobn8wLB9UH8B7rOFgx0ftpYxUVR1qGU1sd7rA6C2_VP3aAwz5s7_peP44fO51s7n2hY_hMJhSZ5CpWTrmqYh-Pdj0JRr38jLohPnoOObJl3sNfno5qxrwES4-yGrakjXi3fAHd819iPakcoY-dxzBnGcJyo-d0MooPlllmRZCPrT3rq7Enl6Um_MO_W2pYfIMp1t7xZ5BMKLRkR"/>
                    
                    <div class="absolute top-3 right-3 md:top-6 md:right-6 bg-surface-container-high/90 backdrop-blur-md px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-outline-variant/30 flex items-center gap-1.5 md:gap-2 shadow-lg">
                        <span class="material-symbols-outlined text-primary text-base md:text-lg">water_drop</span>
                        <span data-i18n="waterproof" class="text-[10px] md:text-xs font-bold text-on-surface">@Localizer["waterproof"]</span>
                    </div>
                    
                    <div class="absolute bottom-3 left-3 md:bottom-6 md:left-6 bg-surface-container-high/90 backdrop-blur-md px-3 py-1.5 md:px-4 md:py-2 rounded-full border border-outline-variant/30 flex items-center gap-1.5 md:gap-2 shadow-lg">
                        <span class="material-symbols-outlined text-tertiary-container text-base md:text-lg">sunny</span>
                        <span data-i18n="uv" class="text-[10px] md:text-xs font-bold text-on-surface">@Localizer["uv"]</span>
                    </div>
                </div>
            </div>


            <!-- Text: order-2 on mobile (bottom), order-1 on desktop (left) -->
            <div class="order-2 lg:order-1 lg:col-span-6 flex flex-col justify-center gap-4 md:gap-6 fade-in-up scroll-animate visible">
                <div class="inline-flex items-center gap-2 px-3 py-1 md:px-4 md:py-1.5 rounded-full bg-surface-container-high border border-outline-variant/30 w-fit shadow-sm scroll-animate delay-100">
                    <span class="w-2 h-2 md:w-2.5 md:h-2.5 rounded-full bg-primary animate-pulse"></span>
                    <span data-i18n="hero_badge" class="text-[10px] md:text-xs font-bold text-on-surface-variant uppercase tracking-wider">@Localizer["hero_badge"]</span>
                </div>

                <h1 class="text-3xl md:text-5xl lg:text-6xl font-extrabold text-on-surface leading-tight tracking-tight scroll-animate delay-200">
                    <span data-i18n="hero_h1_a">@Localizer["hero_h1_a"]</span> 
                    <span data-i18n="hero_h1_b" class="text-primary">@Localizer["hero_h1_b"]</span><span data-i18n="hero_h1_c">@Localizer["hero_h1_c"]</span> 
                    <span data-i18n="hero_h1_d" class="text-tertiary">@Localizer["hero_h1_d"]</span>.
                </h1>

                <p data-i18n="hero_p" class="text-sm md:text-lg text-on-surface-variant max-w-xl leading-relaxed scroll-animate delay-300">
                    @Localizer["hero_p"]
                </p>
                
                <div class="flex flex-col sm:flex-row gap-3 md:gap-4 pt-2 md:pt-4 scroll-animate delay-400">
                    <a href="#shop" data-i18n="btn_shop" class="bg-primary hover:bg-primary-container text-on-primary font-semibold text-center px-6 md:px-8 py-3 md:py-4 rounded-xl transition-all shadow-[0_4px_14px_0_rgba(77,46,229,0.4)] hover:shadow-[0_6px_20px_rgba(77,46,229,0.25)] hover:-translate-y-0.5 duration-200 text-sm md:text-base">
                        @Localizer["btn_shop"]
                    </a>
                </div>

                @* <!-- Scroll Down Indicator -->
                <div class="hidden lg:flex items-center gap-4 mt-8 scroll-animate delay-600">
                    <a href="#shop" class="group flex items-center gap-3 text-on-surface-variant hover:text-primary transition-colors duration-300">
                        <div class="w-10 h-10 rounded-full border border-outline-variant/30 flex items-center justify-center group-hover:border-primary group-hover:bg-primary/5 transition-all duration-300">
                            <span class="material-symbols-outlined text-xl animate-bounce">expand_more</span>
                        </div>
                        <span class="text-xs font-bold uppercase tracking-widest" data-i18n="hero_scroll_down">@Localizer["hero_scroll_down"]</span>
                    </a>
                </div> *@

                <div class="flex items-center gap-3 md:gap-4 mt-4 md:mt-8 pt-4 md:pt-8 border-t border-outline-variant/20 scroll-animate delay-500">
                    <div class="flex -space-x-3 rtl:space-x-reverse">
                        <img alt="User" class="w-8 h-8 md:w-10 md:h-10 rounded-full border-2 border-background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAsbzfpDCD3KQ9gRe7rlAbOhGlqAxgpNnsZCQHyMVIOnG4wEdkisp37Pb9mnLgYmtx_tBHSaSHatWeM2ypINipat-x4fdPPsOEfFz47R_uU0alEAmhYAtzpqKdMMJoR11cldP3ApUtMyn6o4UisAZjO2gjQhlknWO46MpXKZ166Ug7LrSSZ1Rt_dlP5utpPZJZqMe7tMpd7q-atjlknwSaLOJOoUkw1z0YQ-BFtouwU0-X-DTm8vOWxSrSWCS98GplKFuue88lEBZJb"/>
                        <img alt="User" class="w-8 h-8 md:w-10 md:h-10 rounded-full border-2 border-background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDQm5pngnzk7PeW1ocBUUkJ6LYFhH-wq3KTlUHn-wdxnN1yZ25bfxSVUNj45WHfjmNwLJfcW2DC2igPRXk2ofVXb3wJGDGEvRfysWc5uKjlTdSrmoFPY8wMM-X3LrcUtkdZUCmSoxn54AHLHjjdZZgma00bPYfmnduCpfuM8aB3KI39hzYyE3W5e6BQfJwGyzBwDp38B7xc61WDA4SFLV6caOGiIApQTZW_gZtZTMO9P655h37z34TffJIasZt4SSLIL5Ft7WKKlaKd"/>
                        <img alt="User" class="w-8 h-8 md:w-10 md:h-10 rounded-full border-2 border-background" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA4J9mlzPKkqHsy5Xpbqb_aeSoq46z6_uxsNrA1nFW-Pfdxmh0h3Rue-7NZ1bPw_nkXvjJoMNwitjW1rNPqqwenUeSn_yfUjMnspzGb76WcXOsevWvqyycqgluwyd8pYZiagwwJ9H6PSef3YhRxV0DSA_KFTrEtOKZQsZ6_YsTmmPFrm596BYhnAeI0vAQOpR7Q_oEWZmBKeBeGP5o1YomNKoU0KCFOMmxKMiGcHLqRCxBXur9Ixg73ivltG6xQ2JIOdOaJL_GkvJ-K"/>
                    </div>
                    <div class="flex flex-col">
                        <div class="flex text-tertiary">
                            <span class="material-symbols-outlined text-xs md:text-sm fill-icon">star</span>
                            <span class="material-symbols-outlined text-xs md:text-sm fill-icon">star</span>
                            <span class="material-symbols-outlined text-xs md:text-sm fill-icon">star</span>
                            <span class="material-symbols-outlined text-xs md:text-sm fill-icon">star</span>
                            <span class="material-symbols-outlined text-xs md:text-sm fill-icon">star</span>
                        </div>
                        <span data-i18n="hero_trust" class="text-[10px] md:text-xs font-semibold text-on-surface-variant">@Localizer["hero_trust"]</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. Featured Products Section -->
