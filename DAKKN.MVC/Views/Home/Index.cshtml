            <span class="absolute -top-0.5 -end-0.5 w-4 h-4 bg-tertiary-container text-on-tertiary-container text-[8px] font-bold rounded-full flex items-center justify-center shadow-sm" id="cart-badge-mobile">0</span>
        </a>

        <!-- Language Switcher -->
        @await Html.PartialAsync("Partials/_LanguageToggle")

        @await Html.PartialAsync("Partials/_ThemeToggle")
    </div>
</nav>

<!-- Mobile Bottom Navigation Bar -->
<nav id="mobile-bottom-nav" class="mobile-bottom-nav lg:hidden dark:bg-black/90 dark:border-white/10">
