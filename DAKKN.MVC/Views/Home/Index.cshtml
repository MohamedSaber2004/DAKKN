                @Localizer["auth.register.login"]
            </a>
            <a asp-action="Register" asp-controller="Auth" class="bg-primary hover:bg-primary-container text-on-primary text-[14px] font-bold px-6 py-2.5 rounded-full transition-all shadow-lg shadow-primary/20 hover:-translate-y-0.5 active:scale-95">
                @Localizer["auth.login.register"]
            </a>
            <a asp-action="Cart" asp-controller="Shop"
