@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
<div id="signin-modal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/50 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="signin-modal-title">
    <div class="absolute inset-0" onclick="hideSignInModal()"></div>
    <div class="relative bg-white dark:bg-[#1E293B] rounded-2xl p-8 max-w-sm w-full mx-4 shadow-2xl border border-outline-variant/20 dark:border-white/10">
        <button onclick="hideSignInModal()" class="absolute top-4 end-4 w-8 h-8 rounded-full bg-surface-container-high dark:bg-slate-800 flex items-center justify-center hover:bg-primary/10 transition-colors" aria-label="Close">
            <span class="material-symbols-outlined text-lg">close</span>
        </button>
        <div class="text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-3xl text-primary">login</span>
            </div>
            <h3 id="signin-modal-title" class="text-2xl font-extrabold text-on-surface dark:text-white mb-2">@Localizer["signin_modal_title"]</h3>
            <p class="text-sm text-on-surface-variant dark:text-slate-400 mb-8 leading-relaxed">@Localizer["signin_modal_msg"]</p>
            <div class="flex flex-col gap-3">
                <a asp-action="Login" asp-controller="Auth" class="w-full bg-primary hover:bg-primary-container text-on-primary font-bold py-3.5 px-6 rounded-xl transition-all shadow-lg hover:-translate-y-0.5 active:scale-95 text-sm">
                    @Localizer["auth.login.submit"]
                </a>
                <a asp-action="Register" asp-controller="Auth" class="w-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 text-on-surface dark:text-slate-200 font-bold py-3.5 px-6 rounded-xl transition-all border border-outline-variant/20 dark:border-white/5 hover:-translate-y-0.5 active:scale-95 text-sm">
                    @Localizer["auth.login.register"]
                </a>
                <button onclick="hideSignInModal()" class="text-xs text-on-surface-variant dark:text-slate-400 hover:text-primary mt-2 transition-colors">@Localizer["signin_modal_continue"]</button>
            </div>
        </div>
    </div>
</div>