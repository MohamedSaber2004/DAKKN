@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Privacy Policy";
    ViewData["Description"] = "DAKKN's Privacy Policy – how we collect, use, and protect your personal data.";
}

<!-- Top Nav (reuse from landing) -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-surface-container/75 backdrop-blur-md border-b border-outline-variant/10 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="/" class="font-sans text-xl md:text-2xl font-extrabold tracking-tight text-primary logo-glow cursor-pointer" data-i18n="brand">@Localizer["brand"]</a>
        <div class="hidden lg:flex items-center gap-1">
            <a href="/#shop" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">local_fire_department</span><span data-i18n="nav_shop">@Localizer["nav_shop"]</span></a>
            <a href="/#categories" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">grid_view</span><span data-i18n="nav_categories">@Localizer["nav_categories"]</span></a>
            <a href="/#all-products" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">inventory_2</span><span data-i18n="nav_all_products">@Localizer["nav_all_products"]</span></a>
            <a href="/Home/Contact" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">support_agent</span><span data-i18n="f_contact">@Localizer["f_contact"]</span></a>
        </div>
    </div>
    <div class="flex items-center gap-1 md:gap-3">
        <button id="lang-toggle-btn" onclick="toggleLang()" class="lang-pill-premium text-[11px] md:text-[13px] px-3 md:px-4 py-1.5 md:py-2">
            @(System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar") ? "English" : "العربية")
        </button>
        @await Html.PartialAsync("Partials/_ThemeToggle")
    </div>
</nav>

<main class="flex-grow pt-20">

    <!-- ── Hero Header ──────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-cyan-50 border-b border-outline-variant/10">
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-primary/20 w-[400px] h-[400px] -top-24 -left-24"></div>
            <div class="deco-blob animate-blob-2 bg-secondary-container/20 w-[300px] h-[300px] bottom-0 right-0"></div>
            <div class="deco-ring w-[250px] h-[250px] top-8 right-24 opacity-50"></div>
            <div class="deco-dots-grid top-12 left-1/3 opacity-50"></div>
        </div>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-high border border-outline-variant/30 w-fit shadow-sm mx-auto mb-6">
                <span class="material-symbols-outlined text-primary text-lg">shield</span>
                <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider" data-i18n="pp_hero_badge">@Localizer["pp_hero_badge"]</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-on-surface mb-4 tracking-tight" data-i18n="pp_hero_h1">@Localizer["pp_hero_h1"]</h1>
            <p class="text-base text-on-surface-variant leading-relaxed max-w-xl mx-auto" data-i18n="pp_hero_p">
                @Localizer["pp_hero_p"]
            </p>
            <div class="mt-6 flex items-center justify-center gap-2 text-xs text-on-surface-variant/70 font-semibold">
                <span class="material-symbols-outlined text-sm text-primary/60">update</span>
                <span data-i18n="pp_last_updated">@Localizer["pp_last_updated"]</span>
            </div>
        </div>
    </section>

    <!-- ── Main Content ─────────────────────────────────────────── -->
    <section class="py-16 md:py-24 px-4 md:px-16 bg-white">
        <div class="max-w-4xl mx-auto flex flex-col lg:flex-row gap-12">

            <!-- Sticky Table of Contents (desktop) -->
            <aside class="hidden lg:block w-64 flex-shrink-0">
                <div class="sticky top-28 glass-panel rounded-2xl p-6 border border-primary/10">
                    <h2 class="text-xs font-extrabold text-primary uppercase tracking-wider mb-4" data-i18n="pp_toc_title">@Localizer["pp_toc_title"]</h2>
                    <nav class="flex flex-col gap-1">
                        <a href="#pp-collection" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec1_title">@Localizer["pp_sec1_title"]</a>
                        <a href="#pp-usage" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec2_title">@Localizer["pp_sec2_title"]</a>
                        <a href="#pp-sharing" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec3_title">@Localizer["pp_sec3_title"]</a>
                        <a href="#pp-cookies" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec4_title">@Localizer["pp_sec4_title"]</a>
                        <a href="#pp-security" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec5_title">@Localizer["pp_sec5_title"]</a>
                        <a href="#pp-retention" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec6_title">@Localizer["pp_sec6_title"]</a>
                        <a href="#pp-rights" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec7_title">@Localizer["pp_sec7_title"]</a>
                        <a href="#pp-children" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec8_title">@Localizer["pp_sec8_title"]</a>
                        <a href="#pp-changes" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec9_title">@Localizer["pp_sec9_title"]</a>
                        <a href="#pp-contact" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec10_title">@Localizer["pp_sec10_title"]</a>
                    </nav>
                </div>
            </aside>

            <!-- Policy Sections -->
            <div class="flex-1 flex flex-col gap-12">

                <!-- 1. Data We Collect -->
                <div id="pp-collection" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">database</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec1_title">@Localizer["pp_sec1_title"]</h2>
                    </div>
                    <div class="prose-content text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec1_p">@Localizer["pp_sec1_p"]</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_id_title">@Localizer["pp_sec1_id_title"]</p>
                                <p data-i18n="pp_sec1_id_p">@Localizer["pp_sec1_id_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_contact_title">@Localizer["pp_sec1_contact_title"]</p>
                                <p data-i18n="pp_sec1_contact_p">@Localizer["pp_sec1_contact_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_trans_title">@Localizer["pp_sec1_trans_title"]</p>
                                <p data-i18n="pp_sec1_trans_p">@Localizer["pp_sec1_trans_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_tech_title">@Localizer["pp_sec1_tech_title"]</p>
                                <p data-i18n="pp_sec1_tech_p">@Localizer["pp_sec1_tech_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_usage_title">@Localizer["pp_sec1_usage_title"]</p>
                                <p data-i18n="pp_sec1_usage_p">@Localizer["pp_sec1_usage_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_comm_title">@Localizer["pp_sec1_comm_title"]</p>
                                <p data-i18n="pp_sec1_comm_p">@Localizer["pp_sec1_comm_p"]</p>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 2. How We Use Data -->
                <div id="pp-usage" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">manage_accounts</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec2_title">@Localizer["pp_sec2_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec2_p">@Localizer["pp_sec2_p"]</p>
                        <ul class="flex flex-col gap-2 mt-1">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li1">@Localizer["pp_sec2_li1"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li2">@Localizer["pp_sec2_li2"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li3">@Localizer["pp_sec2_li3"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li4">@Localizer["pp_sec2_li4"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li5">@Localizer["pp_sec2_li5"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li6">@Localizer["pp_sec2_li6"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li7">@Localizer["pp_sec2_li7"]</span></li>
                        </ul>
                        <div class="bg-primary/5 border border-primary/15 rounded-xl p-4 mt-2">
                            <p class="font-bold text-primary text-xs mb-1" data-i18n="pp_sec2_basis_title">@Localizer["pp_sec2_basis_title"]</p>
                            <p data-i18n="pp_sec2_basis_p">@Localizer["pp_sec2_basis_p"]</p>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 3. Data Sharing -->
                <div id="pp-sharing" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">share</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec3_title">@Localizer["pp_sec3_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec3_p">@Localizer["pp_sec3_p"]</p>
                        <div class="flex flex-col gap-3 mt-1">
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">local_shipping</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li1_title">@Localizer["pp_sec3_li1_title"]</p><p data-i18n="pp_sec3_li1_p">@Localizer["pp_sec3_li1_p"]</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">payment</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li2_title">@Localizer["pp_sec3_li2_title"]</p><p data-i18n="pp_sec3_li2_p">@Localizer["pp_sec3_li2_p"]</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">analytics</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li3_title">@Localizer["pp_sec3_li3_title"]</p><p data-i18n="pp_sec3_li3_p">@Localizer["pp_sec3_li3_p"]</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">gavel</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li4_title">@Localizer["pp_sec3_li4_title"]</p><p data-i18n="pp_sec3_li4_p">@Localizer["pp_sec3_li4_p"]</p></div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 4. Cookies -->
                <div id="pp-cookies" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">cookie</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec4_title">@Localizer["pp_sec4_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec4_p">@Localizer["pp_sec4_p"]</p>
                        <div class="overflow-x-auto mt-2">
                            <table class="w-full text-xs border-collapse">
                                <thead>
                                    <tr class="bg-primary/8 text-left">
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20 rounded-tl-lg" data-i18n="pp_sec4_th1">@Localizer["pp_sec4_th1"]</th>
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20" data-i18n="pp_sec4_th2">@Localizer["pp_sec4_th2"]</th>
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20 rounded-tr-lg" data-i18n="pp_sec4_th3">@Localizer["pp_sec4_th3"]</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="bg-white hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td1_type">@Localizer["pp_sec4_td1_type"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td1_p">@Localizer["pp_sec4_td1_p"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td1_d">@Localizer["pp_sec4_td1_d"]</td>
                                    </tr>
                                    <tr class="bg-surface-container-lowest hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td2_type">@Localizer["pp_sec4_td2_type"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td2_p">@Localizer["pp_sec4_td2_p"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td2_d">@Localizer["pp_sec4_td2_d"]</td>
                                    </tr>
                                    <tr class="bg-white hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td3_type">@Localizer["pp_sec4_td3_type"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td3_p">@Localizer["pp_sec4_td3_p"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td3_d">@Localizer["pp_sec4_td3_d"]</td>
                                    </tr>
                                    <tr class="bg-surface-container-lowest hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td4_type">@Localizer["pp_sec4_td4_type"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td4_p">@Localizer["pp_sec4_td4_p"]</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td4_d">@Localizer["pp_sec4_td4_d"]</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="mt-2" data-i18n="pp_sec4_footer">@Localizer["pp_sec4_footer"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 5. Data Security -->
                <div id="pp-security" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">lock</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec5_title">@Localizer["pp_sec5_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec5_p">@Localizer["pp_sec5_p"]</p>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-2">
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">https</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item1_title">@Localizer["pp_sec5_item1_title"]</p>
                                <p class="text-xs" data-i18n="pp_sec5_item1_p">@Localizer["pp_sec5_item1_p"]</p>
                            </div>
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">verified_user</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item2_title">@Localizer["pp_sec5_item2_title"]</p>
                                <p class="text-xs" data-i18n="pp_sec5_item2_p">@Localizer["pp_sec5_item2_p"]</p>
                            </div>
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">security</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item3_title">@Localizer["pp_sec5_item3_title"]</p>
                                <p class="text-xs" data-i18n="pp_sec5_item3_p">@Localizer["pp_sec5_item3_p"]</p>
                            </div>
                        </div>
                        <p class="mt-1" data-i18n="pp_sec5_footer">@Localizer["pp_sec5_footer"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 6. Retention -->
                <div id="pp-retention" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">hourglass_top</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec6_title">@Localizer["pp_sec6_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec6_p">@Localizer["pp_sec6_p"]</p>
                        <p data-i18n="pp_sec6_sub">@Localizer["pp_sec6_sub"]</p>
