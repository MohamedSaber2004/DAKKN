@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Privacy Policy";
    ViewData["Description"] = "DAKKN's Privacy Policy – how we collect, use, and protect your personal data.";
}

<!-- Top Nav (reuse from landing) -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-surface-container/75 backdrop-blur-md border-b border-outline-variant/10 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="/" class="font-sans text-xl md:text-2xl font-extrabold tracking-tight text-primary logo-glow cursor-pointer" data-i18n="brand">DAKKN</a>
        <div class="hidden lg:flex items-center gap-1">
            <a href="/#shop" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">local_fire_department</span><span data-i18n="nav_shop">Shop</span></a>
            <a href="/#categories" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">grid_view</span><span data-i18n="nav_categories">Categories</span></a>
            <a href="/#all-products" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">inventory_2</span><span data-i18n="nav_all_products">Products</span></a>
            <a href="/Home/Contact" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">support_agent</span><span data-i18n="f_contact">Contact</span></a>
        </div>
    </div>
    <div class="flex items-center gap-1 md:gap-3">
        <button id="lang-toggle-btn" onclick="toggleLang()" class="lang-pill-premium text-[11px] md:text-[13px] px-3 md:px-4 py-1.5 md:py-2" data-i18n="lang_toggle">العربية</button>
    </div>
</nav>

<main class="flex-grow pt-20">

    <!-- ── Hero Header ──────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-cyan-50 border-b border-outline-variant/10">
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-primary/20 w-[400px] h-[400px] -top-24 -left-24"></div>
            <div class="deco-blob animate-blob-2 bg-secondary-container/20 w-[300px] h-[300px] bottom-0 right-0"></div>
            <div class="deco-ring w-[250px] h-[250px] top-8 right-24 opacity-50"></div>
            <div class="deco-dots-grid top-12 left-1/3 opacity-50"></div>
        </div>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-high border border-outline-variant/30 w-fit shadow-sm mx-auto mb-6">
                <span class="material-symbols-outlined text-primary text-lg">shield</span>
                <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider" data-i18n="pp_hero_badge">Legal</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-on-surface mb-4 tracking-tight" data-i18n="pp_hero_h1">Privacy Policy</h1>
            <p class="text-base text-on-surface-variant leading-relaxed max-w-xl mx-auto" data-i18n="pp_hero_p">
                We are committed to protecting your personal information. This policy explains how DAKKN collects, uses, and safeguards your data.
            </p>
            <div class="mt-6 flex items-center justify-center gap-2 text-xs text-on-surface-variant/70 font-semibold">
                <span class="material-symbols-outlined text-sm text-primary/60">update</span>
                <span data-i18n="pp_last_updated">Last updated: January 1, 2025</span>
            </div>
        </div>
    </section>

    <!-- ── Main Content ─────────────────────────────────────────── -->
    <section class="py-16 md:py-24 px-4 md:px-16 bg-white">
        <div class="max-w-4xl mx-auto flex flex-col lg:flex-row gap-12">

            <!-- Sticky Table of Contents (desktop) -->
            <aside class="hidden lg:block w-64 flex-shrink-0">
                <div class="sticky top-28 glass-panel rounded-2xl p-6 border border-primary/10">
                    <h2 class="text-xs font-extrabold text-primary uppercase tracking-wider mb-4" data-i18n="pp_toc_title">On This Page</h2>
                    <nav class="flex flex-col gap-1">
                        <a href="#pp-collection" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec1_title">1. Data We Collect</a>
                        <a href="#pp-usage" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec2_title">2. How We Use Data</a>
                        <a href="#pp-sharing" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec3_title">3. Data Sharing</a>
                        <a href="#pp-cookies" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec4_title">4. Cookies</a>
                        <a href="#pp-security" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec5_title">5. Data Security</a>
                        <a href="#pp-retention" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec6_title">6. Retention</a>
                        <a href="#pp-rights" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec7_title">7. Your Rights</a>
                        <a href="#pp-children" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec8_title">8. Children</a>
                        <a href="#pp-changes" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec9_title">9. Policy Changes</a>
                        <a href="#pp-contact" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="pp_sec10_title">10. Contact Us</a>
                    </nav>
                </div>
            </aside>

            <!-- Policy Sections -->
            <div class="flex-1 flex flex-col gap-12">

                <!-- 1. Data We Collect -->
                <div id="pp-collection" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">database</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec1_title">1. Data We Collect</h2>
                    </div>
                    <div class="prose-content text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec1_p">When you interact with DAKKN — whether browsing our website, placing an order, or contacting support — we may collect the following categories of information:</p>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_id_title">Identity Data</p>
                                <p data-i18n="pp_sec1_id_p">Full name, username, or similar identifiers you provide when registering or placing an order.</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_contact_title">Contact Data</p>
                                <p data-i18n="pp_sec1_contact_p">Email address, phone number, billing address, and delivery address.</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_trans_title">Transaction Data</p>
                                <p data-i18n="pp_sec1_trans_p">Details of products purchased, payment references, and order history. We do not store full card numbers.</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_tech_title">Technical Data</p>
                                <p data-i18n="pp_sec1_tech_p">IP address, browser type and version, time zone, operating system, and device identifiers.</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_usage_title">Usage Data</p>
                                <p data-i18n="pp_sec1_usage_p">Information about how you navigate our website, including pages visited, links clicked, and referral sources.</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10">
                                <p class="font-bold text-on-surface text-xs uppercase tracking-wider text-primary mb-2" data-i18n="pp_sec1_comm_title">Communications Data</p>
                                <p data-i18n="pp_sec1_comm_p">Messages, feedback, and support tickets you send to us.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 2. How We Use Data -->
                <div id="pp-usage" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">manage_accounts</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec2_title">2. How We Use Your Data</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec2_p">We use the data we collect to operate and improve our business. Specifically, we process your data to:</p>
                        <ul class="flex flex-col gap-2 mt-1">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li1">Process and fulfil your orders, and communicate order status.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li2">Provide customer support and respond to your enquiries.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li3">Send transactional emails such as order confirmations, shipping notifications, and invoices.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li4">Prevent fraud and ensure the security of our platform.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li5">Personalise your browsing experience and display relevant product recommendations.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li6">Send marketing communications where you have opted in (you may unsubscribe at any time).</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="pp_sec2_li7">Comply with legal obligations under Egyptian law and any applicable international regulations.</span></li>
                        </ul>
                        <div class="bg-primary/5 border border-primary/15 rounded-xl p-4 mt-2">
                            <p class="font-bold text-primary text-xs mb-1" data-i18n="pp_sec2_basis_title">Legal Basis for Processing</p>
                            <p data-i18n="pp_sec2_basis_p">We rely on contract performance (to fulfil your orders), legitimate interests (to improve our services and prevent fraud), consent (for marketing), and legal obligation as the lawful bases for processing your personal data.</p>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 3. Data Sharing -->
                <div id="pp-sharing" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">share</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec3_title">3. Data Sharing & Third Parties</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec3_p">We do not sell your personal data. We may share your information only in the following limited circumstances:</p>
                        <div class="flex flex-col gap-3 mt-1">
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">local_shipping</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li1_title">Shipping Providers</p><p data-i18n="pp_sec3_li1_p">We share your name and delivery address with our logistics partners (e.g., courier companies) solely to fulfil your order.</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">payment</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li2_title">Payment Processors</p><p data-i18n="pp_sec3_li2_p">Payment information is handled by PCI-DSS compliant payment gateways. We never see or store your full card details.</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">analytics</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li3_title">Analytics Providers</p><p data-i18n="pp_sec3_li3_p">Aggregated, anonymised usage data may be shared with analytics tools to help us understand how customers use our website.</p></div>
                            </div>
                            <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/20 bg-surface-container-low/50">
                                <span class="material-symbols-outlined text-primary text-xl flex-shrink-0 mt-0.5">gavel</span>
                                <div><p class="font-bold text-on-surface text-sm mb-1" data-i18n="pp_sec3_li4_title">Legal Requirements</p><p data-i18n="pp_sec3_li4_p">We may disclose your data when required by law, court order, or to protect the rights and safety of DAKKN and its users.</p></div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 4. Cookies -->
                <div id="pp-cookies" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">cookie</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec4_title">4. Cookies & Tracking Technologies</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec4_p">We use cookies and similar tracking technologies to enhance your experience on our website. The types of cookies we use include:</p>
                        <div class="overflow-x-auto mt-2">
                            <table class="w-full text-xs border-collapse">
                                <thead>
                                    <tr class="bg-primary/8 text-left">
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20 rounded-tl-lg" data-i18n="pp_sec4_th1">Type</th>
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20" data-i18n="pp_sec4_th2">Purpose</th>
                                        <th class="p-3 font-bold text-on-surface border border-outline-variant/20 rounded-tr-lg" data-i18n="pp_sec4_th3">Duration</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="bg-white hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td1_type">Essential</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td1_p">Required for the website to function, including shopping cart and login sessions.</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td1_d">Session</td>
                                    </tr>
                                    <tr class="bg-surface-container-lowest hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td2_type">Preferences</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td2_p">Remembers your language preference (Arabic/English) and display settings.</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td2_d">1 year</td>
                                    </tr>
                                    <tr class="bg-white hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td3_type">Analytics</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td3_p">Helps us understand how visitors use our site so we can improve it.</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td3_d">2 years</td>
                                    </tr>
                                    <tr class="bg-surface-container-lowest hover:bg-primary/3 transition-colors">
                                        <td class="p-3 border border-outline-variant/20 font-semibold text-primary" data-i18n="pp_sec4_td4_type">Marketing</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td4_p">Used to display relevant ads and track campaign effectiveness (opt-in only).</td>
                                        <td class="p-3 border border-outline-variant/20" data-i18n="pp_sec4_td4_d">90 days</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="mt-2" data-i18n="pp_sec4_footer">You can manage or disable cookies through your browser settings. Note that disabling essential cookies may affect website functionality.</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 5. Data Security -->
                <div id="pp-security" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">lock</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec5_title">5. Data Security</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec5_p">We implement appropriate technical and organisational measures to protect your personal data against unauthorised access, accidental loss, destruction, or damage. Our security practices include:</p>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mt-2">
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">https</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item1_title">TLS/SSL Encryption</p>
                                <p class="text-xs" data-i18n="pp_sec5_item1_p">All data transmitted between your browser and our servers is encrypted.</p>
                            </div>
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">verified_user</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item2_title">Access Control</p>
                                <p class="text-xs" data-i18n="pp_sec5_item2_p">Only authorised personnel have access to personal data, on a need-to-know basis.</p>
                            </div>
                            <div class="text-center p-4 rounded-xl bg-primary/5 border border-primary/15">
                                <span class="material-symbols-outlined text-primary text-3xl mb-2 block">security</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="pp_sec5_item3_title">Regular Audits</p>
                                <p class="text-xs" data-i18n="pp_sec5_item3_p">We conduct regular security reviews and vulnerability assessments.</p>
                            </div>
                        </div>
                        <p class="mt-1" data-i18n="pp_sec5_footer">While we strive to use commercially acceptable means to protect your data, no method of transmission over the internet is 100% secure. If you suspect a security breach, please contact us immediately.</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 6. Retention -->
                <div id="pp-retention" class="policy-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">hourglass_top</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="pp_sec6_title">6. Data Retention</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="pp_sec6_p">We retain your personal data only for as long as necessary to fulfil the purposes for which it was collected, including to satisfy legal, accounting, or reporting requirements.</p>
                        <p data-i18n="pp_sec6_sub">Specifically:</p>
                        <ul class="flex flex-col gap-2">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">schedule</span><strong data-i18n="pp_sec6_li1_title">Order data</strong> <span data-i18n="pp_sec6_li1_p">is kept for 5 years to comply with Egyptian tax and commercial record-keeping regulations.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">schedule</span><strong data-i18n="pp_sec6_li2_title">Account data</strong> <span data-i18n="pp_sec6_li2_p">is retained for the duration of your account, plus 12 months after closure.</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">schedule</span><strong data-i18n="pp_sec6_li3_title">Marketing preferences</strong> <span data-i18n="pp_sec6_li3_p">are kept until you unsubscribe or request erasure.</span></li>
