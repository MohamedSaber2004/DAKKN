@section Scripts {
    <script>
        const sections = document.querySelectorAll('.tc-section');
        const tocLinks = document.querySelectorAll('.toc-link');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    tocLinks.forEach(link => {
                        link.classList.toggle('text-primary', link.getAttribute('href') === '#' + entry.target.id);
                        link.classList.toggle('bg-primary/8', link.getAttribute('href') === '#' + entry.target.id);
                        link.classList.toggle('font-bold', link.getAttribute('href') === '#' + entry.target.id);
                    });
                }
            });
        }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

        sections.forEach(s => observer.observe(s));
    </script>
}
