@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["terms_title"];
    ViewData["Description"] = Localizer["terms_description"];
}

<!-- Top Nav -->
<nav class="fixed top-0 w-full z-50 flex justify-between items-center px-4 md:px-16 h-16 md:h-20 bg-surface/75 dark:bg-surface-container/75 backdrop-blur-md border-b border-outline-variant/10 shadow-sm navbar-animate">
    <div class="flex items-center gap-4 md:gap-6">
        <a href="/" class="font-sans text-xl md:text-2xl font-extrabold tracking-tight text-primary logo-glow cursor-pointer" data-i18n="brand">@Localizer["brand"]</a>
        <div class="hidden lg:flex items-center gap-1">
            <a href="/#shop" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">local_fire_department</span><span data-i18n="nav_shop">@Localizer["nav_shop"]</span></a>
            <a href="/#categories" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">grid_view</span><span data-i18n="nav_categories">@Localizer["nav_categories"]</span></a>
            <a href="/#all-products" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">inventory_2</span><span data-i18n="nav_all_products">@Localizer["nav_all_products"]</span></a>
            <a href="/Home/Contact" class="nav-link-premium nav-icon-link"><span class="material-symbols-outlined text-[17px]">support_agent</span><span data-i18n="f_contact">@Localizer["f_contact"]</span></a>
        </div>
    </div>
    <div class="flex items-center gap-1 md:gap-3">
        @await Html.PartialAsync("Partials/_LanguageToggle")
        @await Html.PartialAsync("Partials/_ThemeToggle")
    </div>
</nav>

<main class="flex-grow pt-20">

    <!-- ── Hero Header ──────────────────────────────────────────── -->
    <section class="relative overflow-hidden py-16 md:py-24 px-4 md:px-16 bg-cyan-50 border-b border-outline-variant/10">
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-2 bg-tertiary-container/30 w-[380px] h-[380px] -top-16 -right-16"></div>
            <div class="deco-blob animate-blob-1 bg-primary/15 w-[280px] h-[280px] bottom-0 left-0"></div>
            <div class="deco-ring w-[220px] h-[220px] bottom-8 right-1/3 opacity-50"></div>
            <div class="deco-shape-diamond top-1/3 left-16 opacity-70"></div>
            <div class="deco-dots-grid bottom-8 left-8 opacity-40"></div>
        </div>
        <div class="relative z-10 max-w-3xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-container-high border border-outline-variant/30 w-fit shadow-sm mx-auto mb-6">
                <span class="material-symbols-outlined text-tertiary text-lg">description</span>
                <span class="text-xs font-bold text-on-surface-variant uppercase tracking-wider" data-i18n="terms_hero_badge">@Localizer["terms_hero_badge"]</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-on-surface mb-4 tracking-tight" data-i18n="terms_hero_h1">@Localizer["terms_hero_h1"]</h1>
            <p class="text-base text-on-surface-variant leading-relaxed max-w-xl mx-auto" data-i18n="terms_hero_p">
                @Localizer["terms_hero_p"]
            </p>
            <div class="mt-6 flex items-center justify-center gap-2 text-xs text-on-surface-variant/70 font-semibold">
                <span class="material-symbols-outlined text-sm text-primary/60">update</span>
                <span data-i18n="terms_last_updated">@Localizer["terms_last_updated"]</span>
            </div>
        </div>
    </section>

    <!-- ── Main Content ─────────────────────────────────────────── -->
    <section class="py-16 md:py-24 px-4 md:px-16 bg-white">
        <div class="max-w-4xl mx-auto flex flex-col lg:flex-row gap-12">

            <!-- Sticky Table of Contents (desktop) -->
            <aside class="hidden lg:block w-64 flex-shrink-0">
                <div class="sticky top-28 glass-panel rounded-2xl p-6 border border-primary/10">
                    <h2 class="text-xs font-extrabold text-primary uppercase tracking-wider mb-4" data-i18n="terms_toc_title">@Localizer["terms_toc_title"]</h2>
                    <nav class="flex flex-col gap-1">
                        <a href="#tc-acceptance" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec1_title">@Localizer["terms_sec1_title"]</a>
                        <a href="#tc-products" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec2_title">@Localizer["terms_sec2_title"]</a>
                        <a href="#tc-pricing" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec3_title">@Localizer["terms_sec3_title"]</a>
                        <a href="#tc-orders" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec4_title">@Localizer["terms_sec4_title"]</a>
                        <a href="#tc-shipping" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec5_title">@Localizer["terms_sec5_title"]</a>
                        <a href="#tc-returns" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec6_title">@Localizer["terms_sec6_title"]</a>
                        <a href="#tc-custom" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec7_title">@Localizer["terms_sec7_title"]</a>
                        <a href="#tc-ip" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec8_title">@Localizer["terms_sec8_title"]</a>
                        <a href="#tc-liability" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec9_title">@Localizer["terms_sec9_title"]</a>
                        <a href="#tc-conduct" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec10_title">@Localizer["terms_sec10_title"]</a>
                        <a href="#tc-governing" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec11_title">@Localizer["terms_sec11_title"]</a>
                        <a href="#tc-changes" class="toc-link text-sm font-medium text-on-surface-variant hover:text-primary py-1.5 px-3 rounded-lg hover:bg-primary/5 transition-all" data-i18n="terms_sec12_title">@Localizer["terms_sec12_title"]</a>
                    </nav>
                </div>
            </aside>

            <!-- Terms Sections -->
            <div class="flex-1 flex flex-col gap-12">

                <!-- Notice Banner -->
                <div class="bg-tertiary-container/30 border border-tertiary/20 rounded-2xl p-5 flex items-start gap-4">
                    <span class="material-symbols-outlined text-tertiary text-2xl flex-shrink-0 mt-0.5">info</span>
                    <div class="text-sm text-on-surface-variant leading-relaxed">
                        <p class="font-bold text-on-surface mb-1" data-i18n="terms_notice_title">@Localizer["terms_notice_title"]</p>
                        <p data-i18n="terms_notice_p">@Localizer["terms_notice_p"]</p>
                    </div>
                </div>

                <!-- 1. Acceptance -->
                <div id="tc-acceptance" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">handshake</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec1_title">@Localizer["terms_sec1_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec1_p1">@Localizer["terms_sec1_p1"]</p>
                        <p data-i18n="terms_sec1_p2">@Localizer["terms_sec1_p2"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 2. Products & Services -->
                <div id="tc-products" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">inventory_2</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec2_title">@Localizer["terms_sec2_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec2_p">@Localizer["terms_sec2_p"]</p>
                        <div class="bg-surface-container-low/70 rounded-xl p-4 border border-outline-variant/20 mt-1">
                            <p class="font-bold text-on-surface text-xs mb-2 uppercase tracking-wide" data-i18n="terms_sec2_sub_title">@Localizer["terms_sec2_sub_title"]</p>
                            <p data-i18n="terms_sec2_sub_p">@Localizer["terms_sec2_sub_p"]</p>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 3. Pricing & Payment -->
                <div id="tc-pricing" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">payments</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec3_title">@Localizer["terms_sec3_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <ul class="flex flex-col gap-2.5">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec3_li1">@Localizer["terms_sec3_li1"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec3_li2">@Localizer["terms_sec3_li2"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec3_li3">@Localizer["terms_sec3_li3"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec3_li4">@Localizer["terms_sec3_li4"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec3_li5">@Localizer["terms_sec3_li5"]</span></li>
                        </ul>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 4. Orders -->
                <div id="tc-orders" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">receipt_long</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec4_title">@Localizer["terms_sec4_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec4_p">@Localizer["terms_sec4_p"]</p>
                        <ul class="flex flex-col gap-2 mt-1">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-on-surface-variant/60 text-sm mt-0.5 flex-shrink-0">radio_button_unchecked</span><span data-i18n="terms_sec4_li1">@Localizer["terms_sec4_li1"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-on-surface-variant/60 text-sm mt-0.5 flex-shrink-0">radio_button_unchecked</span><span data-i18n="terms_sec4_li2">@Localizer["terms_sec4_li2"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-on-surface-variant/60 text-sm mt-0.5 flex-shrink-0">radio_button_unchecked</span><span data-i18n="terms_sec4_li3">@Localizer["terms_sec4_li3"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-on-surface-variant/60 text-sm mt-0.5 flex-shrink-0">radio_button_unchecked</span><span data-i18n="terms_sec4_li4">@Localizer["terms_sec4_li4"]</span></li>
                        </ul>
                        <p data-i18n="terms_sec4_footer">@Localizer["terms_sec4_footer"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 5. Shipping & Delivery -->
                <div id="tc-shipping" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">local_shipping</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec5_title">@Localizer["terms_sec5_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                            <div class="glass-panel rounded-xl p-4 border border-primary/10 text-center">
                                <span class="material-symbols-outlined text-primary text-2xl mb-2 block">business</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="terms_sec5_item1_title">@Localizer["terms_sec5_item1_title"]</p>
                                <p data-i18n="terms_sec5_item1_p">@Localizer["terms_sec5_item1_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10 text-center">
                                <span class="material-symbols-outlined text-primary text-2xl mb-2 block">schedule</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="terms_sec5_item2_title">@Localizer["terms_sec5_item2_title"]</p>
                                <p data-i18n="terms_sec5_item2_p">@Localizer["terms_sec5_item2_p"]</p>
                            </div>
                            <div class="glass-panel rounded-xl p-4 border border-primary/10 text-center">
                                <span class="material-symbols-outlined text-primary text-2xl mb-2 block">public</span>
                                <p class="font-bold text-on-surface text-xs mb-1" data-i18n="terms_sec5_item3_title">@Localizer["terms_sec5_item3_title"]</p>
                                <p data-i18n="terms_sec5_item3_p">@Localizer["terms_sec5_item3_p"]</p>
                            </div>
                        </div>
                        <p class="mt-1" data-i18n="terms_sec5_footer">@Localizer["terms_sec5_footer"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 6. Returns & Refunds -->
                <div id="tc-returns" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">assignment_return</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec6_title">@Localizer["terms_sec6_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <div class="bg-primary/5 border border-primary/15 rounded-xl p-4">
                            <p class="font-bold text-primary text-xs uppercase tracking-wide mb-2" data-i18n="terms_sec6_promise_title">@Localizer["terms_sec6_promise_title"]</p>
                            <p data-i18n="terms_sec6_promise_p">@Localizer["terms_sec6_promise_p"]</p>
                        </div>
                        <p><strong class="text-on-surface" data-i18n="terms_sec6_window">@Localizer["terms_sec6_window"]</strong> <span data-i18n="terms_sec6_window_p">@Localizer["terms_sec6_window_p"]</span></p>
                        <p><strong class="text-on-surface" data-i18n="terms_sec6_cond_title">@Localizer["terms_sec6_cond_title"]</strong></p>
                        <ul class="flex flex-col gap-2">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec6_cond_li1">@Localizer["terms_sec6_cond_li1"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec6_cond_li2">@Localizer["terms_sec6_cond_li2"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-error text-sm mt-0.5 flex-shrink-0">cancel</span><span data-i18n="terms_sec6_cond_li3">@Localizer["terms_sec6_cond_li3"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-error text-sm mt-0.5 flex-shrink-0">cancel</span><span data-i18n="terms_sec6_cond_li4">@Localizer["terms_sec6_cond_li4"]</span></li>
                        </ul>
                        <p><strong class="text-on-surface" data-i18n="terms_sec6_refund_title">@Localizer["terms_sec6_refund_title"]</strong> <span data-i18n="terms_sec6_refund_p">@Localizer["terms_sec6_refund_p"]</span></p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 7. Custom Orders -->
                <div id="tc-custom" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">palette</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec7_title">@Localizer["terms_sec7_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec7_p">@Localizer["terms_sec7_p"]</p>
                        <ul class="flex flex-col gap-2">
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec7_li1">@Localizer["terms_sec7_li1"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec7_li2">@Localizer["terms_sec7_li2"]</span></li>
                            <li class="flex items-start gap-2"><span class="material-symbols-outlined text-primary text-sm mt-0.5 flex-shrink-0">check_circle</span><span data-i18n="terms_sec7_li3">@Localizer["terms_sec7_li3"]</span></li>
                        </ul>
                        <p data-i18n="terms_sec7_footer">@Localizer["terms_sec7_footer"]</p>
                        <div class="bg-surface-container-low/70 rounded-xl p-4 border border-outline-variant/20 mt-1">
                            <p class="font-bold text-on-surface text-xs mb-2" data-i18n="terms_sec7_sub_title">@Localizer["terms_sec7_sub_title"]</p>
                            <p data-i18n="terms_sec7_sub_p">@Localizer["terms_sec7_sub_p"]</p>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 8. Intellectual Property -->
                <div id="tc-ip" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-tertiary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-tertiary text-lg">copyright</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec8_title">@Localizer["terms_sec8_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec8_p1">@Localizer["terms_sec8_p1"]</p>
                        <p data-i18n="terms_sec8_p2">@Localizer["terms_sec8_p2"]</p>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 9. Liability -->
                <div id="tc-liability" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-secondary-container/40 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-secondary text-lg">balance</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec9_title">@Localizer["terms_sec9_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec9_p1">@Localizer["terms_sec9_p1"]</p>
                        <p data-i18n="terms_sec9_p2">@Localizer["terms_sec9_p2"]</p>
                        <div class="bg-error-container/30 border border-error/20 rounded-xl p-4 mt-1 flex gap-3">
                            <span class="material-symbols-outlined text-error flex-shrink-0">warning</span>
                            <p data-i18n="terms_sec9_notice_p">@Localizer["terms_sec9_notice_p"]</p>
                        </div>
                    </div>
                </div>

                <hr class="border-outline-variant/20" />

                <!-- 10. User Conduct -->
                <div id="tc-conduct" class="tc-section scroll-animate">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-9 h-9 rounded-xl bg-primary/15 flex items-center justify-center flex-shrink-0">
                            <span class="material-symbols-outlined text-primary text-lg">policy</span>
                        </div>
                        <h2 class="text-xl font-extrabold text-on-surface" data-i18n="terms_sec10_title">@Localizer["terms_sec10_title"]</h2>
                    </div>
                    <div class="text-sm text-on-surface-variant leading-relaxed flex flex-col gap-3">
                        <p data-i18n="terms_sec10_p">@Localizer["terms_sec10_p"]</p>
                        <ul class="flex flex-col gap-2">
