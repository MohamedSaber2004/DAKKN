@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Landing.LandingPageViewModel
@{
    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
    var hasReviews = Model.Testimonials?.Reviews?.Count > 0;
    var title = !string.IsNullOrEmpty(Model.Testimonials?.Title) ? Model.Testimonials.Title : Localizer["test_h2"];
    var desc = !string.IsNullOrEmpty(Model.Testimonials?.Description) ? Model.Testimonials.Description : Localizer["test_p"];
}
<section id="testimonials" class="relative py-16 md:py-24 px-4 overflow-hidden bg-surface dark:bg-[#0F172A]">
    <div class="deco-blob w-[400px] h-[400px] -top-40 -end-40 bg-primary/5 animate-blob-2"></div>
    <div class="max-w-5xl mx-auto relative z-10">
        <div class="text-center mb-12 scroll-animate">
            <span class="inline-block text-xs font-bold text-primary bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20 mb-4">@Localizer["test_section_badge"]</span>
            <h2 class="text-3xl md:text-4xl font-black text-on-surface dark:text-white">@title</h2>
            <p class="text-on-surface-variant dark:text-slate-400 mt-2">@desc</p>
        </div>
        @if (hasReviews)
        {
            <div class="relative scroll-animate" role="region" aria-label="Customer testimonials" tabindex="0" id="testimonials-region" onkeydown="handleTestimonialKeydown(event)">
                <div id="testimonials-track" class="overflow-hidden">
                    <div id="testimonials-slider" class="flex transition-transform duration-500 ease-out will-change-transform">
                        @for (int i = 0; i < Model.Testimonials.Reviews.Count; i++)
                        {
                            var r = Model.Testimonials.Reviews[i];
                            <div class="min-w-full md:min-w-[50%] lg:min-w-[33.333%] px-3" role="group" aria-roledescription="slide" aria-label="Testimonial @(i+1) of @Model.Testimonials.Reviews.Count">
                                <div class="bg-surface-container-high dark:bg-[#1E293B] rounded-2xl p-6 md:p-8 h-full border border-outline-variant/20 dark:border-white/5 shadow-lg hover:shadow-xl transition-shadow">
                                    <div class="flex items-center gap-1 mb-4">
                                        @for (int s = 0; s < 5; s++)
                                        {
                                            <span class="material-symbols-outlined text-sm @(s < r.Rating ? "text-amber-400" : "text-slate-300 dark:text-slate-600")">@(s < r.Rating ? "star" : "star")</span>
                                        }
                                    </div>
                                    <p class="text-sm md:text-base text-on-surface dark:text-slate-200 leading-relaxed mb-6 italic">"@r.Quote"</p>
                                    <div class="flex items-center gap-3">
                                        @if (!string.IsNullOrEmpty(r.ProfilePictureUrl))
                                        {
                                            <img src="@r.ProfilePictureUrl" alt="@r.Name" class="w-10 h-10 rounded-full object-cover" loading="lazy" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary/30 to-primary/10 flex items-center justify-center text-primary font-bold text-sm">
                                                @r.Name[0]
                                            </div>
                                        }
                                        <div>
                                            <span class="block text-sm font-bold text-on-surface dark:text-white">@r.Name</span>
                                            @if (!string.IsNullOrEmpty(r.Role))
                                            {
                                                <span class="text-xs text-on-surface-variant dark:text-slate-400">@r.Role</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                @if (Model.Testimonials.Reviews.Count > 1)
                {
                    <div class="flex justify-center gap-3 mt-8">
                        <button onclick="prevTestimonial()" class="w-10 h-10 rounded-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 flex items-center justify-center transition-all border border-outline-variant/20 dark:border-white/10" aria-label="Previous testimonial">
                            <span class="material-symbols-outlined text-lg">@(isAr ? "chevron_right" : "chevron_left")</span>
                        </button>
                        <button onclick="nextTestimonial()" class="w-10 h-10 rounded-full bg-surface-container-high dark:bg-slate-800 hover:bg-primary/10 flex items-center justify-center transition-all border border-outline-variant/20 dark:border-white/10" aria-label="Next testimonial">
                            <span class="material-symbols-outlined text-lg">@(isAr ? "chevron_left" : "chevron_right")</span>
                        </button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 scroll-animate">
                <span class="material-symbols-outlined text-5xl text-on-surface-variant/30 dark:text-slate-600 mb-4">format_quote</span>
                <p class="text-on-surface-variant dark:text-slate-400">@Localizer["test_empty"]</p>
            </div>
        }
    </div>
</section>