@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
@{
    var isAr = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("ar");
}
<section id="featured-products" class="relative py-12 md:py-24 px-4 overflow-hidden bg-surface dark:bg-[#0F172A]">
    <div class="deco-blob w-[450px] h-[450px] -bottom-40 -start-40 bg-primary/5 animate-blob-3"></div>
    <div class="max-w-7xl mx-auto relative z-10">
        <div class="flex items-end justify-between mb-8 md:mb-10 scroll-animate">
            <div>
                <span class="inline-block text-xs font-bold text-primary bg-primary/10 px-4 py-1.5 rounded-full border border-primary/20 mb-3">@Localizer["prod_section_badge"]</span>
                <h2 class="text-2xl md:text-4xl font-black text-on-surface dark:text-white">@Localizer["prod_h2"]</h2>
                <p class="text-sm md:text-base text-on-surface-variant dark:text-slate-400 mt-1 md:mt-2">@Localizer["prod_p"]</p>
            </div>
        </div>
        <div id="featured-products-grid" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 scroll-animate delay-100"></div>
        <div class="text-center mt-8 md:mt-10">
            <a asp-action="Register" asp-controller="Auth" class="inline-flex items-center gap-2 text-sm font-bold text-primary hover:text-primary-hover transition-colors group">
                @Localizer["nav_view_all"]
                <span class="material-symbols-outlined text-lg group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">@(isAr ? "arrow_back" : "arrow_forward")</span>
            </a>
        </div>
    </div>
</section>