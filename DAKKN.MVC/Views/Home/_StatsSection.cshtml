@using Microsoft.Extensions.Localization
@using DAKKN.Application.Localization
@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Landing.LandingPageViewModel
@{
    var hasStats = Model.TotalProducts > 0 || Model.TotalOrders > 0 || Model.TotalCustomers > 0 || Model.TotalCategories > 0;
}
@if (hasStats)
{
    <section id="stats" class="relative py-16 md:py-20 px-4 overflow-hidden bg-surface dark:bg-[#0F172A]">
        <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 p-8 md:p-10 rounded-3xl bg-gradient-to-br from-primary/5 via-transparent to-amber-50/30 dark:from-primary/10 dark:via-transparent dark:to-slate-900/50 border border-primary/10 dark:border-white/5">
                @if (Model.TotalProducts > 0)
                {
                    <div class="text-center scroll-animate delay-100">
                        <span class="block text-3xl md:text-4xl font-black text-primary stat-counter" data-target="@Model.TotalProducts">0</span>
                        <span class="text-sm font-medium text-on-surface-variant dark:text-slate-400">@Localizer["stat_products"]</span>
                    </div>
                }
                @if (Model.TotalCategories > 0)
                {
                    <div class="text-center scroll-animate delay-200">
                        <span class="block text-3xl md:text-4xl font-black text-primary stat-counter" data-target="@Model.TotalCategories">0</span>
                        <span class="text-sm font-medium text-on-surface-variant dark:text-slate-400">@Localizer["stat_categories"]</span>
                    </div>
                }
                @if (Model.TotalCustomers > 0)
                {
                    <div class="text-center scroll-animate delay-300">
                        <span class="block text-3xl md:text-4xl font-black text-primary stat-counter" data-target="@Model.TotalCustomers">0</span>
                        <span class="text-sm font-medium text-on-surface-variant dark:text-slate-400">@Localizer["stat_customers"]</span>
                    </div>
                }
                @if (Model.TotalOrders > 0)
                {
                    <div class="text-center scroll-animate delay-400">
                        <span class="block text-3xl md:text-4xl font-black text-primary stat-counter" data-target="@Model.TotalOrders">0</span>
                        <span class="text-sm font-medium text-on-surface-variant dark:text-slate-400">@Localizer["stat_orders"]</span>
                    </div>
                }
            </div>
        </div>
    </section>
}