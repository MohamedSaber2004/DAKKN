@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Auth.ResetPasswordViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["reset.title"];
}

@section Illustration {
    <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 flex items-center justify-center z-20 transform hover:scale-105 transition-transform duration-500">
            <img alt="Dakkn Reset Password Illustration" class="w-full h-full object-cover rounded-2xl shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrjYI8fDsNV_4WUoB2-2zVHGo5IgqParXeGP5kyW0oU5JhRFyco_kP-899V03TTMSPtAb6jvEXeE0lnMQ_KSChHZhxp_y2BmZw-tYILhhx49-JUrnhtLzpYVFcP0xaKvIMblTXrfQ71MozbBYuQ2HfY8cIROXd1VENJR9YpYF3B5kOb0rZQoJhMacVMXimsDY_W0gCpOHSEhb9MzcfX5KOXkiLG6SqHNWbfpfDc1Vs4x98k9n6rov6o2N26teYym1BAe20mxRVioIW">
        </div>
    </div>
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-8">
    <a asp-action="Login" asp-controller="Auth" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-primary transition-colors group">
        <span class="material-symbols-outlined text-[20px] rtl:rotate-180">arrow_back</span>
        @Localizer["forgot.back"]
    </a>
</div>

<div class="mb-10 text-right rtl:text-right ltr:text-left">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
        @Localizer["reset.title"] <span class="text-4xl">🔐</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400">@Localizer["reset.subtitle"]</p>
    <p class="text-sm font-black text-primary mt-1">@Model.Email</p>
</div>

<form asp-action="ResetPassword" asp-controller="Auth" method="post" class="space-y-6" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Email" />

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { 
        For = "NewPassword", 
        LabelKey = "reset.new_password", 
        PlaceholderKey = "reset.new_password_ph",
        LeadingIcon = "lock"
    })

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { 
        For = "ConfirmPassword", 
        LabelKey = "reset.confirm_password", 
        PlaceholderKey = "reset.confirm_password_ph",
        LeadingIcon = "lock"
    })

    <button class="w-full bg-primary hover:bg-[#0c7a77] text-white font-bold py-4 px-6 rounded-xl transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-3 active:scale-[0.98] group" type="submit">
        <span>@Localizer["reset.submit"]</span>
        <span class="material-symbols-outlined text-[20px] group-hover:rotate-180 transition-transform duration-500">lock_reset</span>
    </button>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
