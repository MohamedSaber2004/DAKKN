@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Auth.ResetPasswordViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["reset.title"];
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-6">
    <h1 class="text-3xl font-black text-[var(--color-text-primary)] mb-2" data-i18n="reset.title">@Localizer["reset.title"]</h1>
    <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-1" data-i18n="reset.subtitle">@Localizer["reset.subtitle"]</p>
    <p class="text-sm font-black text-[var(--color-primary)]">@Model.Email</p>
</div>

<form method="post" asp-action="ResetPassword" asp-controller="Auth" class="flex flex-col gap-5" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Email" />

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { For = "NewPassword", LabelKey = "reset.new_password" })

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { For = "ConfirmPassword", LabelKey = "reset.confirm_password" })

    <button type="submit"
            class="h-[56px] mt-4 rounded-2xl bg-[var(--color-primary)] text-white font-bold text-base flex items-center justify-center gap-2 shadow-lg shadow-[var(--color-primary)]/20 hover:bg-[var(--color-primary-hover)] hover:-translate-y-0.5 active:scale-[0.98] transition-all group">
        <span data-i18n="reset.submit">@Localizer["reset.submit"]</span>
        <span class="material-symbols-outlined text-[20px] group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">lock_reset</span>
    </button>
</form>
