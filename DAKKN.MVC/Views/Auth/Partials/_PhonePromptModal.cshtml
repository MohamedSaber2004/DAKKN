@inject IStringLocalizer<Messages> Localizer

<div id="phone-prompt-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-6 overflow-y-auto">
    <div id="phone-prompt-backdrop" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>

    <div class="relative w-full max-w-md transform overflow-hidden rounded-3xl bg-white dark:bg-slate-950 shadow-2xl transition-all border border-slate-200 dark:border-slate-800">
        <button id="phone-prompt-close" type="button" class="absolute top-4 rtl:left-4 ltr:right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors">
            <span class="material-symbols-outlined text-[18px]">close</span>
        </button>

        <div class="p-8">
            <div class="mb-6 text-center">
                <div id="phone-prompt-icon" class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/10 text-primary mb-4">
                    <span class="material-symbols-outlined text-[32px]">person_add</span>
                </div>
                <h3 id="phone-prompt-title" class="text-2xl font-bold text-slate-900 dark:text-white mb-2">
                    @Localizer["auth.register.phone"]
                </h3>
                <p id="phone-prompt-desc" class="text-slate-500 dark:text-slate-400">
                    @Localizer["auth.phone_number_required"]
                </p>
            </div>

            <div class="space-y-4" id="phone-prompt-fields">
                <div id="name-field-group" class="space-y-2 hidden">
                    <label for="modal-name-input" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
                        @Localizer["auth.register.name"]
                    </label>
                    <div class="relative group">
                        <input id="modal-name-input" type="text"
                               class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none ltr:pl-12 rtl:pr-12"
                               placeholder="@Localizer["auth.register.name_ph"]" autocomplete="name">
                        <span class="material-symbols-outlined absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors pointer-events-none">
                            person
                        </span>
                    </div>
                    <span id="modal-name-error" class="text-xs text-red-500 font-bold hidden mt-1"></span>
                </div>

                <div id="phone-field-group" class="space-y-2">
                    <label for="modal-phone-input" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
                        @Localizer["auth.register.phone"]
                    </label>
                    <div class="relative group">
                        <input id="modal-phone-input" type="tel"
                               class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none ltr:pl-12 rtl:pr-12"
                               placeholder="@Localizer["auth.register.phone_ph"]" autocomplete="tel">
                        <span class="material-symbols-outlined absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors pointer-events-none">
                            call
                        </span>
                    </div>
                    <span id="modal-phone-error" class="text-xs text-red-500 font-bold hidden mt-1"></span>
                </div>

                <button id="modal-prompt-submit"
                        class="w-full py-4 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-3 hover:brightness-105 hover:shadow-xl hover:shadow-primary/40 active:scale-[0.98] transition-all duration-300 group">
                    <span>@Localizer["auth.register.submit"]</span>
                    <span class="material-symbols-outlined text-[22px] rtl:rotate-180 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">arrow_forward</span>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    const PhonePromptModal = {
        modal: null,
        backdrop: null,
        closeBtn: null,
        nameInput: null,
        phoneInput: null,
        nameError: null,
        phoneError: null,
        submitBtn: null,
        nameGroup: null,
        iconEl: null,
        titleEl: null,
        descEl: null,
        callback: null,
        isNewUser: false,

        init() {
            this.modal = document.getElementById('phone-prompt-modal');
            this.backdrop = document.getElementById('phone-prompt-backdrop');
            this.closeBtn = document.getElementById('phone-prompt-close');
            this.nameInput = document.getElementById('modal-name-input');
            this.phoneInput = document.getElementById('modal-phone-input');
            this.nameError = document.getElementById('modal-name-error');
            this.phoneError = document.getElementById('modal-phone-error');
            this.submitBtn = document.getElementById('modal-prompt-submit');
            this.nameGroup = document.getElementById('name-field-group');
            this.iconEl = document.getElementById('phone-prompt-icon').querySelector('span');
            this.titleEl = document.getElementById('phone-prompt-title');
            this.descEl = document.getElementById('phone-prompt-desc');

            if (this.submitBtn) {
                this.submitBtn.onclick = () => this.submit();
            }
            if (this.closeBtn) {
                this.closeBtn.onclick = () => this.hide();
            }
            if (this.backdrop) {
                this.backdrop.onclick = () => this.hide();
            }

            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && !this.modal.classList.contains('hidden')) {
                    this.hide();
                }
            });

            if (this.phoneInput) {
                this.phoneInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') this.submit();
                });
            }
            if (this.nameInput) {
                this.nameInput.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') this.submit();
                });
            }
        },

        submit() {
            var name = this.nameInput ? this.nameInput.value.trim() : '';
            var phone = this.phoneInput ? this.phoneInput.value.trim() : '';
            var valid = true;

            this.hideErrors();

            if (this.isNewUser && !name) {
                this.showError(this.nameError, '@Localizer["alert.name_required"]');
                valid = false;
            }

            if (!phone) {
                this.showError(this.phoneError, '@Localizer["alert.phone_required"]');
                valid = false;
            } else if (phone.length < 10) {
                this.showError(this.phoneError, '@Localizer["alert.phone_invalid"]');
                valid = false;
            }

            if (!valid) return;

            if (this.callback) {
                this.callback({ name: name, phone: phone });
            }
        },

        show(options) {
            if (!this.modal) this.init();
            this.isNewUser = options && options.isNewUser;
            this.callback = options && options.callback;

            if (this.isNewUser) {
                this.nameGroup.classList.remove('hidden');
                this.iconEl.textContent = 'person_add';
                this.titleEl.textContent = '@Localizer["auth.register.welcome"]';
                this.descEl.textContent = '@Localizer["auth.register.fill_details"]';
            } else {
                this.nameGroup.classList.add('hidden');
                this.nameInput.value = '';
                this.iconEl.textContent = 'call';
                this.titleEl.textContent = '@Localizer["auth.register.phone"]';
                this.descEl.textContent = '@Localizer["auth.phone_number_required"]';
            }

            this.modal.classList.remove('hidden');
            this.modal.classList.add('flex');

            if (this.isNewUser && this.nameInput) {
                this.nameInput.focus();
            } else if (this.phoneInput) {
                this.phoneInput.focus();
            }
        },

        hide() {
            if (!this.modal) return;
            this.modal.classList.add('hidden');
            this.modal.classList.remove('flex');
            if (this.nameInput) this.nameInput.value = '';
            if (this.phoneInput) this.phoneInput.value = '';
            this.hideErrors();
        },

        showError(el, msg) {
            if (!el) return;
            el.innerText = msg;
            el.classList.remove('hidden');
        },

        hideErrors() {
            if (this.nameError) { this.nameError.innerText = ''; this.nameError.classList.add('hidden'); }
            if (this.phoneError) { this.phoneError.innerText = ''; this.phoneError.classList.add('hidden'); }
        }
    };

    document.addEventListener('DOMContentLoaded', () => PhonePromptModal.init());
</script>
