@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Auth.RegisterViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["auth.register.title"];
}

@section Illustration {
    <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 flex items-center justify-center z-20 transform hover:scale-105 transition-transform duration-500">
            <img alt="Dakkn Register Illustration" class="w-full h-full object-cover rounded-2xl shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrjYI8fDsNV_4WUoB2-2zVHGo5IgqParXeGP5kyW0oU5JhRFyco_kP-899V03TTMSPtAb6jvEXeE0lnMQ_KSChHZhxp_y2BmZw-tYILhhx49-JUrnhtLzpYVFcP0xaKvIMblTXrfQ71MozbBYuQ2HfY8cIROXd1VENJR9YpYF3B5kOb0rZQoJhMacVMXimsDY_W0gCpOHSEhb9MzcfX5KOXkiLG6SqHNWbfpfDc1Vs4x98k9n6rov6o2N26teYym1BAe20mxRVioIW">
        </div>
    </div>
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-8">
    <a asp-action="Index" asp-controller="Home" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-primary transition-colors group">
        <span class="material-symbols-outlined text-[20px]">home</span>
        @Localizer["auth.back_to_home"]
    </a>
</div>

<div class="mb-10 rtl:text-right ltr:text-left">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2 rtl:flex-row-reverse">
        @Localizer["auth.register.title"] <span class="text-4xl">🚀</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400">@Localizer["auth.register.subtitle"]</p>
</div>

<form asp-action="Register" asp-controller="Auth" method="post" class="space-y-6" novalidate>
    @Html.AntiForgeryToken()

    <div class="space-y-2">
        <label asp-for="FullName" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
            @Localizer["auth.register.name"]
        </label>
        <div class="relative group">
            <input asp-for="FullName" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none ltr:pl-12 rtl:pr-12" 
                   placeholder="@Localizer["auth.register.name_ph"]" type="text" autocomplete="name">
            <span class="material-symbols-outlined absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                person
            </span>
        </div>
        <span asp-validation-for="FullName" class="text-xs text-red-500 font-bold block mt-1"></span>
    </div>

    <div class="space-y-2">
        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
            @Localizer["auth.login.email"]
        </label>
        <div class="relative group">
            <input asp-for="Email" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none ltr:pl-12 rtl:pr-12" 
                   placeholder="@Localizer["auth.login.email_ph"]" type="email" autocomplete="email">
            <span class="material-symbols-outlined absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                mail
            </span>
        </div>
        <span asp-validation-for="Email" class="text-xs text-red-500 font-bold block mt-1"></span>
    </div>

    <div class="space-y-2">
        <label asp-for="PhoneNumber" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
            @Localizer["auth.register.phone"]
        </label>
        <div class="relative group">
            <input asp-for="PhoneNumber" class="w-full px-4 py-3.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none ltr:pl-12 rtl:pr-12" 
                   placeholder="@Localizer["auth.register.phone_ph"]" type="tel" autocomplete="tel">
            <span class="material-symbols-outlined absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                call
            </span>
        </div>
        <span asp-validation-for="PhoneNumber" class="text-xs text-red-500 font-bold block mt-1"></span>
    </div>

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { 
        For = "Password", 
        LabelKey = "auth.login.password",
        PlaceholderKey = "auth.login.password_ph",
        LeadingIcon = "lock"
    })

        @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { 
            For = "ConfirmPassword", 
            LabelKey = "auth.register.confirm_password",
            PlaceholderKey = "auth.register.confirm_password_ph",
            LeadingIcon = "lock"
        })

        <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer group">
                <input asp-for="RememberMe" type="checkbox"
                       class="w-5 h-5 rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-primary focus:ring-primary/20 transition-all cursor-pointer">
                    <span class="text-xs font-bold text-slate-500 group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">
                        @Localizer["auth.login.remember"]
                    </span>
                </label>
            </div>

    <button class="w-full py-4 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-3 hover:brightness-105 hover:shadow-xl hover:shadow-primary/40 active:scale-[0.98] transition-all duration-300 group" type="submit">
        <span>@Localizer["auth.register.submit"]</span>
        <span class="material-symbols-outlined text-[22px] rtl:rotate-180 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">arrow_forward</span>
    </button>
</form>

<div class="flex items-center gap-4 my-8">
    <div class="h-px bg-slate-200 dark:bg-slate-800 flex-1"></div>
    <span class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">@Localizer["auth.login.or_social"]</span>
    <div class="h-px bg-slate-200 dark:bg-slate-800 flex-1"></div>
</div>

<div class="flex gap-4">
    <div id="google-login-btn" class="w-full h-[52px]"></div>
</div>

<p class="mt-10 text-center text-sm font-medium text-slate-600 dark:text-slate-400">
    @Localizer["auth.register.has_account"]
    <a asp-action="Login" asp-controller="Auth" asp-route-returnUrl="@Model.ReturnUrl"
       class="text-primary font-bold hover:underline underline-offset-4 decoration-2 ms-1">
       @Localizer["auth.register.login"]
    </a>
</p>

@await Html.PartialAsync("Partials/_PhonePromptModal")

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
        function handleCredentialResponse(response) {
            const idToken = response.credential;
            
            // Check if the account exists and needs a phone number
            fetch('/auth/check-google-account', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify(idToken)
            })
            .then(res => {
                if (res.ok) {
                    return res.json().then(data => {
                        if (data.needsPhoneNumber) {
                            // Show the modal if phone number is missing
                            PhonePromptModal.show((phone) => {
                                performGoogleLogin(idToken, phone);
                            });
                        } else {
                            // Account already complete, login directly
                            performGoogleLogin(idToken);
                        }
                    });
                } else {
                    return res.json().then(err => { throw err; });
                }
            })
            .catch(err => {
                console.error('Google account check error:', err);
                alert(err.message || '@Localizer["auth_google_check_error"]');
            });
        }

        function performGoogleLogin(idToken, phoneNumber = null) {
            fetch('/auth/login-google', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                body: JSON.stringify({
                    idToken: idToken,
                    phoneNumber: phoneNumber
                })
            })
            .then(res => {
                if (res.ok) {
                    return res.json().then(data => {
                        PhonePromptModal.hide();
                        let targetUrl = '@(Model.ReturnUrl ?? "/")';
                        if (targetUrl === '/') {
                            if (data.roles && data.roles.includes('Admin')) {
                                targetUrl = '/Admin/Dashboard';
                            } else {
                                targetUrl = '/customer';
                            }
                        }
                        window.location.href = targetUrl;
                    });
                } else {
                    return res.json().then(err => { 
                        if (err.message && err.message.includes('phone_number_required') || (err.errors && err.errors.PhoneNumber)) {
                            PhonePromptModal.showError(err.message || '@Localizer["alert.phone_required"]');
                        } else {
                            throw err; 
                        }
                    });
                }
            })
            .catch(err => {
                console.error('Google login error:', err);
                alert(err.message || '@Localizer["auth_google_login_error"]');
            });
        }

        function initGoogleLogin() {
            const clientId = "@ViewData["GoogleClientId"]";
            console.log("Initializing Google Login with Client ID:", clientId);

            if (!clientId) {
                console.error("Google Client ID is missing! Please check your configuration.");
                return;
            }

            if (typeof google === 'undefined' || !google.accounts) {
                console.log("Google library not loaded yet, retrying...");
                setTimeout(initGoogleLogin, 100);
                return;
            }

            google.accounts.id.initialize({
                client_id: clientId,
                callback: handleCredentialResponse,
                auto_select: false,
                cancel_on_tap_outside: true,
                locale: "@System.Globalization.CultureInfo.CurrentUICulture.Name"
            });

            const btnContainer = document.getElementById('google-login-btn');
            if (btnContainer) {
                google.accounts.id.renderButton(
                    btnContainer,
                    { 
                        theme: "outline", 
                        size: "large", 
                        width: btnContainer.offsetWidth,
                        shape: "rectangular",
                        text: "signup_with",
                        logo_alignment: "center"
                    }
                );
            }
            
            // Also show One Tap if possible
            google.accounts.id.prompt();
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initGoogleLogin);
        } else {
            initGoogleLogin();
        }
    </script>
}
