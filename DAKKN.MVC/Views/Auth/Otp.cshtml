@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Auth.OtpViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["otp.title"];
}

@section Illustration {
    <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 flex items-center justify-center z-20 transform hover:scale-105 transition-transform duration-500">
            <img alt='@Localizer["auth_illustration_alt"]' class="w-full h-full object-cover rounded-2xl shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrjYI8fDsNV_4WUoB2-2zVHGo5IgqParXeGP5kyW0oU5JhRFyco_kP-899V03TTMSPtAb6jvEXeE0lnMQ_KSChHZhxp_y2BmZw-tYILhhx49-JUrnhtLzpYVFcP0xaKvIMblTXrfQ71MozbBYuQ2HfY8cIROXd1VENJR9YpYF3B5kOb0rZQoJhMacVMXimsDY_W0gCpOHSEhb9MzcfX5KOXkiLG6SqHNWbfpfDc1Vs4x98k9n6rov6o2N26teYym1BAe20mxRVioIW">
        </div>
    </div>
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-8">
    <a asp-action="Login" asp-controller="Auth" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-primary transition-colors group">
        <span class="material-symbols-outlined text-[20px] rtl:rotate-180">arrow_back</span>
        @Localizer["forgot.back"]
    </a>
</div>

<div class="mb-10 text-right rtl:text-right ltr:text-left">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
        @Localizer["otp.title"] <span class="text-4xl">📧</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400">@Localizer["otp.subtitle"] <span class="font-bold text-primary">@Model.Email</span></p>
</div>

<form asp-action="Otp" asp-controller="Auth" method="post" class="space-y-8" novalidate id="otp-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Email" />
    <input type="hidden" asp-for="Purpose" />

    <div class="space-y-4">
        @await Html.PartialAsync("Partials/_OtpInput")
        <span asp-validation-for="Code" class="text-xs text-red-500 font-bold block text-center mt-2"></span>
    </div>

    <div class="text-center space-y-4">
        <p class="text-sm font-medium text-slate-500">
            @Localizer["otp.expires"] <span id="otp-countdown" class="font-bold text-primary">10:00</span>
        </p>
        
        <div class="flex flex-col gap-3">
            <button class="w-full py-4 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/30 flex items-center justify-center gap-3 hover:brightness-105 hover:shadow-xl hover:shadow-primary/40 active:scale-[0.98] transition-all duration-300 group" type="submit">
                <span>@Localizer["otp.submit"]</span>
                <span class="material-symbols-outlined text-[20px] group-hover:scale-110 transition-transform">verified_user</span>
            </button>
        </div>
    </div>
</form>

<div class="mt-4 text-center">
    <p class="text-sm font-medium text-slate-500">
        @Localizer["otp.no_code"]
        <form asp-action="ResendOtp" asp-controller="Auth" method="post" id="resend-form" class="inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="email" value="@Model.Email" />
            <input type="hidden" name="purpose" value="@Model.Purpose" />
            <button type="submit" class="text-primary font-bold hover:underline ms-1 bg-transparent border-none p-0 cursor-pointer">
                @Localizer["otp.resend"]
            </button>
        </form>
    </p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
