@inject IStringLocalizer<Messages> Localizer
@model DAKKN.MVC.ViewModels.Auth.ForgotPasswordViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["forgot.title"];
}

@section Illustration {
    <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 flex items-center justify-center z-20 transform hover:scale-105 transition-transform duration-500">
            <img alt='@Localizer["auth_illustration_alt"]' class="w-full h-full object-cover rounded-2xl shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrjYI8fDsNV_4WUoB2-2zVHGo5IgqParXeGP5kyW0oU5JhRFyco_kP-899V03TTMSPtAb6jvEXeE0lnMQ_KSChHZhxp_y2BmZw-tYILhhx49-JUrnhtLzpYVFcP0xaKvIMblTXrfQ71MozbBYuQ2HfY8cIROXd1VENJR9YpYF3B5kOb0rZQoJhMacVMXimsDY_W0gCpOHSEhb9MzcfX5KOXkiLG6SqHNWbfpfDc1Vs4x98k9n6rov6o2N26teYym1BAe20mxRVioIW">
        </div>
    </div>
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-8">
    <a asp-action="Login" asp-controller="Auth" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-primary transition-colors group">
        <span class="material-symbols-outlined text-[20px] rtl:rotate-180">arrow_back</span>
        @Localizer["forgot.back"]
    </a>
</div>

<div class="mb-10 text-right rtl:text-right ltr:text-left">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
        @Localizer["forgot.title"] <span class="text-4xl">🔑</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400">@Localizer["forgot.subtitle"]</p>
</div>

<form asp-action="ForgotPassword" asp-controller="Auth" method="post" class="space-y-6" novalidate>
    @Html.AntiForgeryToken()

    <div class="space-y-2">
        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
            @Localizer["auth.login.email"]
        </label>
        <div class="relative group">
            <input asp-for="Email" class="w-full px-4 py-3.5 pr-12 ltr:ps-12 ltr:pr-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-right rtl:text-right ltr:text-left" 
                   placeholder="@Localizer["auth.login.email_ph"]" type="email" autocomplete="email">
            <span class="material-symbols-outlined absolute right-4 ltr:left-4 ltr:right-auto top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                mail
            </span>
        </div>
        <span asp-validation-for="Email" class="text-xs text-red-500 font-bold block mt-1"></span>
    </div>

    <button class="w-full bg-primary hover:brightness-110 shadow-primary/30 flex items-center justify-center gap-3 active:scale-[0.98] group" type="submit">
        <span>@Localizer["forgot.submit"]</span>
        <span class="material-symbols-outlined text-[20px] rtl:rotate-180 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">send</span>
    </button>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
