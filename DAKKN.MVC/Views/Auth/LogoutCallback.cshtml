@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Logging out...";
}

<div class="flex flex-col items-center justify-center py-20">
    <div class="preloader-spinner mb-6 border-red-500 border-t-red-500"></div>
    <p class="text-slate-500 font-bold animate-pulse">@Localizer["auth.logging_out"]</p>
</div>

@section Scripts {
    <script>
        (function() {
            // Clear all local session data
            localStorage.removeItem('dakkn_access_token');
            localStorage.removeItem('dakkn_refresh_token');
            
            // Redirect back to login
            window.location.href = '/auth/login';
        })();
    </script>
}
