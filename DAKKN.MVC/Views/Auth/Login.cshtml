@model DAKKN.MVC.ViewModels.Auth.LoginViewModel
@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = Localizer["auth.login.title"];
}

@section Illustration {
    <div class="relative w-[400px] h-[400px]">
        <div class="absolute inset-0 flex items-center justify-center z-20 transform hover:scale-105 transition-transform duration-500">
            <img alt="Dakkn Login Illustration" class="w-full h-full object-cover rounded-2xl shadow-2xl" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDrjYI8fDsNV_4WUoB2-2zVHGo5IgqParXeGP5kyW0oU5JhRFyco_kP-899V03TTMSPtAb6jvEXeE0lnMQ_KSChHZhxp_y2BmZw-tYILhhx49-JUrnhtLzpYVFcP0xaKvIMblTXrfQ71MozbBYuQ2HfY8cIROXd1VENJR9YpYF3B5kOb0rZQoJhMacVMXimsDY_W0gCpOHSEhb9MzcfX5KOXkiLG6SqHNWbfpfDc1Vs4x98k9n6rov6o2N26teYym1BAe20mxRVioIW">
        </div>
    </div>
}

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="mb-8">
    <a asp-action="Index" asp-controller="Home" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-primary transition-colors group">
        <span class="material-symbols-outlined text-[20px]">home</span>
        @Localizer["auth.back_to_home"]
    </a>
</div>

<div class="mb-10 text-right rtl:text-right ltr:text-left">
    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2 flex items-center gap-2">
        @Localizer["auth.login.title"] <span class="text-4xl">👋</span>
    </h1>
    <p class="text-slate-500 dark:text-slate-400">@Localizer["auth.login.subtitle"]</p>
</div>

<form asp-action="Login" asp-controller="Auth" method="post" class="space-y-6" novalidate>
    @Html.AntiForgeryToken()

    <div class="space-y-2">
        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 dark:text-slate-300 mr-1 ms-1">
            @Localizer["auth.login.email"]
        </label>
        <div class="relative group">
            <input asp-for="Email" class="w-full px-4 py-3.5 pr-12 ltr:ps-12 ltr:pr-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 focus:bg-white dark:focus:bg-black focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none text-right rtl:text-right ltr:text-left" 
                   placeholder="@Localizer["auth.login.email_ph"]" type="email" autocomplete="email">
            <span class="material-symbols-outlined absolute right-4 ltr:left-4 ltr:right-auto top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors">
                mail
            </span>
        </div>
        <span asp-validation-for="Email" class="text-xs text-red-500 font-bold block mt-1"></span>
    </div>

    @await Html.PartialAsync("Partials/_PasswordInput", new DAKKN.MVC.ViewModels.Shared.PasswordInputModel { 
        For = "Password", 
        LabelKey = "auth.login.password",
        PlaceholderKey = "auth.login.password_ph",
        LeadingIcon = "lock"
    })

    <div class="flex items-center justify-between">
        <label class="flex items-center gap-2 cursor-pointer group">
            <input asp-for="RememberMe" type="checkbox" 
                   class="w-5 h-5 rounded-lg border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-900 text-primary focus:ring-primary/20 transition-all cursor-pointer">
            <span class="text-xs font-bold text-slate-500 group-hover:text-slate-700 dark:group-hover:text-slate-300 transition-colors">
                @Localizer["auth.login.remember"]
            </span>
        </label>
        <a asp-action="ForgotPassword" asp-controller="Auth" class="text-sm font-medium text-primary hover:underline">
            @Localizer["auth.login.forgot"]
        </a>
    </div>

    <button class="w-full bg-primary hover:bg-[#0c7a77] text-white font-bold py-4 px-6 rounded-xl transition-all shadow-lg shadow-primary/20 flex items-center justify-center gap-3 active:scale-[0.98] group" type="submit">
        <span>@Localizer["auth.login.submit"]</span>
        <span class="material-symbols-outlined text-[20px] rtl:rotate-180 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform">arrow_forward</span>
    </button>
</form>

<div class="mt-10 text-center">
    <p class="text-slate-600 dark:text-slate-400 font-medium">
        @Localizer["auth.login.no_account"]
        <a asp-action="Register" asp-controller="Auth" class="text-primary font-bold mr-1 ms-1 hover:underline">
            @Localizer["auth.login.register"]
        </a>
    </p>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}