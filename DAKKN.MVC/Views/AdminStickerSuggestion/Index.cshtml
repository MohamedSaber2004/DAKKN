@model DAKKN.Application.Common.Models.PagginatedResult<DAKKN.Application.Features.StickerSuggestions.DTOs.StickerSuggestionDto>
@using DAKKN.Domain.Enums
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_sticker_suggestions"];
    var currentStatus = Context.Request.Query["status"].FirstOrDefault();
}

<div class="p-4 md:p-6">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
        <div>
            <h1 class="text-xl md:text-2xl font-bold">@Localizer["admin_sticker_suggestions"]</h1>
            <p class="text-gray-500 text-sm">@Localizer["admin_sticker_suggestions_subtitle"]</p>
        </div>
    </div>

    @if (TempData["Success"] is not null)
    {
        <div class="bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg mb-6">
            @TempData["Success"]
        </div>
    }

    <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="p-4 border-b border-gray-200 dark:border-gray-700">
            <form method="get" class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3">
                <label class="text-sm font-medium">@Localizer["admin_sticker_suggestions_filter_status"]:</label>
                <select name="status" class="w-full sm:w-auto px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" onchange="this.form.submit()">
                    <option value="">@Localizer["admin_sticker_suggestions_filter_all"]</option>
                    @foreach (var status in Enum.GetValues<SuggestionStatus>())
                    {
                        <option value="@((int)status)" selected="@(currentStatus == ((int)status).ToString())">@Localizer[$"suggestion_status_{status.ToString().ToLower()}"]</option>
                    }
                </select>
            </form>
        </div>

        @if (!Model.Items.Any())
        {
            <div class="text-center py-16 text-gray-400">
                <span class="material-symbols-outlined text-5xl mb-4">lightbulb</span>
                <p>@Localizer["admin_sticker_suggestions_empty"]</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full min-w-[600px]">
                    <thead>
                        <tr class="text-left text-sm font-medium text-gray-500 border-b border-gray-200 dark:border-gray-700">
                            <th class="px-4 py-3 whitespace-nowrap">@Localizer["admin_sticker_suggestions_user"]</th>
                            <th class="px-4 py-3 whitespace-nowrap">@Localizer["admin_sticker_suggestions_th_title"]</th>
                            <th class="px-4 py-3 whitespace-nowrap">@Localizer["admin_sticker_suggestions_th_status"]</th>
                            <th class="px-4 py-3 whitespace-nowrap">@Localizer["admin_sticker_suggestions_th_date"]</th>
                            <th class="px-4 py-3 whitespace-nowrap">@Localizer["admin_sticker_suggestions_th_actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var item in Model.Items)
                        {
                            <tr class="text-sm">
                                <td class="px-4 py-3">@item.UserEmail</td>
                                <td class="px-4 py-3 font-medium">@item.Title</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium whitespace-nowrap
                                        @(item.Status switch
                                        {
                                            "Pending" => "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300",
                                            "UnderReview" => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
                                            "Approved" => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300",
                                            "Rejected" => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300",
                                            _ => "bg-gray-100 text-gray-700"
                                        })">
                                        @Localizer[$"suggestion_status_{item.Status.ToLower()}"]
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-gray-500 whitespace-nowrap">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="px-4 py-3">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="text-primary-600 hover:text-primary-700 font-medium whitespace-nowrap">
                                        @Localizer["admin_sticker_suggestions_details"]
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            if (Model.TotalPages > 1)
            {
                <div class="flex flex-col sm:flex-row sm:items-center justify-between px-4 py-3 border-t border-gray-200 dark:border-gray-700 gap-3">
                    <span class="text-sm text-gray-500">@Localizer["common_page_of", Model.PageNumber, Model.TotalPages]</span>
                    <div class="flex gap-2">
                        @if (Model.HasPreviousPage)
                        {
                            <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-status="@currentStatus" class="px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition">@Localizer["common_previous"]</a>
                        }
                        @if (Model.HasNextPage)
                        {
                            <a asp-action="Index" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-status="@currentStatus" class="px-3 py-1.5 rounded border border-gray-300 dark:border-gray-600 text-sm hover:bg-gray-50 dark:hover:bg-gray-800 transition">@Localizer["common_next"]</a>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>
