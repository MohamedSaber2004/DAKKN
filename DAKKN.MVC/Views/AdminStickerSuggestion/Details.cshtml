@model DAKKN.Application.Features.StickerSuggestions.DTOs.StickerSuggestionDto
@using DAKKN.Domain.Enums
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_sticker_suggestion_details_title"];
}

<div class="p-4 md:p-6 max-w-4xl mx-auto">
    <a asp-action="Index" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 mb-6">
        <span class="material-symbols-outlined text-lg">arrow_back</span>
        @Localizer["admin_sticker_suggestion_back"]
    </a>

    @if (TempData["Success"] is not null)
    {
        <div class="bg-green-100 dark:bg-green-900/30 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-300 px-4 py-3 rounded-lg mb-6">
            @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] is not null)
    {
        <div class="bg-red-100 dark:bg-red-900/30 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-300 px-4 py-3 rounded-lg mb-6">
            @TempData["Error"]
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 md:p-6">
            <div class="flex flex-wrap items-start justify-between mb-4 gap-2">
                <h1 class="text-xl md:text-2xl font-bold break-words flex-1 min-w-0">@Model.Title</h1>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium flex-shrink-0
                    @(Model.Status switch
                    {
                        "Pending" => "bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300",
                        "UnderReview" => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
                        "Approved" => "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300",
                        "Rejected" => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300",
                        _ => "bg-gray-100 text-gray-700"
                    })">
                    @Localizer[$"suggestion_status_{Model.Status.ToLower()}"]
                </span>
            </div>

            <p class="text-gray-600 dark:text-gray-300 whitespace-pre-wrap break-words">@Model.Description</p>

            @if (!string.IsNullOrEmpty(Model.Tags))
            {
                <div class="mt-4 flex flex-wrap gap-2">
                    @foreach (var tag in Model.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-50 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">@tag</span>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.ReferenceImagePath))
            {
                <div class="mt-6">
                    <h3 class="text-sm font-medium mb-2">@Localizer["admin_sticker_suggestion_image"]</h3>
                    <img src="/suggestions/@Model.ReferenceImagePath" alt="Reference" class="max-w-full h-auto rounded-lg border border-gray-300" />
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.AdminNote))
            {
                <div class="mt-6 p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg border border-gray-200 dark:border-gray-600">
                    <h3 class="text-sm font-medium mb-1">@Localizer["admin_sticker_suggestion_admin_note"]</h3>
                    <p class="text-gray-600 dark:text-gray-300">@Model.AdminNote</p>
                </div>
            }

            <p class="text-xs text-gray-400 mt-6">
                @Localizer["admin_sticker_suggestion_submitted_by", Model.UserEmail, Model.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")]
            </p>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-4 md:p-6">
            <h2 class="text-lg font-semibold mb-4">@Localizer["admin_sticker_suggestion_update_status"]</h2>

            <form asp-action="UpdateStatus" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="SuggestionId" value="@Model.Id" />
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4"></div>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">@Localizer["admin_sticker_suggestion_new_status"]</label>
                        <select name="NewStatus" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800">
                            @foreach (var status in Enum.GetValues<SuggestionStatus>())
                            {
                                <option value="@((int)status)" selected="@(Model.Status == status.ToString())">@Localizer[$"suggestion_status_{status.ToString().ToLower()}"]</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium mb-1">@Localizer["admin_sticker_suggestion_admin_note"]</label>
                        <textarea name="AdminNote" rows="4" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800" placeholder="@Localizer["admin_sticker_suggestion_note_ph"]">@Model.AdminNote</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium mb-1">@Localizer["admin_sticker_suggestion_converted_product"]</label>
                        <input name="ConvertedProductId" type="hidden" value="@Model.ConvertedProductId" />
                        <input id="productIdDisplay" type="text" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800" placeholder="@Localizer["admin_sticker_suggestion_product_ph"]" value="@Model.ConvertedProductId" />
                    </div>

                    <button type="submit" class="w-full h-[52px] bg-primary text-on-primary rounded-2xl font-bold shadow-large flex items-center justify-center gap-3 hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200">
                        <span class="material-symbols-outlined">save</span>
                        @Localizer["admin_save_changes"]
                    </button>
                </div>
            </form>
            <script>
                document.getElementById('productIdDisplay')?.addEventListener('input', function() {
                    document.querySelector('input[name="ConvertedProductId"]').value = this.value;
                });
            </script>
        </div>
    </div>
</div>
