@using DAKKN.Application.Features.Support.DTOs
@using DAKKN.Application.Localization
@using DAKKN.Application.Features.Support.Commands.CreateTicket
@model CreateTicketCommand
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["supp_new_ticket"];
    var categories = ViewBag.Categories as List<SupportCategoryDto> ?? new();
    var priorities = new[] { "Low", "Medium", "High", "Urgent" };
    var isAr = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="max-w-4xl mx-auto px-lg py-xl">
    <!-- Header -->
    <div class="mb-xl space-y-md">
        <a asp-action="Index" class="inline-flex items-center gap-2 text-text-secondary hover:text-primary transition-colors group">
            <span class="material-symbols-outlined text-lg rtl:rotate-180 group-hover:-translate-x-1 transition-transform">arrow_back</span>
            <span class="font-bold">@Localizer["orders_back"]</span>
        </a>
        <h1 class="customer-page-title text-text-primary dark:text-inverse-on-surface">@Localizer["supp_new_ticket"]</h1>
        <p class="text-text-secondary dark:text-outline-variant">@Localizer["supp_new_ticket_desc"]</p>
    </div>

    <!-- Ticket Form -->
    <form asp-action="NewTicket" method="post" enctype="multipart/form-data" class="section-card p-lg md:p-2xl shadow-small space-y-xl">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <!-- Category -->
            <div class="space-y-3">
                <label asp-for="CategoryId" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_ticket_cat"]</label>
                <div class="relative">
                    <select asp-for="CategoryId" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none appearance-none font-medium dark:text-inverse-on-surface">
                        <option value="" class="dark:bg-[#1E293B] dark:text-inverse-on-surface">@Localizer["supp_ticket_cat_ph"]</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id" class="dark:bg-[#1E293B] dark:text-inverse-on-surface">@(isAr ? cat.ArName : cat.Name)</option>
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-text-secondary dark:text-outline-variant">expand_more</span>
                </div>
                <span asp-validation-for="CategoryId" class="text-error text-xs font-bold px-2"></span>
            </div>

            <!-- Priority -->
            <div class="space-y-3">
                <label asp-for="Priority" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_priority"]</label>
                <div class="relative">
                    <select asp-for="Priority" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none appearance-none font-medium dark:text-inverse-on-surface">
                        @foreach (var p in priorities)
                        {
                            <option value="@p" selected="@(p == "Medium")" class="dark:bg-[#1E293B] dark:text-inverse-on-surface">@Localizer[$"admin_support_priority_{p.ToLower()}"]</option>
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-text-secondary dark:text-outline-variant">expand_more</span>
                </div>
                <span asp-validation-for="Priority" class="text-error text-xs font-bold px-2"></span>
            </div>

            <!-- Phone -->
            <div class="space-y-3">
                <label asp-for="PhoneNumber" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_phone"]</label>
                <input asp-for="PhoneNumber" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium dark:text-inverse-on-surface dark:placeholder:text-outline-variant" placeholder="@Localizer["supp_phone"]" />
                <span asp-validation-for="PhoneNumber" class="text-error text-xs font-bold px-2"></span>
            </div>

            <!-- Order Number -->
            <div class="space-y-3">
                <label asp-for="OrderNumber" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_ticket_order_id_label"]</label>
                <input asp-for="OrderNumber" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium dark:text-inverse-on-surface dark:placeholder:text-outline-variant" placeholder="@Localizer["supp_ticket_order_id_ph"]" />
                <span asp-validation-for="OrderNumber" class="text-error text-xs font-bold px-2"></span>
            </div>
        </div>

        <!-- Subject -->
        <div class="space-y-3">
            <label asp-for="Subject" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_ticket_subject"]</label>
            <input asp-for="Subject" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium text-lg dark:text-inverse-on-surface dark:placeholder:text-outline-variant" placeholder="@Localizer["supp_ticket_subject_ph"]" />
            <span asp-validation-for="Subject" class="text-error text-xs font-bold px-2"></span>
        </div>

        <!-- Message -->
        <div class="space-y-3">
            <label asp-for="Message" class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_ticket_msg"]</label>
            <textarea asp-for="Message" rows="6" class="w-full bg-surface-container dark:bg-white/5 border border-border dark:border-outline/20 rounded-3xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium resize-none dark:text-inverse-on-surface dark:placeholder:text-outline-variant" placeholder="@Localizer["supp_ticket_msg_ph"]"></textarea>
            <span asp-validation-for="Message" class="text-error text-xs font-bold px-2"></span>
        </div>

        <!-- Attachments Drag & Drop -->
        <div class="space-y-3">
            <label class="block text-sm font-bold text-text-secondary dark:text-outline-variant uppercase tracking-widest px-2">@Localizer["supp_attachments"]</label>
            <div id="drop-zone" class="p-lg border-2 border-dashed border-border dark:border-outline/20 rounded-3xl text-center group hover:border-primary/50 transition-all cursor-pointer relative">
                <input id="file-input" name="attachments" type="file" multiple class="hidden" accept=".png,.jpg,.jpeg,.gif,.pdf,.doc,.docx,.zip" />
                <div id="drop-content" class="space-y-2">
                    <div class="w-12 h-12 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-text-secondary group-hover:text-primary mb-3">
                        <span class="material-symbols-outlined">cloud_upload</span>
                    </div>
                    <p class="font-bold text-sm text-text-secondary dark:text-outline-variant">@Localizer["supp_drop_files"]</p>
                    <p class="text-xs text-text-secondary mt-1">@Localizer["supp_ticket_attach_sub"]</p>
                </div>
                <div id="file-preview" class="hidden mt-lg grid grid-cols-2 md:grid-cols-4 gap-3"></div>
            </div>
        </div>

        <!-- Submit -->
        <div class="pt-lg flex flex-col sm:flex-row gap-md items-center">
            <button type="submit" class="w-full md:w-auto bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background px-12 py-5 rounded-2xl font-bold text-lg hover:scale-[1.02] active:scale-[0.98] transition-all shadow-large">
                @Localizer["supp_ticket_submit"]
            </button>
            <a asp-action="Index" class="text-text-secondary hover:text-primary font-bold transition-colors">@Localizer["orders_back"]</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function() {
            const dropZone = document.getElementById('drop-zone');
            const fileInput = document.getElementById('file-input');
            const preview = document.getElementById('file-preview');
            const dropContent = document.getElementById('drop-content');

            dropZone.addEventListener('click', function(e) {
                if (e.target !== fileInput) fileInput.click();
            });

            dropZone.addEventListener('dragover', function(e) {
                e.preventDefault();
                dropZone.classList.add('border-primary', 'bg-primary/5');
            });

            dropZone.addEventListener('dragleave', function() {
                dropZone.classList.remove('border-primary', 'bg-primary/5');
            });

            dropZone.addEventListener('drop', function(e) {
                e.preventDefault();
                dropZone.classList.remove('border-primary', 'bg-primary/5');
                if (e.dataTransfer.files.length) {
                    fileInput.files = e.dataTransfer.files;
                    updatePreview(e.dataTransfer.files);
                }
            });

            fileInput.addEventListener('change', function() {
                if (this.files.length) updatePreview(this.files);
            });

            function updatePreview(files) {
                preview.innerHTML = '';
                preview.classList.remove('hidden');
                dropContent.classList.add('hidden');

                Array.from(files).forEach(function(file, index) {
                    const div = document.createElement('div');
                    div.className = 'relative bg-surface-container dark:bg-white/5 rounded-2xl p-3 text-center group/item text-text-secondary dark:text-outline-variant';

                    const removeBtn = document.createElement('button');
                    removeBtn.type = 'button';
                    removeBtn.className = 'absolute -top-2 -right-2 w-6 h-6 bg-error text-on-primary rounded-full flex items-center justify-center text-xs opacity-0 group-hover/item:opacity-100 transition-opacity z-10';
                    removeBtn.innerHTML = '<span class="material-symbols-outlined text-sm">close</span>';
                    removeBtn.onclick = function(e) {
                        e.stopPropagation();
                        removeFile(index);
                    };
                    div.appendChild(removeBtn);

                    if (file.type.startsWith('image/')) {
                        const img = document.createElement('img');
                        img.className = 'w-full h-20 object-cover rounded-xl mb-2';
                        img.src = URL.createObjectURL(file);
                        div.appendChild(img);
                    } else {
                        const icon = document.createElement('span');
                        icon.className = 'material-symbols-outlined text-3xl text-text-secondary block mb-2';
                        icon.textContent = 'description';
                        div.appendChild(icon);
                    }

                    const name = document.createElement('p');
                    name.className = 'text-xs font-bold truncate text-text-secondary';
                    name.textContent = file.name;
                    div.appendChild(name);

                    const size = document.createElement('p');
                    size.className = 'text-[10px] text-text-secondary/60';
                    size.textContent = (file.size / 1024).toFixed(1) + ' @Localizer["supp_kb"]';
                    div.appendChild(size);

                    preview.appendChild(div);
                });
            }

            function removeFile(index) {
                const dt = new DataTransfer();
                const files = fileInput.files;
                for (let i = 0; i < files.length; i++) {
                    if (i !== index) dt.items.add(files[i]);
                }
                fileInput.files = dt.files;
                if (fileInput.files.length === 0) {
                    preview.classList.add('hidden');
                    dropContent.classList.remove('hidden');
                } else {
                    updatePreview(fileInput.files);
                }
            }
        })();
    </script>
}
