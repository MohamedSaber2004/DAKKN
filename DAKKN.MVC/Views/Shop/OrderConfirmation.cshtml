@using DAKKN.Application.Features.Orders.DTOs
@model OrderDetailDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["order_placed_title"];
}

<div class="bg-surface dark:bg-[#080e1a] min-h-screen pt-28 pb-16 px-4 md:px-16">
    <div class="max-w-4xl mx-auto text-center">
        <div class="relative inline-block mb-xl">
            <div class="w-32 h-32 bg-success/10 rounded-full flex items-center justify-center mx-auto text-success animate-bounce-slow">
                <span class="material-symbols-outlined text-6xl">check_circle</span>
            </div>
            <div class="absolute -top-4 -right-4 w-8 h-8 bg-primary/20 rounded-full blur-xl animate-pulse"></div>
            <div class="absolute -bottom-4 -left-4 w-12 h-12 bg-secondary/20 rounded-full blur-xl animate-pulse delay-700"></div>
        </div>

        <div class="space-y-md mb-2xl">
            <h1 class="text-4xl md:text-5xl font-bold text-on-surface dark:text-white">@Localizer["order_placed_title"]</h1>
            <p class="text-xl text-on-surface-variant dark:text-slate-400 max-w-xl mx-auto leading-relaxed">@Localizer["order_placed_subtitle"]</p>
        </div>

        <div class="bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-6 md:p-8 shadow-lg inline-block min-w-[320px] md:min-w-[400px] mb-2xl">
            <div class="text-xs uppercase tracking-[0.2em] text-outline font-bold mb-2">@Localizer["order_number"]</div>
            <div class="text-3xl font-bold text-primary mb-xl">@Model.OrderNumber</div>

            <div class="border-t border-outline-variant/10 dark:border-white/5 pt-xl space-y-md">
                <div class="flex justify-between">
                    <p class="text-[10px] uppercase font-bold text-outline">@Localizer["order_date"]</p>
                    <p class="font-bold text-on-surface dark:text-white">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                </div>
                <div class="border-t border-outline-variant/10 dark:border-white/5 pt-md space-y-sm">
                    <p class="text-[10px] uppercase font-bold text-outline mb-sm">@Localizer["checkout_items"]</p>
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex justify-between items-center py-1">
                            <span class="font-medium text-sm text-left text-on-surface dark:text-white">@item.ProductName</span>
                            <span class="font-bold text-on-surface dark:text-white text-sm">@Localizer["checkout_qty"]: @item.Quantity</span>
                        </div>
                    }
                </div>
                <div class="bg-surface dark:bg-[#080e1a] p-4 rounded-2xl flex justify-between items-center">
                    <span class="font-medium text-on-surface dark:text-white">@Localizer["order_total"]</span>
                    <span class="text-xl font-bold text-primary">@Model.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</span>
                </div>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row justify-center gap-lg">
            <a asp-controller="Home" asp-action="Index" class="bg-primary text-on-primary px-xl py-5 rounded-3xl font-bold text-lg shadow-large hover:scale-105 transition-all flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">storefront</span>
                @Localizer["order_continue_shopping"]
            </a>
        </div>

        <p class="mt-2xl text-sm text-on-surface-variant dark:text-slate-400">
            @Localizer["conf_need_help"] <a asp-controller="Home" asp-action="Index" class="text-primary font-bold hover:underline">@Localizer["conf_contact_support"]</a>
        </p>
    </div>
</div>

<style>
    @@keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }
    .animate-bounce-slow {
        animation: bounce-slow 3s ease-in-out infinite;
    }
</style>
