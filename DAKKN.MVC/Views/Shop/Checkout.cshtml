@model GuestCartViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["checkout_h1"];
    var isAr = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("ar");
    var backIcon = isAr ? "arrow_forward" : "arrow_back";
    var govName = isAr && !string.IsNullOrEmpty(Model.GovernorateArName) ? Model.GovernorateArName : Model.GovernorateName;
}

<div class="bg-surface dark:bg-[#080e1a] min-h-screen pt-28 pb-16 px-4 md:px-16">
    <div class="max-w-7xl mx-auto">
        <div class="mb-xl flex items-center gap-md">
            <a asp-action="Cart" class="w-10 h-10 rounded-full bg-surface dark:bg-[#0d1a2a] border border-outline-variant/20 dark:border-white/5 flex items-center justify-center text-on-surface-variant dark:text-slate-400 hover:text-primary transition-all">
                <span class="material-symbols-outlined">@backIcon</span>
            </a>
            <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white">@Localizer["checkout_h1"]</h1>
        </div>

        <form asp-action="PlaceOrder" method="post" class="grid grid-cols-1 lg:grid-cols-3 gap-2xl items-start">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ShippingGovernorateId" value="@Model.ShippingGovernorateId" />

            <div class="lg:col-span-2 space-y-lg">
                <section class="bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-6 md:p-8 shadow-sm space-y-xl">
                    <div class="flex items-center gap-md">
                        <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">local_shipping</span>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-on-surface dark:text-white">@Localizer["checkout_shipping_h"]</h2>
                            <p class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer["checkout_shipping_p"]</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-xl pt-md">
                        <div class="md:col-span-2 space-y-2">
                            <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["checkout_name"]</label>
                            <div class="relative">
                                <input required type="text" name="CustomerName" class="w-full px-12 py-4 bg-surface dark:bg-[#080e1a] rounded-2xl border border-outline-variant/20 dark:border-white/5 focus:ring-2 focus:ring-primary outline-none transition-all font-medium text-on-surface dark:text-white" placeholder="@Localizer["checkout_name_ph"]">
                                <span class="material-symbols-outlined absolute start-4 top-1/2 -translate-y-1/2 text-outline">person</span>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["checkout_phone"]</label>
                            <div class="flex items-center bg-surface dark:bg-[#080e1a] rounded-2xl border border-outline-variant/20 dark:border-white/5 focus-within:ring-2 focus-within:ring-primary transition-all overflow-hidden">
                                <div class="px-4 py-4 border-e border-outline-variant/20 dark:border-white/5 bg-surface-container dark:bg-white/5 flex items-center gap-2">
                                    <img src="https://flagcdn.com/w20/eg.png" width="20" alt="@Localizer["flag_egypt_alt"]">
                                    <span class="text-sm font-bold text-on-surface dark:text-white">+20</span>
                                </div>
                                <input required type="tel" name="CustomerPhone" class="flex-1 px-4 py-4 bg-transparent border-none outline-none focus:ring-0 font-medium text-on-surface dark:text-white" placeholder="@Localizer["checkout_phone_ph"]">
                            </div>
                        </div>

                        <div class="md:col-span-2 space-y-2">
                            <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["checkout_address"]</label>
                            <textarea required name="ShippingAddress" rows="3" class="w-full px-4 py-4 bg-surface dark:bg-[#080e1a] rounded-2xl border border-outline-variant/20 dark:border-white/5 focus:ring-2 focus:ring-primary outline-none transition-all font-medium text-on-surface dark:text-white" placeholder="@Localizer["checkout_address_ph"]"></textarea>
                        </div>

                        <div class="md:col-span-2 space-y-2">
                            <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["order_notes"]</label>
                            <textarea name="Notes" rows="1" class="w-full px-4 py-4 bg-surface dark:bg-[#080e1a] rounded-2xl border border-outline-variant/20 dark:border-white/5 focus:ring-2 focus:ring-primary outline-none transition-all font-medium text-on-surface dark:text-white" placeholder="@Localizer["checkout_notes_ph"]"></textarea>
                        </div>
                    </div>
                </section>
            </div>

            <div class="space-y-lg">
                @if (Model.ShippingGovernorateId.HasValue)
                {
                    <section class="bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-6 md:p-8 shadow-sm space-y-lg">
                        <div class="flex items-center gap-md">
                            <div class="w-10 h-10 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                                <span class="material-symbols-outlined">local_shipping</span>
                            </div>
                            <h3 class="text-lg font-bold text-on-surface dark:text-white">@Localizer[LocalizationKeys.CheckoutMessages.ShippingCardTitle.Key]</h3>
                        </div>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center">
                                <span class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer[LocalizationKeys.CheckoutMessages.GovLabel.Key]</span>
                                <span class="font-bold text-on-surface dark:text-white">@govName</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer[LocalizationKeys.CheckoutMessages.ShippingCost.Key]</span>
                                <span class="font-bold text-on-surface dark:text-white">@Model.ShippingPrice.ToString("N0") @Html.Raw(Localizer["Currency_EGP"])</span>
                            </div>
                        </div>
                    </section>
                }

                <section class="bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-6 md:p-8 shadow-sm space-y-xl">
                    <h2 class="text-2xl font-bold text-on-surface dark:text-white">@Localizer["checkout_summary_h"]</h2>

                    <div class="space-y-md divide-y divide-outline-variant/10 dark:divide-white/5">
                        @{
                            var cartSubtotal = Model.Items.Sum(i => i.Price * i.Quantity);
                        }
                        @foreach (var item in Model.Items)
                        {
                            var itemTotal = item.Price * item.Quantity;
                            <div class="flex items-center gap-md pt-md first:pt-0">
                                <div class="w-14 h-14 rounded-2xl bg-surface dark:bg-[#080e1a] overflow-hidden flex-shrink-0 border border-outline-variant/10 dark:border-white/5">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover">
                                    }
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="font-bold text-on-surface dark:text-white truncate">@(isAr && !string.IsNullOrEmpty(item.ArName) ? item.ArName : item.Name)</p>
                                    <p class="text-sm text-on-surface-variant dark:text-slate-400">@Localizer["checkout_qty"]: @item.Quantity</p>
                                </div>
                                <p class="font-bold text-on-surface dark:text-white whitespace-nowrap">@itemTotal.ToString("N0") @Html.Raw(Localizer["Currency_EGP"])</p>
                            </div>
                        }
                    </div>

                    <div class="border-t border-outline-variant/10 dark:border-white/5 pt-xl space-y-2">
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant dark:text-slate-400">@Localizer["order_subtotal"]</span>
                            <span class="font-bold text-on-surface dark:text-white">@cartSubtotal.ToString("N0") @Html.Raw(Localizer["Currency_EGP"])</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant dark:text-slate-400">@Localizer["order_shipping"]</span>
                            <span class="font-bold text-on-surface dark:text-white">@Model.ShippingPrice.ToString("N0") @Html.Raw(Localizer["Currency_EGP"])</span>
                        </div>
                        <div class="flex justify-between text-lg pt-2">
                            <span class="font-bold text-on-surface dark:text-white">@Localizer["order_total"]</span>
                            <span class="font-bold text-primary">@((cartSubtotal + Model.ShippingPrice).ToString("N0")) @Html.Raw(Localizer["Currency_EGP"])</span>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-primary text-on-primary py-5 rounded-3xl font-bold text-lg shadow-large hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">lock</span>
                        @Localizer["checkout_submit"]
                    </button>
                </section>
            </div>
        </form>
    </div>
</div>

<style>
    select,
    input,
    textarea {
        direction: inherit;
        text-align: inherit;
    }
    [dir="rtl"] select {
        background-position: left 0.75rem center !important;
        padding-left: 2.5rem !important;
        padding-right: 1rem !important;
    }
</style>
