@model GuestCartViewModel
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = Localizer["nav_cart"];
    var isAr = System.Threading.Thread.CurrentThread.CurrentUICulture.Name.StartsWith("ar");
}

<div class="min-h-screen bg-surface dark:bg-[#080e1a] pt-28 pb-16 px-4 md:px-16">
    <div class="max-w-7xl mx-auto">
        <div class="mb-10">
            <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface dark:text-white mb-2">@Localizer["cart_h1"]</h1>
            <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full" id="shipping-status-dot"></span>
                <p id="free-shipping-info" class="text-sm"></p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
            <div class="lg:col-span-2 space-y-4" id="cart-items-container">
                @if (Model.IsEmpty)
                {
                    <div id="cart-empty-state" class="py-20 text-center">
                        <div class="w-24 h-24 bg-surface-container-high dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-on-surface-variant/30 mb-6">
                            <span class="material-symbols-outlined text-5xl">shopping_cart</span>
                        </div>
                        <h2 class="text-2xl font-bold text-on-surface dark:text-white mb-2">@Localizer["cart_empty_h"]</h2>
                        <p class="text-on-surface-variant dark:text-slate-400 max-w-sm mx-auto mb-8">@Localizer["cart_empty_p"]</p>
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                            <a asp-action="Products" asp-controller="Shop" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-2xl font-bold hover:shadow-lg hover:-translate-y-0.5 transition-all">
                                @Localizer[LocalizationKeys.CartMessages.BrowseProducts.Key] <span class="material-symbols-outlined">arrow_forward</span>
                            </a>
                            <a asp-action="Products" asp-controller="Shop" class="inline-flex items-center gap-2 text-on-surface-variant dark:text-slate-400 hover:text-primary font-bold transition-colors px-8 py-4">
                                <span class="material-symbols-outlined text-sm">arrow_back</span>
                                @Localizer[LocalizationKeys.CartMessages.ContinueShopping.Key]
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    foreach (var item in Model.Items)
                    {
                        <div class="cart-item group bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-6 shadow-sm hover:shadow-md transition-all" data-product-id="@item.ProductId" data-price="@item.Price">
                            <div class="flex flex-col sm:flex-row gap-4">
                                <div class="w-full sm:w-28 h-28 rounded-2xl overflow-hidden bg-white/5 flex-shrink-0">
                                    <img src="@(item.ImageUrl ?? "/images/placeholders/product-placeholder.svg")" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="@(isAr ? item.ArName : item.Name)" loading="lazy" onerror="this.src='/images/placeholders/product-placeholder.svg'" />
                                </div>
                                <div class="flex-1 min-w-0 flex flex-col justify-between">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-bold text-xl text-on-surface dark:text-white truncate group-hover:text-primary transition-colors">@(isAr && !string.IsNullOrEmpty(item.ArName) ? item.ArName : item.Name)</h3>
                                        </div>
                                        <button onclick="removeItem('@item.ProductId')" class="w-10 h-10 rounded-full flex items-center justify-center text-on-surface-variant hover:text-red-500 hover:bg-red-500/5 transition-all">
                                            <span class="material-symbols-outlined">delete</span>
                                        </button>
                                    </div>
                                    <div class="flex justify-between items-end mt-4">
                                        <div class="flex items-center gap-3 bg-surface-container dark:bg-white/5 p-1.5 rounded-2xl border border-outline-variant/10">
                                            <button onclick="updateQty('@item.ProductId', -1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-[#0d1a2a] shadow-sm flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all text-on-surface dark:text-white">-</button>
                                            <span class="item-qty font-bold w-8 text-center text-on-surface dark:text-white" data-product-id="@item.ProductId">@item.Quantity</span>
                                            <button onclick="updateQty('@item.ProductId', 1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-[#0d1a2a] shadow-sm flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all text-on-surface dark:text-white">+</button>
                                        </div>
                                        <div class="text-end">
                                            <p class="text-xs text-on-surface-variant dark:text-slate-400">@Localizer["cart_unit"]: @item.Price.ToString("N2") @Localizer["Currency_EGP"]</p>
                                            <p class="font-bold text-xl text-primary item-total">@((item.Price * item.Quantity).ToString("N2")) @Localizer["Currency_EGP"]</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <aside class="space-y-6 sticky top-28" id="cart-sidebar">
                <div class="bg-surface-container-low dark:bg-[#0d1a2a] rounded-[32px] border border-outline-variant/10 p-8 shadow-lg space-y-6">
                    <h2 class="text-2xl font-bold text-on-surface dark:text-white">@Localizer["cart_summary_h"]</h2>

                    @if (!Model.IsEmpty)
                    {
                        <div class="space-y-4">
                            <div class="flex justify-between text-on-surface-variant dark:text-slate-400">
                                <span>@Localizer["cart_subtotal"] (<span id="summary-items-count">@Model.TotalQuantity</span> @Localizer["cart_items"])</span>
                                <span id="summary-subtotal" class="font-bold text-on-surface dark:text-white">@Model.Subtotal.ToString("N2") @Localizer["Currency_EGP"]</span>
                            </div>

                            <div class="bg-surface-container dark:bg-white/5 rounded-2xl p-4 space-y-3">
                                <label class="text-xs font-bold text-on-surface-variant dark:text-slate-400 uppercase tracking-wider flex items-center gap-2">
                                    <span class="material-symbols-outlined text-sm">local_shipping</span>
                                    @Localizer[LocalizationKeys.ShippingMessages.ShippingInfo.Key]
                                </label>
                                <select id="shipping-gov-select" class="w-full bg-surface dark:bg-[#0d1a2a] border border-outline-variant/20 rounded-xl px-4 py-3 outline-none focus:ring-2 focus:ring-primary text-on-surface dark:text-white transition-all" onchange="updateShipping()">
                                    <option value="">@Localizer[LocalizationKeys.ShippingMessages.SelectGov.Key]</option>
                                    @foreach (var gov in Model.Governorates)
                                    {
                                        <option value="@gov.Id" data-price="@gov.ShippingPrice" selected="@(Model.ShippingGovernorateId == gov.Id ? true : null)">
                                            @(isAr ? gov.ArName : gov.Name) (@gov.ShippingPrice.ToString("N0") @Localizer["Currency_EGP"])
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="flex justify-between text-on-surface-variant dark:text-slate-400">
                                <span>@Localizer["cart_shipping"]</span>
                                <span id="summary-shipping" class="font-bold text-on-surface dark:text-white">
                                    @if (Model.ShippingGovernorateId.HasValue)
                                    {
                                        @(Model.ShippingPrice.ToString("N2")) @Localizer["Currency_EGP"]
                                    }
                                    else
                                    {
                                        <span class="text-on-surface-variant/50">--</span>
                                    }
                                </span>
                            </div>

                            <div class="h-px bg-outline-variant/20"></div>
                            <div class="flex justify-between items-end">
                                <span class="font-bold text-lg text-on-surface dark:text-white">@Localizer["cart_total"]</span>
                                <div class="text-end">
                                    <div id="summary-total" class="text-3xl font-bold text-primary">@Model.Total.ToString("N2") @Localizer["Currency_EGP"]</div>
                                    <div class="text-[10px] text-on-surface-variant dark:text-slate-400 uppercase tracking-widest mt-1">@Localizer["cart_vat_inc"]</div>
                                </div>
                            </div>
                        </div>

                        <a asp-action="Checkout" asp-controller="Shop" class="w-full bg-primary text-on-primary py-5 rounded-3xl font-bold text-xl shadow-large hover:scale-[1.02] hover:shadow-2xl transition-all flex items-center justify-center gap-3">
                            @Localizer["cart_checkout"]
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    }

                    <div class="flex flex-col gap-3">
                        <div class="flex items-center gap-3 p-4 bg-surface-container dark:bg-white/5 rounded-2xl">
                            <span class="material-symbols-outlined text-primary">verified_user</span>
                            <div class="text-xs">
                                <p class="font-bold text-on-surface dark:text-white">@Localizer["cart_secure_h"]</p>
                                <p class="text-on-surface-variant dark:text-slate-400">@Localizer["cart_secure_p"]</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3 p-4 bg-surface-container dark:bg-white/5 rounded-2xl">
                            <span class="material-symbols-outlined text-primary">local_shipping</span>
                            <div class="text-xs">
                                <p class="font-bold text-on-surface dark:text-white">@Localizer["cart_fast_h"]</p>
                                <p class="text-on-surface-variant dark:text-slate-400">@Localizer["cart_fast_p"]</p>
                            </div>
                        </div>
                    </div>
                </div>

                <a asp-action="Products" asp-controller="Shop" class="flex items-center justify-center gap-2 text-on-surface-variant dark:text-slate-400 hover:text-primary font-bold transition-colors">
                    <span class="material-symbols-outlined text-sm">arrow_back</span>
                    @Localizer[LocalizationKeys.CartMessages.ContinueShopping.Key]
                </a>
            </aside>
        </div>
    </div>
</div>

<style>
    .cart-item {
        animation: slideIn 0.4s ease-out forwards;
    }
    [dir="ltr"] .cart-item {
        animation: slideInLtr 0.4s ease-out forwards;
    }
    [dir="rtl"] .cart-item {
        animation: slideInRtl 0.4s ease-out forwards;
    }
    @@keyframes slideInLtr {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes slideInRtl {
        from { opacity: 0; transform: translateX(10px); }
        to { opacity: 1; transform: translateX(0); }
    }
    .item-removed {
        transform: scale(0.95);
        opacity: 0;
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <script>
        const csrfToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
        const currencyEgp = '@Localizer["Currency_EGP"]';
        let selectedGovId = '@Model.ShippingGovernorateId';
        let currentShipping = @Model.ShippingPrice.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);

        async function updateQty(productId, delta) {
            const qtyEl = document.querySelector(`.item-qty[data-product-id="${productId}"]`);
            if (!qtyEl) return;
            const currentQty = parseInt(qtyEl.textContent);
            const newQty = Math.max(1, currentQty + delta);
            if (newQty === currentQty) return;

            try {
                const response = await fetch('/api/v1/cart/update-quantity', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId: productId, quantity: newQty })
                });
                const data = await response.json();
                if (data.success) {
                    updateCartBadge(data.data);
                    qtyEl.textContent = newQty;
                    recalculateTotals();
                }
            } catch (e) {
                console.error('Failed to update quantity:', e);
                window.location.reload();
            }
        }

        async function removeItem(productId, skipConfirm) {
            if (!skipConfirm) {
                const item = document.querySelector(`.cart-item[data-product-id="${productId}"]`);
                if (item) item.classList.add('item-removed');
            }

            setTimeout(async () => {
                try {
                    const response = await fetch(`/api/v1/cart/remove/${productId}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await response.json();
                    if (data.success) {
                        updateCartBadge(data.data);
                        const item = document.querySelector(`.cart-item[data-product-id="${productId}"]`);
                        if (item) item.remove();
                        recalculateTotals();
                        checkIfEmpty();
                    }
                } catch (e) {
                    console.error('Failed to remove item:', e);
                    window.location.reload();
                }
            }, 300);
        }

        async function updateShipping() {
            const select = document.getElementById('shipping-gov-select');
            const govId = select.value;
            if (!govId) return;

            try {
                const response = await fetch('/api/v1/cart/shipping', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ shippingGovernorateId: govId })
                });
                const data = await response.json();
                if (data.success) {
                    selectedGovId = govId;
                    currentShipping = parseFloat(data.data.shippingPrice) || 0;
                    recalculateTotals();
                }
            } catch (e) {
                console.error('Failed to update shipping:', e);
                window.location.reload();
            }
        }

        function recalculateTotals() {
            let subtotal = 0;
            let itemCount = 0;
            const items = document.querySelectorAll('.cart-item');

            items.forEach(item => {
                const qty = parseInt(item.querySelector('.item-qty').textContent);
                const price = parseFloat(item.dataset.price);
                const total = qty * price;
                subtotal += total;
                itemCount += qty;
                const totalEl = item.querySelector('.item-total');
                if (totalEl) totalEl.textContent = total.toFixed(2) + ' ' + currencyEgp;
            });

            const shipping = currentShipping || 0;
            const total = subtotal + shipping;

            const subtotalEl = document.getElementById('summary-subtotal');
            const shippingEl = document.getElementById('summary-shipping');
            const totalEl = document.getElementById('summary-total');
            const itemsCountEl = document.getElementById('summary-items-count');

            if (subtotalEl) subtotalEl.textContent = subtotal.toFixed(2) + ' ' + currencyEgp;
            if (shippingEl) {
                if (shipping > 0) {
                    shippingEl.textContent = shipping.toFixed(2) + ' ' + currencyEgp;
                } else if (selectedGovId) {
                    shippingEl.textContent = '0.00 ' + currencyEgp;
                } else {
                    shippingEl.innerHTML = '<span class="text-on-surface-variant/50">--</span>';
                }
            }
            if (totalEl) totalEl.textContent = total.toFixed(2) + ' ' + currencyEgp;
            if (itemsCountEl) itemsCountEl.textContent = itemCount;
        }

        function checkIfEmpty() {
            const items = document.querySelectorAll('.cart-item');
            if (items.length === 0) {
                window.location.reload();
            }
        }

        function updateCartBadge(count) {
            document.querySelectorAll('[id^="cart-badge"]').forEach(el => el.textContent = count || 0);
        }

        window.addEventListener('DOMContentLoaded', function() {
            const select = document.getElementById('shipping-gov-select');
            if (select && selectedGovId) {
                select.value = selectedGovId;
            }
        });
    </script>
}
