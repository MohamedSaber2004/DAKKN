@using DAKKN.Application.Features.Support.DTOs
@using DAKKN.Application.Common.Models
@using DAKKN.Application.Localization
@model SupportTicketDetailsDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = $"{Localizer["supp_ticket_details"]} # {Model.TicketNumber}";
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<!-- Top Bar -->
<div class="mb-lg flex flex-col lg:flex-row justify-between items-start lg:items-center gap-md">
    <div>
        <div class="flex flex-wrap items-center gap-sm mb-xs">
            <span class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_ticket_no"]</span>
            <h2 class="text-h2 text-admin-primary dark:text-white">#@Model.TicketNumber</h2>
            @{
                var statusClass = Model.Status switch
                {
                    "Open" => "bg-primary/10 text-primary",
                    "InProgress" => "bg-amber-500/10 text-amber-500",
                    "WaitingCustomer" => "bg-purple-500/10 text-purple-500",
                    "Resolved" => "bg-green-500/10 text-green-500",
                    "Closed" => "bg-slate-500/10 text-slate-500",
                    _ => "bg-admin-card text-admin-secondary dark:text-slate-400"
                };
                var priorityClass = Model.Priority switch
                {
                    "Urgent" => "bg-error-container/20 text-error",
                    "High" => "bg-tertiary-container/20 text-tertiary",
                    "Medium" => "bg-secondary-container/20 text-secondary",
                    _ => "bg-admin-card text-admin-secondary dark:text-slate-400"
                };
            }
            <span class="@statusClass px-sm py-xs rounded-full text-caption font-bold">@Localizer[$"supp_status_{Model.Status?.ToLower()}"]</span>
            <span class="@priorityClass px-sm py-xs rounded-full text-caption font-bold">@Localizer[$"supp_priority_{Model.Priority?.ToLower()}"]</span>
        </div>
        <p class="text-body text-admin-secondary dark:text-slate-400">@Model.Subject</p>
    </div>
    <div class="flex flex-wrap items-center gap-2">
        <div class="relative">
            <button type="button" onclick="this.nextElementSibling.classList.toggle('hidden')" class="bg-admin-card dark:bg-[#1E293B] border border-admin-border dark:border-white/10 px-4 py-2 rounded-full text-body font-bold text-admin-secondary dark:text-slate-400 hover:text-primary transition-all flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">more_vert</span>
                @Localizer["supp_actions"]
            </button>
            <div class="hidden absolute ltr:right-0 rtl:left-0 top-full mt-1 bg-surface dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl shadow-lg py-1 min-w-[180px] z-50">
                <form asp-action="CloseTicket" asp-route-id="@Model.Id" method="post" class="block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full text-left rtl:text-right px-4 py-2 text-sm text-admin-primary dark:text-white hover:bg-admin-page dark:hover:bg-white/5 dark:hover:bg-white/5 flex items-center gap-2"><span class="material-symbols-outlined text-sm">check_circle</span> @Localizer["supp_close_ticket"]</button>
                </form>
                <form asp-action="Reopen" asp-route-id="@Model.Id" method="post" class="block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full text-left rtl:text-right px-4 py-2 text-sm text-admin-primary dark:text-white hover:bg-admin-page dark:hover:bg-white/5 dark:hover:bg-white/5 flex items-center gap-2"><span class="material-symbols-outlined text-sm">replay</span> @Localizer["supp_reopen_ticket"]</button>
                </form>
                <hr class="border-admin-border dark:border-white/5 my-1">
                <div class="px-4 py-2 text-sm font-bold text-admin-secondary dark:text-slate-400">@Localizer["supp_change_priority"]</div>
                <form asp-action="UpdatePriority" asp-route-id="@Model.Id" method="post" class="px-4 pb-2">
                    @Html.AntiForgeryToken()
                    <select name="newPriority" onchange="this.form.submit()" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-lg px-2 py-1 text-sm outline-none dark:text-white">
                        <option value="low" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.Priority == "low")">@Localizer["supp_priority_low"]</option>
                        <option value="medium" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.Priority == "medium")">@Localizer["supp_priority_medium"]</option>
                        <option value="high" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.Priority == "high")">@Localizer["supp_priority_high"]</option>
                        <option value="urgent" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.Priority == "urgent")">@Localizer["supp_priority_urgent"]</option>
                    </select>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
    <!-- Left Column: Conversation -->
    <div class="lg:col-span-2 space-y-lg">
        <div class="bg-admin-card dark:bg-[#1E293B] rounded-2xl border border-admin-border dark:border-white/10 shadow-sm overflow-hidden flex flex-col transition-colors">
            <!-- Messages -->
            <div class="flex-1 overflow-y-auto p-lg flex flex-col gap-lg bg-background/30 dark:bg-dark-page/10 custom-scrollbar max-h-[480px]">
                @if (Model.Replies != null && Model.Replies.Any())
                {
                    @foreach (var msg in Model.Replies)
                    {
                        var isCustomer = !msg.IsStaffReply;
                        <div class="flex gap-md @(isCustomer ? "" : "flex-row-reverse")">
                            <div class="w-10 h-10 rounded-full @(isCustomer ? "bg-primary-container" : "bg-primary") flex items-center justify-center shrink-0 shadow-sm @(isCustomer ? "text-primary" : "text-on-primary") font-bold">
                                @(msg.UserName?.Length > 0 ? msg.UserName[0] : '?')
                            </div>
                            <div class="@(isCustomer ? "bg-surface dark:bg-surface-container-high" : "bg-primary-container/10 dark:bg-primary/10") p-md rounded-2xl @(isCustomer ? "ltr:rounded-tl-none rtl:rounded-tr-none" : "ltr:rounded-tr-none rtl:rounded-tl-none") shadow-sm border @(isCustomer ? "border-border dark:border-outline/20" : "border-primary/20") max-w-[80%] transition-colors">
                                <div class="flex justify-between items-baseline mb-sm @(isCustomer ? "" : "flex-row-reverse")">
                                    <span class="font-body-lg text-body-lg font-bold text-text-primary dark:text-inverse-on-surface">@msg.UserName</span>
                                    <span class="font-caption text-caption text-text-secondary dark:text-outline">@msg.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                                </div>
                                <p class="font-body text-body text-text-primary dark:text-inverse-on-surface leading-relaxed whitespace-pre-wrap">@msg.Message</p>
                                @if (msg.Attachments != null && msg.Attachments.Any())
                                {
                                    <div class="mt-sm flex flex-wrap gap-2">
                                        @foreach (var att in msg.Attachments)
                                        {
                                            <a href="@att.Url" target="_blank" class="inline-flex items-center gap-1 px-3 py-1 bg-surface-container-low dark:bg-surface-container-high rounded-lg text-caption text-primary hover:underline">
                                                <span class="material-symbols-outlined text-sm">attach_file</span>
                                                @att.FileName
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="flex flex-col items-center justify-center py-12 text-admin-secondary dark:text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-3">chat_bubble_outline</span>
                        <p class="font-bold">@Localizer["supp_no_messages"]</p>
                    </div>
                }
            </div>

            <!-- Reply Form -->
            <div class="p-lg border-t border-border dark:border-outline/20 bg-surface dark:bg-surface-container transition-colors">
                <form asp-action="Reply" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="flex gap-md items-end">
                    @Html.AntiForgeryToken()
                    <label class="w-12 h-12 flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light hover:bg-surface-container-low dark:hover:bg-surface-container-high rounded-xl transition-all cursor-pointer">
                        <span class="material-symbols-outlined">attach_file</span>
                        <input type="file" name="attachments" multiple class="hidden" accept=".jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.zip" onchange="previewReplyFiles(this)">
                    </label>
                    <div class="flex-1 relative">
                        <textarea name="Message" class="w-full bg-surface-container-low dark:bg-surface-container-high border border-border dark:border-outline/20 focus:border-primary focus:ring-1 focus:ring-primary rounded-xl py-3 px-4 font-body text-body text-on-surface dark:text-inverse-on-surface resize-none h-[52px] outline-none transition-all" placeholder="@Localizer["supp_reply_placeholder"]" required></textarea>
                        <div id="file-preview" class="hidden mt-2 grid grid-cols-3 gap-2"></div>
                    </div>
                    <button type="submit" class="px-xl h-[52px] bg-primary text-on-primary rounded-xl font-body-lg text-body-lg shadow-sm hover:brightness-110 active:scale-95 transition-all flex items-center gap-sm">
                        @Localizer["btn_send"]
                        <span class="material-symbols-outlined text-[20px] ltr:rotate-0 rtl:rotate-180">send</span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Right Column: Sidebar -->
    <div class="space-y-lg">
        <!-- Customer Info -->
        <section class="bg-admin-card dark:bg-[#1E293B] p-lg rounded-2xl border border-admin-border dark:border-white/10 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-admin-primary dark:text-white">
                <span class="material-symbols-outlined text-primary">account_circle</span>
                @Localizer["supp_customer_info"]
            </h3>
            <div class="flex items-center gap-md mb-lg">
                <div class="h-12 w-12 rounded-full bg-secondary-container/30 flex items-center justify-center text-secondary text-h3 font-bold">
                    @(Model.CustomerName?.Length > 0 ? Model.CustomerName[0] : '?')
                </div>
                <div>
                    <h4 class="text-body-lg font-bold text-admin-primary dark:text-white">@Model.CustomerName</h4>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Model.CustomerEmail</p>
                </div>
            </div>
            <div class="space-y-sm">
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_phone"]</p>
                    <p class="text-body font-bold dark:text-white" dir="ltr">@Model.CustomerPhone</p>
                </div>
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_total_tickets"]</p>
                    <p class="text-body font-bold dark:text-white">—</p>
                </div>
            </div>
        </section>

        <!-- Ticket Info -->
        <section class="bg-admin-card dark:bg-[#1E293B] p-lg rounded-2xl border border-admin-border dark:border-white/10 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-admin-primary dark:text-white">
                <span class="material-symbols-outlined text-primary">info</span>
                @Localizer["supp_ticket_info"]
            </h3>
            <div class="space-y-sm">
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_category"]</p>
                    <p class="text-body font-bold dark:text-white">@(System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar") && !string.IsNullOrEmpty(Model.CategoryArName) ? Model.CategoryArName : Model.CategoryName)</p>
                </div>
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_assigned_to"]</p>
                    <p class="text-body font-bold dark:text-white">@Model.AssignedToName</p>
                </div>
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_created_date"]</p>
                    <p class="text-body font-bold dark:text-white">@Model.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                </div>
                <div>
                    <p class="text-caption text-admin-secondary dark:text-slate-400">@Localizer["supp_last_updated"]</p>
                    <p class="text-body font-bold dark:text-white">@(Model.UpdatedAt?.ToLocalTime().ToString("MMM dd, yyyy HH:mm") ?? "—")</p>
                </div>
            </div>
        </section>

        <!-- Internal Notes -->
        <section class="bg-admin-card dark:bg-[#1E293B] p-lg rounded-2xl border border-admin-border dark:border-white/10 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-admin-primary dark:text-white">
                <span class="material-symbols-outlined text-primary">note</span>
                @Localizer["supp_internal_notes"]
            </h3>
            <div class="space-y-sm mb-md max-h-[200px] overflow-y-auto custom-scrollbar">
                @if (Model.InternalNotes != null && Model.InternalNotes.Any())
                {
                    @foreach (var note in Model.InternalNotes)
                    {
                        <div class="p-3 rounded-xl bg-admin-page/50 dark:bg-white/5">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-caption font-bold text-admin-primary dark:text-white">@note.UserName</span>
                                <span class="text-[10px] text-admin-secondary dark:text-slate-400">@note.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")</span>
                            </div>
                            <p class="text-sm text-admin-secondary dark:text-slate-400">@note.Note</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-admin-secondary dark:text-slate-400 text-center py-4">@Localizer["supp_no_notes"]</p>
                }
            </div>
            <form asp-action="AddNote" asp-route-id="@Model.Id" method="post" class="flex gap-2">
                @Html.AntiForgeryToken()
                <input type="text" name="Note" class="flex-1 bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-3 py-2 text-sm outline-none focus:ring-1 focus:ring-primary text-admin-primary dark:text-white" placeholder="@Localizer["supp_add_note_ph"]">
                <button type="submit" class="w-9 h-9 rounded-xl bg-primary text-on-primary flex items-center justify-center hover:brightness-110 transition-all">
                    <span class="material-symbols-outlined text-sm">add</span>
                </button>
            </form>
        </section>

        <!-- Activity Timeline -->
        <section class="bg-admin-card dark:bg-[#1E293B] p-lg rounded-2xl border border-admin-border dark:border-white/10 shadow-sm transition-colors">
            <h3 class="text-h4 flex items-center gap-sm mb-md text-admin-primary dark:text-white">
                <span class="material-symbols-outlined text-primary">timeline</span>
                @Localizer["supp_activity"]
            </h3>
            <div class="space-y-md relative ltr:before:left-2 rtl:before:right-2 before:content-[''] before:absolute before:top-2 before:bottom-2 before:w-px before:bg-admin-border dark:before:bg-white/5 max-h-[240px] overflow-y-auto custom-scrollbar">
                @if (Model.Activities != null && Model.Activities.Any())
                {
                    @foreach (var log in Model.Activities)
                    {
                        <div class="relative ltr:pl-8 rtl:pr-8">
                            <div class="absolute ltr:left-0 rtl:right-0 top-1 w-4 h-4 rounded-full bg-primary border-4 border-admin-card dark:border-[#1E293B]"></div>
                            <p class="text-body font-bold text-admin-primary dark:text-white text-sm">@log.Action</p>
                            <p class="text-caption text-admin-secondary dark:text-slate-400">
                                @log.CreatedAt.ToLocalTime().ToString("MMM dd, HH:mm")
                                @if (!string.IsNullOrEmpty(log.UserName))
                                {
                                    <span> - @log.UserName</span>
                                }
                            </p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-sm text-admin-secondary dark:text-slate-400 text-center py-4">@Localizer["supp_no_activity"]</p>
                }
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        function previewReplyFiles(input) {
            var preview = document.getElementById('file-preview');
            preview.innerHTML = '';
            if (input.files.length > 0) {
                preview.classList.remove('hidden');
                Array.from(input.files).forEach(function(file) {
                    var div = document.createElement('div');
                    div.className = 'relative bg-surface-container-low dark:bg-surface-container-high rounded-lg p-2 text-center';
                    if (file.type.startsWith('image/')) {
                        var img = document.createElement('img');
                        img.className = 'w-full h-16 object-cover rounded';
                        img.src = URL.createObjectURL(file);
                        div.appendChild(img);
                    } else {
                        var icon = document.createElement('span');
                        icon.className = 'material-symbols-outlined text-2xl text-text-secondary block';
                        icon.textContent = 'description';
                        div.appendChild(icon);
                    }
                    var name = document.createElement('p');
                    name.className = 'text-[10px] truncate mt-1 text-text-secondary';
                    name.textContent = file.name;
                    div.appendChild(name);
                    preview.appendChild(div);
                });
            } else {
                preview.classList.add('hidden');
            }
        }
    </script>
    <style>
        .filled-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
}
