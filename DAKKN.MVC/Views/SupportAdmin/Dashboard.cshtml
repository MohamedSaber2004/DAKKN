@using DAKKN.Application.Features.Support.DTOs
@using DAKKN.Application.Common.Models
@using DAKKN.Application.Localization
@model SupportDashboardStatsDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["supp_dashboard"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<div class="space-y-6 pb-12">

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
        <a asp-action="Tickets" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_total_tickets"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.TotalTickets</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-xl filled-icon">confirmation_number</span>
            </div>
        </a>
        <a asp-action="Tickets" asp-route-status="Open" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_open"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.OpenTickets</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500">
                <span class="material-symbols-outlined text-xl filled-icon">mark_email_unread</span>
            </div>
        </a>
        <a asp-action="Tickets" asp-route-status="InProgress" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_pending"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.PendingTickets</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                <span class="material-symbols-outlined text-xl filled-icon">pending_actions</span>
            </div>
        </a>
        <a asp-action="Tickets" asp-route-status="WaitingCustomer" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_waiting_customer"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.WaitingCustomer</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-500">
                <span class="material-symbols-outlined text-xl filled-icon">hourglass_empty</span>
            </div>
        </a>
        <a asp-action="Tickets" asp-route-status="Closed" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_closed"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.ClosedTickets</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-green-500/10 flex items-center justify-center text-green-500">
                <span class="material-symbols-outlined text-xl filled-icon">check_circle</span>
            </div>
        </a>
        <a asp-action="Tickets" asp-route-priority="High" class="premium-card p-5 flex items-center justify-between hover:ring-2 hover:ring-primary/30 transition-all cursor-pointer">
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400 mb-1">@Localizer["supp_high_priority"]</p>
                <h3 class="text-2xl font-black text-admin-primary dark:text-white">@Model.HighPriorityTickets</h3>
            </div>
            <div class="w-11 h-11 rounded-xl bg-red-500/10 flex items-center justify-center text-red-500">
                <span class="material-symbols-outlined text-xl filled-icon">priority_high</span>
            </div>
        </a>
    </div>

    <!-- Average Response/Resolution Times -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="premium-card p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-2xl">quickreply</span>
            </div>
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400">@Localizer["supp_avg_response_time"]</p>
                <h3 class="text-xl font-black text-admin-primary dark:text-white">@Model.AverageResponseTime</h3>
            </div>
        </div>
        <div class="premium-card p-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-tertiary/10 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-2xl">checklist</span>
            </div>
            <div>
                <p class="text-xs font-semibold text-admin-secondary dark:text-slate-400 dark:text-slate-400">@Localizer["supp_avg_resolution_time"]</p>
                <h3 class="text-xl font-black text-admin-primary dark:text-white">@Model.AverageResolutionTime</h3>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="premium-card p-6">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white mb-4">@Localizer["supp_tickets_by_day"]</h3>
            <div class="relative h-[260px]">
                <canvas id="ticketsByDayChart"></canvas>
                <div id="chart-empty-1" class="hidden flex-col items-center justify-center h-full text-admin-secondary dark:text-slate-400">
                    <span class="material-symbols-outlined text-5xl mb-3">bar_chart</span>
                    <p class="font-bold">@Localizer["admin_chart_no_data"]</p>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="premium-card p-6">
                <h3 class="text-lg font-bold text-admin-primary dark:text-white mb-4">@Localizer["supp_priority_distribution"]</h3>
                <div class="relative h-[200px]">
                    <canvas id="priorityChart"></canvas>
                    <div id="chart-empty-2" class="hidden flex-col items-center justify-center h-full text-admin-secondary dark:text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-3">pie_chart</span>
                        <p class="font-bold">@Localizer["admin_chart_no_data"]</p>
                    </div>
                </div>
            </div>
            <div class="premium-card p-6">
                <h3 class="text-lg font-bold text-admin-primary dark:text-white mb-4">@Localizer["supp_category_distribution"]</h3>
                <div class="relative h-[200px]">
                    <canvas id="categoryChart"></canvas>
                    <div id="chart-empty-3" class="hidden flex-col items-center justify-center h-full text-admin-secondary dark:text-slate-400">
                        <span class="material-symbols-outlined text-5xl mb-3">pie_chart</span>
                        <p class="font-bold">@Localizer["admin_chart_no_data"]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="premium-card p-6">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white mb-4">@Localizer["supp_status_distribution"]</h3>
            <div class="relative h-[220px]">
                <canvas id="statusChart"></canvas>
                <div id="chart-empty-4" class="hidden flex-col items-center justify-center h-full text-admin-secondary dark:text-slate-400">
                    <span class="material-symbols-outlined text-5xl mb-3">donut_large</span>
                    <p class="font-bold">@Localizer["admin_chart_no_data"]</p>
                </div>
            </div>
        </div>

        <!-- Top Issues -->
        <div class="premium-card p-6">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white mb-4">@Localizer["supp_top_issues"]</h3>
            @if (Model.TopIssues != null && Model.TopIssues.Any())
            {
                <div class="space-y-3">
                    @foreach (var issue in Model.TopIssues)
                    {
                        <div class="flex items-center justify-between p-3 rounded-xl bg-admin-page/50 dark:bg-white/5">
                            <div class="flex items-center gap-3 min-w-0">
                                <span class="material-symbols-outlined text-admin-secondary dark:text-slate-400">sell</span>
                                <span class="font-bold text-sm text-admin-primary dark:text-white truncate">@issue.Subject</span>
                            </div>
                            <span class="text-xs font-bold text-admin-secondary dark:text-slate-400 whitespace-nowrap">@issue.Count @Localizer["supp_tickets_count"]</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-8 text-admin-secondary dark:text-slate-400">
                    <span class="material-symbols-outlined text-4xl mb-2">check_circle</span>
                    <p class="font-bold">@Localizer["supp_no_issues"]</p>
                </div>
            }
        </div>
    </div>

    <!-- Recent Tickets -->
    <div class="premium-card p-6">
        <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white">@Localizer["supp_recent_tickets"]</h3>
            <a asp-action="Tickets" class="text-sm font-bold text-primary hover:underline">@Localizer["supp_view_all"]</a>
        </div>
        @if (Model.RecentTickets.Any())
        {
            <div class="overflow-x-auto custom-scrollbar">
                <table class="w-full text-start border-collapse">
                    <thead class="bg-admin-page dark:bg-white/5 text-admin-secondary dark:text-slate-400 dark:text-slate-400 font-body border-b border-admin-border dark:border-white/5">
                        <tr>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">#</th>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">@Localizer["supp_customer"]</th>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">@Localizer["supp_ticket_subject"]</th>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">@Localizer["supp_status_timeline"]</th>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">@Localizer["supp_priority"]</th>
                            <th class="p-3 text-left rtl:text-right font-bold text-xs">@Localizer["supp_created_date"]</th>
                            <th class="p-3 text-center font-bold text-xs">@Localizer["admin_order_actions"]</th>
                        </tr>
                    </thead>
                    <tbody class="text-body text-admin-primary dark:text-white divide-y divide-border dark:divide-white/5">
                        @foreach (var ticket in Model.RecentTickets)
                        {
                            <tr class="hover:bg-admin-card dark:hover:bg-white/[0.04] transition-colors group">
                                <td class="p-3 font-bold text-primary dark:text-primary-light text-xs">#@ticket.TicketNumber</td>
                                <td class="p-3 text-sm">@ticket.CustomerName</td>
                                <td class="p-3 max-w-[200px] truncate text-sm font-medium">@ticket.Subject</td>
                                <td class="p-3">
                                    <span class="px-2.5 py-1 rounded-full text-caption font-bold @(ticket.Status switch {
                                        "Open" => "bg-primary/10 text-primary",
                                        "InProgress" => "bg-amber-500/10 text-amber-500",
                                        "WaitingCustomer" => "bg-purple-500/10 text-purple-500",
                                        "Resolved" => "bg-green-500/10 text-green-500",
                                        "Closed" => "bg-slate-500/10 text-slate-500",
                                        _ => "bg-admin-card text-admin-secondary"
                                    })">@Localizer[$"admin_support_{ticket.Status.ToLower()}"]</span>
                                </td>
                                <td class="p-3">
                                    <span class="px-2.5 py-1 rounded-full text-caption font-bold @(ticket.Priority switch {
                                        "Urgent" => "bg-red-500/10 text-red-500",
                                        "High" => "bg-orange-500/10 text-orange-500",
                                        "Medium" => "bg-blue-500/10 text-blue-500",
                                        _ => "bg-admin-card text-admin-secondary"
                                    })">@Localizer[$"admin_support_priority_{ticket.Priority.ToLower()}"]</span>
                                </td>
                                <td class="p-3 text-sm text-admin-secondary dark:text-slate-400">@ticket.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="p-3 text-center">
                                    <a asp-action="TicketDetails" asp-route-id="@ticket.Id" class="inline-flex items-center justify-center w-8 h-8 rounded-full text-admin-secondary dark:text-slate-400 hover:text-primary hover:bg-primary-container/20 dark:hover:bg-primary/20 transition-all" title="@Localizer["supp_view_details"]">
                                        <span class="material-symbols-outlined text-lg">visibility</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="flex flex-col items-center justify-center py-8 text-admin-secondary dark:text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-2">confirmation_number</span>
                <p class="font-bold">@Localizer["supp_no_tickets"]</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"
            onerror="document.querySelectorAll('[id^=chart-empty-]').forEach(function(el) { el.classList.remove('hidden'); el.classList.add('flex'); })"></script>
    <script>
        @{
            var jsonOpts = new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase };
        }
        const ticketsByDay = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TicketsByDay ?? new List<DAKKN.Application.Features.Support.DTOs.ChartDataPoint>(), jsonOpts));
        const priorityData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PriorityDistribution ?? new List<DAKKN.Application.Features.Support.DTOs.ChartDataPoint>(), jsonOpts));
        const categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryDistribution ?? new List<DAKKN.Application.Features.Support.DTOs.ChartDataPoint>(), jsonOpts));
        const statusData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StatusDistribution ?? new List<DAKKN.Application.Features.Support.DTOs.ChartDataPoint>(), jsonOpts));

        document.addEventListener('DOMContentLoaded', function() {
            if (typeof Chart === 'undefined') return;
            const isDark = document.documentElement.classList.contains('dark');
            const textColor = isDark ? '#7d93ae' : '#94a3b8';
            const gridColor = isDark ? 'rgba(255, 255, 255, 0.05)' : 'rgba(0, 0, 0, 0.05)';
            const primaryColor = '#0e908c';

            function makeBarChart(id, data) {
                const canvas = document.getElementById(id);
                if (!canvas) return;
                const items = data || [];
                if (items.length === 0) {
                    canvas.classList.add('hidden');
                    var empty = document.getElementById(id.replace('Chart', '').replace('ticketsByDay', 'chart-empty-1'));
                    if (empty) { empty.classList.remove('hidden'); empty.classList.add('flex'); }
                    return;
                }
                try {
                    new Chart(canvas.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: items.map(function(d) { return d.label || ''; }),
                            datasets: [{
                                label: '@Localizer["supp_tickets_count"]',
                                data: items.map(function(d) { return d.value ?? 0; }),
                                backgroundColor: 'rgba(14, 144, 140, 0.7)',
                                borderColor: primaryColor,
                                borderWidth: 1,
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                x: { grid: { display: false }, ticks: { color: textColor, font: { size: 10 } } },
                                y: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 10 } } }
                            }
                        }
                    });
                } catch(e) { console.error(e); }
            }

            function makePieChart(id, data, colors) {
                const canvas = document.getElementById(id);
                if (!canvas) return;
                const items = data || [];
                if (items.length === 0) {
                    canvas.classList.add('hidden');
                    return;
                }
                try {
                    new Chart(canvas.getContext('2d'), {
                        type: 'doughnut',
                        data: {
                            labels: items.map(function(d) { return d.label || ''; }),
                            datasets: [{
                                data: items.map(function(d) { return d.value ?? 0; }),
                                backgroundColor: colors || ['#0e908c','#f59e0b','#ef4444','#8b5cf6','#3b82f6','#22c55e']
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    position: 'bottom',
                                    labels: { color: textColor, font: { size: 10 }, boxWidth: 12, padding: 8 }
                                }
                            }
                        }
                    });
                } catch(e) { console.error(e); }
            }

            makeBarChart('ticketsByDayChart', ticketsByDay);
            makePieChart('priorityChart', priorityData, ['#ef4444','#f59e0b','#3b82f6','#22c55e']);
            makePieChart('categoryChart', categoryData);
            makePieChart('statusChart', statusData, ['#0e908c','#f59e0b','#3b82f6','#22c55e','#8b5cf6']);
        });
    </script>
    <style>
        .filled-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
}
