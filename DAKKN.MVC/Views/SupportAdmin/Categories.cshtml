@using DAKKN.Application.Features.Support.DTOs
@using DAKKN.Application.Common.Models
@using DAKKN.Application.Localization
@model List<SupportCategoryDto>
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["admin_support_categories"];
}

<div class="mb-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-md">
    <div>
        <h2 class="font-h2 text-h2 text-admin-primary dark:text-white mb-sm">@Localizer["admin_support_categories"]</h2>
        <p class="font-body text-body text-admin-secondary dark:text-slate-400">@Localizer["supp_manage_categories_desc"]</p>
    </div>
    <button type="button" onclick="openCreateModal()" class="bg-primary text-on-primary px-5 py-2.5 rounded-full text-body font-bold hover:brightness-110 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-sm">add</span>
        @Localizer["supp_add_category"]
    </button>
</div>

@await Html.PartialAsync("Partials/_AuthAlert")

<div class="premium-card overflow-hidden">
    <div class="overflow-x-auto custom-scrollbar">
        <table class="w-full text-start border-collapse">
            <thead class="bg-admin-page dark:bg-white/5 text-admin-secondary dark:text-slate-400 font-body border-b border-admin-border dark:border-white/5">
                <tr>
                    <th class="p-md text-left rtl:text-right font-bold">@Localizer["supp_category_name"]</th>
                    <th class="p-md text-left rtl:text-right font-bold">@Localizer["supp_category_arname"]</th>
                    <th class="p-md text-left rtl:text-right font-bold">@Localizer["supp_display_order"]</th>
                    <th class="p-md text-left rtl:text-right font-bold">@Localizer["supp_active"]</th>
                    <th class="p-md text-center font-bold">@Localizer["admin_order_actions"]</th>
                </tr>
            </thead>
            <tbody class="text-body text-admin-primary dark:text-white divide-y divide-border dark:divide-white/5">
                @foreach (var cat in Model)
                {
                    <tr class="hover:bg-admin-card dark:hover:bg-white/[0.04] transition-colors group">
                        <td class="p-md font-medium dark:text-white">@cat.Name</td>
                        <td class="p-md text-admin-secondary dark:text-slate-400">@cat.ArName</td>
                        <td class="p-md dark:text-white">@cat.DisplayOrder</td>
                        <td class="p-md">
                            @if (cat.IsActive)
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 bg-green-500/10 text-green-500 rounded-full text-caption font-bold">
                                    <span class="material-symbols-outlined text-sm">check_circle</span>
                                    @Localizer["supp_yes"]
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 bg-red-500/10 text-red-500 rounded-full text-caption font-bold">
                                    <span class="material-symbols-outlined text-sm">cancel</span>
                                    @Localizer["supp_no"]
                                </span>
                            }
                        </td>
                        <td class="p-md text-center">
                            <div class="flex items-center justify-center gap-1">
                                <button type="button" onclick="openEditModal('@cat.Id', '@Html.Raw(cat.Name.Replace("'","\\'"))', '@Html.Raw(cat.ArName?.Replace("'","\\'"))', '@cat.DisplayOrder', @(cat.IsActive ? "true" : "false"))" class="inline-flex items-center justify-center w-9 h-9 rounded-full text-admin-secondary dark:text-slate-400 hover:text-primary hover:bg-primary-container/20 dark:hover:bg-primary/20 transition-all" title="@Localizer["supp_edit"]">
                                    <span class="material-symbols-outlined text-lg">edit</span>
                                </button>
                                <form asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('@Localizer["supp_delete_confirm"]')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center justify-center w-9 h-9 rounded-full text-admin-secondary dark:text-slate-400 hover:text-error hover:bg-error/10 transition-all" title="@Localizer["supp_delete"]">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Count == 0)
    {
        <div class="p-lg text-center">
            <p class="text-body text-admin-secondary dark:text-slate-400">@Localizer["supp_no_categories"]</p>
        </div>
    }
</div>

<!-- Create Modal -->
<div id="createModal" class="fixed inset-0 z-[300] hidden flex items-center justify-center bg-black/40 backdrop-blur-sm" onclick="if(event.target===this)closeModal('createModal')">
    <div class="bg-surface dark:bg-[#1E293B] rounded-2xl shadow-xl border border-admin-border dark:border-white/10 p-6 w-full max-w-md mx-4" onclick="event.stopPropagation()">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white">@Localizer["supp_add_category"]</h3>
            <button type="button" onclick="closeModal('createModal')" class="w-8 h-8 rounded-full flex items-center justify-center text-admin-secondary dark:text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="CreateCategory" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_category_name"]</label>
                <input type="text" name="name" required class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white" placeholder="@Localizer["supp_category_name_ph"]">
            </div>
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_category_arname"]</label>
                <input type="text" name="arName" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white" placeholder="@Localizer["supp_category_arname_ph"]">
            </div>
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_display_order"]</label>
                <input type="number" name="displayOrder" value="0" min="0" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" name="isActive" id="createIsActive" checked class="w-5 h-5 rounded border-admin-border dark:border-white/10 text-primary focus:ring-primary">
                <label for="createIsActive" class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["supp_active"]</label>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeModal('createModal')" class="px-4 py-2 rounded-xl border border-admin-border dark:border-white/10 text-admin-secondary dark:text-slate-400 hover:text-primary dark:hover:text-white transition-all font-bold">@Localizer["supp_cancel"]</button>
                <button type="submit" class="px-4 py-2 rounded-xl bg-primary text-on-primary font-bold hover:brightness-110 transition-all">@Localizer["supp_save"]</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="fixed inset-0 z-[300] hidden flex items-center justify-center bg-black/40 backdrop-blur-sm" onclick="if(event.target===this)closeModal('editModal')">
    <div class="bg-surface dark:bg-[#1E293B] rounded-2xl shadow-xl border border-admin-border dark:border-white/10 p-6 w-full max-w-md mx-4" onclick="event.stopPropagation()">
        <div class="flex justify-between items-center mb-4">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white">@Localizer["supp_edit_category"]</h3>
            <button type="button" onclick="closeModal('editModal')" class="w-8 h-8 rounded-full flex items-center justify-center text-admin-secondary dark:text-slate-400 hover:text-primary hover:bg-primary/10 transition-all">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="EditCategory" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="editId">
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_category_name"]</label>
                <input type="text" name="name" id="editName" required class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
            </div>
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_category_arname"]</label>
                <input type="text" name="arName" id="editArName" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
            </div>
            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1">@Localizer["supp_display_order"]</label>
                <input type="number" name="displayOrder" id="editDisplayOrder" min="0" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" name="isActive" id="editIsActive" class="w-5 h-5 rounded border-admin-border dark:border-white/10 text-primary focus:ring-primary">
                <label for="editIsActive" class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["supp_active"]</label>
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="closeModal('editModal')" class="px-4 py-2 rounded-xl border border-admin-border dark:border-white/10 text-admin-secondary dark:text-slate-400 hover:text-primary dark:hover:text-white transition-all font-bold">@Localizer["supp_cancel"]</button>
                <button type="submit" class="px-4 py-2 rounded-xl bg-primary text-on-primary font-bold hover:brightness-110 transition-all">@Localizer["supp_update"]</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() {
            document.getElementById('createModal').classList.remove('hidden');
        }
        function openEditModal(id, name, arName, displayOrder, isActive) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editArName').value = arName || '';
            document.getElementById('editDisplayOrder').value = displayOrder;
            document.getElementById('editIsActive').checked = isActive;
            
            const form = document.querySelector('#editModal form');
            if (form) {
                form.action = '/support/categories/edit/' + id;
            }
            
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeModal(id) {
            document.getElementById(id).classList.add('hidden');
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                document.querySelectorAll('[id$=Modal]').forEach(function(m) { m.classList.add('hidden'); });
            }
        });
    </script>
    <style>
        .filled-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
}
