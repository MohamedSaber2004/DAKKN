@using DAKKN.Application.Features.Support.DTOs
@using DAKKN.Application.Common.Models
@using DAKKN.Application.Localization
@model SupportSettingsDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Localizer["supp_settings"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isAr = culture.StartsWith("ar");
}

<div class="mb-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-md">
    <div>
        <h2 class="font-h2 text-h2 text-admin-primary dark:text-white mb-sm">@Localizer["supp_settings"]</h2>
        <p class="font-body text-body text-admin-secondary dark:text-slate-400 dark:text-slate-400">@Localizer["supp_settings_desc"]</p>
    </div>
</div>

<div class="max-w-3xl">
    <form asp-action="Settings" method="post" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- General Settings -->
        <div class="premium-card p-6 space-y-5">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">settings</span>
                @Localizer["supp_general_settings"]
            </h3>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_support_email"]</label>
                <input type="email" name="supportEmail" value="@Model.SupportEmail" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white" placeholder="support@dakkn.com">
            </div>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_default_priority"]</label>
                <div class="relative">
                    <select name="defaultPriority" dir="@(isAr ? "rtl" : "ltr")" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 ltr:pr-10 rtl:pl-10 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white appearance-none cursor-pointer">
                        <option value="low" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.DefaultPriority == "low")">@Localizer["supp_priority_low"]</option>
                        <option value="medium" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.DefaultPriority == "medium")">@Localizer["supp_priority_medium"]</option>
                        <option value="high" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.DefaultPriority == "high")">@Localizer["supp_priority_high"]</option>
                        <option value="urgent" class="dark:bg-[#1E293B] dark:text-white" selected="@(Model.DefaultPriority == "urgent")">@Localizer["supp_priority_urgent"]</option>
                    </select>
                    <span class="material-symbols-outlined absolute ltr:right-3 rtl:left-3 top-1/2 -translate-y-1/2 text-admin-secondary dark:text-slate-400 pointer-events-none">arrow_drop_down</span>
                </div>
            </div>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_default_response_time"]</label>
                <input type="text" name="defaultResponseTime" value="@Model.DefaultResponseTime" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white" placeholder="24h">
            </div>
        </div>

        <!-- Attachments -->
        <div class="premium-card p-6 space-y-5">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">attach_file</span>
                @Localizer["supp_attachment_settings"]
            </h3>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_max_attachment_size"] (MB)</label>
                <input type="number" name="maxAttachmentSize" value="@Model.MaxAttachmentSize" min="1" max="50" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
            </div>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_allowed_extensions"]</label>
                <input type="text" name="allowedExtensions" value="@Model.AllowedExtensions" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white" placeholder=".jpg,.png,.pdf,.zip">
                <p class="text-xs text-admin-secondary dark:text-slate-400 mt-1">@Localizer["supp_allowed_extensions_hint"]</p>
            </div>
        </div>

        <!-- Auto Close -->
        <div class="premium-card p-6 space-y-5">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">schedule</span>
                @Localizer["supp_auto_close_settings"]
            </h3>

            <div>
                <label class="block text-sm font-bold text-admin-primary dark:text-white mb-1.5">@Localizer["supp_auto_close_days"]</label>
                <input type="number" name="autoCloseDays" value="@Model.AutoCloseDays" min="0" max="365" class="w-full bg-admin-input dark:bg-[#1E293B] border border-admin-border dark:border-white/10 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary text-admin-primary dark:text-white">
                <p class="text-xs text-admin-secondary dark:text-slate-400 mt-1">@Localizer["supp_auto_close_days_hint"]</p>
            </div>
        </div>

        <!-- Notifications -->
        <div class="premium-card p-6 space-y-5">
            <h3 class="text-lg font-bold text-admin-primary dark:text-white flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">notifications</span>
                @Localizer["supp_notification_settings"]
            </h3>

            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["supp_email_on_new_ticket"]</p>
                    <p class="text-xs text-admin-secondary dark:text-slate-400">@Localizer["supp_email_on_new_ticket_desc"]</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="notifyOnNewTicket" value="true" class="sr-only peer" @(Model.NotifyOnNewTicket ? "checked" : "")>
                    <div class="w-11 h-6 bg-admin-border dark:bg-white/10 rounded-full peer peer-checked:bg-primary peer-focus:ring-2 peer-focus:ring-primary/30 after:content-[''] after:absolute after:top-0.5 after:start-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full"></div>
                </label>
            </div>

            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["supp_email_on_reply"]</p>
                    <p class="text-xs text-admin-secondary dark:text-slate-400">@Localizer["supp_email_on_reply_desc"]</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="notifyOnReply" value="true" class="sr-only peer" @(Model.NotifyOnReply ? "checked" : "")>
                    <div class="w-11 h-6 bg-admin-border dark:bg-white/10 rounded-full peer peer-checked:bg-primary peer-focus:ring-2 peer-focus:ring-primary/30 after:content-[''] after:absolute after:top-0.5 after:start-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full"></div>
                </label>
            </div>

            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-bold text-admin-primary dark:text-white">@Localizer["supp_email_on_assignment"]</p>
                    <p class="text-xs text-admin-secondary dark:text-slate-400">@Localizer["supp_email_on_assignment_desc"]</p>
                </div>
                <label class="relative inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="notifyOnAssignment" value="true" class="sr-only peer" @(Model.NotifyOnAssignment ? "checked" : "")>
                    <div class="w-11 h-6 bg-admin-border dark:bg-white/10 rounded-full peer peer-checked:bg-primary peer-focus:ring-2 peer-focus:ring-primary/30 after:content-[''] after:absolute after:top-0.5 after:start-0.5 after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full"></div>
                </label>
            </div>
        </div>

        <!-- Submit -->
        <div class="flex justify-end gap-3">
            <a asp-action="Dashboard" class="px-6 py-3 rounded-xl border border-admin-border dark:border-white/10 text-admin-secondary dark:text-slate-400 hover:text-primary dark:hover:text-white transition-all font-bold">@Localizer["supp_cancel"]</a>
            <button type="submit" class="px-6 py-3 rounded-xl bg-primary text-on-primary font-bold hover:brightness-110 transition-all flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">save</span>
                @Localizer["supp_save_settings"]
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <style>
        .filled-icon { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
}
