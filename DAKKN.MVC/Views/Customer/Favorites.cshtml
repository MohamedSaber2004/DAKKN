@using DAKKN.MVC.ViewModels.Customer
@model FavoritesViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["fav_title"];
}

<div class="max-w-7xl mx-auto px-lg py-xl space-y-xl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
        <div>
            <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">
                @Localizer["fav_title"] 
                <span class="text-primary bg-primary/10 px-3 py-1 rounded-2xl text-2xl ml-2">@Model.FavoriteProducts.Count</span>
            </h1>
            <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["fav_subtitle"]</p>
        </div>
    </div>

    @if (Model.FavoriteProducts.Any())
    {
        <!-- Favorites Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-lg">
            @foreach (var product in Model.FavoriteProducts)
            {
                <div class="product-card group bg-surface dark:bg-inverse-surface rounded-[32px] border border-border dark:border-outline/10 overflow-hidden shadow-small hover:shadow-large transition-all duration-500 hover:-translate-y-2">
                    <div class="aspect-square relative overflow-hidden bg-white/5">
                        <img src="@product.ImageUrls.FirstOrDefault()" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        
                        <button onclick="removeFromFavorites('@product.Id')" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-error/10 backdrop-blur-md shadow-medium flex items-center justify-center text-error hover:bg-error hover:text-white transition-all opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0" title="@Localizer["fav_remove"]">
                            <span class="material-symbols-outlined text-xl filled-icon">favorite</span>
                        </button>
                    </div>
                    
                    <div class="p-lg">
                        <div class="flex justify-between items-start mb-xs">
                            <a asp-action="ProductDetails" asp-route-id="@product.Id">
                                <h3 class="font-bold text-lg group-hover:text-primary transition-colors truncate pr-2">@product.Name</h3>
                            </a>
                            <span class="font-bold text-primary flex-shrink-0">@product.Price @Localizer["Currency_EGP"]</span>
                        </div>
                        <p class="text-xs text-text-secondary font-medium uppercase tracking-wider mb-lg">@string.Join(", ", product.FinishOptions)</p>
                        
                        <div class="flex items-center gap-md">
                            <button class="flex-1 bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background py-3 rounded-2xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
                                @Localizer["add_cart"]
                            </button>
                            <a asp-action="ProductDetails" asp-route-id="@product.Id" class="w-12 h-12 rounded-2xl border border-border dark:border-outline/20 flex items-center justify-center text-text-secondary hover:text-primary hover:bg-primary/5 transition-all">
                                <span class="material-symbols-outlined">visibility</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="py-32 text-center space-y-xl bg-surface dark:bg-inverse-surface rounded-[40px] border border-dashed border-border dark:border-outline/20">
            <div class="w-24 h-24 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-outline opacity-30">
                <span class="material-symbols-outlined text-5xl">favorite</span>
            </div>
            <div class="space-y-md">
                <h2 class="text-2xl font-bold">@Localizer["fav_empty_h"]</h2>
                <p class="text-text-secondary max-w-sm mx-auto">@Localizer["fav_empty_p"]</p>
            </div>
            <a asp-action="Products" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold hover:shadow-large hover:-translate-y-1 transition-all">
                @Localizer["orders_empty_btn"] <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function removeFromFavorites(productId) {
            // Logic to remove from favorites via API would go here
            console.log('Removing product:', productId);
            
            // For now, just visually remove it
            const card = event.target.closest('.product-card');
            card.style.opacity = '0';
            card.style.transform = 'scale(0.9)';
            setTimeout(() => {
                card.remove();
                // Check if grid is empty to show empty state
                const grid = document.querySelector('.grid');
                if (grid && grid.children.length === 0) {
                    location.reload(); // Reload to show empty state
                }
            }, 300);
        }
    </script>
}

<style>
    .filled-icon {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>
