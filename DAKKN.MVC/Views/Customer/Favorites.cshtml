@using DAKKN.MVC.ViewModels.Customer
@model FavoritesViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["fav_title"];
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
}

<div class="max-w-7xl mx-auto px-lg py-xl space-y-xl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
        <div>
            <h1 class="customer-page-title text-text-primary dark:text-inverse-on-surface">
                @Localizer["fav_title"]
                <span class="text-primary bg-primary/10 px-3 py-1 rounded-2xl text-2xl ml-2">@Model.FavoriteProducts.Count</span>
            </h1>
            <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["fav_subtitle"]</p>
        </div>
    </div>

    @Html.AntiForgeryToken()

    @if (Model.FavoriteProducts.Any())
    {
        <!-- Favorites Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-lg" id="fav-grid">
            @foreach (var product in Model.FavoriteProducts)
            {
                <div class="product-card group bg-surface dark:bg-inverse-surface rounded-[32px] border border-border dark:border-outline/10 overflow-hidden shadow-small hover:shadow-large transition-all duration-500 hover:-translate-y-2" data-id="@product.Id">
                    <div class="aspect-square relative overflow-hidden bg-white/5">
                        <img src="@product.ImageUrl" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    </div>

                    <div class="p-lg">
                        <div class="flex justify-between items-start mb-xs">
                            <a asp-action="ProductDetails" asp-route-id="@product.Id" class="min-w-0 overflow-hidden">
                                <h3 class="font-bold text-lg group-hover:text-primary transition-colors truncate">@(isArabic ? product.ArName : product.Name)</h3>
                            </a>
                            <span class="font-bold text-primary flex-shrink-0">@product.Price @Localizer["Currency_EGP"]</span>
                        </div>
                        <p class="text-xs text-text-secondary font-medium uppercase tracking-wider mb-lg">@(isArabic ? product.CategoryArName : product.CategoryName)</p>

                        @if (product.QuantityInStock == 0)
                        {
                            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-red-500 mb-lg">
                                <span class="material-symbols-outlined text-xs">block</span>
                                @Localizer["inventory_out_of_stock"]
                            </span>
                        }
                        else if (product.QuantityInStock <= product.DangerQuantity)
                        {
                            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-amber-500 mb-lg">
                                <span class="material-symbols-outlined text-xs">warning</span>
                                @Localizer["inventory_only_x_left", product.QuantityInStock]
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1 text-[10px] font-bold text-green-500 mb-lg">
                                <span class="material-symbols-outlined text-xs">check_circle</span>
                                @Localizer["inventory_in_stock"]
                            </span>
                        }

                        <div class="flex items-center gap-md">
                            @if (product.QuantityInStock > 0)
                            {
                                <button onclick="guestAddToCart(this, '@product.Id','@(isArabic ? product.ArName : product.Name)','@product.Price','@(product.ImageFullUrl ?? product.ImageUrl)')"
                                        class="flex-1 bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background py-3 rounded-2xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined text-lg">add_shopping_cart</span>
                                    @Localizer["add_cart"]
                                </button>
                            }
                            else
                            {
                                <button disabled class="flex-1 bg-gray-300 dark:bg-gray-700 text-gray-500 dark:text-gray-400 py-3 rounded-2xl font-bold text-sm cursor-not-allowed flex items-center justify-center gap-2">
                                    <span class="material-symbols-outlined text-lg">block</span>
                                    @Localizer["inventory_out_of_stock"]
                                </button>
                            }
                            <button onclick="removeFavorite('@product.Id', this)" class="w-12 h-12 rounded-2xl border border-border dark:border-outline/20 flex items-center justify-center text-error hover:bg-error hover:text-white hover:border-error transition-all" title="@Localizer["fav_remove"]">
                                <span class="material-symbols-outlined text-lg filled-icon">favorite</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="empty-state space-y-xl">
            <div class="empty-state-icon">
                <span class="material-symbols-outlined text-5xl">favorite</span>
            </div>
            <div class="space-y-md">
                <h2 class="text-2xl font-bold">@Localizer["fav_empty_h"]</h2>
                <p class="text-text-secondary max-w-sm mx-auto">@Localizer["fav_empty_p"]</p>
            </div>
            <a asp-action="Products" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold hover:shadow-large hover:-translate-y-1 transition-all">
                @Localizer["orders_empty_btn"] <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        function removeFavorite(productId, btn) {
            var card = btn.closest('.product-card');

            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            var headers = { 'Content-Type': 'application/json' };
            if (token) headers['RequestVerificationToken'] = token.value;

            fetch('/customer/favorites/remove', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({ productId: productId })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    card.style.opacity = '0';
                    card.style.transform = 'scale(0.9)';
                    setTimeout(function() {
                        card.remove();
                        var grid = document.getElementById('fav-grid');
                        if (grid && grid.children.length === 0) {
                            location.reload();
                        }
                    }, 300);
                }
            })
            .catch(function(e) {
                console.error('Remove favorite failed:', e);
            });
        }
    </script>
}

<style>
    .filled-icon {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>
