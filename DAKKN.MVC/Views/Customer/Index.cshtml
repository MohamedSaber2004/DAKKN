@using DAKKN.MVC.ViewModels.Customer
@using System.Security.Claims
@model CustomerDashboardViewModel
@{
    Layout = "_LayoutCustomer";
    var dashboard = Model.Dashboard;
    var fullName = User.FindFirstValue("FullName") ?? User.Identity?.Name ?? Localizer["customer_greeting_fallback"].Value;
    var firstName = fullName.Split(' ')[0];
}

<div class="max-w-7xl mx-auto px-lg py-xl space-y-3xl">
    <!-- Header & Welcome -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
        <div>
            <h1 class="customer-page-title text-text-primary dark:text-white">@Localizer["Dashboard_Welcome"], @firstName! 👋</h1>
            <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["Dashboard_SubHeader"]</p>
        </div>
        <div class="flex gap-md">
            <a asp-action="Products" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-105 transition-all">
                @Localizer["Dashboard_BrowseNew"]
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-xl">
        <div class="bg-surface dark:bg-[#1E293B] rounded-[28px] border border-border dark:border-white/5 p-xl shadow-medium flex items-center gap-lg">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary dark:text-primary-light flex-shrink-0">
                <span class="material-symbols-outlined text-3xl">shopping_bag</span>
            </div>
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-text-secondary dark:text-outline-variant">@Localizer["dashboard_orders_count"]</p>
                <h3 class="text-3xl font-black text-text-primary dark:text-white">@dashboard.TotalOrders</h3>
            </div>
        </div>
        <div class="bg-surface dark:bg-[#1E293B] rounded-[28px] border border-border dark:border-white/5 p-xl shadow-medium flex items-center gap-lg">
            <div class="w-14 h-14 rounded-2xl bg-error/10 flex items-center justify-center text-error flex-shrink-0">
                <span class="material-symbols-outlined text-3xl">favorite</span>
            </div>
            <div>
                <p class="text-xs font-bold uppercase tracking-widest text-text-secondary dark:text-outline-variant">@Localizer["dashboard_fav_count"]</p>
                <h3 class="text-3xl font-black text-text-primary dark:text-white">@dashboard.TotalFavorites</h3>
            </div>
        </div>
    </div>

    <!-- Custom Order CTA Card -->
    <section class="bg-gradient-to-br from-primary to-primary-light rounded-[40px] p-0.5 shadow-large">
        <div class="bg-surface dark:bg-[#1E293B] rounded-[39px] p-xl flex flex-col md:flex-row items-center gap-xl relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
            <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-primary-light rounded-full blur-3xl"></div>
            
            <div class="flex-1 space-y-md relative z-10 text-center md:text-left rtl:md:text-right">
                <span class="bg-primary/10 text-primary dark:text-primary-light px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest">@Localizer["hero_badge"]</span>
                <h2 class="text-3xl md:text-4xl font-bold text-text-primary dark:text-white">@Localizer["custom_upload_h"]?</h2>
                <p class="text-text-secondary dark:text-outline-variant text-lg max-w-2xl">@Localizer["custom_upload_p"]</p>
                <div class="pt-md">
                    <a asp-action="CustomOrder" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold text-lg hover:shadow-large hover:-translate-y-1 transition-all">
                        @Localizer["custom_submit"] <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                </div>
            </div>

            <div class="w-full md:w-80 h-64 bg-surface-container-low dark:bg-black/20 rounded-3xl flex items-center justify-center relative overflow-hidden group border border-border dark:border-white/5">
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-48 h-48 border-2 border-dashed border-primary/30 rounded-full animate-spin-slow"></div>
                </div>
                <span class="material-symbols-outlined text-6xl text-primary animate-bounce">upload_file</span>
            </div>
        </div>
    </section>

    @if (dashboard.LastOrder != null)
    {
        <!-- Order Tracking Card -->
        <section class="relative overflow-hidden bg-surface dark:bg-[#1E293B] rounded-[40px] border border-border dark:border-white/5 shadow-large p-xl group">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full -mr-20 -mt-20 blur-3xl group-hover:scale-110 transition-transform duration-700"></div>
            
            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-xl">
                <div class="flex items-center gap-xl">
                    <div class="w-20 h-20 rounded-3xl bg-primary/10 flex items-center justify-center text-primary dark:text-primary-light border border-primary/20">
                        <span class="material-symbols-outlined text-4xl">local_shipping</span>
                    </div>
                    <div>
                        <span class="text-xs font-bold uppercase tracking-widest text-primary dark:text-primary-light mb-1 block">@Localizer["Dashboard_LastOrder"]</span>
                        <h2 class="text-2xl font-bold text-text-primary dark:text-white">@Localizer["admin_order_no"] @dashboard.LastOrder.OrderNumber</h2>
                        <p class="text-text-secondary dark:text-outline-variant">@dashboard.LastOrder.ItemCount @Localizer["admin_order_items"] • @dashboard.LastOrder.OrderDate.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>

                <div class="flex flex-col items-end gap-md">
                    <div class="flex items-center gap-3">
                        <span class="w-3 h-3 rounded-full bg-primary animate-pulse"></span>
                        <span class="font-bold text-lg text-primary dark:text-primary-light">@Localizer["status_shipped"]</span>
                    </div>
                    <button class="bg-surface-container dark:bg-black/20 px-lg py-3 rounded-2xl font-bold text-sm text-text-primary dark:text-white hover:bg-primary hover:text-on-primary transition-all border border-border dark:border-white/5">
                        @Localizer["Dashboard_TrackOrder"]
                    </button>
                </div>
            </div>

            <div class="mt-xl h-2 bg-surface-container-highest dark:bg-black/40 rounded-full relative overflow-hidden">
                <div class="absolute inset-y-0 left-0 bg-primary rounded-full transition-all duration-1000 shadow-[0_0_10px_rgba(14,144,140,0.5)]" style="width: 75%"></div>
            </div>
        </section>
    }

    <!-- Suggest for You -->
    @if (dashboard.Recommendations.Count > 0)
    {
        <section class="space-y-xl">
            <div class="flex justify-between items-end mb-lg">
                <div>
                    <h2 class="font-h2 text-h2 font-bold text-text-primary dark:text-white">@Localizer["Dashboard_Suggested"]</h2>
                    <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["Dashboard_Suggested_Sub"]</p>
                </div>
                <a asp-action="Products" class="text-primary dark:text-primary-light font-bold hover:underline flex items-center gap-1 text-sm">
                    @Localizer["admin_view_all"] <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-xl">
                @foreach (var prod in dashboard.Recommendations)
                {
                    <div class="group bg-surface dark:bg-[#1E293B] rounded-[32px] border border-border dark:border-white/5 overflow-hidden shadow-medium hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
                        <a asp-action="ProductDetails" asp-route-id="@prod.Id" class="block">
                            <div class="aspect-square relative overflow-hidden bg-surface-container dark:bg-black/20">
                                <img src="@prod.ImageUrl" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" loading="lazy">
                                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            </div>
                        </a>
                        <div class="p-lg space-y-md">
                            <div class="min-w-0">
                                <a asp-action="ProductDetails" asp-route-id="@prod.Id" class="no-underline">
                                    <h4 class="font-bold text-text-primary dark:text-white truncate group-hover:text-primary dark:group-hover:text-primary-light transition-colors">@prod.Name</h4>
                                </a>
                                <p class="text-xs text-text-secondary dark:text-outline-variant">@(string.IsNullOrEmpty(prod.CategoryName) ? "" : prod.CategoryName)</p>
                            </div>

                            @if (prod.AverageRating > 0)
                            {
                                <div class="flex items-center gap-2">
                                    <div class="flex gap-0.5">
                                        @for (int s = 0; s < 5; s++)
                                        {
                                            <span class="material-symbols-outlined text-sm @(s < (int)prod.AverageRating ? "text-amber-400 fill-icon" : "text-border dark:text-outline-variant")">star</span>
                                        }
                                    </div>
                                    <span class="text-xs font-medium text-text-secondary dark:text-outline-variant">@prod.AverageRating.ToString("0.0") (@prod.ReviewCount)</span>
                                </div>
                            }

                            <div class="flex items-center justify-between pt-sm border-t border-border dark:border-white/5">
                                <span class="text-xl font-bold text-primary dark:text-primary-light">@prod.Price.ToString("N0") @Localizer["Currency_EGP"]</span>
                                <a asp-action="ProductDetails" asp-route-id="@prod.Id" class="w-10 h-10 rounded-xl bg-primary/10 text-primary dark:text-primary-light flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all">
                                    <span class="material-symbols-outlined text-lg">visibility</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- My Recent Reviews -->
    @if (ViewData["RecentReviews"] is List<DAKKN.Application.Features.BrandReviews.DTOs.BrandReviewDto> recentReviews && recentReviews.Count > 0)
    {
        <section class="space-y-xl">
            <div class="flex justify-between items-end mb-lg">
                <div>
                    <h2 class="font-h2 text-h2 font-bold text-text-primary dark:text-white">@Localizer["brand_reviews_my_reviews"]</h2>
                    <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["brand_reviews_recent"]</p>
                </div>
                <a asp-action="BrandReviews" class="text-primary dark:text-primary-light font-bold hover:underline flex items-center gap-1 text-sm">
                    @Localizer["admin_view_all"] <span class="material-symbols-outlined text-sm">arrow_forward</span>
                </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-xl">
                @foreach (var review in recentReviews)
                {
                    <div class="bg-surface dark:bg-[#1E293B] rounded-[32px] border border-border dark:border-white/5 p-xl shadow-medium hover:shadow-lg transition-all">
                        <div class="flex items-center gap-1 mb-md">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span class="material-symbols-outlined text-lg @(i <= review.Rating ? "text-amber-400 fill-icon" : "text-border dark:text-outline-variant")">star</span>
                            }
                            <span class="text-xs font-medium text-text-secondary dark:text-outline-variant ltr:ml-auto rtl:mr-auto">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>

                        <h4 class="font-bold text-text-primary dark:text-white mb-sm">@review.ReviewTitle</h4>
                        <p class="text-sm text-text-secondary dark:text-outline-variant line-clamp-3 leading-relaxed">
                            @(review.ReviewText.Length > 120 ? review.ReviewText[..120] + "..." : review.ReviewText)
                        </p>

                        <div class="mt-lg pt-md border-t border-border dark:border-white/5 text-right">
                            <a asp-action="BrandReviews" class="text-xs font-bold text-primary dark:text-primary-light hover:underline">@Localizer["brand_reviews_view"]</a>
                        </div>
                    </div>
                }
            </div>
        </section>
    }
</div>
