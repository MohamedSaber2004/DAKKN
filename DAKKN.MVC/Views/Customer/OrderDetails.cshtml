@using DAKKN.MVC.ViewModels.Customer
@using DAKKN.MVC.ViewModels.Admin
@model CustomerOrderDetailsViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["orders_details_title"];
}

<div class="max-w-5xl mx-auto px-lg py-xl space-y-xl">
    <!-- Back Button & Header -->
    <div class="space-y-md">
        <a asp-action="Orders" class="inline-flex items-center gap-2 text-text-secondary hover:text-primary transition-colors group">
            <span class="material-symbols-outlined text-lg rtl:rotate-180 group-hover:-translate-x-1 transition-transform">arrow_back</span>
            <span class="font-bold">@Localizer["orders_back"]</span>
        </a>
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
            <div>
                <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">
                    @Localizer["orders_details_title"] #@Model.OrderId
                </h1>
                <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["orders_details_subtitle"]</p>
            </div>
            @{
                var statusClass = Model.Status switch
                {
                    OrderStatus.Processing => "bg-primary/10 text-primary",
                    OrderStatus.Shipped => "bg-secondary/10 text-secondary",
                    OrderStatus.Delivered => "bg-success/10 text-success",
                    OrderStatus.Cancelled => "bg-error/10 text-error",
                    _ => "bg-surface-container dark:bg-white/5 text-text-secondary"
                };
                
                var statusIcon = Model.Status switch
                {
                    OrderStatus.Processing => "pending_actions",
                    OrderStatus.Shipped => "local_shipping",
                    OrderStatus.Delivered => "check_circle",
                    OrderStatus.Cancelled => "cancel",
                    _ => "info"
                };
            }
            <div class="flex items-center gap-2 px-6 py-3 rounded-2xl @statusClass font-bold shadow-small">
                <span class="material-symbols-outlined filled-icon">@statusIcon</span>
                <span>@Localizer[$"status_{Model.Status.ToString().ToLower()}"]</span>
            </div>
        </div>
    </div>

    <!-- Status Tracker -->
    <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg md:p-xl shadow-small overflow-hidden">
        <div class="relative flex justify-between items-center max-w-3xl mx-auto py-8">
            <!-- Progress Line -->
            <div class="absolute left-0 right-0 h-1 bg-surface-container dark:bg-white/10 top-1/2 -translate-y-1/2 rounded-full"></div>
            <div class="absolute left-0 h-1 bg-primary top-1/2 -translate-y-1/2 rounded-full transition-all duration-1000" 
                 style="width: @(Model.Status == OrderStatus.Delivered ? "100%" : Model.Status == OrderStatus.Shipped ? "66%" : "33%")"></div>

            <!-- Step 1: Placed -->
            <div class="relative z-10 flex flex-col items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center shadow-medium">
                    <span class="material-symbols-outlined">receipt_long</span>
                </div>
                <div class="text-center">
                    <p class="font-bold text-sm">@Localizer["status_pending"]</p>
                    <p class="text-xs text-text-secondary">@Model.OrderDate.ToString("MMM dd")</p>
                </div>
            </div>

            <!-- Step 2: Processing -->
            <div class="relative z-10 flex flex-col items-center gap-4">
                <div class="w-12 h-12 rounded-full @(Model.Status >= OrderStatus.Processing ? "bg-primary text-on-primary shadow-medium" : "bg-surface-container dark:bg-white/10 text-text-secondary") flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined">manufacturing</span>
                </div>
                <div class="text-center">
                    <p class="font-bold text-sm">@Localizer["status_processing"]</p>
                </div>
            </div>

            <!-- Step 3: Shipped -->
            <div class="relative z-10 flex flex-col items-center gap-4">
                <div class="w-12 h-12 rounded-full @(Model.Status >= OrderStatus.Shipped ? "bg-primary text-on-primary shadow-medium" : "bg-surface-container dark:bg-white/10 text-text-secondary") flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined">local_shipping</span>
                </div>
                <div class="text-center">
                    <p class="font-bold text-sm">@Localizer["status_shipped"]</p>
                </div>
            </div>

            <!-- Step 4: Delivered -->
            <div class="relative z-10 flex flex-col items-center gap-4">
                <div class="w-12 h-12 rounded-full @(Model.Status >= OrderStatus.Delivered ? "bg-primary text-on-primary shadow-medium" : "bg-surface-container dark:bg-white/10 text-text-secondary") flex items-center justify-center transition-colors">
                    <span class="material-symbols-outlined">home</span>
                </div>
                <div class="text-center">
                    <p class="font-bold text-sm">@Localizer["status_delivered"]</p>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
        <!-- Items List -->
        <div class="lg:col-span-2 space-y-lg">
            <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] overflow-hidden shadow-small transition-all">
                <div class="p-lg border-b border-border dark:border-outline/10 bg-surface-container-low dark:bg-white/5 flex items-center justify-between">
                    <h2 class="font-bold text-xl flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">shopping_bag</span>
                        @Localizer["admin_order_items"] (@Model.Items.Count)
                    </h2>
                </div>
                <div class="divide-y divide-border dark:divide-outline/10">
                    @foreach (var item in Model.Items)
                    {
                        <div class="p-lg flex items-center gap-6 hover:bg-primary/5 transition-colors group">
                            <div class="w-24 h-24 rounded-2xl overflow-hidden border border-border dark:border-outline/10 shadow-small flex-shrink-0">
                                <img src="@item.ImageUrl" alt="@item.ProductName" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            </div>
                            <div class="flex-grow min-w-0">
                                <h3 class="font-bold text-lg text-text-primary dark:text-inverse-on-surface truncate">@item.ProductName</h3>
                                <div class="flex flex-wrap gap-x-4 gap-y-1 mt-1 text-sm text-text-secondary">
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">straighten</span> @item.Dimensions</span>
                                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-xs">tag</span> SKU: @item.Sku</span>
                                </div>
                                <div class="flex items-center justify-between mt-4">
                                    <p class="font-bold text-primary">@item.UnitPrice.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</p>
                                    <p class="text-text-secondary font-bold">x @item.Quantity</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Activity Log -->
            <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg md:p-xl shadow-small">
                <h2 class="font-bold text-xl mb-xl flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">history</span>
                    @Localizer["admin_order_system_log"]
                </h2>
                <div class="space-y-lg relative before:content-[''] before:absolute before:top-2 before:bottom-2 before:left-4 before:w-px before:bg-border dark:before:bg-outline/10 rtl:before:left-auto rtl:before:right-4">
                    @foreach (var log in Model.Logs)
                    {
                        <div class="relative pl-12 rtl:pl-0 rtl:pr-12">
                            <div class="absolute left-3 rtl:left-auto rtl:right-3 top-1 w-3 h-3 rounded-full bg-primary border-4 border-surface dark:border-inverse-surface shadow-small"></div>
                            <p class="font-bold text-text-primary dark:text-inverse-on-surface">@log.Message</p>
                            <p class="text-xs text-text-secondary mt-1">@log.Timestamp</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Summary & Info Sidebar -->
        <div class="space-y-lg">
            <!-- Shipping Info -->
            <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg shadow-small transition-all">
                <h2 class="font-bold text-xl mb-lg flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">location_on</span>
                    @Localizer["orders_shipping_info"]
                </h2>
                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-surface-container dark:bg-white/5 flex items-center justify-center text-text-secondary">
                            <span class="material-symbols-outlined text-lg">person</span>
                        </div>
                        <div>
                            <p class="text-xs text-text-secondary uppercase font-bold tracking-wider">@Localizer["checkout_name"]</p>
                            <p class="font-bold">Ahmed Mahmoud</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-surface-container dark:bg-white/5 flex items-center justify-center text-text-secondary">
                            <span class="material-symbols-outlined text-lg">map</span>
                        </div>
                        <div>
                            <p class="text-xs text-text-secondary uppercase font-bold tracking-wider">@Localizer["checkout_address"]</p>
                            <p class="font-bold">@Model.ShippingAddress</p>
                            <p class="text-sm">@Model.ShippingGovernorate</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-10 h-10 rounded-full bg-surface-container dark:bg-white/5 flex items-center justify-center text-text-secondary">
                            <span class="material-symbols-outlined text-lg">call</span>
                        </div>
                        <div>
                            <p class="text-xs text-text-secondary uppercase font-bold tracking-wider">@Localizer["checkout_phone"]</p>
                            <p class="font-bold">@Model.ShippingPhone</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg shadow-small transition-all">
                <h2 class="font-bold text-xl mb-lg flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">payments</span>
                    @Localizer["orders_summary"]
                </h2>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-text-secondary">@Localizer["orders_subtotal"]</span>
                        <span class="font-bold">@Model.Subtotal.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-text-secondary">@Localizer["orders_shipping"]</span>
                        <span class="font-bold text-success">@Model.ShippingFee.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</span>
                    </div>
                    <div class="pt-4 border-t border-border dark:border-outline/10 flex justify-between items-center">
                        <span class="text-lg font-bold">@Localizer["orders_total"]</span>
                        <span class="text-2xl font-bold text-primary">@Model.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</span>
                    </div>
                </div>
                
                <div class="mt-xl space-y-md">
                    @if (Model.Status == OrderStatus.Shipped || Model.Status == OrderStatus.Delivered)
                    {
                        <button class="w-full bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background py-4 rounded-2xl font-bold hover:scale-[1.02] active:scale-[0.98] transition-all shadow-medium flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">local_shipping</span>
                            @Localizer["orders_track_shipment"]
                        </button>
                    }
                    <button class="w-full bg-surface-container dark:bg-white/5 text-text-primary dark:text-inverse-on-surface border border-border dark:border-outline/20 py-4 rounded-2xl font-bold hover:bg-primary/5 transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">support_agent</span>
                        @Localizer["orders_help"]
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .filled-icon {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
}
