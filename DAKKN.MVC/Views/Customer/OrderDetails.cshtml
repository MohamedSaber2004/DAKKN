@using DAKKN.MVC.ViewModels.Customer
@using DAKKN.Domain.Enums
@model CustomerOrderDetailsViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["order_details"] + " #" + Model.OrderNumber;
}

<div class="max-w-5xl mx-auto px-lg py-xl space-y-xl">
    <!-- Order Header -->
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-md">
        <div>
            <div class="flex flex-wrap items-center gap-sm mb-xs">
                <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">@Model.OrderNumber</h1>
                @{
                    var statusClass = Model.Status switch
                    {
                        OrderStatus.Delivered => "bg-primary/10 text-primary",
                        OrderStatus.Processing => "bg-secondary/10 text-secondary",
                        OrderStatus.Shipped => "bg-tertiary/10 text-tertiary",
                        OrderStatus.Cancelled => "bg-error/10 text-error",
                        OrderStatus.Pending => "bg-primary/10 text-primary",
                        _ => "bg-surface-container-highest text-text-secondary"
                    };
                }
                <span class="@statusClass px-sm py-xs rounded-full text-caption font-bold">@Localizer[$"order_status_{Model.Status.ToString()}"]</span>
            </div>
            <p class="text-body text-text-secondary dark:text-outline-variant">
                @Localizer["order_date"]: @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy - HH:mm")
            </p>
            @if (!string.IsNullOrEmpty(Model.TrackingNumber))
            {
                <p class="text-body text-text-secondary dark:text-outline-variant">
                    @Localizer["order_tracking"]: <span dir="ltr">@Model.TrackingNumber</span>
                </p>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-lg">
        <!-- Left: Items & History -->
        <div class="lg:col-span-2 space-y-lg">
            <!-- Order Items -->
            <section class="bg-surface dark:bg-inverse-surface rounded-[32px] border border-border dark:border-outline/10 overflow-hidden shadow-small">
                <div class="p-lg border-b border-border dark:border-outline/10">
                    <h3 class="text-h4 font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["order_items"] (@Model.Items.Count)</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-start border-collapse">
                        <thead class="text-caption text-text-secondary dark:text-outline border-b border-border dark:border-outline/10">
                            <tr>
                                <th class="p-md text-start">@Localizer["admin_order_product"]</th>
                                <th class="p-md text-start">@Localizer["admin_order_qty"]</th>
                                <th class="p-md text-start">@Localizer["admin_order_price"]</th>
                                <th class="p-md text-start">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border dark:divide-outline/10">
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="p-md">
                                        <div class="flex items-center gap-md">
                                            @if (!string.IsNullOrEmpty(item.ProductImageUrl))
                                            {
                                                <div class="w-12 h-12 rounded-lg border border-border dark:border-outline/20 overflow-hidden bg-surface-container-low flex-shrink-0">
                                                    <img src="@item.ProductImageUrl" alt="@item.ProductName" class="w-full h-full object-cover">
</div>

<!-- Cancel Order Modal -->
<div id="cancel-modal" class="fixed inset-0 z-[100] flex items-center justify-center hidden" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeCancelModal()"></div>
    <div class="relative bg-surface dark:bg-inverse-surface rounded-[32px] shadow-2xl border border-border dark:border-outline/10 p-xl max-w-md w-[90%] mx-4">
        <button onclick="closeCancelModal()" class="absolute top-4 end-4 w-10 h-10 rounded-full bg-surface-container dark:bg-surface-container-high hover:bg-primary/10 flex items-center justify-center text-text-secondary hover:text-primary transition-all">
            <span class="material-symbols-outlined text-xl">close</span>
        </button>
        <div class="w-14 h-14 rounded-2xl bg-error/10 flex items-center justify-center mx-auto mb-lg">
            <span class="material-symbols-outlined text-3xl text-error">cancel</span>
        </div>
        <h3 class="text-h3 font-bold text-center text-text-primary dark:text-inverse-on-surface mb-sm">@Localizer["order_cancel"]</h3>
        <p class="text-body text-center text-text-secondary mb-xl">@Localizer["order_cancel_confirm"]</p>
        <div class="space-y-lg">
            <div class="flex flex-col gap-xs">
                <label class="font-bold text-sm text-outline px-1 uppercase">@Localizer["order_cancel_reason_ph"]</label>
                <textarea id="cancel-reason" rows="3" class="bg-surface-container dark:bg-surface-container-high border border-border dark:border-outline/10 rounded-xl p-md w-full resize-none focus:ring-1 focus:ring-primary outline-none" placeholder="@Localizer["order_cancel_reason_ph"]"></textarea>
            </div>
            <div class="flex gap-md">
                <button onclick="closeCancelModal()" class="flex-1 bg-surface-container dark:bg-surface-container-high border border-border dark:border-outline/10 px-lg py-3 rounded-full font-bold hover:brightness-95 transition-all">
                    @Localizer["order_cancel_back"]
                </button>
                <button id="confirm-cancel-btn" onclick="submitCancel()" class="flex-1 bg-error text-on-primary px-lg py-3 rounded-full font-bold hover:brightness-110 transition-all">
                    @Localizer["order_cancel"]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cancelOrderId = null;

        function openCancelModal(orderId) {
            cancelOrderId = orderId;
            document.getElementById('cancel-reason').value = '';
            document.getElementById('cancel-modal').classList.remove('hidden');
        }

        function closeCancelModal() {
            document.getElementById('cancel-modal').classList.add('hidden');
            cancelOrderId = null;
        }

        function submitCancel() {
            const btn = document.getElementById('confirm-cancel-btn');
            btn.disabled = true;
            btn.textContent = '@Localizer["loading"]';

            const reason = document.getElementById('cancel-reason').value.trim();

            fetch('/customer/order-details/' + cancelOrderId + '/cancel', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ reason: reason || null })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || '@Localizer["order_cancel_error"]');
                    btn.disabled = false;
                    btn.textContent = '@Localizer["order_cancel"]';
                }
            })
            .catch(err => {
                console.error('Cancel error:', err);
                alert('@Localizer["order_cancel_error"]');
                btn.disabled = false;
                btn.textContent = '@Localizer["order_cancel"]';
            });
        }
    </script>
}
                                            }
                                            <p class="font-bold text-text-primary dark:text-inverse-on-surface">@item.ProductName</p>
                                        </div>
                                    </td>
                                    <td class="p-md text-text-secondary">@item.Quantity</td>
                                    <td class="p-md whitespace-nowrap text-text-secondary">@item.UnitPrice.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                                    <td class="p-md whitespace-nowrap font-bold text-text-primary dark:text-inverse-on-surface">@item.TotalPrice.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-surface-container-low dark:bg-surface-container-highest/20">
                            <tr>
                                <td colspan="3" class="p-md text-end font-bold">@Localizer["order_subtotal"]</td>
                                <td class="p-md font-bold">@Model.Subtotal.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="p-md text-end">@Localizer["order_shipping"]</td>
                                <td class="p-md">@Model.ShippingCost.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                            </tr>
                            <tr class="text-primary">
                                <td colspan="3" class="p-md text-end font-bold text-h4">@Localizer["order_total"]</td>
                                <td class="p-md font-bold text-h4">@Model.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </section>

            <!-- Status History -->
            <section class="bg-surface dark:bg-inverse-surface p-lg rounded-[32px] border border-border dark:border-outline/10 shadow-small">
                <h3 class="text-h4 font-bold mb-md text-text-primary dark:text-inverse-on-surface flex items-center gap-sm">
                    <span class="material-symbols-outlined text-primary">history</span>
                    @Localizer["order_history"]
                </h3>
                <div class="space-y-md relative ltr:before:left-2 rtl:before:right-2 before:content-[''] before:absolute before:top-2 before:bottom-2 before:w-px before:bg-border dark:before:bg-outline/10">
                    @foreach (var log in Model.StatusHistory)
                    {
                        <div class="relative ltr:pl-8 rtl:pr-8">
                            <div class="absolute ltr:left-0 rtl:right-0 top-1 w-4 h-4 rounded-full bg-primary border-4 border-surface dark:border-inverse-surface"></div>
                            <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">
                                @Localizer[$"order_status_{log.Status.ToString()}"]
                            </p>
                            <p class="text-caption text-text-secondary dark:text-outline">
                                @log.ChangedAt.ToLocalTime().ToString("dd MMM yyyy - HH:mm")
                            </p>
                        </div>
                    }
                    @if (Model.StatusHistory.Count == 0)
                    {
                        <p class="text-body text-text-secondary">@Localizer["order_history_empty"]</p>
                    }
                </div>
            </section>
        </div>

        <!-- Right: Shipping Info -->
        <div class="space-y-lg">
            <section class="bg-surface dark:bg-inverse-surface p-lg rounded-[32px] border border-border dark:border-outline/10 shadow-small">
                <h3 class="text-h4 font-bold mb-md text-text-primary dark:text-inverse-on-surface flex items-center gap-sm">
                    <span class="material-symbols-outlined text-primary">local_shipping</span>
                    @Localizer["order_shipping_address"]
                </h3>
                <div class="space-y-sm">
                    <div>
                        <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_shipping_address"]</p>
                        <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.ShippingAddress</p>
                    </div>
                    <div>
                        <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_governorate"]</p>
                        <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface">@Model.ShippingGovernorate</p>
                    </div>
                    <div>
                        <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_phone"]</p>
                        <p class="text-body font-bold text-text-primary dark:text-inverse-on-surface" dir="ltr">@Model.ShippingPhone</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div>
                            <p class="text-caption text-text-secondary dark:text-outline">@Localizer["order_notes"]</p>
                            <p class="text-body text-text-primary dark:text-inverse-on-surface">@Model.Notes</p>
                        </div>
                    }
                </div>
            </section>

            @if (Model.Status == OrderStatus.Pending || Model.Status == OrderStatus.Confirmed || Model.Status == OrderStatus.Processing)
            {
                <button onclick="openCancelModal('@Model.Id')" class="w-full bg-error text-on-primary px-lg py-3 rounded-full font-bold hover:brightness-110 transition-all">
                    @Localizer["order_cancel"]
                </button>
            }
            @if (Model.Status == OrderStatus.Cancelled || Model.Status == OrderStatus.Delivered)
            {
                <form asp-action="DeleteOrder" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="w-full bg-outline text-on-primary px-lg py-3 rounded-full font-bold hover:brightness-110 transition-all" onclick="return confirm('@Localizer["order_delete_confirm"]')">
                        @Localizer["order_delete"]
                    </button>
                </form>
            }
        </div>
    </div>
</div>
