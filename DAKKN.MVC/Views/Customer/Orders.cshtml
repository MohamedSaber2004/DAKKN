@using DAKKN.MVC.ViewModels.Customer
@using DAKKN.Domain.Enums
@model CustomerOrderListViewModel
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["nav_orders"];
}

<div class="max-w-5xl mx-auto px-lg py-xl space-y-xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
        <div>
            <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">
                @Localizer["nav_orders"] 
                <span class="text-primary bg-primary/10 px-3 py-1 rounded-2xl text-2xl ml-2">@Model.Orders.Count</span>
            </h1>
            <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["orders_p"]</p>
        </div>
    </div>

    <div id="orders-list" class="space-y-lg pt-md">
        @foreach (var order in Model.Orders)
        {
            var statusClass = order.Status switch
            {
                OrderStatus.Pending => "bg-primary/10 text-primary",
                OrderStatus.Processing => "bg-secondary/10 text-secondary",
                OrderStatus.Shipped => "bg-tertiary/10 text-tertiary",
                OrderStatus.Delivered => "bg-success/10 text-success",
                OrderStatus.Cancelled => "bg-error/10 text-error",
                _ => "bg-surface-container-highest text-text-secondary"
            };

            <div class="order-card group bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg md:p-xl shadow-small hover:shadow-large transition-all duration-500">
                <div class="flex flex-wrap items-center justify-between gap-4 mb-xl">
                    <div class="flex flex-col gap-1">
                        <span class="text-text-secondary text-xs font-bold uppercase tracking-widest">@Localizer["orders_id_label"]</span>
                        <h3 class="text-xl font-bold text-text-primary dark:text-inverse-on-surface">@order.OrderNumber</h3>
                    </div>
                    <div class="flex items-center gap-2 px-5 py-2 rounded-full @statusClass">
                        <span class="text-sm font-bold">@Localizer[$"order_status_{order.Status.ToString()}"]</span>
                    </div>
                </div>

                <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-xl py-xl border-y border-border dark:border-outline/10">
                    <div class="flex items-center gap-6">
                        <div>
                            <div class="text-2xl font-bold text-text-primary dark:text-inverse-on-surface">@order.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</div>
                            <div class="text-sm text-text-secondary">@Localizer["order_item_count", order.ItemCount]</div>
                        </div>
                    </div>
                    <div class="text-text-secondary text-sm flex items-center gap-2 bg-surface-container dark:bg-white/5 px-4 py-2 rounded-xl">
                        <span class="material-symbols-outlined text-lg">schedule</span>
                        @order.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                    </div>
                </div>

                <div class="flex items-center justify-between mt-xl">
                    <a asp-action="OrderDetails" asp-route-id="@order.Id" class="text-primary font-bold flex items-center gap-2 hover:underline">
                        @Localizer["order_view_details"]
                        <span class="material-symbols-outlined rtl:rotate-180">arrow_right_alt</span>
                    </a>
                </div>
            </div>
        }
    </div>

    @if (Model.Orders.Count == 0)
    {
        <div class="py-32 text-center space-y-xl bg-surface dark:bg-inverse-surface rounded-[40px] border border-dashed border-border dark:border-outline/20">
            <div class="w-24 h-24 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-outline opacity-30">
                <span class="material-symbols-outlined text-5xl">package_2</span>
            </div>
            <div class="space-y-md">
                <h2 class="text-2xl font-bold">@Localizer["order_no_orders"]</h2>
                <p class="text-text-secondary max-w-sm mx-auto">@Localizer["order_no_orders_desc"]</p>
            </div>
            <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold hover:shadow-large hover:-translate-y-1 transition-all">
                @Localizer["order_continue_shopping"] <span class="material-symbols-outlined">arrow_forward</span>
            </a>
        </div>
    }
</div>
