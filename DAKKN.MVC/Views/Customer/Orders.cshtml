@using DAKKN.MVC.ViewModels.Customer
@model CustomerDashboardViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["admin_orders"];
}

<div class="max-w-5xl mx-auto px-lg py-xl space-y-xl">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-lg">
        <div>
            <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">
                @Localizer["admin_orders"] 
                <span class="text-primary bg-primary/10 px-3 py-1 rounded-2xl text-2xl ml-2">4</span>
            </h1>
            <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["orders_p"]</p>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="flex items-center gap-sm overflow-x-auto pb-4 no-scrollbar border-b border-border dark:border-outline/10">
        <button onclick="filterOrders('all')" class="order-filter-tab active px-xl py-3 rounded-full bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background font-bold whitespace-nowrap shadow-medium transition-all" data-filter="all">
            @Localizer["orders_filter_all"]
        </button>
        <button onclick="filterOrders('active')" class="order-filter-tab px-xl py-3 rounded-full bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 text-text-secondary hover:bg-primary/5 whitespace-nowrap transition-all" data-filter="active">
            @Localizer["orders_filter_active"]
        </button>
        <button onclick="filterOrders('completed')" class="order-filter-tab px-xl py-3 rounded-full bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 text-text-secondary hover:bg-primary/5 whitespace-nowrap transition-all" data-filter="completed">
            @Localizer["orders_filter_completed"]
        </button>
    </div>

    <!-- Orders List -->
    <div id="orders-list" class="space-y-lg pt-md">
        
        <!-- Order Card 1 (Processing) -->
        <div class="order-card group bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg md:p-xl shadow-small hover:shadow-large transition-all duration-500" data-status="active">
            <div class="flex flex-wrap items-center justify-between gap-4 mb-xl">
                <div class="flex flex-col gap-1">
                    <span class="text-text-secondary text-xs font-bold uppercase tracking-widest">@Localizer["orders_id_label"]</span>
                    <h3 class="text-xl font-bold text-text-primary dark:text-inverse-on-surface">#DK-2024-892A</h3>
                </div>
                
                <div class="flex items-center gap-2 px-5 py-2 rounded-full bg-primary/10 text-primary">
                    <span class="material-symbols-outlined text-lg filled-icon">pending_actions</span>
                    <span class="text-sm font-bold">@Localizer["status_processing"]</span>
                </div>
            </div>

            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-xl py-xl border-y border-border dark:border-outline/10">
                <div class="flex items-center gap-6">
                    <!-- Overlapping Thumbnails -->
                    <div class="flex -space-x-4 rtl:space-x-reverse">
                        <img src="https://lh3.googleusercontent.com/aida/AP1WRLvk0o2fHlsgnzmZ9xrrRAnUTq9hl5CW063LX44OhYiXj0ZAadSE46fIAmtHQKBEzfk8NKsMl6AwohhVGiDgxsbst33TGFkDW68Y9_d3C1Cvf-mtviXqQYHM-Aqnsunu3Q6Yy2-9A5mXcsO80D173UvbE44Odz0GI41kQbHK_cLtDiruHCKTT15snGH5XT7Y6MLMfFd4rUCTY71ZJwiOba19bKW0Du2pMXYtJtF-I-h5V-wypv1z0Vztp_M" class="w-16 h-16 rounded-2xl border-4 border-surface dark:border-inverse-surface object-cover shadow-small" alt="Sticker 1">
                        <img src="https://lh3.googleusercontent.com/aida/AP1WRLvk0o2fHlsgnzmZ9xrrRAnUTq9hl5CW063LX44OhYiXj0ZAadSE46fIAmtHQKBEzfk8NKsMl6AwohhVGiDgxsbst33TGFkDW68Y9_d3C1Cvf-mtviXqQYHM-Aqnsunu3Q6Yy2-9A5mXcsO80D173UvbE44Odz0GI41kQbHK_cLtDiruHCKTT15snGH5XT7Y6MLMfFd4rUCTY71ZJwiOba19bKW0Du2pMXYtJtF-I-h5V-wypv1z0Vztp_M" class="w-16 h-16 rounded-2xl border-4 border-surface dark:border-inverse-surface object-cover shadow-small" alt="Sticker 2">
                        <div class="w-16 h-16 rounded-2xl border-4 border-surface dark:border-inverse-surface bg-surface-container-high dark:bg-white/10 flex items-center justify-center text-text-secondary font-bold shadow-small">+1</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-text-primary dark:text-inverse-on-surface">245.00 @Html.Raw(Localizer["Currency_EGP"])</div>
                        <div class="text-sm text-text-secondary">3 @Localizer["admin_order_items"]</div>
                    </div>
                </div>
                
                <div class="text-text-secondary text-sm flex items-center gap-2 bg-surface-container dark:bg-white/5 px-4 py-2 rounded-xl">
                    <span class="material-symbols-outlined text-lg">schedule</span>
                    2 @Localizer["admin_time_ago", "hours"]
                </div>
            </div>

            <div class="flex items-center justify-between mt-xl">
                <a asp-action="OrderDetails" asp-route-id="DK-2024-892A" class="text-primary font-bold flex items-center gap-2 hover:underline">
                    @Localizer["orders_view_details"]
                    <span class="material-symbols-outlined rtl:rotate-180">arrow_right_alt</span>
                </a>
                <button class="bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background px-xl py-3 rounded-full font-bold hover:scale-105 active:scale-95 transition-all shadow-medium">
                    @Localizer["orders_track_order"]
                </button>
            </div>
        </div>

        <!-- Order Card 2 (Delivered) -->
        <div class="order-card group bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 rounded-[32px] p-lg md:p-xl shadow-small hover:shadow-large transition-all duration-500" data-status="completed">
            <div class="flex flex-wrap items-center justify-between gap-4 mb-xl">
                <div class="flex flex-col gap-1">
                    <span class="text-text-secondary text-xs font-bold uppercase tracking-widest">@Localizer["orders_id_label"]</span>
                    <h3 class="text-xl font-bold text-text-primary dark:text-inverse-on-surface">#DK-2024-712B</h3>
                </div>
                
                <div class="flex items-center gap-2 px-5 py-2 rounded-full bg-success/10 text-success">
                    <span class="material-symbols-outlined text-lg filled-icon">check_circle</span>
                    <span class="text-sm font-bold">@Localizer["status_delivered"]</span>
                </div>
            </div>

            <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-xl py-xl border-y border-border dark:border-outline/10">
                <div class="flex items-center gap-6">
                    <div class="flex -space-x-4 rtl:space-x-reverse">
                        <img src="https://lh3.googleusercontent.com/aida/AP1WRLvk0o2fHlsgnzmZ9xrrRAnUTq9hl5CW063LX44OhYiXj0ZAadSE46fIAmtHQKBEzfk8NKsMl6AwohhVGiDgxsbst33TGFkDW68Y9_d3C1Cvf-mtviXqQYHM-Aqnsunu3Q6Yy2-9A5mXcsO80D173UvbE44Odz0GI41kQbHK_cLtDiruHCKTT15snGH5XT7Y6MLMfFd4rUCTY71ZJwiOba19bKW0Du2pMXYtJtF-I-h5V-wypv1z0Vztp_M" class="w-16 h-16 rounded-2xl border-4 border-surface dark:border-inverse-surface object-cover shadow-small" alt="Sticker 3">
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-text-primary dark:text-inverse-on-surface">80.00 @Html.Raw(Localizer["Currency_EGP"])</div>
                        <div class="text-sm text-text-secondary">1 @Localizer["admin_order_items"]</div>
                    </div>
                </div>
                
                <div class="text-text-secondary text-sm flex items-center gap-2 bg-surface-container dark:bg-white/5 px-4 py-2 rounded-xl">
                    <span class="material-symbols-outlined text-lg">calendar_today</span>
                    May 12, 2024
                </div>
            </div>

            <div class="flex items-center justify-between mt-xl">
                <a asp-action="OrderDetails" asp-route-id="DK-2024-892A" class="text-primary font-bold flex items-center gap-2 hover:underline">
                    @Localizer["orders_view_details"]
                    <span class="material-symbols-outlined rtl:rotate-180">arrow_right_alt</span>
                </a>
                <button class="bg-surface-container dark:bg-white/10 text-text-primary dark:text-inverse-on-surface border border-border dark:border-outline/20 px-xl py-3 rounded-full font-bold hover:bg-primary hover:text-on-primary hover:border-primary active:scale-95 transition-all">
                    @Localizer["orders_reorder"]
                </button>
            </div>
        </div>

    </div>

    <!-- Empty State -->
    <div id="orders-empty" class="hidden py-32 text-center space-y-xl bg-surface dark:bg-inverse-surface rounded-[40px] border border-dashed border-border dark:border-outline/20">
        <div class="w-24 h-24 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-outline opacity-30">
            <span class="material-symbols-outlined text-5xl">package_2</span>
        </div>
        <div class="space-y-md">
            <h2 class="text-2xl font-bold">@Localizer["orders_empty_h"]</h2>
            <p class="text-text-secondary max-w-sm mx-auto">@Localizer["orders_empty_p"]</p>
        </div>
        <a asp-action="Products" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold hover:shadow-large hover:-translate-y-1 transition-all">
            @Localizer["orders_empty_btn"] <span class="material-symbols-outlined">arrow_forward</span>
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function filterOrders(status) {
            // Update Tab UI
            document.querySelectorAll('.order-filter-tab').forEach(tab => {
                if (tab.dataset.filter === status) {
                    tab.classList.add('bg-text-primary', 'dark:bg-inverse-on-surface', 'text-background', 'dark:text-on-background', 'shadow-medium');
                    tab.classList.remove('bg-surface', 'dark:bg-inverse-surface', 'text-text-secondary', 'border-border', 'dark:border-outline/10');
                } else {
                    tab.classList.remove('bg-text-primary', 'dark:bg-inverse-on-surface', 'text-background', 'dark:text-on-background', 'shadow-medium');
                    tab.classList.add('bg-surface', 'dark:bg-inverse-surface', 'text-text-secondary', 'border-border', 'dark:border-outline/10');
                }
            });

            // Filter Cards
            const cards = document.querySelectorAll('.order-card');
            let visibleCount = 0;

            cards.forEach(card => {
                if (status === 'all' || card.dataset.status === status) {
                    card.style.display = 'block';
                    card.style.animation = 'fadeIn 0.4s ease-out forwards';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            // Handle Empty State
            const emptyState = document.getElementById('orders-empty');
            const ordersList = document.getElementById('orders-list');
            
            if (visibleCount === 0) {
                ordersList.classList.add('hidden');
                emptyState.classList.remove('hidden');
            } else {
                ordersList.classList.remove('hidden');
                emptyState.classList.add('hidden');
            }
        }

        // Initial check
        window.addEventListener('DOMContentLoaded', () => {
            const cards = document.querySelectorAll('.order-card');
            if (cards.length === 0) {
                filterOrders('all'); // Triggers empty state
            }
        });
    </script>
}

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
