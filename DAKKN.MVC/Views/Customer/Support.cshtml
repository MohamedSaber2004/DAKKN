@using DAKKN.MVC.ViewModels.Customer
@using DAKKN.MVC.ViewModels.Admin
@model CustomerSupportDashboardViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["nav_support"];
}

<div class="max-w-6xl mx-auto px-lg py-xl space-y-2xl">
    <!-- Hero Header -->
    <div class="text-center space-y-md">
        <h1 class="customer-page-title text-text-primary dark:text-inverse-on-surface">@Localizer["supp_dashboard_title"]</h1>
        <p class="text-text-secondary dark:text-outline-variant max-w-2xl mx-auto">@Localizer["orders_details_subtitle"]</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-success/10 border border-success/20 text-success p-lg rounded-2xl flex items-center gap-4 animate-in fade-in slide-in-from-top-4">
            <span class="material-symbols-outlined">check_circle</span>
            <p class="font-bold">@TempData["SuccessMessage"]</p>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
        <!-- Main Content: Ticket List -->
        <div class="lg:col-span-2 space-y-lg">
            <div class="flex items-center justify-between">
                <h2 class="font-bold text-2xl flex items-center gap-3">
                    <span class="material-symbols-outlined text-primary">confirmation_number</span>
                    @Localizer["supp_previous_tickets"]
                </h2>
                <a asp-action="NewTicket" class="bg-primary text-on-primary px-xl py-3 rounded-2xl font-bold hover:shadow-large hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined">add</span>
                    @Localizer["supp_new_ticket"]
                </a>
            </div>

            <div class="space-y-md">
                @if (Model.Tickets.Any())
                {
                    @foreach (var ticket in Model.Tickets)
                    {
                        var statusClass = ticket.Status switch
                        {
                            TicketStatus.Open => "bg-primary/10 text-primary",
                            TicketStatus.InProgress => "bg-secondary/10 text-secondary",
                            TicketStatus.Resolved => "bg-success/10 text-success",
                            _ => "bg-surface-container text-text-secondary"
                        };

                        <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 p-lg rounded-3xl hover:border-primary/30 transition-all group">
                            <div class="flex flex-col md:flex-row justify-between gap-lg">
                                <div class="space-y-2">
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs font-bold text-text-secondary uppercase tracking-widest">#@ticket.TicketId</span>
                                        <span class="status-pill @statusClass">
                                            @Localizer[$"admin_support_{ticket.Status.ToString().ToLower()}"]
                                        </span>
                                    </div>
                                    <h3 class="font-bold text-lg group-hover:text-primary transition-colors">@ticket.Subject</h3>
                                    <p class="text-sm text-text-secondary line-clamp-1">@Localizer["supp_last_activity"] @ticket.CreatedAt.ToShortDateString()</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <button class="w-12 h-12 rounded-2xl bg-surface-container dark:bg-white/5 flex items-center justify-center text-text-secondary hover:text-primary transition-all">
                                        <span class="material-symbols-outlined">chat_bubble</span>
                                    </button>
                                    <button class="px-lg h-12 rounded-2xl border border-border dark:border-outline/20 font-bold text-sm hover:bg-primary/5 transition-all">
                                        @Localizer["supp_view_details"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-20 bg-surface-container/30 dark:bg-white/5 rounded-[40px] border border-dashed border-border dark:border-outline/20 space-y-lg">
                        <div class="w-20 h-20 bg-surface-container dark:bg-white/10 rounded-full flex items-center justify-center mx-auto text-outline/30">
                            <span class="material-symbols-outlined text-4xl">support_agent</span>
                        </div>
                        <div class="space-y-md">
                            <h3 class="font-bold text-xl">@Localizer["supp_no_tickets"]</h3>
                            <p class="text-text-secondary max-w-sm mx-auto">@Localizer["supp_no_tickets_desc"]</p>
                        </div>
                        <a asp-action="NewTicket" class="inline-flex items-center gap-2 bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background px-xl py-3.5 rounded-2xl font-bold hover:scale-105 active:scale-95 transition-all">
                            @Localizer["supp_create_first_ticket"]
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar: Contact Info -->
        <div class="space-y-xl">
            <h2 class="font-bold text-2xl flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">alternate_email</span>
                @Localizer["supp_quick_help"]
            </h2>

            <div class="space-y-md">
                <!-- WhatsApp -->
                <a href="https://wa.me/@Model.ContactInfo.WhatsApp" target="_blank" class="block bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 p-lg rounded-3xl hover:border-[#25D366]/50 transition-all group relative overflow-hidden">
                    <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-[#25D366]/5 rounded-full blur-2xl group-hover:bg-[#25D366]/10 transition-colors"></div>
                    <div class="flex items-center gap-4">
                        <div class="w-14 h-14 rounded-2xl bg-[#25D366]/10 flex items-center justify-center text-[#25D366]">
                            <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.353-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.87 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                        </div>
                        <div>
                            <p class="text-xs text-text-secondary uppercase font-bold tracking-widest">@Localizer["supp_instant_chat"]</p>
                            <h3 class="font-bold text-lg">@Localizer["supp_contact_wa"]</h3>
                        </div>
                    </div>
                </a>

                <!-- Phone -->
                <a href="tel:@Model.ContactInfo.Phone" class="block bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 p-lg rounded-3xl hover:border-primary/50 transition-all group relative overflow-hidden">
                    <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors"></div>
                    <div class="flex items-center gap-4">
                        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined text-3xl">phone</span>
                        </div>
                        <div>
                            <p class="text-xs text-text-secondary uppercase font-bold tracking-widest">@Localizer["supp_phone_support"]</p>
                            <h3 class="font-bold text-lg">@Model.ContactInfo.Phone</h3>
                        </div>
                    </div>
                </a>

                <!-- Socials -->
                <div class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 p-lg rounded-3xl space-y-lg">
                    <p class="text-xs text-text-secondary uppercase font-bold tracking-widest px-2">@Localizer["supp_follow_updates"]</p>
                    <div class="flex justify-between items-center px-2">
                        <a href="#" class="flex flex-col items-center gap-2 group">
                            <div class="w-12 h-12 rounded-2xl bg-surface-container dark:bg-white/5 flex items-center justify-center group-hover:bg-[#E1306C]/10 group-hover:text-[#E1306C] transition-all">
                                <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.819.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.125-1.664 4.671-4.919 4.819-1.265.058-1.645.069-4.85.069-3.204 0-3.584-.012-4.849-.069-3.254-.149-4.77-1.691-4.919-4.819-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.125 1.664-4.671 4.919-4.819 1.265-.057 1.644-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                            </div>
                            <span class="text-xs font-bold">@Localizer["social_instagram"]</span>
                        </a>
                        <a href="#" class="flex flex-col items-center gap-2 group">
                            <div class="w-12 h-12 rounded-2xl bg-surface-container dark:bg-white/5 flex items-center justify-center group-hover:bg-text-primary group-hover:text-background transition-all">
                                <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.036 2.612.012 3.914.012.317.316.662.612.98.943 1.134.024 2.268.012 3.402.012.114.39.228.78.342 1.17 1.066.012 2.132.012 3.198 0-.084 1.344-.144 2.688-.24 4.032-.576.012-1.164.012-1.74 0-.108 1.164-.228 2.316-.324 3.48-.12.876-.432 1.728-.852 2.508-.348.648-.84 1.236-1.44 1.68-.696.516-1.5.888-2.352 1.044-1.044.18-2.112.192-3.156.036-1.08-.156-2.112-.552-2.988-1.224a5.96 5.96 0 01-1.92-2.7c-.24-.768-.348-1.572-.324-2.376.012-1.2.3-2.388.852-3.468a6.3 6.3 0 011.668-2.112c1.116-.876 2.52-1.392 3.936-1.428.168.108.348.192.528.276-1.02.108-2.028.468-2.88 1.068a4.9 4.9 0 00-1.8 2.376c-.228.696-.3 1.428-.216 2.16.084.792.36 1.56.816 2.22.612.876 1.536 1.488 2.556 1.74 1.056.24 2.184.18 3.204-.156 1-.348 1.872-.996 2.472-1.848.552-.756.888-1.656.96-2.58.072-.888.024-1.788-.132-2.676-.048-.3-.12-.612-.192-.912l.144-.012c.048-.06.096-.108.132-.168.216-.408.432-.828.648-1.236-.612.012-1.224 0-1.836 0v-.12c-.528.012-1.056 0-1.584 0l.012-.036c.216-.408.432-.816.648-1.236.216-.408.42-.816.636-1.236l-1.056.024c-.156.3-.324.6-.48.912-.168.324-.348.636-.516.96-.924.012-1.848 0-2.772 0l-.06-.132c.312-.588.624-1.188.936-1.788.168-.312.336-.624.504-.948l-1.056.024c-.168.3-.324.6-.492.9-.156.312-.324.612-.48.912h-2.184L12.525.02z"/></svg>
                            </div>
                            <span class="text-xs font-bold">@Localizer["social_tiktok"]</span>
                        </a>
                        <a href="#" class="flex flex-col items-center gap-2 group">
                            <div class="w-12 h-12 rounded-2xl bg-surface-container dark:bg-white/5 flex items-center justify-center group-hover:bg-[#FF0000]/10 group-hover:text-[#FF0000] transition-all">
                                <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.016 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.016 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                            </div>
                            <span class="text-xs font-bold">@Localizer["social_youtube"]</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
