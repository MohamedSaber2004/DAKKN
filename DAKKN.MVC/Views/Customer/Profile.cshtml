@inject IStringLocalizer<Messages> Localizer
@model CustomerProfileViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["profile_title"];
}

<div class="max-w-4xl mx-auto px-lg py-xl space-y-lg pb-32">
    <!-- Header -->
    <div class="mb-xl">
        <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-white">@Localizer["nav_profile"]</h1>
        <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["profile_settings_subtitle"]</p>
    </div>

    <!-- Personal Information Section -->
    <section class="bg-surface dark:bg-[#1E293B] rounded-[32px] p-xl shadow-medium border border-border dark:border-white/5">
        <div class="flex justify-between items-start mb-xl border-b border-border dark:border-white/10 pb-md">
            <div>
                <h2 class="font-h3 text-h3 text-text-primary dark:text-white">@Localizer["admin_basic_info"]</h2>
                <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["profile_basic_p"]</p>
            </div>
        </div>

        <form class="space-y-xl">
            <!-- Avatar Section -->
            <div class="flex items-center gap-lg">
                <div class="relative group">
                    <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface dark:border-[#1E293B] shadow-small">
                        <img id="profileAvatar" alt="User Avatar" class="w-full h-full object-cover"
                             src="@(Model.HasProfileImage ? Model.ProfileImageSrc : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName)}&background=69d2cf&color=005957&size=200")">
                    </div>
                    <!-- Loading Spinner Overlay -->
                    <div id="avatarSpinner" class="absolute inset-0 rounded-full bg-black/40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity">
                        <span class="material-symbols-outlined text-white animate-spin text-2xl">progress_activity</span>
                    </div>
                    <!-- Camera Icon Overlay -->
                    <button id="changeImageBtn" type="button" class="absolute bottom-0 right-0 w-8 h-8 bg-surface dark:bg-[#1E293B] rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-110 transition-transform border border-border dark:border-white/10">
                        <span class="material-symbols-outlined text-[18px]">camera_alt</span>
                    </button>
                    <!-- Hidden File Input -->
                    <input id="profileImageInput" type="file" accept=".jpg,.jpeg,.png,.webp" class="hidden">
                </div>
                <div>
                    <h4 class="font-bold text-text-primary dark:text-white">@Localizer["admin_profile_pic"]</h4>
                    <p class="text-xs text-text-secondary dark:text-outline-variant mb-3">@Localizer["profile_pic_format"]</p>
                    <div class="flex gap-2">
                        <button id="changeImageTextBtn" type="button" class="px-4 py-2 bg-primary/10 text-primary dark:text-primary-light rounded-xl font-bold text-sm hover:bg-primary/20 transition-colors">@Localizer["admin_change"]</button>
                        @if (Model.HasProfileImage)
                        {
                            <button id="removeImageBtn" type="button" class="px-4 py-2 bg-error/10 text-error rounded-xl font-bold text-sm hover:bg-error/20 transition-colors">@Localizer["admin_remove"]</button>
                        }
                    </div>
                </div>
            </div>

            <!-- Messages -->
            <div id="profileImageMessage" class="hidden"></div>

            <!-- Form Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["admin_first_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all placeholder:text-text-secondary dark:placeholder:text-outline" type="text" value="@(Model.FullName.Split(' ').ElementAtOrDefault(0) ?? "")">
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["admin_last_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all placeholder:text-text-secondary dark:placeholder:text-outline" type="text" value="@(Model.FullName.Contains(' ') ? Model.FullName.Split(' ')[1] : "")">
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["auth.login.email"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container-low dark:bg-black/40 rounded-2xl border border-border dark:border-white/10 text-text-secondary dark:text-outline-variant cursor-not-allowed opacity-70" disabled type="email" value="@Model.Email">
                </div>
            </div>

            <button type="submit" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-103 transition-all">
                @Localizer["admin_save_changes"]
            </button>
        </form>
    </section>

    <!-- Appearance Section -->
    <section class="bg-surface dark:bg-[#1E293B] rounded-[32px] p-xl shadow-medium border border-border dark:border-white/5">
        <div class="mb-xl border-b border-border dark:border-white/10 pb-md">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-white">@Localizer["admin_appearance"]</h2>
            <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_appearance_desc"]</p>
        </div>

        <div class="space-y-xl">
            <!-- Theme Selection -->
            <div class="space-y-md">
                <h4 class="font-bold text-text-primary dark:text-white">@Localizer["admin_theme_select"]</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-lg">
                    <button onclick="setThemeAndSync('light')" class="flex items-center justify-between p-lg rounded-2xl border-2 transition-all group bg-white dark:bg-black/20 border-border dark:border-white/10 hover:border-primary/50 text-text-primary dark:text-white" id="customer-theme-light">
                        <div class="flex items-center gap-md">
                            <span class="material-symbols-outlined text-yellow-500 group-[.active]:filled-icon">light_mode</span>
                            <span class="font-bold">@Localizer["admin_theme_light"]</span>
                        </div>
                        <div class="w-6 h-6 rounded-full border-2 border-border dark:border-white/20 group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                        </div>
                    </button>
                    <button onclick="setThemeAndSync('dark')" class="flex items-center justify-between p-lg rounded-2xl border-2 transition-all group bg-surface-container dark:bg-black/20 border-border dark:border-white/10 hover:border-primary/50 text-text-primary dark:text-white" id="customer-theme-dark">
                        <div class="flex items-center gap-md">
                            <span class="material-symbols-outlined text-primary-light group-[.active]:filled-icon">dark_mode</span>
                            <span class="font-bold">@Localizer["admin_theme_dark"]</span>
                        </div>
                        <div class="w-6 h-6 rounded-full border-2 border-border dark:border-white/20 group-[.active]:border-primary group-[.active]:bg-primary flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-xs opacity-0 group-[.active]:opacity-100">check</span>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Color Selection -->
            <div class="space-y-md pt-lg border-t border-border dark:border-white/10">
                <h4 class="font-bold text-text-primary dark:text-white">@Localizer["admin_primary_color"]</h4>
                <div class="flex flex-wrap gap-md">
                    @{
                        var colors = new[] { 
                            new { Name = "Teal", Hex = "#0E908C" },
                            new { Name = "Blue", Hex = "#3B82F6" },
                            new { Name = "Purple", Hex = "#8B5CF6" },
                            new { Name = "Pink", Hex = "#EC4899" },
                            new { Name = "Orange", Hex = "#F59E0B" }
                        };
                    }
                    @foreach (var color in colors)
                    {
                        <button type="button" onclick="setPrimaryColorAndSync('@color.Hex')" 
                                class="w-10 h-10 rounded-full border-4 transition-all hover:scale-110 shadow-sm"
                                style="background-color: @color.Hex;"
                                data-customer-color="@color.Hex">
                        </button>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- Security Section -->
    <section class="bg-surface dark:bg-[#1E293B] rounded-[32px] p-xl shadow-medium border border-border dark:border-white/5">
        <div class="mb-xl border-b border-border dark:border-white/10 pb-md">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-white">@Localizer["admin_security"]</h2>
            <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_security_desc"]</p>
        </div>
        
        <div class="space-y-lg">
            <button class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-white/10 hover:bg-primary/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-surface-container dark:bg-black/20 flex items-center justify-center text-primary dark:text-primary-light group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">key</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-text-primary dark:text-white">@Localizer["profile_change_pwd"]</h4>
                        <p class="text-xs text-text-secondary dark:text-outline-variant">@Localizer["profile_change_pwd_p"]</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-outline dark:text-outline-variant">chevron_right</span>
            </button>

            <button class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-white/10 hover:bg-error/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-error/10 flex items-center justify-center text-error group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">delete_forever</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-error">@Localizer["profile_delete_acc"]</h4>
                        <p class="text-xs text-error/70">@Localizer["profile_delete_acc_p"]</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-error/30">chevron_right</span>
            </button>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        const MAX_FILE_SIZE = 5 * 1024 * 1024; // 5 MB
        const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

        const avatarImg = document.getElementById('profileAvatar');
        const fileInput = document.getElementById('profileImageInput');
        const changeBtn = document.getElementById('changeImageBtn');
        const changeTextBtn = document.getElementById('changeImageTextBtn');
        const removeBtn = document.getElementById('removeImageBtn');
        const spinner = document.getElementById('avatarSpinner');
        const messageEl = document.getElementById('profileImageMessage');

        function showMessage(text, type) {
            messageEl.className = 'px-4 py-3 rounded-xl font-bold text-sm ' +
                (type === 'success' ? 'bg-success/10 text-success' : 'bg-error/10 text-error');
            messageEl.textContent = text;
            messageEl.classList.remove('hidden');
            setTimeout(() => { messageEl.classList.add('hidden'); }, 4000);
        }

        function showLoading(show) {
            spinner.classList.toggle('opacity-0', !show);
            spinner.classList.toggle('pointer-events-none', !show);
        }

        function getCsrfToken() {
            const meta = document.querySelector('input[name="__RequestVerificationToken"]');
            return meta ? meta.value : '';
        }

        // Open file picker
        function triggerFileInput() {
            fileInput.click();
        }
        changeBtn.addEventListener('click', triggerFileInput);
        if (changeTextBtn) changeTextBtn.addEventListener('click', triggerFileInput);

        // Validate and upload
        fileInput.addEventListener('change', async function () {
            const file = this.files[0];
            if (!file) return;

            if (!ALLOWED_TYPES.includes(file.type)) {
                showMessage('@Localizer["uploadfile.filenotvalid"]', 'error');
                this.value = '';
                return;
            }

            if (file.size > MAX_FILE_SIZE) {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.FileTooLarge.Value]', 'error');
                this.value = '';
                return;
            }

            showLoading(true);

            const formData = new FormData();
            formData.append('profileImage', file);
            formData.append('__RequestVerificationToken', getCsrfToken());

            try {
                const res = await fetch('/customer/profile/update-image', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();

                if (data.success) {
                    avatarImg.src = data.imageUrl;
                    showMessage(data.message, 'success');
                    // Show remove button if it was hidden
                    if (!document.getElementById('removeImageBtn')) {
                        const btnContainer = document.querySelector('.flex.gap-2');
                        const btn = document.createElement('button');
                        btn.id = 'removeImageBtn';
                        btn.type = 'button';
                        btn.className = 'px-4 py-2 bg-error/10 text-error rounded-xl font-bold text-sm hover:bg-error/20 transition-colors';
                        btn.textContent = '@Localizer["admin_remove"]';
                        btn.addEventListener('click', removeImage);
                        btnContainer.appendChild(btn);
                    }
                } else {
                    showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
                }
            } catch {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
            }

            showLoading(false);
            this.value = '';
        });

        // Remove image
        async function removeImage() {
            showLoading(true);

            const formData = new FormData();
            formData.append('__RequestVerificationToken', getCsrfToken());

            try {
                const res = await fetch('/customer/profile/remove-image', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();

                if (data.success) {
                    avatarImg.src = 'https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&background=69d2cf&color=005957&size=200';
                    showMessage(data.message, 'success');
                    // Hide remove button
                    const btn = document.getElementById('removeImageBtn');
                    if (btn) btn.remove();
                } else {
                    showMessage(data.message || '@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
                }
            } catch {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
            }

            showLoading(false);
        }

        if (removeBtn) removeBtn.addEventListener('click', removeImage);

        function setThemeAndSync(theme) {
            const isDark = theme === 'dark';
            if (isDark) document.documentElement.classList.add('dark');
            else document.documentElement.classList.remove('dark');
            
            localStorage.setItem('dakkn_theme', theme);
            updateThemeUI(theme);
            
            if (typeof syncSettingsToDatabase === 'function') {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || window.csrfToken;
                syncSettingsToDatabase({ theme: theme, isDarkMode: isDark }, token);
            }
        }

        function updateThemeUI(theme) {
            document.querySelectorAll('[id^="customer-theme-"]').forEach(btn => btn.classList.remove('active', 'border-primary'));
            const activeBtn = document.getElementById('customer-theme-' + theme);
            if (activeBtn) activeBtn.classList.add('active', 'border-primary');
        }

        function setPrimaryColorAndSync(color) {
            document.documentElement.style.setProperty('--primary-color', color);
            updateColorUI(color);
            
            if (typeof syncSettingsToDatabase === 'function') {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || window.csrfToken;
                syncSettingsToDatabase({ primaryColor: color }, token);
            }
        }

        function updateColorUI(color) {
            document.querySelectorAll('[data-customer-color]').forEach(btn => {
                const btnColor = btn.getAttribute('data-customer-color');
                if (btnColor === color) {
                    btn.classList.add('scale-110', 'ring-2', 'ring-offset-2', 'ring-primary');
                } else {
                    btn.classList.remove('scale-110', 'ring-2', 'ring-offset-2', 'ring-primary');
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const currentTheme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
            updateThemeUI(currentTheme);
            
            const currentPrimary = getComputedStyle(document.documentElement).getPropertyValue('--primary-color').trim();
            if (currentPrimary) updateColorUI(currentPrimary);
        });
    </script>
}
