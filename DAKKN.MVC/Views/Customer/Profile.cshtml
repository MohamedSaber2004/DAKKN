@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = "My Profile";
}

<div class="max-w-4xl mx-auto px-lg py-xl space-y-lg pb-32">
    <!-- Header -->
    <div class="mb-xl">
        <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_profile"]</h1>
        <p class="text-text-secondary dark:text-outline-variant mt-2">Manage your account settings and preferences.</p>
    </div>

    <!-- Personal Information Section -->
    <section class="bg-surface dark:bg-inverse-surface rounded-[32px] p-xl shadow-medium border border-border dark:border-outline/10">
        <div class="flex justify-between items-start mb-xl border-b border-border dark:border-outline/20 pb-md">
            <div>
                <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_basic_info"]</h2>
                <p class="text-sm text-text-secondary mt-1">Update your personal details.</p>
            </div>
        </div>

        <form class="space-y-xl">
            <!-- Avatar Section -->
            <div class="flex items-center gap-lg">
                <div class="relative group">
                    <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface dark:border-inverse-surface shadow-small">
                        <img alt="User Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=69d2cf&color=005957&size=200">
                    </div>
                    <button class="absolute bottom-0 right-0 w-8 h-8 bg-surface dark:bg-surface-container-high rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-110 transition-transform border border-border dark:border-outline/20" type="button">
                        <span class="material-symbols-outlined text-[18px]">edit</span>
                    </button>
                </div>
                <div>
                    <h4 class="font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["admin_profile_pic"]</h4>
                    <p class="text-xs text-text-secondary mb-3">Square images work best. Max 5MB.</p>
                    <button class="px-4 py-2 bg-primary/10 text-primary rounded-xl font-bold text-sm hover:bg-primary/20 transition-colors" type="button">@Localizer["admin_change"]</button>
                </div>
            </div>

            <!-- Form Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["admin_first_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container dark:bg-inverse-surface-container rounded-2xl border border-border dark:border-outline/20 focus:ring-2 focus:ring-primary outline-none transition-all" type="text" value="@User.Identity.Name.Split(' ')[0]">
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["admin_last_name"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container dark:bg-inverse-surface-container rounded-2xl border border-border dark:border-outline/20 focus:ring-2 focus:ring-primary outline-none transition-all" type="text" value="@(User.Identity.Name.Contains(" ") ? User.Identity.Name.Split(' ')[1] : "")">
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="block font-bold text-sm text-outline uppercase tracking-wider px-1">@Localizer["auth.login.email"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container-low dark:bg-inverse-surface-container rounded-2xl border border-border dark:border-outline/20 text-text-secondary cursor-not-allowed opacity-70" disabled type="email" value="@User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value">
                </div>
            </div>

            <button type="submit" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-103 transition-all">
                @Localizer["admin_save_changes"]
            </button>
        </form>
    </section>

    <!-- Security Section -->
    <section class="bg-surface dark:bg-inverse-surface rounded-[32px] p-xl shadow-medium border border-border dark:border-outline/10">
        <div class="mb-xl border-b border-border dark:border-outline/20 pb-md">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-inverse-on-surface">@Localizer["admin_security"]</h2>
            <p class="text-sm text-text-secondary mt-1">Manage your password and account security.</p>
        </div>
        
        <div class="space-y-lg">
            <button class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-outline/10 hover:bg-primary/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-surface-container dark:bg-inverse-surface-container flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">key</span>
                    </div>
                    <div>
                        <h4 class="font-bold">Change Password</h4>
                        <p class="text-xs text-text-secondary">Update your login credentials regularly.</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-outline">chevron_right</span>
            </button>

            <button class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-outline/10 hover:bg-error/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-error/10 flex items-center justify-center text-error group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">delete_forever</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-error">Delete Account</h4>
                        <p class="text-xs text-error/70">Permanently remove your data and collection.</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-error/30">chevron_right</span>
            </button>
        </div>
    </section>
</div>
