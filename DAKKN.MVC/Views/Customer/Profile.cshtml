@inject IStringLocalizer<Messages> Localizer
@model CustomerProfileViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["profile_title"];
}

<div class="max-w-4xl mx-auto px-lg py-xl space-y-lg pb-32">
    <!-- Header -->
    <div class="mb-xl">
        <h1 class="customer-page-title text-text-primary dark:text-white">@Localizer["nav_profile"]</h1>
        <p class="text-text-secondary dark:text-outline-variant mt-2">@Localizer["profile_settings_subtitle"]</p>
    </div>

    <!-- Personal Information Section -->
    <section class="settings-section">
        <div class="settings-section-header flex justify-between items-start">
            <div>
                <h2 class="font-h3 text-h3 text-text-primary dark:text-white">@Localizer["admin_basic_info"]</h2>
                <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["profile_basic_p"]</p>
            </div>
        </div>

        <form id="profileForm" class="space-y-xl">
            @Html.AntiForgeryToken()
            <!-- Avatar Section -->
            <div class="flex items-center gap-lg">
                <div class="relative group">
                    <div class="w-24 h-24 rounded-full overflow-hidden border-4 border-surface dark:border-[#1E293B] shadow-small">
                        <img id="profileAvatar" alt='@Localizer["profile_avatar_alt"]' class="w-full h-full object-cover"
                             src="@(Model.HasProfileImage ? Model.ProfileImageSrc : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(Model.FullName)}&background=69d2cf&color=005957&size=200")">
                    </div>
                    <!-- Loading Spinner Overlay -->
                    <div id="avatarSpinner" class="absolute inset-0 rounded-full bg-black/40 flex items-center justify-center opacity-0 pointer-events-none transition-opacity">
                        <span class="material-symbols-outlined text-white animate-spin text-2xl">progress_activity</span>
                    </div>
                    <!-- Camera Icon Overlay -->
                    <button id="changeImageBtn" type="button" class="absolute bottom-0 right-0 w-8 h-8 bg-surface dark:bg-[#1E293B] rounded-full shadow-md flex items-center justify-center text-primary dark:text-primary-light hover:scale-110 transition-transform border border-border dark:border-white/10">
                        <span class="material-symbols-outlined text-[18px]">camera_alt</span>
                    </button>
                    <!-- Hidden File Input -->
                    <input id="profileImageInput" type="file" accept=".jpg,.jpeg,.png,.webp" class="hidden">
                </div>
                <div>
                    <h4 class="font-bold text-text-primary dark:text-white">@Localizer["admin_profile_pic"]</h4>
                    <p class="text-xs text-text-secondary dark:text-outline-variant mb-3">@Localizer["profile_pic_format"]</p>
                    <div class="flex gap-2">
                        <button id="changeImageTextBtn" type="button" class="px-4 py-2 bg-primary/10 text-primary dark:text-primary-light rounded-xl font-bold text-sm hover:bg-primary/20 transition-colors">@Localizer["admin_change"]</button>
                        @if (Model.HasProfileImage)
                        {
                            <button id="removeImageBtn" type="button" class="px-4 py-2 bg-error/10 text-error rounded-xl font-bold text-sm hover:bg-error/20 transition-colors">@Localizer["admin_remove"]</button>
                        }
                    </div>
                </div>
            </div>

            <!-- Messages -->
            <div id="profileImageMessage" class="hidden"></div>

            <!-- Form Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-lg">
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["admin_first_name"]</label>
                    <input id="firstName" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all placeholder:text-text-secondary dark:placeholder:text-outline" type="text" value="@(Model.FullName.Split(' ').ElementAtOrDefault(0) ?? "")">
                </div>
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["admin_last_name"]</label>
                    <input id="lastName" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all placeholder:text-text-secondary dark:placeholder:text-outline" type="text" value="@(Model.FullName.Contains(' ') ? Model.FullName.Split(' ')[1] : "")">
                </div>
                <div class="space-y-2 md:col-span-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["auth.login.email"]</label>
                    <input class="w-full px-4 py-3 bg-surface-container-low dark:bg-black/40 rounded-2xl border border-border dark:border-white/10 text-text-secondary dark:text-outline-variant cursor-not-allowed opacity-70" disabled type="email" value="@Model.Email">
                </div>
            </div>

            <button type="submit" class="bg-primary text-on-primary px-xl py-md rounded-full font-bold shadow-medium hover:scale-103 transition-all">
                @Localizer["admin_save_changes"]
            </button>
        </form>
    </section>

    <!-- Security Section -->
    <section class="settings-section">
        <div class="settings-section-header">
            <h2 class="font-h3 text-h3 text-text-primary dark:text-white">@Localizer["admin_security"]</h2>
            <p class="text-sm text-text-secondary dark:text-outline-variant mt-1">@Localizer["admin_security_desc"]</p>
        </div>
        
        <div class="space-y-lg">
            <button type="button" onclick="openChangePasswordModal()" class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-white/10 hover:bg-primary/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-surface-container dark:bg-black/20 flex items-center justify-center text-primary dark:text-primary-light group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">key</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-text-primary dark:text-white">@Localizer["profile_change_pwd"]</h4>
                        <p class="text-xs text-text-secondary dark:text-outline-variant">@Localizer["profile_change_pwd_p"]</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-outline dark:text-outline-variant">chevron_right</span>
            </button>

            <button type="button" onclick="openDeleteAccountModal()" class="w-full flex items-center justify-between p-lg rounded-2xl border border-border dark:border-white/10 hover:bg-error/5 transition-all group text-left rtl:text-right">
                <div class="flex items-center gap-lg">
                    <div class="w-12 h-12 rounded-full bg-error/10 flex items-center justify-center text-error group-hover:scale-110 transition-transform">
                        <span class="material-symbols-outlined">delete_forever</span>
                    </div>
                    <div>
                        <h4 class="font-bold text-error">@Localizer["profile_delete_acc"]</h4>
                        <p class="text-xs text-error/70">@Localizer["profile_delete_acc_p"]</p>
                    </div>
                </div>
                <span class="material-symbols-outlined text-error/30">chevron_right</span>
            </button>
        </div>
    </section>
</div>

<!-- Change Password Modal -->
<div id="changePasswordModal" class="fixed inset-0 z-50 flex items-center justify-center p-lg hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeChangePasswordModal()"></div>
    <div class="customer-modal-panel relative bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-2xl w-full max-w-md border border-border dark:border-white/10 max-h-[90vh] overflow-y-auto">
        <div class="p-xl">
            <div class="flex items-center justify-between mb-lg">
                <h3 class="font-h3 text-h3 font-bold text-text-primary dark:text-white">@Localizer["profile_change_pwd"]</h3>
                <button type="button" onclick="closeChangePasswordModal()" class="w-10 h-10 rounded-full bg-surface-container dark:bg-black/20 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="space-y-lg">
                <!-- Current Password -->
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["profile_current_password"]</label>
                    <div class="relative">
                        <input id="cp-current" type="password" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all pr-12">
                        <button type="button" onclick="togglePassword('cp-current', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                </div>

                <!-- New Password -->
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["profile_new_password"]</label>
                    <div class="relative">
                        <input id="cp-new" type="password" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all pr-12">
                        <button type="button" onclick="togglePassword('cp-new', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                    <!-- Password Strength Indicator -->
                    <div class="mt-2">
                        <div class="flex gap-1">
                            <div id="str-bar-1" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-all"></div>
                            <div id="str-bar-2" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-all"></div>
                            <div id="str-bar-3" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-all"></div>
                            <div id="str-bar-4" class="h-1 flex-1 rounded-full bg-gray-200 dark:bg-gray-700 transition-all"></div>
                        </div>
                        <p id="str-text" class="text-xs text-text-secondary dark:text-outline-variant mt-1">@Localizer["profile_password_requirements"]</p>
                    </div>
                </div>

                <!-- Confirm New Password -->
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["profile_confirm_password"]</label>
                    <div class="relative">
                        <input id="cp-confirm" type="password" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-primary outline-none transition-all pr-12">
                        <button type="button" onclick="togglePassword('cp-confirm', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                </div>

                <div id="cp-error" class="hidden px-4 py-3 rounded-2xl bg-error/10 text-error text-sm font-bold"></div>

                <button id="cp-submit" type="button" onclick="submitChangePassword()" class="w-full bg-primary text-on-primary py-3 rounded-2xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined text-lg">lock</span>
                    <span>@Localizer["admin_update_password"]</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Account Modal -->
<div id="deleteAccountModal" class="fixed inset-0 z-50 flex items-center justify-center p-lg hidden">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeDeleteAccountModal()"></div>
    <div class="customer-modal-panel relative bg-surface dark:bg-[#1E293B] rounded-[32px] shadow-2xl w-full max-w-md border border-border dark:border-white/10 max-h-[90vh] overflow-y-auto">
        <div class="p-xl">
            <div class="flex items-center justify-between mb-lg">
                <h3 class="font-h3 text-h3 font-bold text-error">@Localizer["profile_delete_acc"]</h3>
                <button type="button" onclick="closeDeleteAccountModal()" class="w-10 h-10 rounded-full bg-surface-container dark:bg-black/20 flex items-center justify-center text-text-secondary hover:text-text-primary transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="space-y-lg">
                <!-- Warning -->
                <div class="p-lg rounded-2xl bg-error/5 border border-error/20">
                    <div class="flex items-start gap-md">
                        <span class="material-symbols-outlined text-error flex-shrink-0">warning</span>
                        <div>
                            <p class="font-bold text-error text-sm">@Localizer["profile_delete_account_warning"]</p>
                        </div>
                    </div>
                </div>

                <!-- Type DELETE -->
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["profile_delete_account_type_confirm"]</label>
                    <input id="da-confirm-text" type="text" placeholder="@Localizer["profile_delete_ph"]" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-error outline-none transition-all placeholder:text-text-secondary">
                </div>

                <!-- Current Password -->
                <div class="space-y-2">
                    <label class="block font-bold text-sm text-outline dark:text-outline-variant uppercase tracking-wider px-1">@Localizer["profile_delete_account_password"]</label>
                    <div class="relative">
                        <input id="da-password" type="password" class="w-full px-4 py-3 bg-surface-container dark:bg-black/20 rounded-2xl border border-border dark:border-white/10 text-text-primary dark:text-white focus:ring-2 focus:ring-error outline-none transition-all pr-12">
                        <button type="button" onclick="togglePassword('da-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-text-secondary hover:text-text-primary transition-colors">
                            <span class="material-symbols-outlined text-xl">visibility_off</span>
                        </button>
                    </div>
                </div>

                <div id="da-error" class="hidden px-4 py-3 rounded-2xl bg-error/10 text-error text-sm font-bold"></div>

                <div class="flex gap-md">
                    <button type="button" onclick="closeDeleteAccountModal()" class="flex-1 px-4 py-3 rounded-2xl border border-border dark:border-white/10 font-bold text-sm hover:bg-surface-container transition-all">
                        @Localizer["profile_cancel"]
                    </button>
                    <button id="da-submit" type="button" onclick="submitDeleteAccount()" class="flex-1 bg-error text-white py-3 rounded-2xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-lg">delete_forever</span>
                        <span>@Localizer["profile_delete_acc"]</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container -->
<div id="toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3"></div>

@section Scripts {
    <script>
        // ── Toast System ──
        function showToast(text, type) {
            var container = document.getElementById('toast-container');
            var toast = document.createElement('div');
            var isSuccess = type === 'success';
            toast.className = 'flex items-center gap-3 px-5 py-4 rounded-2xl shadow-xl font-bold text-sm animate-slide-up border ' +
                (isSuccess
                    ? 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 border-green-200 dark:border-green-800'
                    : 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 border-red-200 dark:border-red-800');
            toast.innerHTML = '<span class="material-symbols-outlined text-lg">' + (isSuccess ? 'check_circle' : 'error') + '</span><span>' + text + '</span>';
            container.appendChild(toast);
            setTimeout(function () { toast.style.opacity = '0'; toast.style.transform = 'translateX(100%)'; setTimeout(function () { toast.remove(); }, 300); }, 4000);
        }

        // ── Profile Form Save ──
        document.getElementById('profileForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            var form = e.target;
            var btn = form.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-lg">progress_activity</span>';

            try {
                var res = await fetch('/customer/profile/update', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({
                        firstName: document.getElementById('firstName').value,
                        lastName: document.getElementById('lastName').value
                    })
                });
                var data = await res.json();
                if (data.success) {
                    showToast(data.message || '@Localizer["admin_save_success"]', 'success');
                } else {
                    showToast(data.message || '@Localizer["admin_save_error"]', 'error');
                }
            } catch {
                showToast('@Localizer["admin_save_error"]', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '@Localizer["admin_save_changes"]';
            }
        });

        // ── Password Toggle ──
        function togglePassword(inputId, btn) {
            var input = document.getElementById(inputId);
            var icon = btn.querySelector('.material-symbols-outlined');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        }

        // ── Password Strength ──
        document.getElementById('cp-new').addEventListener('input', function () {
            var val = this.value;
            var bars = [
                document.getElementById('str-bar-1'),
                document.getElementById('str-bar-2'),
                document.getElementById('str-bar-3'),
                document.getElementById('str-bar-4')
            ];
            var text = document.getElementById('str-text');

            var score = 0;
            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[a-z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;

            var colors = ['', 'bg-red-500', 'bg-orange-500', 'bg-yellow-500', 'bg-green-500'];
            var labels = ['', '@Localizer["password_strength_weak"]', '@Localizer["password_strength_fair"]', '@Localizer["password_strength_good"]', '@Localizer["password_strength_strong"]'];

            bars.forEach(function (bar, i) {
                bar.className = 'h-1 flex-1 rounded-full transition-all ' + (i < score ? colors[score] : 'bg-gray-200 dark:bg-gray-700');
            });
            text.textContent = score > 0 ? labels[score] : '@Localizer["profile_password_requirements"]';
            text.className = 'text-xs mt-1 ' + (score > 0 ? 'font-bold text-' + (score === 4 ? 'green' : score === 3 ? 'yellow' : score === 2 ? 'orange' : 'red') + '-500' : 'text-text-secondary dark:text-outline-variant');
        });

        // ── Change Password Modal ──
        function openChangePasswordModal() {
            document.getElementById('changePasswordModal').classList.remove('hidden');
        }
        function closeChangePasswordModal() {
            document.getElementById('changePasswordModal').classList.add('hidden');
            document.getElementById('cp-error').classList.add('hidden');
        }

        async function submitChangePassword() {
            var btn = document.getElementById('cp-submit');
            var current = document.getElementById('cp-current').value;
            var newPwd = document.getElementById('cp-new').value;
            var confirm = document.getElementById('cp-confirm').value;
            var errorEl = document.getElementById('cp-error');

            // Client-side validation
            if (!current || !newPwd || !confirm) {
                errorEl.textContent = '@Localizer["alert.validation.required"]';
                errorEl.classList.remove('hidden');
                return;
            }
            if (newPwd !== confirm) {
                errorEl.textContent = '@Localizer["alert.passwords_mismatch"]';
                errorEl.classList.remove('hidden');
                return;
            }
            if (newPwd.length < 8) {
                errorEl.textContent = '@Localizer["alert.password_min_length"]';
                errorEl.classList.remove('hidden');
                return;
            }

            errorEl.classList.add('hidden');
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-lg">progress_activity</span> @Localizer["loading"]';

            try {
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                var headers = { 'Content-Type': 'application/json' };
                if (token) headers['RequestVerificationToken'] = token.value;

                var res = await fetch('/customer/profile/change-password', {
                    method: 'POST',
                    headers: headers,
                    body: JSON.stringify({ currentPassword: current, newPassword: newPwd, confirmPassword: confirm })
                });
                var data = await res.json();

                if (data.success) {
                    showToast(data.message, 'success');
                    closeChangePasswordModal();
                    document.getElementById('cp-current').value = '';
                    document.getElementById('cp-new').value = '';
                    document.getElementById('cp-confirm').value = '';
                } else {
                    errorEl.textContent = data.message;
                    errorEl.classList.remove('hidden');
                }
            } catch (e) {
                errorEl.textContent = '@Localizer["profile_password_change_error"]';
                errorEl.classList.remove('hidden');
            }

            btn.disabled = false;
            btn.innerHTML = '<span class="material-symbols-outlined text-lg">lock</span><span>@Localizer["admin_update_password"]</span>';
        }

        // ── Delete Account Modal ──
        function openDeleteAccountModal() {
            document.getElementById('deleteAccountModal').classList.remove('hidden');
        }
        function closeDeleteAccountModal() {
            document.getElementById('deleteAccountModal').classList.add('hidden');
            document.getElementById('da-error').classList.add('hidden');
        }

        async function submitDeleteAccount() {
            var btn = document.getElementById('da-submit');
            var confirmText = document.getElementById('da-confirm-text').value;
            var password = document.getElementById('da-password').value;
            var errorEl = document.getElementById('da-error');

            if (confirmText !== 'DELETE') {
                errorEl.textContent = '@Localizer["profile_type_delete_to_confirm"]';
                errorEl.classList.remove('hidden');
                return;
            }
            if (!password) {
                errorEl.textContent = '@Localizer["alert.password_required"]';
                errorEl.classList.remove('hidden');
                return;
            }

            errorEl.classList.add('hidden');
            btn.disabled = true;
            btn.innerHTML = '<span class="animate-spin material-symbols-outlined text-lg">progress_activity</span> @Localizer["loading"]';

            try {
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                var headers = { 'Content-Type': 'application/json' };
                if (token) headers['RequestVerificationToken'] = token.value;

                var res = await fetch('/customer/profile/delete-account', {
                    method: 'POST',
                    headers: headers,
                    body: JSON.stringify({ currentPassword: password, confirmationText: confirmText })
                });
                var data = await res.json();

                if (data.success) {
                    showToast(data.message, 'success');
                    setTimeout(function () {
                        window.location.href = data.redirectUrl || '/';
                    }, 1500);
                } else {
                    errorEl.textContent = data.message;
                    errorEl.classList.remove('hidden');
                    btn.disabled = false;
                    btn.innerHTML = '<span class="material-symbols-outlined text-lg">delete_forever</span><span>@Localizer["profile_delete_acc"]</span>';
                }
            } catch (e) {
                errorEl.textContent = '@Localizer["profile_delete_account_error"]';
                errorEl.classList.remove('hidden');
                btn.disabled = false;
                btn.innerHTML = '<span class="material-symbols-outlined text-lg">delete_forever</span><span>@Localizer["profile_delete_acc"]</span>';
            }
        }

        // Close modals on Escape
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeChangePasswordModal();
                closeDeleteAccountModal();
            }
        });

        // ── Original Profile Image / Theme Scripts ──
        const MAX_FILE_SIZE = 5 * 1024 * 1024;
        const ALLOWED_TYPES = ['image/jpeg', 'image/png', 'image/webp'];

        const avatarImg = document.getElementById('profileAvatar');
        const fileInput = document.getElementById('profileImageInput');
        const changeBtn = document.getElementById('changeImageBtn');
        const changeTextBtn = document.getElementById('changeImageTextBtn');
        const removeBtn = document.getElementById('removeImageBtn');
        const spinner = document.getElementById('avatarSpinner');
        const messageEl = document.getElementById('profileImageMessage');

        function showMessage(text, type) {
            messageEl.className = 'px-4 py-3 rounded-xl font-bold text-sm ' +
                (type === 'success' ? 'bg-success/10 text-success' : 'bg-error/10 text-error');
            messageEl.textContent = text;
            messageEl.classList.remove('hidden');
            setTimeout(() => { messageEl.classList.add('hidden'); }, 4000);
        }

        function showLoading(show) {
            spinner.classList.toggle('opacity-0', !show);
            spinner.classList.toggle('pointer-events-none', !show);
        }

        function getCsrfToken() {
            const meta = document.querySelector('input[name="__RequestVerificationToken"]');
            return meta ? meta.value : '';
        }

        function triggerFileInput() { fileInput.click(); }
        changeBtn.addEventListener('click', triggerFileInput);
        if (changeTextBtn) changeTextBtn.addEventListener('click', triggerFileInput);

        fileInput.addEventListener('change', async function () {
            const file = this.files[0];
            if (!file) return;
            if (!ALLOWED_TYPES.includes(file.type)) {
                showMessage('@Localizer["uploadfile.filenotvalid"]', 'error');
                this.value = '';
                return;
            }
            if (file.size > MAX_FILE_SIZE) {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.FileTooLarge.Value]', 'error');
                this.value = '';
                return;
            }
            showLoading(true);
            const formData = new FormData();
            formData.append('profileImage', file);
            formData.append('__RequestVerificationToken', getCsrfToken());
            try {
                const res = await fetch('/customer/profile/update-image', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    avatarImg.src = data.imageUrl;
                    showMessage(data.message, 'success');
                    if (!document.getElementById('removeImageBtn')) {
                        const btnContainer = document.querySelector('.flex.gap-2');
                        const btn = document.createElement('button');
                        btn.id = 'removeImageBtn';
                        btn.type = 'button';
                        btn.className = 'px-4 py-2 bg-error/10 text-error rounded-xl font-bold text-sm hover:bg-error/20 transition-colors';
                        btn.textContent = '@Localizer["admin_remove"]';
                        btn.addEventListener('click', removeImage);
                        btnContainer.appendChild(btn);
                    }
                } else {
                    showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
                }
            } catch {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
            }
            showLoading(false);
            this.value = '';
        });

        async function removeImage() {
            showLoading(true);
            const formData = new FormData();
            formData.append('__RequestVerificationToken', getCsrfToken());
            try {
                const res = await fetch('/customer/profile/remove-image', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    avatarImg.src = 'https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&background=69d2cf&color=005957&size=200';
                    showMessage(data.message, 'success');
                    const btn = document.getElementById('removeImageBtn');
                    if (btn) btn.remove();
                } else {
                    showMessage(data.message || '@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
                }
            } catch {
                showMessage('@Localizer[LocalizationKeys.ProfileImageMessages.UploadFailed.Value]', 'error');
            }
            showLoading(false);
        }

        if (removeBtn) removeBtn.addEventListener('click', removeImage);


    </script>
    <style>
        .animate-slide-up {
            animation: slideUp 0.3s ease-out;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}
