@using DAKKN.MVC.ViewModels.Customer
@model ProductDetailsViewModel
@{
    Layout = "_LayoutCustomer";
    var product = Model.Product;
}

<div class="max-w-7xl mx-auto px-lg py-xl">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-text-secondary mb-xl">
        <a asp-action="Products" class="hover:text-primary transition-colors">@Localizer["Product_Products"]</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-text-primary dark:text-inverse-on-surface font-bold">@product.Name</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2xl">
        <!-- Image Gallery -->
        <div class="space-y-lg">
            <div class="aspect-square rounded-[48px] bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 overflow-hidden shadow-large group relative">
                <img src="@product.ImageUrls.FirstOrDefault()" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="@product.Name">
                <div class="absolute top-8 right-8 flex flex-col gap-sm">
                    <button class="w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center text-text-secondary hover:text-error transition-all">
                        <span class="material-symbols-outlined">favorite</span>
                    </button>
                    <button class="w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center text-text-secondary hover:text-primary transition-all">
                        <span class="material-symbols-outlined">share</span>
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-4 gap-md">
                @foreach (var imageUrl in product.ImageUrls)
                {
                    <div class="aspect-square rounded-2xl bg-surface-container dark:bg-inverse-surface border-2 border-primary overflow-hidden cursor-pointer hover:opacity-80 transition-all">
                        <img src="@imageUrl" class="w-full h-full object-cover" alt="@product.Name">
                    </div>
                }
            </div>
        </div>

        <!-- Product Info -->
        <div class="flex flex-col">
            <div class="mb-xl pb-xl border-b border-border dark:border-outline/10">
                <span class="bg-primary/10 text-primary px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-md inline-block">@Localizer["Product_BestSeller"]</span>
                <h1 class="font-h1 text-h1 font-bold mb-sm">@product.Name</h1>
                <div class="flex items-center gap-xl">
                    <span class="text-3xl font-bold text-primary">@product.Price @Localizer["Currency_EGP"]</span>
                    <div class="flex items-center gap-1 text-yellow-500">
                        <span class="material-symbols-outlined text-lg filled-icon">star</span>
                        <span class="font-bold">@product.Rating</span>
                        <span class="text-text-secondary text-sm font-medium ml-1">(@product.ReviewCount @Localizer["Product_Reviews"])</span>
                    </div>
                </div>
                <p class="text-text-secondary dark:text-outline-variant mt-lg leading-relaxed">
                    @product.Description
                </p>
            </div>

            <!-- Configuration -->
            <div class="space-y-xl mb-2xl">
                @if (product.FinishOptions.Any())
                {
                    <div>
                        <h4 class="font-bold text-sm uppercase tracking-widest text-outline mb-md">@Localizer["Product_FinishEffect"]</h4>
                        <div class="flex flex-wrap gap-md">
                            @foreach (var finish in product.FinishOptions)
                            {
                                <button class="px-xl py-3 rounded-2xl border-2 @(finish == product.FinishOptions[0] ? "border-primary bg-primary/5 text-primary" : "border-border dark:border-outline/10 text-text-secondary hover:border-primary/50") font-bold transition-all">
                                    @finish
                                </button>
                            }
                        </div>
                    </div>
                }

                @if (product.SizeOptions.Any())
                {
                    <div>
                        <h4 class="font-bold text-sm uppercase tracking-widest text-outline mb-md">@Localizer["Product_Size"]</h4>
                        <div class="flex flex-wrap gap-md">
                            @foreach (var size in product.SizeOptions)
                            {
                                <button class="w-16 h-16 rounded-2xl border-2 @(size == product.SizeOptions[0] ? "border-primary bg-primary/5 text-primary" : "border-border dark:border-outline/10 text-text-secondary") flex items-center justify-center font-bold">
                                    @size
                                </button>
                            }
                        </div>
                    </div>
                }

                <div>
                    <h4 class="font-bold text-sm uppercase tracking-widest text-outline mb-md">@Localizer["Product_Quantity"]</h4>
                    <div class="flex items-center gap-md">
                        <div class="flex items-center bg-surface-container dark:bg-inverse-surface rounded-2xl border border-border dark:border-outline/10 p-1">
                            <button class="w-10 h-10 rounded-xl hover:bg-white/5 flex items-center justify-center"><span class="material-symbols-outlined">remove</span></button>
                            <input type="number" value="1" class="w-12 bg-transparent border-none text-center font-bold focus:ring-0">
                            <button class="w-10 h-10 rounded-xl hover:bg-white/5 flex items-center justify-center"><span class="material-symbols-outlined">add</span></button>
                        </div>
                        <p class="text-xs text-text-secondary">@Localizer["Product_BulkSavings"]</p>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-lg mt-auto">
                <button class="flex-1 bg-primary text-on-primary h-16 rounded-3xl font-bold text-lg shadow-large hover:scale-103 transition-all flex items-center justify-center gap-3">
                    <span class="material-symbols-outlined">shopping_cart</span>
                    @Localizer["Product_AddToCart"]
                </button>
                <button class="w-16 h-16 rounded-3xl border-2 border-border dark:border-outline/10 flex items-center justify-center text-text-secondary hover:text-primary transition-all">
                    <span class="material-symbols-outlined">local_shipping</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Features Grid (Trust builder) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg mt-3xl pt-2xl border-t border-border dark:border-outline/10">
        @foreach (var feature in product.Features)
        {
            <div class="flex items-center gap-lg">
                <div class="w-14 h-14 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                    <span class="material-symbols-outlined">@feature.Icon</span>
                </div>
                <div>
                    <h4 class="font-bold">@feature.Title</h4>
                    <p class="text-sm text-text-secondary">@feature.Description</p>
                </div>
            </div>
        }
    </div>
</div>
