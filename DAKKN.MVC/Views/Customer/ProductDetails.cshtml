@using DAKKN.MVC.ViewModels.Customer
@model ProductDetailsViewModel
@{
    Layout = "_LayoutCustomer";
    var product = Model.Product;
    var culture = System.Globalization.CultureInfo.CurrentCulture.Name;
    var isArabic = culture.StartsWith("ar");
    var isFavorited = ViewData["IsFavorited"] is true;
}

<div class="max-w-7xl mx-auto px-lg py-xl">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-text-secondary mb-xl">
        <a asp-action="Products" class="hover:text-primary transition-colors">@Localizer["Product_Products"]</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-text-primary dark:text-inverse-on-surface font-bold">@(isArabic ? product.ArName : product.Name)</span>
    </nav>

    @Html.AntiForgeryToken()

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-2xl">
        <!-- Image Gallery -->
        <div class="space-y-lg">
            <div class="aspect-square rounded-[48px] bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 overflow-hidden shadow-large group relative">
                <img src="@product.ImageUrl" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="@(isArabic ? product.ArName : product.Name)">
                <div class="absolute top-8 right-8 flex flex-col gap-sm">
                    <button type="button" id="fav-top-btn" onclick="toggleFav('@product.Id', this)" class="w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center transition-all @(isFavorited ? "text-error" : "text-text-secondary hover:text-error")">
                        <span class="material-symbols-outlined @(isFavorited ? "filled-icon" : "")">favorite</span>
                    </button>
                    <button class="w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center text-text-secondary hover:text-primary transition-all">
                        <span class="material-symbols-outlined">share</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Product Info -->
        <div class="flex flex-col">
            <div class="mb-xl pb-xl border-b border-border dark:border-outline/10">
                <span class="bg-primary/10 text-primary px-4 py-1 rounded-full text-xs font-bold uppercase tracking-widest mb-md inline-block">@(isArabic ? product.CategoryArName : product.CategoryName)</span>
                <h1 class="customer-page-title mb-sm">@(isArabic ? product.ArName : product.Name)</h1>
                <div class="flex items-center gap-xl">
                    <span class="text-3xl font-bold text-primary">@product.Price @Localizer["Currency_EGP"]</span>
                    <partial name="_ProductRatingWidget" model="@product.Id" />
                </div>
                <p class="text-text-secondary dark:text-outline-variant mt-lg leading-relaxed">
                    @(isArabic ? product.ArDescription : product.Description)
                </p>

                <!-- Stock Info -->
                <div class="mt-4 mb-4">
                    @if (product.QuantityInStock == 0)
                    {
                        <div class="flex items-center gap-2 text-red-500">
                            <span class="material-symbols-outlined">block</span>
                            <span class="font-bold text-sm">@Localizer["inventory_out_of_stock"]</span>
                        </div>
                    }
                    else if (product.QuantityInStock <= product.DangerQuantity)
                    {
                        <div class="flex items-center gap-2 text-amber-500">
                            <span class="material-symbols-outlined">warning</span>
                            <span class="font-bold text-sm">@Localizer["inventory_only_x_left", product.QuantityInStock]</span>
                        </div>
                    }
                    else
                    {
                        <div class="flex items-center gap-2 text-green-500">
                            <span class="material-symbols-outlined">check_circle</span>
                            <span class="font-bold text-sm">@Localizer["inventory_in_stock"]</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Actions -->
            <div class="flex flex-col sm:flex-row gap-lg mt-auto">
                <div class="flex gap-lg flex-1">
                    @if (product.QuantityInStock > 0)
                    {
                        <button onclick="guestAddToCart(this, '@product.Id', '@(isArabic ? product.ArName : product.Name)', '@product.Price', '@(product.ImageFullUrl ?? product.ImageUrl)')"
                                class="flex-1 bg-primary text-on-primary h-16 rounded-3xl font-bold text-lg shadow-large hover:scale-103 transition-all flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined">shopping_cart</span>
                            @Localizer["Product_AddToCart"]
                        </button>
                    }
                    else
                    {
                        <button disabled class="flex-1 bg-gray-300 text-gray-500 h-16 rounded-3xl font-bold text-lg cursor-not-allowed flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined">block</span>
                            @Localizer["inventory_out_of_stock"]
                        </button>
                    }
                    <button onclick="toggleFav('@product.Id', this)" id="fav-action-btn" class="h-16 px-6 rounded-3xl border-2 font-bold text-sm transition-all flex items-center justify-center gap-2 @(isFavorited ? "bg-error/10 text-error border-error/30 hover:bg-error hover:text-white" : "border-border dark:border-outline/10 text-text-secondary hover:text-error hover:border-error/30")">
                        <span class="material-symbols-outlined @(isFavorited ? "filled-icon" : "")">favorite</span>
                        <span id="fav-action-text">@(isFavorited ? Localizer["fav_remove"] : Localizer["fav_add"])</span>
                    </button>
                </div>
                <button class="w-16 h-16 rounded-3xl border-2 border-border dark:border-outline/10 flex items-center justify-center text-text-secondary hover:text-primary transition-all">
                    <span class="material-symbols-outlined">local_shipping</span>
                </button>
            </div>
        </div>
    </div>

   @*  <!-- Features Grid (Trust builder) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-lg mt-3xl pt-2xl border-t border-border dark:border-outline/10">
        <div class="flex items-center gap-lg">
            <div class="w-14 h-14 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                <span class="material-symbols-outlined">water_drop</span>
            </div>
            <div>
                <h4 class="font-bold">@Localizer["waterproof"]</h4>
                <p class="text-sm text-text-secondary">@Localizer["feat3_p"]</p>
            </div>
        </div>
        <div class="flex items-center gap-lg">
            <div class="w-14 h-14 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                <span class="material-symbols-outlined">wb_sunny</span>
            </div>
            <div>
                <h4 class="font-bold">@Localizer["uv"]</h4>
                <p class="text-sm text-text-secondary">@Localizer["feat3_p"]</p>
            </div>
        </div>
        <div class="flex items-center gap-lg">
            <div class="w-14 h-14 rounded-full bg-primary/10 text-primary flex items-center justify-center">
                <span class="material-symbols-outlined">verified</span>
            </div>
            <div>
                <h4 class="font-bold">@Localizer["Product_BestSeller"]</h4>
                <p class="text-sm text-text-secondary">@Localizer["hero_badge"]</p>
            </div>
        </div>
    </div> *@
</div>

<!-- Related Products -->
@{
    var relatedViewData = new ViewDataDictionary(ViewData) { { "ContainerClass", "max-w-7xl mx-auto px-lg pb-xl" }, { "DetailsRoute", "/customer/product/" } };
}
<partial name="Partials/_RelatedProducts" model="Model.RelatedProducts" view-data="@relatedViewData" />

@section Scripts {
    <script>
        function toggleFav(productId, btn) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            var headers = { 'Content-Type': 'application/json' };
            if (token) headers['RequestVerificationToken'] = token.value;

            fetch('/customer/favorites/toggle', {
                method: 'POST',
                headers: headers,
                body: JSON.stringify({ productId: productId })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    var isFav = data.isFavorited;
                    // Update top-right heart icon
                    var topBtn = document.getElementById('fav-top-btn');
                    if (topBtn) {
                        var topIcon = topBtn.querySelector('.material-symbols-outlined');
                        if (isFav) {
                            topBtn.className = 'w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center transition-all text-error';
                            topIcon.classList.add('filled-icon');
                        } else {
                            topBtn.className = 'w-12 h-12 rounded-full bg-surface/90 backdrop-blur-md shadow-medium flex items-center justify-center transition-all text-text-secondary hover:text-error';
                            topIcon.classList.remove('filled-icon');
                        }
                    }
                    // Update bottom action button
                    var bottomBtn = document.getElementById('fav-action-btn');
                    var bottomIcon = bottomBtn.querySelector('.material-symbols-outlined');
                    var bottomText = document.getElementById('fav-action-text');
                    if (isFav) {
                        bottomBtn.className = 'h-16 px-6 rounded-3xl border-2 font-bold text-sm transition-all flex items-center justify-center gap-2 bg-error/10 text-error border-error/30 hover:bg-error hover:text-white';
                        bottomIcon.classList.add('filled-icon');
                        bottomText.textContent = '@Localizer["fav_remove"]';
                    } else {
                        bottomBtn.className = 'h-16 px-6 rounded-3xl border-2 font-bold text-sm transition-all flex items-center justify-center gap-2 border-border dark:border-outline/10 text-text-secondary hover:text-error hover:border-error/30';
                        bottomIcon.classList.remove('filled-icon');
                        bottomText.textContent = '@Localizer["fav_add"]';
                    }
                }
            })
            .catch(function(e) { console.error('Toggle favorite failed:', e); });
        }
    </script>
}

<style>
    .filled-icon {
        font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

