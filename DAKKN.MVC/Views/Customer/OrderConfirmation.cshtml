@using DAKKN.Application.Features.Orders.DTOs
@model OrderDetailDto
@inject IStringLocalizer<Messages> Localizer
@{
    Layout = "_LayoutCustomer";
}

<div class="max-w-4xl mx-auto px-lg py-24 text-center">
    <div class="relative inline-block mb-xl">
        <div class="w-32 h-32 bg-success/10 rounded-full flex items-center justify-center mx-auto text-success animate-bounce-slow">
            <span class="material-symbols-outlined text-6xl">check_circle</span>
        </div>
        <div class="absolute -top-4 -right-4 w-8 h-8 bg-primary/20 rounded-full blur-xl animate-pulse"></div>
        <div class="absolute -bottom-4 -left-4 w-12 h-12 bg-secondary/20 rounded-full blur-xl animate-pulse delay-700"></div>
    </div>

    <div class="space-y-md mb-2xl">
        <h1 class="text-4xl md:text-5xl font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["order_placed_title"]</h1>
        <p class="text-xl text-text-secondary max-w-xl mx-auto leading-relaxed">@Localizer["order_placed_subtitle"]</p>
    </div>

    <div class="bg-surface dark:bg-inverse-surface rounded-[40px] border border-border dark:border-outline/10 p-xl shadow-large inline-block min-w-[320px] md:min-w-[400px] mb-2xl">
        <div class="text-xs uppercase tracking-[0.2em] text-outline font-bold mb-2">@Localizer["order_number"]</div>
        <div class="text-3xl font-bold text-primary mb-xl">@Model.OrderNumber</div>

            <div class="border-t border-border dark:border-outline/10 pt-xl space-y-md">
                <div class="flex justify-between">
                    <p class="text-[10px] uppercase font-bold text-outline">@Localizer["order_date"]</p>
                    <p class="font-bold">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                </div>
                <div class="border-t border-border/50 dark:border-outline/5 pt-md space-y-sm">
                    <p class="text-[10px] uppercase font-bold text-outline mb-sm">@Localizer["checkout_items"]</p>
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex justify-between items-center py-1">
                            <span class="font-medium text-sm text-left">@item.ProductName</span>
                            <span class="font-bold text-sm">@Localizer["checkout_qty"]: @item.Quantity</span>
                        </div>
                    }
                </div>
                <div class="bg-surface-container dark:bg-white/5 p-4 rounded-2xl flex justify-between items-center">
                    <span class="font-medium">@Localizer["order_total"]</span>
                    <span class="text-xl font-bold text-primary">@Model.TotalAmount.ToString("N2") @Html.Raw(Localizer["Currency_EGP"])</span>
                </div>
        </div>
    </div>

    <div class="flex flex-col sm:flex-row justify-center gap-lg">
        <a asp-action="Orders" class="bg-primary text-on-primary px-xl py-5 rounded-3xl font-bold text-lg shadow-large hover:scale-105 transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">local_shipping</span>
            @Localizer["conf_track_btn"]
        </a>
        <a asp-controller="Home" asp-action="Index" class="bg-surface dark:bg-inverse-surface border border-border dark:border-outline/10 px-xl py-5 rounded-3xl font-bold text-lg hover:bg-primary hover:text-on-primary hover:border-primary transition-all flex items-center justify-center gap-2">
            <span class="material-symbols-outlined">storefront</span>
            @Localizer["order_continue_shopping"]
        </a>
    </div>

    <p class="mt-2xl text-sm text-text-secondary">
        @Localizer["conf_need_help"] <a asp-controller="Home" asp-action="Support" class="text-primary font-bold hover:underline">@Localizer["conf_contact_support"]</a>
    </p>
</div>

<style>
    @@keyframes bounce-slow {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }
    .animate-bounce-slow {
        animation: bounce-slow 3s ease-in-out infinite;
    }
</style>
