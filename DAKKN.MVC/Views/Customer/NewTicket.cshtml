@using DAKKN.MVC.ViewModels.Customer
@model NewTicketViewModel
@{
    Layout = "_LayoutCustomer";
    ViewData["Title"] = Localizer["supp_new_ticket"];
}

<div class="max-w-4xl mx-auto px-lg py-xl">
    <!-- Header -->
    <div class="mb-xl space-y-md">
        <a asp-action="Support" class="inline-flex items-center gap-2 text-text-secondary hover:text-primary transition-colors group">
            <span class="material-symbols-outlined text-lg rtl:rotate-180 group-hover:-translate-x-1 transition-transform">arrow_back</span>
            <span class="font-bold">@Localizer["orders_back"]</span>
        </a>
        <h1 class="customer-page-title text-text-primary dark:text-inverse-on-surface">@Localizer["supp_new_ticket"]</h1>
        <p class="text-text-secondary dark:text-outline-variant">@Localizer["supp_new_ticket_desc"]</p>
    </div>

    <!-- Ticket Form (Quiet/Luxurious Style) -->
    <form asp-action="CreateTicket" method="post" class="section-card p-lg md:p-2xl shadow-small space-y-xl">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-2 gap-xl">
            <!-- Category -->
            <div class="space-y-3">
                <label asp-for="Category" class="block text-sm font-bold text-text-secondary uppercase tracking-widest px-2">@Localizer["supp_ticket_cat"]</label>
                <div class="relative">
                    <select asp-for="Category" class="w-full bg-surface-container dark:bg-white/5 border-none rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none appearance-none bg-none font-medium">
                        <option value="">@Localizer["supp_ticket_cat_ph"]</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat">@cat</option>
                        }
                    </select>
                    <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-text-secondary">expand_more</span>
                </div>
                <span asp-validation-for="Category" class="text-error text-xs font-bold px-2"></span>
            </div>

            <!-- Order ID (Optional) -->
            <div class="space-y-3">
                <label asp-for="OrderId" class="block text-sm font-bold text-text-secondary uppercase tracking-widest px-2">@Localizer["supp_ticket_order_id_label"]</label>
                <input asp-for="OrderId" class="w-full bg-surface-container dark:bg-white/5 border-none rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium" placeholder="@Localizer["supp_ticket_order_id_ph"]">
                <span asp-validation-for="OrderId" class="text-error text-xs font-bold px-2"></span>
            </div>
        </div>

        <!-- Subject -->
        <div class="space-y-3">
            <label asp-for="Subject" class="block text-sm font-bold text-text-secondary uppercase tracking-widest px-2">@Localizer["supp_ticket_subject"]</label>
            <input asp-for="Subject" class="w-full bg-surface-container dark:bg-white/5 border-none rounded-2xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium text-lg" placeholder="@Localizer["supp_ticket_subject_ph"]">
            <span asp-validation-for="Subject" class="text-error text-xs font-bold px-2"></span>
        </div>

        <!-- Message -->
        <div class="space-y-3">
            <label asp-for="Message" class="block text-sm font-bold text-text-secondary uppercase tracking-widest px-2">@Localizer["supp_ticket_msg"]</label>
            <textarea asp-for="Message" rows="6" class="w-full bg-surface-container dark:bg-white/5 border-none rounded-3xl py-4 px-lg focus:ring-2 focus:ring-primary outline-none font-medium resize-none" placeholder="@Localizer["supp_ticket_msg_ph"]"></textarea>
            <span asp-validation-for="Message" class="text-error text-xs font-bold px-2"></span>
        </div>

        <!-- Attachments Placeholder -->
        <div class="p-lg border-2 border-dashed border-border dark:border-outline/20 rounded-3xl text-center group hover:border-primary/50 transition-all cursor-pointer">
            <div class="w-12 h-12 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-text-secondary group-hover:text-primary mb-3">
                <span class="material-symbols-outlined">attach_file</span>
            </div>
            <p class="font-bold text-sm">@Localizer["supp_ticket_attach_label"]</p>
            <p class="text-xs text-text-secondary mt-1">@Localizer["supp_ticket_attach_sub"]</p>
        </div>

        <!-- Submit -->
        <div class="pt-lg">
            <button type="submit" class="w-full md:w-auto bg-text-primary dark:bg-inverse-on-surface text-background dark:text-on-background px-12 py-5 rounded-2xl font-bold text-lg hover:scale-[1.02] active:scale-[0.98] transition-all shadow-large">
                @Localizer["supp_ticket_submit"]
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
