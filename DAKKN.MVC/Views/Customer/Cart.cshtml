@{
    Layout = "_LayoutCustomer";
}

<div class="max-w-7xl mx-auto px-lg py-xl">
    <div class="mb-xl">
        <h1 class="font-h1 text-h1 font-bold text-text-primary dark:text-inverse-on-surface">@Localizer["cart_h1"]</h1>
        <div class="flex items-center gap-2 mt-2">
            <span class="w-2 h-2 rounded-full bg-success"></span>
            <p id="free-shipping-info" class="text-sm text-text-secondary"></p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-2xl items-start">
        <!-- Cart Items List -->
        <div class="lg:col-span-2 space-y-lg">
            <div id="cart-items-container" class="space-y-md">
                <!-- Sample Item 1 -->
                <div class="cart-item group bg-surface dark:bg-inverse-surface rounded-[32px] border border-border dark:border-outline/10 p-lg shadow-small hover:shadow-medium transition-all" data-id="1" data-price="70">
                    <div class="flex flex-col sm:flex-row gap-lg">
                        <div class="w-full sm:w-32 h-32 rounded-2xl overflow-hidden bg-white/5 flex-shrink-0">
                            <img src="https://lh3.googleusercontent.com/aida/AP1WRLvk0o2fHlsgnzmZ9xrrRAnUTq9hl5CW063LX44OhYiXj0ZAadSE46fIAmtHQKBEzfk8NKsMl6AwohhVGiDgxsbst33TGFkDW68Y9_d3C1Cvf-mtviXqQYHM-Aqnsunu3Q6Yy2-9A5mXcsO80D173UvbE44Odz0GI41kQbHK_cLtDiruHCKTT15snGH5XT7Y6MLMfFd4rUCTY71ZJwiOba19bKW0Du2pMXYtJtF-I-h5V-wypv1z0Vztp_M" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Retro Cassette">
                        </div>
                        <div class="flex-1 min-w-0 flex flex-col justify-between">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-xl truncate group-hover:text-primary transition-colors">Retro Cassette</h3>
                                    <p class="text-xs text-text-secondary font-medium uppercase tracking-wider">Holographic Vinyl • 5x5 cm</p>
                                </div>
                                <button onclick="removeItem(1)" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-error hover:bg-error/5 transition-all">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                            <div class="flex justify-between items-end mt-lg">
                                <div class="flex items-center gap-md bg-surface-container dark:bg-white/5 p-1.5 rounded-2xl border border-border dark:border-outline/10">
                                    <button onclick="updateQty(1, -1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-inverse-surface shadow-small flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all">-</button>
                                    <span class="item-qty font-bold w-8 text-center">3</span>
                                    <button onclick="updateQty(1, 1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-inverse-surface shadow-small flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all">+</button>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs text-text-secondary">Unit: 70 @Html.Raw(Localizer["Currency_EGP"])</p>
                                    <p class="font-bold text-xl text-primary item-total">210.00 @Html.Raw(Localizer["Currency_EGP"])</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sample Item 2 -->
                <div class="cart-item group bg-surface dark:bg-inverse-surface rounded-[32px] border border-border dark:border-outline/10 p-lg shadow-small hover:shadow-medium transition-all" data-id="2" data-price="35">
                    <div class="flex flex-col sm:flex-row gap-lg">
                        <div class="w-full sm:w-32 h-32 rounded-2xl overflow-hidden bg-white/5 flex-shrink-0">
                            <img src="https://lh3.googleusercontent.com/aida/AP1WRLvk0o2fHlsgnzmZ9xrrRAnUTq9hl5CW063LX44OhYiXj0ZAadSE46fIAmtHQKBEzfk8NKsMl6AwohhVGiDgxsbst33TGFkDW68Y9_d3C1Cvf-mtviXqQYHM-Aqnsunu3Q6Yy2-9A5mXcsO80D173UvbE44Odz0GI41kQbHK_cLtDiruHCKTT15snGH5XT7Y6MLMfFd4rUCTY71ZJwiOba19bKW0Du2pMXYtJtF-I-h5V-wypv1z0Vztp_M" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" alt="Custom Design">
                        </div>
                        <div class="flex-1 min-w-0 flex flex-col justify-between">
                            <div class="flex justify-between items-start">
                                <div>
                                    <h3 class="font-bold text-xl truncate group-hover:text-primary transition-colors">Custom Order Sticker</h3>
                                    <p class="text-xs text-text-secondary font-medium uppercase tracking-wider">Premium Vinyl • Die Cut • 7x7 cm</p>
                                </div>
                                <button onclick="removeItem(2)" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-error hover:bg-error/5 transition-all">
                                    <span class="material-symbols-outlined">delete</span>
                                </button>
                            </div>
                            <div class="flex justify-between items-end mt-lg">
                                <div class="flex items-center gap-md bg-surface-container dark:bg-white/5 p-1.5 rounded-2xl border border-border dark:border-outline/10">
                                    <button onclick="updateQty(2, -1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-inverse-surface shadow-small flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all">-</button>
                                    <span class="item-qty font-bold w-8 text-center">1</span>
                                    <button onclick="updateQty(2, 1)" class="w-8 h-8 rounded-xl bg-surface dark:bg-inverse-surface shadow-small flex items-center justify-center hover:bg-primary hover:text-on-primary transition-all">+</button>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs text-text-secondary">Unit: 35 @Html.Raw(Localizer["Currency_EGP"])</p>
                                    <p class="font-bold text-xl text-primary item-total">35.00 @Html.Raw(Localizer["Currency_EGP"])</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Empty State -->
            <div id="cart-empty-state" class="hidden py-32 text-center space-y-xl bg-surface dark:bg-inverse-surface rounded-[40px] border border-dashed border-border dark:border-outline/20">
                <div class="w-24 h-24 bg-surface-container dark:bg-white/5 rounded-full flex items-center justify-center mx-auto text-outline opacity-30">
                    <span class="material-symbols-outlined text-5xl">shopping_cart</span>
                </div>
                <div class="space-y-md">
                    <h2 class="text-2xl font-bold">@Localizer["cart_empty_h"]</h2>
                    <p class="text-text-secondary max-w-sm mx-auto">@Localizer["cart_empty_p"]</p>
                </div>
                <a asp-action="Products" class="inline-flex items-center gap-2 bg-primary text-on-primary px-xl py-4 rounded-2xl font-bold hover:shadow-large hover:-translate-y-1 transition-all">
                    @Localizer["orders_empty_btn"] <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>
        </div>

        <!-- Sidebar Summary -->
        <aside class="space-y-lg sticky top-24">
            <div class="bg-surface dark:bg-inverse-surface rounded-[40px] border border-border dark:border-outline/10 p-xl shadow-large space-y-xl">
                <h2 class="text-2xl font-bold">@Localizer["cart_summary_h"]</h2>
                
                <div class="space-y-md">
                    <div class="flex justify-between text-text-secondary">
                        <span>@Localizer["cart_subtotal"]</span>
                        <span id="summary-subtotal"></span>
                    </div>
                    <div class="flex justify-between text-text-secondary">
                        <span>@Localizer["cart_shipping"]</span>
                        <span id="summary-shipping"></span>
                    </div>
                    <div id="discount-row" class="hidden flex justify-between text-success">
                        <span>@Localizer["custom_discount"]</span>
                        <span id="summary-discount"></span>
                    </div>
                    <div class="h-px bg-border dark:bg-outline/10"></div>
                    <div class="flex justify-between items-end">
                        <span class="font-bold text-lg">@Localizer["cart_total"]</span>
                        <div class="text-right">
                            <div id="summary-total" class="text-4xl font-bold text-primary"></div>
                            <div class="text-[10px] text-text-secondary uppercase tracking-widest mt-1">@Localizer["cart_vat_inc"]</div>
                        </div>
                    </div>
                </div>

                <!-- Promo Code -->
                <div class="space-y-md">
                    <div class="flex flex-wrap gap-3">
                        <input type="text" class="flex-1 min-w-[200px] bg-surface-container dark:bg-white/5 border border-border dark:border-outline/10 rounded-2xl px-5 py-3.5 outline-none focus:ring-2 focus:ring-primary transition-all text-sm uppercase font-bold tracking-widest placeholder:normal-case placeholder:font-normal" placeholder="@Localizer["cart_promo_ph"]">
                        <button class="flex-grow sm:flex-grow-0 bg-primary/10 text-primary px-8 py-3.5 rounded-2xl font-bold text-sm hover:bg-primary hover:text-on-primary transition-all">@Localizer["cart_promo_btn"]</button>
                    </div>
                </div>

                <button class="w-full bg-primary text-on-primary py-5 rounded-3xl font-bold text-xl shadow-large hover:scale-[1.02] hover:shadow-2xl transition-all flex items-center justify-center gap-3">
                    @Localizer["cart_checkout"]
                    <span class="material-symbols-outlined">chevron_right</span>
                </button>

                <div class="flex flex-col gap-4">
                    <div class="flex items-center gap-3 p-4 bg-surface-container dark:bg-white/5 rounded-2xl">
                        <span class="material-symbols-outlined text-primary">verified_user</span>
                        <div class="text-xs text-left rtl:text-right">
                            <p class="font-bold">@Localizer["cart_secure_h"]</p>
                            <p class="text-text-secondary">@Localizer["cart_secure_p"]</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 p-4 bg-surface-container dark:bg-white/5 rounded-2xl">
                        <span class="material-symbols-outlined text-primary">local_shipping</span>
                        <div class="text-xs text-left rtl:text-right">
                            <p class="font-bold">@Localizer["cart_fast_h"]</p>
                            <p class="text-text-secondary">@Localizer["cart_fast_p"]</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <a asp-action="Products" class="flex items-center justify-center gap-2 text-text-secondary hover:text-primary font-bold transition-colors">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                @Localizer["cart_continue_shopping"]
            </a>
        </aside>
    </div>
</div>

<style>
    .cart-item {
        animation: slideIn 0.4s ease-out forwards;
    }
    @@keyframes slideIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
    .item-removed {
        transform: scale(0.95);
        opacity: 0;
        transition: all 0.3s ease;
    }
</style>

@section Scripts {
    <script>
        const shippingThreshold = 500;
        const flatShipping = 45;
        // Use a hidden div to safely decode currency symbol
        const decodeEntities = (function() {
            const el = document.createElement('div');
            return function(str) {
                if(str && typeof str === 'string') {
                    el.innerHTML = str;
                    str = el.textContent;
                    el.textContent = '';
                }
                return str;
            }
        })();

        const currencyEgp = decodeEntities('@Html.Raw(Localizer["Currency_EGP"])');

        function updateQty(id, delta) {
            const item = document.querySelector(`.cart-item[data-id="${id}"]`);
            if (!item) return;
            const qtyLabel = item.querySelector('.item-qty');
            const totalLabel = item.querySelector('.item-total');
            const unitPrice = parseFloat(item.dataset.price);
            
            let qty = parseInt(qtyLabel.textContent) + delta;
            if (qty < 1) return;
            
            qtyLabel.textContent = qty;
            totalLabel.innerHTML = `${(qty * unitPrice).toFixed(2)} ${currencyEgp}`;
            
            calculateTotals();
        }

        function removeItem(id) {
            const item = document.querySelector(`.cart-item[data-id="${id}"]`);
            if (!item) return;
            item.classList.add('item-removed');
            setTimeout(() => {
                item.remove();
                calculateTotals();
                checkIfEmpty();
            }, 300);
        }

        function calculateTotals() {
            let subtotal = 0;
            const items = document.querySelectorAll('.cart-item');
            
            items.forEach(item => {
                const qty = parseInt(item.querySelector('.item-qty').textContent);
                const price = parseFloat(item.dataset.price);
                subtotal += (qty * price);
            });

            const shipping = subtotal >= shippingThreshold ? 0 : flatShipping;
            const total = subtotal + shipping;

            // Update Summary
            const subtotalEl = document.getElementById('summary-subtotal');
            const shippingEl = document.getElementById('summary-shipping');
            const totalEl = document.getElementById('summary-total');

            if (subtotalEl) subtotalEl.innerHTML = `${subtotal.toFixed(2)} ${currencyEgp}`;
            if (shippingEl) shippingEl.innerHTML = shipping === 0 ? 'FREE' : `${shipping.toFixed(2)} ${currencyEgp}`;
            if (totalEl) totalEl.innerHTML = `${total.toFixed(2)} ${currencyEgp}`;

            // Update Shipping Info
            const info = document.getElementById('free-shipping-info');
            if (info) {
                if (subtotal >= shippingThreshold) {
                    info.innerHTML = decodeEntities('@Html.Raw(Localizer["cart_free_shipping_msg"])');
                    info.classList.add('text-success');
                    info.classList.remove('text-text-secondary');
                } else {
                    const left = shippingThreshold - subtotal;
                    const msg = decodeEntities('@Html.Raw(Localizer["cart_free_shipping_left", "PLACEHOLDER"])');
                    info.innerHTML = msg.replace('PLACEHOLDER', `<span class='font-bold'>${left.toFixed(0)}</span>`);
                    info.classList.remove('text-success');
                    info.classList.add('text-text-secondary');
                }
            }
        }

        function checkIfEmpty() {
            const items = document.querySelectorAll('.cart-item');
            if (items.length === 0) {
                const container = document.getElementById('cart-items-container');
                const emptyState = document.getElementById('cart-empty-state');
                if (container) container.classList.add('hidden');
                if (emptyState) emptyState.classList.remove('hidden');
            }
        }

        window.addEventListener('DOMContentLoaded', calculateTotals);
    </script>
}
