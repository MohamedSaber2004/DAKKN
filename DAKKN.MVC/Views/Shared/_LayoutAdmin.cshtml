            <span>@Localizer["admin_sticker_suggestions"]</span>
        </a>
        <a asp-controller="Admin" asp-action="Shipping" class="admin-bnav-item @(currentAction == "Shipping" && currentController == "Admin" ? "admin-bnav-active" : "")" title="@Localizer["admin_shipping.title"]">
            <span class="material-symbols-outlined @(currentAction == "Shipping" && currentController == "Admin" ? "filled-icon" : "")">map</span>
