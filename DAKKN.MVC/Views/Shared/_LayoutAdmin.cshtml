@inject IStringLocalizer<Messages> Localizer
@using System.Security.Claims
@using DAKKN.Application.Localization
@using System.Text.Json
@inject IMediator Mediator
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var fullName = User.FindFirstValue("FullName");
    if (string.IsNullOrWhiteSpace(fullName))
    {
        fullName = User.Identity?.Name ?? Localizer["admin_fallback_name"].Value;
    }

    var isDarkMode = false;
    var themeName = "light";
    var primaryColor = "#0E908C";
    var primaryRgb = "14, 144, 140";

    // Separate admin cookies — never shared with customer
    var themeCookie = Context.Request.Cookies["dakkn_admin_theme"];
    var langCookie = Context.Request.Cookies["dakkn_admin_lang"];
    if (!string.IsNullOrEmpty(themeCookie))
    {
        isDarkMode = themeCookie == "dark";
        themeName = themeCookie;
    }
    else if (User.Identity?.IsAuthenticated == true)
    {
        try 
        {
            var settings = await Mediator.Send(new GetUserSettingsQuery());
            isDarkMode = settings.IsDarkMode;
            themeName = settings.Theme;
        }
        catch { /* Fallback to default */ }
    }
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" class="@(isDarkMode ? "dark" : "")" data-dakkn-loading="true" style="--primary-color: @primaryColor; --primary-rgb: @primaryRgb;">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta name="robots" content="noindex, nofollow" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/favicon.png" />
    <link rel="apple-touch-icon" href="~/favicon.png" />
    <meta name="description" content="@(ViewData["Description"] ?? Localizer["seo_description"])" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content="@(ViewData["Title"] ?? "DAKKN")" />
    <meta property="og:description" content="@(ViewData["Description"] ?? Localizer["seo_description"])" />
    <meta property="og:image"       content="@($"{Context.Request.Scheme}://{Context.Request.Host}/images/logo.png")" />
    <meta property="og:site_name"   content="DAKKN" />
    <meta property="og:locale"      content="@(culture == "ar" ? "ar_SA" : "en_US")" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@(ViewData["Title"] ?? "DAKKN")" />
    <meta name="twitter:description" content="@(ViewData["Description"] ?? Localizer["seo_description"])" />
    <meta name="twitter:image"       content="@($"{Context.Request.Scheme}://{Context.Request.Host}/images/logo.png")" />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.tailwindcss.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://cdn.tailwindcss.com" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Admin Stylesheet -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
        body { font-family: 'Inter', 'Cairo', sans-serif; transition: background-color 0.3s ease; }

        /* Prevent FOUC and show preloader */
        [data-dakkn-loading] body {
            visibility: hidden !important;
            overflow: hidden !important;
        }

        #dakkn-preloader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: visible !important;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        #dakkn-preloader.fade-out {
            opacity: 0;
            visibility: hidden !important;
        }
        .dark #dakkn-preloader { background: var(--dark-page, #0A2030); }

        .preloader-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100px;
            height: 100px;
        }
        .preloader-spinner {
            position: absolute;
            width: 80px;
            height: 80px;
            border: 3px solid rgba(var(--primary-rgb, 14, 144, 140), 0.15);
            border-top-color: var(--primary-color, #0E908C);
            border-radius: 50%;
            animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }
        .preloader-logo {
            position: absolute;
            height: 36px;
            width: auto;
            animation: pulse-logo 2s ease-in-out infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        @@keyframes pulse-logo {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; }
        }

        /* Page fade-in transition */
        #admin-canvas { animation: pageFadeIn 0.25s ease-out; }
        @@keyframes pageFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

        /* Collapsible Sidebar Styles */
        .admin-sidebar {
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
        }

        /* Tablet: sidebar auto-collapses to icon-only (80px) */
        @@media (min-width: 768px) and (max-width: 1279px) {
            .admin-sidebar {
                width: 80px !important;
            }
            .admin-sidebar .sidebar-text { display: none !important; }
            .admin-sidebar .nav-item {
                justify-content: center !important;
                padding-left: 0 !important;
                padding-right: 0 !important;
                margin-left: 8px !important;
                margin-right: 8px !important;
            }
            .admin-sidebar .add-product-btn span:last-child { display: none !important; }
            .admin-sidebar .add-product-btn {
                width: 44px !important; height: 44px !important;
                padding: 0 !important; border-radius: 50% !important;
            }
            .admin-sidebar .admin-brand-info {
                justify-content: center !important;
                padding-left: 0 !important;
                padding-right: 0 !important;
            }

            /* Tablet expanded: user clicked toggle to show full sidebar with text */
            .tablet-sidebar-expanded .admin-sidebar {
                width: 256px !important;
                position: fixed !important;
                top: 0; bottom: 0; left: 0;
                z-index: 200 !important;
                box-shadow: 4px 0 24px rgba(0,0,0,0.15) !important;
            }
            [dir="rtl"].tablet-sidebar-expanded .admin-sidebar {
                left: auto !important; right: 0;
            }
            .tablet-sidebar-expanded .admin-sidebar .sidebar-text { display: inline !important; }
            .tablet-sidebar-expanded .admin-sidebar .nav-item {
                justify-content: flex-start !important;
                padding-left: 16px !important;
                padding-right: 16px !important;
                margin-left: 0 !important;
                margin-right: 0 !important;
            }
            .tablet-sidebar-expanded .admin-sidebar .add-product-btn span:last-child { display: inline !important; }
            .tablet-sidebar-expanded .admin-sidebar .add-product-btn {
                width: 100% !important; height: 52px !important;
                padding: 0 16px !important; border-radius: 18px !important;
            }
            .tablet-sidebar-expanded .admin-sidebar .admin-brand-info {
                justify-content: flex-start !important;
                padding-left: 24px !important;
                padding-right: 24px !important;
            }
        }

        .sidebar-is-collapsed .admin-sidebar {
            width: 80px !important;
        }

        .sidebar-is-collapsed .sidebar-text {
            opacity: 0;
            pointer-events: none;
            width: 0;
            overflow: hidden;
            display: none;
        }

        .sidebar-is-collapsed .admin-logo-img {
            height: 40px !important;
        }

        .sidebar-is-collapsed .nav-item {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
            margin-left: 8px;
            margin-right: 8px;
        }

        .sidebar-is-collapsed .add-product-btn span:last-child {
            display: none;
        }

        .sidebar-is-collapsed .add-product-btn {
            width: 48px;
            height: 48px;
            padding: 0;
            border-radius: 50%;
        }

        .nav-item {
            transition: all 0.2s ease;
        }

        /* Mobile Bottom Nav */
        #admin-bottom-nav {
            position: fixed;
            bottom: 0; left: 0; right: 0;
            z-index: 100;
            display: none;
            background: var(--surface, #fff);
            border-top: 1px solid var(--border-color, rgba(0,0,0,.08));
            box-shadow: 0 -4px 24px rgba(0,0,0,.10);
            padding-bottom: env(safe-area-inset-bottom, 0);
        }
        @@media (max-width: 767px) {
            #admin-bottom-nav { display: flex !important; }
            #admin-canvas { padding-bottom: 80px !important; }
        }
        .dark #admin-bottom-nav {
            background: #1E293B;
            border-top-color: rgba(255,255,255,.06);
        }

        /* Admin support sub-list */
        #admin-support-sub-list {
            transition: max-height 0.25s ease;
        }
        #admin-support-chevron.rotate-180 {
            transform: rotate(180deg);
        }

        /* Collapsed/icon-only sidebar: sub-list becomes an overlay dropdown */
        .sidebar-is-collapsed #admin-support-sub-list,
        .admin-sidebar:not(.tablet-sidebar-expanded) #admin-support-sub-list {
            display: none;
            position: fixed;
            left: 80px;
            width: 220px;
            background: var(--surface, #fff);
            border-radius: 0.75rem;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            z-index: 300;
            padding: 8px 0 !important;
            max-height: none !important;
            overflow: visible !important;
            border: 1px solid var(--border-color, rgba(0,0,0,0.08));
        }
        .dark .sidebar-is-collapsed #admin-support-sub-list,
        .dark .admin-sidebar:not(.tablet-sidebar-expanded) #admin-support-sub-list {
            background: #1E293B;
            border-color: rgba(255,255,255,0.06);
        }
        [dir="rtl"] .sidebar-is-collapsed #admin-support-sub-list,
        [dir="rtl"] .admin-sidebar:not(.tablet-sidebar-expanded) #admin-support-sub-list {
            left: auto !important;
            right: 80px;
        }
        .sidebar-is-collapsed #admin-support-sub-list .sidebar-text,
        .admin-sidebar:not(.tablet-sidebar-expanded) #admin-support-sub-list .sidebar-text {
            display: inline !important;
            opacity: 1 !important;
            width: auto !important;
            pointer-events: auto !important;
        }
        .sidebar-is-collapsed #admin-support-sub-list .nav-item,
        .admin-sidebar:not(.tablet-sidebar-expanded) #admin-support-sub-list .nav-item {
            justify-content: flex-start !important;
            padding-left: 12px !important;
            padding-right: 12px !important;
            margin-left: 4px !important;
            margin-right: 4px !important;
        }
    </style>

    <script>
        // Admin-specific cookie prefix — never shared with customer
        window.dakknCookiePrefix = 'dakkn_admin_';

        // High-priority theme application to prevent light-mode flash
        (function() {
            // Priority: Use admin-specific localStorage, fall back to server value
            const savedTheme = localStorage.getItem('dakkn_admin_theme');
            const serverTheme = "@themeName";
            const serverIsDark = @(isDarkMode.ToString().ToLower());
            
            const effectiveTheme = savedTheme || serverTheme || 'light';
            const effectiveIsDark = effectiveTheme === 'dark';
            
            localStorage.setItem('dakkn_admin_theme', effectiveTheme);
            if (effectiveIsDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // Admin language — read cookie, save to localStorage
            function getCookieValue(name) {
                var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                return match ? decodeURIComponent(match[2]) : null;
            }
            var adminLang = getCookieValue('dakkn_admin_lang');
            const culture = "@culture";
            localStorage.setItem('dakkn_admin_lang', adminLang || culture);
            // If admin lang cookie exists and differs from server culture, reload
            if (adminLang && adminLang !== culture) {
                window.location.href = '/Translation/SetLanguage?culture=' + adminLang + '&returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
            }

            // Initialize Sidebar State
            // Only apply JS-collapsed class on desktop (tablet uses CSS media query for icon-only mode)
            const isCollapsed = localStorage.getItem('dakkn_sidebar_collapsed') === 'true';
            if (isCollapsed && window.innerWidth >= 1280) {
                document.documentElement.classList.add('sidebar-is-collapsed');
            }
        })();

        document.addEventListener('DOMContentLoaded', function() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenInput) {
                window.csrfToken = tokenInput.value;
            }
        });

        // ── No JWT silent refresh needed for admin (uses cookie auth) ─────

        // Failsafe: Ensure preloader is hidden even if scripts fail or hang
        setTimeout(() => {
            const preloader = document.getElementById('dakkn-preloader');
            if (preloader) {
                preloader.style.opacity = '0';
                setTimeout(() => {
                    preloader.remove();
                    document.documentElement.removeAttribute('data-dakkn-loading');
                }, 400);
            }
        }, 2000);
    </script>

    <script>
        // Inject current translations immediately to avoid flickering
        window.currentTranslations = @Html.Raw(JsonSerializer.Serialize(DAKKN.Application.Localization.JsonLocalizationProvider.GetTranslations(culture)));
    </script>
</head>
<body class="text-text-primary dark:text-white h-screen overflow-hidden flex bg-background dark:bg-[#0F172A] transition-colors duration-300">
    
    <!-- Preloader Overlay -->
    @await Html.PartialAsync("Partials/_Preloader")

    <!-- Sidebar Overlay for Mobile -->
    <div id="sidebar-overlay" class="sidebar-overlay md:hidden" onclick="toggleSidebar()"></div>

    <!-- Mobile Bottom Nav (visible only on < 768px) -->
    <nav id="admin-bottom-nav" class="items-center justify-around px-2 py-2 gap-1">
        <a asp-controller="Admin" asp-action="Dashboard" class="admin-bnav-item @(currentAction == "Dashboard" && currentController == "Admin" ? "admin-bnav-active" : "")" title="@Localizer["admin_overview"]">
            <span class="material-symbols-outlined @(currentAction == "Dashboard" && currentController == "Admin" ? "filled-icon" : "")">dashboard</span>
            <span>@Localizer["admin_overview"]</span>
        </a>
        <a asp-controller="Admin" asp-action="Orders" class="admin-bnav-item @(currentAction == "Orders" && currentController == "Admin" ? "admin-bnav-active" : "")" title="@Localizer["admin_orders"]">
            <span class="material-symbols-outlined @(currentAction == "Orders" && currentController == "Admin" ? "filled-icon" : "")">shopping_cart</span>
            <span>@Localizer["admin_orders"]</span>
        </a>
        <a asp-controller="Admin" asp-action="AddProduct" class="admin-bnav-fab" title="@Localizer["admin_add_product"]">
            <span class="material-symbols-outlined">add</span>
        </a>
        <a asp-controller="Admin" asp-action="Inventory" class="admin-bnav-item @(currentAction == "Inventory" && currentController == "Admin" ? "admin-bnav-active" : "")" title="@Localizer["admin_inventory"]">
            <span class="material-symbols-outlined @(currentAction == "Inventory" && currentController == "Admin" ? "filled-icon" : "")">inventory_2</span>
            <span>@Localizer["admin_inventory"]</span>
        </a>
        <a asp-controller="AdminStickerSuggestion" asp-action="Index" class="admin-bnav-item" title="@Localizer["admin_sticker_suggestions"]">
