            <a asp-controller="Admin" asp-action="Users" class="nav-item flex items-center gap-md @(currentAction == "Users" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_users"]">
                <span class="material-symbols-outlined @(currentAction == "Users" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">group</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_users"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="nav-item flex items-center gap-md @(currentAction == "Orders" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_orders"]">
                <span class="material-symbols-outlined @(currentAction == "Orders" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">shopping_cart</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_orders"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Inventory" class="nav-item flex items-center gap-md @(currentAction == "Inventory" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_inventory"]">
                <span class="material-symbols-outlined @(currentAction == "Inventory" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">inventory_2</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_inventory"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Categories" class="nav-item flex items-center gap-md @((currentAction == "Categories" || currentAction == "CreateCategory" || currentAction == "EditCategory") && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_categories"]">
                <span class="material-symbols-outlined @((currentAction == "Categories" || currentAction == "CreateCategory" || currentAction == "EditCategory") && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">category</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_categories"]</span>
            </a>
            <div class="nav-section">
                <button type="button" onclick="toggleAdminSupportSubList()" class="nav-item w-full flex items-center gap-md px-4 py-3 rounded-xl @(currentController == "SupportAdmin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") transition-all duration-200" title="@Localizer["admin_support"]">
                    <span class="material-symbols-outlined flex-shrink-0">support_agent</span>
                    <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_support"]</span>
                    <span id="admin-support-chevron" class="material-symbols-outlined sidebar-text ml-auto transition-transform @(currentController == "SupportAdmin" ? "rotate-180" : "")">expand_more</span>
                </button>
                <div id="admin-support-sub-list" style="overflow:hidden;@(currentController == "SupportAdmin" ? "max-height:300px" : "max-height:0")">
                    <div class="pt-1 pb-1 space-y-1 ltr:pl-8 rtl:pr-8">
                        <a asp-controller="SupportAdmin" asp-action="Tickets" class="nav-item flex items-center gap-md @(currentController == "SupportAdmin" && (currentAction == "Tickets" || currentAction == "TicketDetails") ? "active bg-primary/10 text-primary dark:text-primary-light font-bold" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-2 rounded-xl transition-all duration-200">
                            <span class="material-symbols-outlined text-sm flex-shrink-0">confirmation_number</span>
                            <span class="font-caption text-caption sidebar-text">@Localizer["admin_support_tickets"]</span>
                        </a>
                        <a asp-controller="SupportAdmin" asp-action="Categories" class="nav-item flex items-center gap-md @(currentController == "SupportAdmin" && currentAction == "Categories" ? "active bg-primary/10 text-primary dark:text-primary-light font-bold" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-2 rounded-xl transition-all duration-200">
                            <span class="material-symbols-outlined text-sm flex-shrink-0">category</span>
                            <span class="font-caption text-caption sidebar-text">@Localizer["admin_support_categories"]</span>
                        </a>
                        <a asp-controller="SupportAdmin" asp-action="FAQs" class="nav-item flex items-center gap-md @(currentController == "SupportAdmin" && currentAction == "FAQs" ? "active bg-primary/10 text-primary dark:text-primary-light font-bold" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-2 rounded-xl transition-all duration-200">
                            <span class="material-symbols-outlined text-sm flex-shrink-0">quiz</span>
                            <span class="font-caption text-caption sidebar-text">@Localizer["admin_support_faq"]</span>
                        </a>
                        <a asp-controller="SupportAdmin" asp-action="Settings" class="nav-item flex items-center gap-md @(currentController == "SupportAdmin" && currentAction == "Settings" ? "active bg-primary/10 text-primary dark:text-primary-light font-bold" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-2 rounded-xl transition-all duration-200">
                            <span class="material-symbols-outlined text-sm flex-shrink-0">settings</span>
                            <span class="font-caption text-caption sidebar-text">@Localizer["admin_settings"]</span>
                        </a>
                    </div>
                </div>
            </div>
            <a asp-controller="Admin" asp-action="Shipping" class="nav-item flex items-center gap-md @((currentAction == "Shipping" || currentAction == "CreateShipping" || currentAction == "EditShipping") && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_shipping.title"]">
                <span class="material-symbols-outlined @((currentAction == "Shipping" || currentAction == "CreateShipping" || currentAction == "EditShipping") && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">map</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_shipping.title"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Content" class="nav-item flex items-center gap-md @(currentAction == "Content" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_content_mgmt"]">
                <span class="material-symbols-outlined @(currentAction == "Content" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">edit_note</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_content_mgmt"]</span>
            </a>
            <a asp-controller="Admin" asp-action="BrandReviews" class="nav-item flex items-center gap-md @(currentAction == "BrandReviews" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["brand_reviews_admin_title"]">
                <span class="material-symbols-outlined @(currentAction == "BrandReviews" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">rate_review</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["brand_reviews_admin_title"]</span>
            </a>
            <a asp-controller="AdminStickerSuggestion" asp-action="Index" class="nav-item flex items-center gap-md @(currentAction == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "AdminStickerSuggestion" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_sticker_suggestions"]">
                <span class="material-symbols-outlined @(currentAction == "Index" && ViewContext.RouteData.Values["controller"]?.ToString() == "AdminStickerSuggestion" ? "filled-icon" : "") flex-shrink-0">lightbulb</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_sticker_suggestions"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Settings" class="nav-item flex items-center gap-md @(currentAction == "Settings" && currentController == "Admin" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl mt-auto transition-all duration-200" title="@Localizer["admin_settings"]">
                <span class="material-symbols-outlined @(currentAction == "Settings" && currentController == "Admin" ? "filled-icon" : "") flex-shrink-0">settings</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_settings"]</span>
            </a>

            <div class="mt-sm">
                <form id="logout-form" asp-controller="Auth" asp-action="Logout" method="post">
                    <input type="hidden" name="refreshToken" id="logout-refresh-token" />
                    <button type="button" onclick="submitLogout()" class="nav-item w-full flex items-center gap-md text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 px-4 py-3 transition-all duration-200 rounded-xl" title="@Localizer["auth.logout"]">
                        <span class="material-symbols-outlined flex-shrink-0">logout</span>
                        <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["auth.logout"]</span>
                    </button>
                </form>
            </div>
        </nav>
        <div class="p-md border-t border-border dark:border-white/5 flex justify-center items-center">
            <a asp-controller="Admin" asp-action="AddProduct" class="add-product-btn w-full bg-primary text-on-primary h-[52px] rounded-[18px] shadow-small font-body-lg text-body-lg flex items-center justify-center gap-sm hover:scale-105 transition-all duration-200 overflow-hidden" title="@Localizer["admin_add_product"]">
                <span class="material-symbols-outlined flex-shrink-0">add</span>
                <span class="sidebar-text whitespace-nowrap">@Localizer["admin_add_product"]</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main data-page-entrance class="flex-1 flex flex-col h-screen overflow-hidden bg-background dark:bg-[#0F172A] transition-colors duration-300">
        <!-- TopNavBar -->
        <header class="flex justify-between items-center w-full px-lg py-md z-30 bg-surface/80 dark:bg-[#1E293B]/80 backdrop-blur-md flex-shrink-0 border-b border-border dark:border-white/5 transition-colors duration-300">
            <div class="flex items-center gap-md">
                <!-- Sidebar Toggle -->
                <button onclick="toggleSidebar()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline-variant dark:hover:text-primary-light transition-colors hover:bg-primary/5 dark:hover:bg-white/5">
                    <span class="material-symbols-outlined" id="sidebar-toggle-icon">menu_open</span>
                </button>
                <div class="md:hidden">
                    <h2 class="text-base font-bold text-text-primary dark:text-white truncate max-w-[160px]">@ViewData["Title"]</h2>
                </div>
                <div class="hidden md:block">
                    <h2 class="font-h3 text-h3 font-bold text-text-primary dark:text-white">@ViewData["Title"]</h2>
                </div>
            </div>
            <div class="flex items-center gap-lg">
                <div class="relative hidden sm:block">
                    <input class="bg-surface-container dark:bg-white/5 rounded-full py-2 px-4 ltr:pl-10 ltr:pr-4 rtl:pr-10 rtl:pl-4 text-body font-body border border-transparent dark:border-white/5 focus:ring-2 focus:ring-primary dark:focus:ring-primary-light focus:bg-surface dark:focus:bg-white/10 outline-none w-64 text-text-primary dark:text-white placeholder:text-text-secondary dark:placeholder:text-outline transition-all" placeholder="@Localizer["admin_search"]" type="text">
                    <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-text-secondary dark:text-outline">search</span>
                </div>
                <div class="flex items-center gap-sm">
                    @await Html.PartialAsync("Partials/_LanguageToggle")
                    @await Html.PartialAsync("Partials/_ThemeToggle")
                </div>
                <div class="w-10 h-10 rounded-full bg-primary-container overflow-hidden cursor-pointer shadow-small border border-border dark:border-white/10">
                    <img alt='@Localizer["admin_avatar_alt"]' class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@(fullName)&background=69d2cf&color=005957">
                </div>
            </div>
        </header>

        <!-- Scrollable Canvas -->
        <div id="admin-canvas" class="flex-1 overflow-y-auto p-margin-mobile md:p-xl custom-scrollbar">
            @RenderBody()
            <!-- Spacer for bottom scrolling -->
            <div class="h-xl"></div>
        </div>
    </main>

    <!-- Back to Top -->
    <button id="back-to-top" class="opacity-0 pointer-events-none" aria-label="@Localizer["back_to_top"]">
        <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/js/landing.js" asp-append-version="true" defer></script>
    <script src="~/js/site-animations.js" asp-append-version="true" defer></script>

    <script>
        // Sidebar Toggle Logic
        function toggleSidebar() {
            if (window.innerWidth < 768) {
                // On mobile, bottom nav handles navigation; hamburger toggles slide-over drawer
                document.documentElement.classList.toggle('mobile-sidebar-open');
            } else {
                // On tablet/desktop, toggle collapse between full/icon-only
                const isTablet = window.innerWidth < 1280;
                if (isTablet) {
                    // Tablet: CSS media query makes sidebar icon-only by default.
                    // Toggle 'tablet-sidebar-expanded' to show full sidebar with text.
                    const isExpanded = document.documentElement.classList.toggle('tablet-sidebar-expanded');
                    updateSidebarIcon(!isExpanded);
                    setTabletOverlay(isExpanded);
                } else {
                    const isCollapsed = document.documentElement.classList.toggle('sidebar-is-collapsed');
                    localStorage.setItem('dakkn_sidebar_collapsed', isCollapsed);
                    updateSidebarIcon(isCollapsed);
                }
            }
        }

        function collapseSidebarTablet() {
            document.documentElement.classList.remove('tablet-sidebar-expanded');
            updateSidebarIcon(true);
            setTabletOverlay(false);
        }

        function setTabletOverlay(show) {
            const overlay = document.getElementById('tablet-sidebar-overlay');
            if (!overlay) return;
            if (show) {
                overlay.style.opacity = '1';
                overlay.style.pointerEvents = 'auto';
            } else {
                overlay.style.opacity = '0';
                overlay.style.pointerEvents = 'none';
            }
        }

        function updateSidebarIcon(isCollapsed) {
            const icon = document.getElementById('sidebar-toggle-icon');
            if (icon) {
                icon.textContent = isCollapsed ? 'menu' : 'menu_open';
            }
        }


        function toggleAdminSupportSubList() {
            const list = document.getElementById('admin-support-sub-list');
            const chevron = document.getElementById('admin-support-chevron');
            const btn = document.querySelector('button[onclick="toggleAdminSupportSubList()"]');
            if (!list) return;
            const isCollapsed = document.documentElement.classList.contains('sidebar-is-collapsed') ||
                (window.innerWidth >= 768 && window.innerWidth < 1280 && !document.documentElement.classList.contains('tablet-sidebar-expanded'));
            if (isCollapsed) {
                const isVisible = getComputedStyle(list).display !== 'none';
                if (isVisible) {
                    list.style.display = 'none';
                    if (chevron) chevron.classList.remove('rotate-180');
                } else {
                    if (btn) {
                        const rect = btn.getBoundingClientRect();
                        list.style.top = Math.max(rect.top, 8) + 'px';
                    }
                    list.style.display = 'block';
                    if (chevron) chevron.classList.add('rotate-180');
                }
            } else {
                const isOpen = list.style.maxHeight !== '0px' && list.style.maxHeight !== '0';
                list.style.maxHeight = isOpen ? '0' : '300px';
                if (chevron) chevron.classList.toggle('rotate-180', !isOpen);
            }
        }

        function submitLogout() {
            const form = document.getElementById('logout-form');
            const tokenInput = document.getElementById('logout-refresh-token');
            const refreshToken = localStorage.getItem('dakkn_refresh_token');
            
            if (tokenInput) tokenInput.value = refreshToken || '';
            form.submit();
        }

        // Initialize State on Load
        document.addEventListener('DOMContentLoaded', () => {
            // Automatically wrap tables in overflow-x-auto if not already wrapped
            document.querySelectorAll('#admin-canvas table').forEach(table => {
                if (!table.parentElement.classList.contains('overflow-x-auto') && !table.classList.contains('no-wrap-table')) {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'overflow-x-auto custom-scrollbar my-4 rounded-xl border border-admin-border bg-admin-card';
                    table.parentNode.insertBefore(wrapper, table);
                    wrapper.appendChild(table);
                }
            });

            // On desktop only, restore collapsed state from localStorage
            if (window.innerWidth >= 1280) {
                const savedCollapsed = localStorage.getItem('dakkn_sidebar_collapsed') === 'true';
                if (savedCollapsed) {
                    document.documentElement.classList.add('sidebar-is-collapsed');
                    updateSidebarIcon(true);
                } else {
                    updateSidebarIcon(false);
                }
            } else {
                // Tablet or mobile: sidebar starts as icon-only (CSS handles it); icon shows 'menu'
                updateSidebarIcon(true);
            }
        });

        // Close overlay sub-list when clicking outside
        document.addEventListener('click', function(e) {
            const list = document.getElementById('admin-support-sub-list');
            const btn = document.querySelector('button[onclick="toggleAdminSupportSubList()"]');
            if (list && btn && getComputedStyle(list).display !== 'none') {
                const isCollapsed = document.documentElement.classList.contains('sidebar-is-collapsed') ||
                    (window.innerWidth >= 768 && window.innerWidth < 1280 && !document.documentElement.classList.contains('tablet-sidebar-expanded'));
                if (isCollapsed && !list.contains(e.target) && !btn.contains(e.target)) {
                    list.style.display = 'none';
                    const chevron = document.getElementById('admin-support-chevron');
                    if (chevron) chevron.classList.remove('rotate-180');
                }
            }
        });

        // Clean up inline styles when resizing between collapsed/full modes
        let resizeTimer;
        window.addEventListener('resize', function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function() {
                const list = document.getElementById('admin-support-sub-list');
                if (list) {
                    const isCollapsed = document.documentElement.classList.contains('sidebar-is-collapsed') ||
                        (window.innerWidth >= 768 && window.innerWidth < 1280 && !document.documentElement.classList.contains('tablet-sidebar-expanded'));
                    if (!isCollapsed) {
                        list.style.display = '';
                        list.style.top = '';
                        list.style.position = '';
                    }
                }
            }, 100);
        });

        // Hover-based link prefetching for instant page transitions
        let prefetchTimer;
        document.addEventListener('mouseover', function(e) {
            const link = e.target.closest('a[href]');
            if (!link || !link.href.startsWith(location.origin) || link.href === location.href) return;
            clearTimeout(prefetchTimer);
            prefetchTimer = setTimeout(function() {
                const l = document.createElement('link');
                l.rel = 'prefetch';
                l.href = link.href;
                document.head.appendChild(l);
            }, 80);
        }, { passive: true });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
