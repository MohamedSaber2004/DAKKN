@inject IStringLocalizer<Messages> Localizer
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" data-dakkn-loading="true">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta name="robots" content="noindex, nofollow" />
    <title>@ViewData["Title"] - @Localizer["brand"] @Localizer["admin_dashboard"]</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Admin Stylesheet -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
        body { font-family: 'Inter', 'Cairo', sans-serif; transition: background-color 0.3s ease; }
    </style>

    <script>
        (function() {
            const theme = localStorage.getItem('dakkn_theme');
            if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();

        window.csrfToken = "@Html.AntiForgeryToken()".match(/value="([^"]+)"/)[1];
    </script>
</head>
<body class="text-text-primary dark:text-inverse-on-surface h-screen overflow-hidden flex bg-background dark:bg-dark-page transition-colors duration-300">
    
    <!-- Preloader Overlay -->
    @await Html.PartialAsync("Partials/_Preloader")

    <!-- SideNavBar -->
    <aside class="hidden md:flex flex-col admin-sidebar ltr:left-0 ltr:border-r rtl:right-0 rtl:border-l h-screen w-64 shadow-medium z-40 relative flex-shrink-0 transition-colors duration-300">
        <div class="p-lg border-b border-border dark:border-outline/20 flex flex-col items-center justify-center gap-sm group cursor-pointer">
            <div class="admin-logo-container">
                <img src="/images/logo.png" alt="DAKKN Logo" class="h-16 admin-logo-img dark:brightness-125" />
            </div>
            <h1 class="font-h2 text-h2 font-bold text-primary dark:text-primary-light">@Localizer["brand"]</h1>
            <p class="font-body text-body text-text-secondary dark:text-outline-variant">@Localizer["admin_dashboard"]</p>
        </div>
        <nav class="flex-1 overflow-y-auto custom-scrollbar py-md px-sm flex flex-col gap-sm">
            <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-md @(currentAction == "Index" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") rounded-xl px-4 py-3 scale-100 hover:scale-103 transition-all duration-200">
                <span class="material-symbols-outlined @(currentAction == "Index" ? "filled-icon" : "")">dashboard</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_overview"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Users" class="flex items-center gap-md @(currentAction == "Users" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") px-4 py-3 hover:scale-105 transition-transform duration-200 rounded-xl">
                <span class="material-symbols-outlined @(currentAction == "Users" ? "filled-icon" : "")">group</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_users"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="flex items-center gap-md @(currentAction == "Orders" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") px-4 py-3 hover:scale-105 transition-transform duration-200 rounded-xl">
                <span class="material-symbols-outlined @(currentAction == "Orders" ? "filled-icon" : "")">shopping_cart</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_orders"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Inventory" class="flex items-center gap-md @(currentAction == "Inventory" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") px-4 py-3 hover:scale-105 transition-transform duration-200 rounded-xl">
                <span class="material-symbols-outlined @(currentAction == "Inventory" ? "filled-icon" : "")">inventory_2</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_inventory"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Support" class="flex items-center gap-md @(currentAction == "Support" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") px-4 py-3 hover:scale-105 transition-transform duration-200 rounded-xl">
                <span class="material-symbols-outlined @(currentAction == "Support" ? "filled-icon" : "")">support_agent</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_support"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Settings" class="flex items-center gap-md @(currentAction == "Settings" ? "bg-primary-container text-on-primary-container" : "text-text-secondary hover:text-primary") px-4 py-3 hover:scale-105 transition-transform duration-200 rounded-xl mt-auto">
                <span class="material-symbols-outlined @(currentAction == "Settings" ? "filled-icon" : "")">settings</span>
                <span class="font-body-lg text-body-lg">@Localizer["admin_settings"]</span>
            </a>
        </nav>
        <div class="p-md border-t border-border">
            <a asp-controller="Admin" asp-action="AddProduct" class="w-full bg-primary text-on-primary h-[52px] rounded-[18px] shadow-small font-body-lg text-body-lg flex items-center justify-center gap-sm hover:scale-105 transition-transform duration-200">
                <span class="material-symbols-outlined">add</span>
                @Localizer["admin_add_product"]
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden bg-background dark:bg-on-background transition-colors duration-300">
        <!-- TopNavBar -->
        <header class="flex justify-between items-center w-full px-lg py-md z-30 bg-surface/80 dark:bg-inverse-surface/80 backdrop-blur-md flex-shrink-0 border-b border-border dark:border-outline/10 transition-colors duration-300">
            <div class="flex items-center gap-md md:hidden">
                <span class="material-symbols-outlined text-primary dark:text-primary-light cursor-pointer text-2xl">menu</span>
                <div class="admin-logo-container">
                    <img src="/images/logo.png" alt="DAKKN Logo" class="h-10 admin-logo-img dark:brightness-125" />
                </div>
            </div>
            <div class="hidden md:block">
                <h2 class="font-h3 text-h3 font-bold text-text-primary dark:text-inverse-on-surface">@ViewData["Title"]</h2>
            </div>
            <div class="flex items-center gap-lg">
                <div class="relative hidden sm:block">
                    <input class="bg-surface-container dark:bg-surface-container-high rounded-full py-2 px-4 ltr:pl-10 ltr:pr-4 rtl:pr-10 rtl:pl-4 text-body font-body border-none focus:ring-2 focus:ring-primary dark:focus:ring-primary-light outline-none w-64 text-text-primary dark:text-inverse-on-surface placeholder:text-text-secondary dark:placeholder:text-outline transition-all" placeholder="@Localizer["admin_search"]" type="text">
                    <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-text-secondary dark:text-outline">search</span>
                </div>
                <div class="flex items-center gap-sm">
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light transition-colors hover:bg-surface-container dark:hover:bg-surface-container-high">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <!-- Language Switcher -->
                    <button onclick="toggleLang()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light transition-colors hover:bg-surface-container dark:hover:bg-surface-container-high" title="Switch Language">
                        <span class="material-symbols-outlined">translate</span>
                    </button>
                    <!-- Dark Mode Toggle -->
                    <button onclick="toggleDarkMode()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline dark:hover:text-primary-light transition-colors hover:bg-surface-container dark:hover:bg-surface-container-high" title="Toggle Theme">
                        <span class="material-symbols-outlined" id="dark-mode-icon">dark_mode</span>
                    </button>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary-container overflow-hidden cursor-pointer shadow-small">
                    <img alt="Admin Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=Admin&background=69d2cf&color=005957">
                </div>
            </div>
        </header>

        <!-- Scrollable Canvas -->
        <div class="flex-1 overflow-y-auto p-margin-mobile md:p-xl custom-scrollbar">
            @RenderBody()
            <!-- Spacer for bottom scrolling -->
            <div class="h-xl"></div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>

    <script>
        // Dark Mode Logic
        function toggleDarkMode() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('dakkn_theme', isDark ? 'dark' : 'light');
            updateDarkModeIcon(isDark);
        }

        function updateDarkModeIcon(isDark) {
            const icon = document.getElementById('dark-mode-icon');
            if (icon) {
                icon.textContent = isDark ? 'light_mode' : 'dark_mode';
            }
        }

        // Initialize Theme on Load
        (function() {
            const savedTheme = localStorage.getItem('dakkn_theme');
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const isDark = savedTheme === 'dark' || (!savedTheme && systemPrefersDark);
            updateDarkModeIcon(isDark);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
