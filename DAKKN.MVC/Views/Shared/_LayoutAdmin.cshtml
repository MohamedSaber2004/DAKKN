@inject IStringLocalizer<Messages> Localizer
@using System.Security.Claims
@using DAKKN.Application.Localization
@inject IMediator Mediator
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var fullName = User.FindFirstValue("FullName");
    if (string.IsNullOrWhiteSpace(fullName))
    {
        fullName = User.Identity?.Name ?? "Admin";
    }

    var isDarkMode = false;
    var themeName = "light";
    var primaryColor = "#0E908C";
    var primaryRgb = "14, 144, 140";
    if (User.Identity?.IsAuthenticated == true)
    {
        try 
        {
            var settings = await Mediator.Send(new GetUserSettingsQuery());
            isDarkMode = settings.IsDarkMode;
            themeName = settings.Theme;
            primaryColor = settings.PrimaryColor ?? "#0E908C";

            if (primaryColor.StartsWith("#") && primaryColor.Length == 7)
            {
                var r = Convert.ToInt32(primaryColor.Substring(1, 2), 16);
                var g = Convert.ToInt32(primaryColor.Substring(3, 2), 16);
                var b = Convert.ToInt32(primaryColor.Substring(5, 2), 16);
                primaryRgb = $"{r}, {g}, {b}";
            }
        }
        catch { /* Fallback to default */ }
    }
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" class="@(isDarkMode ? "dark" : "")" data-dakkn-loading="true" style="--primary-color: @primaryColor; --primary-rgb: @primaryRgb;">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta name="robots" content="noindex, nofollow" />
    <title>@ViewData["Title"] - @Localizer["brand"] @Localizer["admin_dashboard"]</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Admin Stylesheet -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    <style>
        body { font-family: 'Inter', 'Cairo', sans-serif; transition: background-color 0.3s ease; }

        /* Collapsible Sidebar Styles */
        .admin-sidebar {
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
        }

        .sidebar-is-collapsed .admin-sidebar {
            width: 80px !important;
        }

        .sidebar-is-collapsed .sidebar-text,
        .sidebar-is-collapsed .admin-brand-info {
            opacity: 0;
            pointer-events: none;
            width: 0;
            overflow: hidden;
            display: none;
        }

        .sidebar-is-collapsed .admin-logo-img {
            height: 40px !important;
        }

        .sidebar-is-collapsed .nav-item {
            justify-content: center;
            padding-left: 0;
            padding-right: 0;
            margin-left: 8px;
            margin-right: 8px;
        }

        .sidebar-is-collapsed .add-product-btn span:last-child {
            display: none;
        }

        .sidebar-is-collapsed .add-product-btn {
            width: 48px;
            height: 48px;
            padding: 0;
            border-radius: 50%;
        }

        .nav-item {
            transition: all 0.2s ease;
        }
    </style>

    <script>
        // High-priority theme application to prevent light-mode flash
        (function() {
            // Server-side values
            const serverTheme = "@themeName";
            const serverIsDark = @(isDarkMode.ToString().ToLower());
            
            // Priority: Use server-side value if available to ensure synchronization
            if (serverTheme) {
                localStorage.setItem('dakkn_theme', serverTheme);
                if (serverIsDark) {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
            } else {
                // Fallback to localStorage for guest or if server fails
                const savedTheme = localStorage.getItem('dakkn_theme');
                if (savedTheme === 'dark') {
                    document.documentElement.classList.add('dark');
                }
            }

            // Sync language with localStorage
            const culture = "@culture";
            localStorage.setItem('dakkn_lang', culture);

            // Initialize Sidebar State
            const isCollapsed = localStorage.getItem('dakkn_sidebar_collapsed') === 'true';
            if (isCollapsed || window.innerWidth < 1280) {
                document.documentElement.classList.add('sidebar-is-collapsed');
            }
        })();

        document.addEventListener('DOMContentLoaded', function() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenInput) {
                window.csrfToken = tokenInput.value;
            }
        });

        // Failsafe: Ensure preloader is hidden even if scripts fail or hang
        setTimeout(() => {
            const preloader = document.getElementById('dakkn-preloader');
            if (preloader) {
                preloader.style.opacity = '0';
                setTimeout(() => {
                    preloader.remove();
                    document.documentElement.removeAttribute('data-dakkn-loading');
                }, 400);
            }
        }, 2000);
    </script>
</head>
<body class="text-text-primary dark:text-white h-screen overflow-hidden flex bg-background dark:bg-[#0F172A] transition-colors duration-300">
    
    <!-- Preloader Overlay -->
    @await Html.PartialAsync("Partials/_Preloader")

    <!-- Sidebar Overlay for Mobile -->
    <div id="sidebar-overlay" class="sidebar-overlay md:hidden" onclick="toggleSidebar()"></div>

    <!-- SideNavBar -->
    <aside id="admin-sidebar" class="hidden md:flex flex-col admin-sidebar ltr:left-0 ltr:border-r rtl:right-0 rtl:border-l h-screen w-64 shadow-medium z-40 relative flex-shrink-0 transition-all duration-300 bg-surface dark:bg-[#1E293B] border-border dark:border-white/5">
        <div class="p-lg border-b border-border dark:border-white/5 flex flex-col items-center justify-center gap-sm group cursor-pointer overflow-hidden">
            <div class="admin-logo-container transition-all duration-300">
                <img src="/images/logo.png" alt="DAKKN Logo" class="h-16 admin-logo-img dark:brightness-125 transition-all duration-300" />
            </div>
            <div class="admin-brand-info text-center transition-all duration-300">
                <h1 class="font-h2 text-h2 font-bold text-primary dark:text-primary-light whitespace-nowrap">@Localizer["brand"]</h1>
                <p class="font-body text-body text-text-secondary dark:text-outline-variant whitespace-nowrap">@Localizer["admin_dashboard"]</p>
            </div>
        </div>
        <nav class="flex-1 overflow-y-auto custom-scrollbar py-md px-sm flex flex-col gap-sm">
            <a asp-controller="Admin" asp-action="Index" class="nav-item flex items-center gap-md @(currentAction == "Index" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-xl px-4 py-3 transition-all duration-200" title="@Localizer["admin_overview"]">
                <span class="material-symbols-outlined @(currentAction == "Index" ? "filled-icon" : "") flex-shrink-0">dashboard</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_overview"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Users" class="nav-item flex items-center gap-md @(currentAction == "Users" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_users"]">
                <span class="material-symbols-outlined @(currentAction == "Users" ? "filled-icon" : "") flex-shrink-0">group</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_users"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Orders" class="nav-item flex items-center gap-md @(currentAction == "Orders" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_orders"]">
                <span class="material-symbols-outlined @(currentAction == "Orders" ? "filled-icon" : "") flex-shrink-0">shopping_cart</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_orders"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Inventory" class="nav-item flex items-center gap-md @(currentAction == "Inventory" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_inventory"]">
                <span class="material-symbols-outlined @(currentAction == "Inventory" ? "filled-icon" : "") flex-shrink-0">inventory_2</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_inventory"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Categories" class="nav-item flex items-center gap-md @(currentAction == "Categories" || currentAction == "CreateCategory" || currentAction == "EditCategory" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_categories"]">
                <span class="material-symbols-outlined @(currentAction == "Categories" || currentAction == "CreateCategory" || currentAction == "EditCategory" ? "filled-icon" : "") flex-shrink-0">category</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_categories"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Support" class="nav-item flex items-center gap-md @(currentAction == "Support" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_support"]">
                <span class="material-symbols-outlined @(currentAction == "Support" ? "filled-icon" : "") flex-shrink-0">support_agent</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_support"]</span>
            </a>
            <a asp-controller="Admin" asp-action="Content" class="nav-item flex items-center gap-md @(currentAction == "Content" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["admin_content_mgmt"]">
                <span class="material-symbols-outlined @(currentAction == "Content" ? "filled-icon" : "") flex-shrink-0">edit_note</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_content_mgmt"]</span>
            </a>
            <a asp-controller="Admin" asp-action="BrandReviews" class="nav-item flex items-center gap-md @(currentAction == "BrandReviews" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer["brand_reviews_admin_title"]">
                <span class="material-symbols-outlined @(currentAction == "BrandReviews" ? "filled-icon" : "") flex-shrink-0">rate_review</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["brand_reviews_admin_title"]</span>
            </a>

            <a asp-controller="Admin" asp-action="Shipping" class="nav-item flex items-center gap-md @(currentAction == "Shipping" || currentAction == "CreateShipping" || currentAction == "EditShipping" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl transition-all duration-200" title="@Localizer[LocalizationKeys.AdminShipping.Title.Key]">
                <span class="material-symbols-outlined @(currentAction == "Shipping" || currentAction == "CreateShipping" || currentAction == "EditShipping" ? "filled-icon" : "") flex-shrink-0">local_shipping</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer[LocalizationKeys.AdminShipping.Title.Key]</span>
            </a>

            <a asp-controller="Admin" asp-action="Settings" class="nav-item flex items-center gap-md @(currentAction == "Settings" ? "active bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") px-4 py-3 rounded-xl mt-auto transition-all duration-200" title="@Localizer["admin_settings"]">
                <span class="material-symbols-outlined @(currentAction == "Settings" ? "filled-icon" : "") flex-shrink-0">settings</span>
                <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["admin_settings"]</span>
            </a>

            <div class="mt-sm">
                <form id="logout-form" asp-controller="Auth" asp-action="Logout" method="post">
                    <input type="hidden" name="refreshToken" id="logout-refresh-token" />
                    <button type="button" onclick="submitLogout()" class="nav-item w-full flex items-center gap-md text-red-500 hover:bg-red-50 dark:hover:bg-red-900/10 px-4 py-3 transition-all duration-200 rounded-xl" title="@Localizer["auth.logout"]">
                        <span class="material-symbols-outlined flex-shrink-0">logout</span>
                        <span class="font-body-lg text-body-lg sidebar-text whitespace-nowrap">@Localizer["auth.logout"]</span>
                    </button>
                </form>
            </div>
        </nav>
        <div class="p-md border-t border-border dark:border-white/5 flex justify-center items-center">
            <a asp-controller="Admin" asp-action="AddProduct" class="add-product-btn w-full bg-primary text-on-primary h-[52px] rounded-[18px] shadow-small font-body-lg text-body-lg flex items-center justify-center gap-sm hover:scale-105 transition-all duration-200 overflow-hidden" title="@Localizer["admin_add_product"]">
                <span class="material-symbols-outlined flex-shrink-0">add</span>
                <span class="sidebar-text whitespace-nowrap">@Localizer["admin_add_product"]</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden bg-background dark:bg-[#0F172A] transition-colors duration-300">
        <!-- TopNavBar -->
        <header class="flex justify-between items-center w-full px-lg py-md z-30 bg-surface/80 dark:bg-[#1E293B]/80 backdrop-blur-md flex-shrink-0 border-b border-border dark:border-white/5 transition-colors duration-300">
            <div class="flex items-center gap-md">
                <!-- Sidebar Toggle -->
                <button onclick="toggleSidebar()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline-variant dark:hover:text-primary-light transition-colors hover:bg-primary/5 dark:hover:bg-white/5">
                    <span class="material-symbols-outlined" id="sidebar-toggle-icon">menu_open</span>
                </button>
                <div class="admin-logo-container md:hidden">
                    <img src="/images/logo.png" alt="DAKKN Logo" class="h-10 admin-logo-img dark:brightness-125" />
                </div>
                <div class="hidden md:block">
                    <h2 class="font-h3 text-h3 font-bold text-text-primary dark:text-white">@ViewData["Title"]</h2>
                </div>
            </div>
            <div class="flex items-center gap-lg">
                <div class="relative hidden sm:block">
                    <input class="bg-surface-container dark:bg-white/5 rounded-full py-2 px-4 ltr:pl-10 ltr:pr-4 rtl:pr-10 rtl:pl-4 text-body font-body border border-transparent dark:border-white/5 focus:ring-2 focus:ring-primary dark:focus:ring-primary-light focus:bg-surface dark:focus:bg-white/10 outline-none w-64 text-text-primary dark:text-white placeholder:text-text-secondary dark:placeholder:text-outline transition-all" placeholder="@Localizer["admin_search"]" type="text">
                    <span class="material-symbols-outlined absolute ltr:left-3 rtl:right-3 top-1/2 -translate-y-1/2 text-text-secondary dark:text-outline">search</span>
                </div>
                <div class="flex items-center gap-sm">
                    @await Html.PartialAsync("Partials/_LanguageToggle")
                    @await Html.PartialAsync("Partials/_ThemeToggle")
                    <button class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline-variant dark:hover:text-primary-light transition-colors hover:bg-primary/5 dark:hover:bg-white/5 relative">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary-container overflow-hidden cursor-pointer shadow-small border border-border dark:border-white/10">
                    <img alt="Admin Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@(fullName)&background=69d2cf&color=005957">
                </div>
            </div>
        </header>

        <!-- Scrollable Canvas -->
        <div id="admin-canvas" class="flex-1 overflow-y-auto p-margin-mobile md:p-xl custom-scrollbar">
            @RenderBody()
            <!-- Spacer for bottom scrolling -->
            <div class="h-xl"></div>
        </div>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/landing.js" asp-append-version="true"></script>

    <script>
        // Sidebar Toggle Logic
        function toggleSidebar() {
            if (window.innerWidth < 768) {
                document.documentElement.classList.toggle('mobile-sidebar-open');
            } else {
                const isCollapsed = document.documentElement.classList.toggle('sidebar-is-collapsed');
                localStorage.setItem('dakkn_sidebar_collapsed', isCollapsed);
                updateSidebarIcon(isCollapsed);
            }
        }

        function updateSidebarIcon(isCollapsed) {
            const icon = document.getElementById('sidebar-toggle-icon');
            if (icon) {
                icon.textContent = isCollapsed ? 'menu' : 'menu_open';
            }
        }

        function submitLogout() {
            const form = document.getElementById('logout-form');
            const tokenInput = document.getElementById('logout-refresh-token');
            const refreshToken = localStorage.getItem('dakkn_refresh_token');
            
            if (tokenInput) tokenInput.value = refreshToken || '';
            form.submit();
        }

        // Initialize State on Load
        (function() {
            const isCollapsed = document.documentElement.classList.contains('sidebar-is-collapsed');
            updateSidebarIcon(isCollapsed);

            window.addEventListener('resize', () => {
                if (window.innerWidth < 1280) {
                    if (!document.documentElement.classList.contains('sidebar-is-collapsed')) {
                        document.documentElement.classList.add('sidebar-is-collapsed');
                        updateSidebarIcon(true);
                    }
                }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
