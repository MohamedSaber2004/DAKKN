@inject IStringLocalizer<Messages> Localizer
@using System.Security.Claims
@inject IMediator Mediator
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var fullName = User.FindFirstValue("FullName") ?? User.Identity?.Name ?? Localizer["layout_user_fallback"].Value;

    var isDarkMode = false;
    var themeName = "light";
    var primaryColor = "#0E908C";
    var primaryRgb = "14, 144, 140";
    var profilePictureUrl = string.Empty;

    // Separate customer cookies — never shared with admin
    var themeCookie = Context.Request.Cookies["dakkn_customer_theme"];
    var langCookie = Context.Request.Cookies["dakkn_customer_lang"];
    if (!string.IsNullOrEmpty(themeCookie))
    {
        isDarkMode = themeCookie == "dark";
        themeName = themeCookie;
    }
    else if (User.Identity?.IsAuthenticated == true)
    {
        try 
        {
            var settings = await Mediator.Send(new GetUserSettingsQuery());
            isDarkMode = settings.IsDarkMode;
            themeName = settings.Theme;
            profilePictureUrl = settings.ProfilePictureUrl ?? string.Empty;
        }
        catch { /* Fallback to default */ }
    }

    string ResolveProfileUrl(string? url, string name)
    {
        if (string.IsNullOrEmpty(url))
            return $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(name)}&background=69d2cf&color=005957";
        if (url.StartsWith("http") || url.StartsWith("/"))
            return url;
        return $"/files/{url}";
    }
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" class="@(isDarkMode ? "dark" : "")" data-dakkn-loading="true" style="--primary-color: @primaryColor; --primary-rgb: @primaryRgb;">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/favicon.png" />
    <link rel="apple-touch-icon" href="~/favicon.png" />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.tailwindcss.com" />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="dns-prefetch" href="https://cdn.tailwindcss.com" />

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Shared Styles -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/customer.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        /* Page fade-in transition */
        main { animation: pageFadeIn 0.25s ease-out; }
        @@keyframes pageFadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

        /* ── Customer Sidebar Transitions ─────────────────────────── */
        .customer-sidebar {
            overflow: hidden;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                        transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Desktop collapsed (≥ 1280px) */
        .sidebar-is-collapsed .customer-sidebar {
            width: 80px !important;
        }
        .sidebar-is-collapsed .sidebar-text,
        .sidebar-is-collapsed .brand-info {
            opacity: 0; pointer-events: none;
            width: 0; overflow: hidden;
            display: none !important;
        }
        .sidebar-is-collapsed .nav-item {
            justify-content: center;
            padding-left: 0 !important; padding-right: 0 !important;
            margin-left: 8px; margin-right: 8px;
        }
        .sidebar-is-collapsed .logout-btn {
            justify-content: center;
            padding-left: 0 !important; padding-right: 0 !important;
        }

        /* Tablet (768–1279px): icon-only by default via CSS, no JS class needed */
        @@media (min-width: 768px) and (max-width: 1279px) {
            .customer-sidebar {
                width: 80px !important;
            }
            .customer-sidebar .sidebar-text { display: none !important; }
            .customer-sidebar .nav-item {
                justify-content: center !important;
                padding-left: 0 !important; padding-right: 0 !important;
                margin-left: 8px !important; margin-right: 8px !important;
            }
            .customer-sidebar .logout-btn {
                justify-content: center !important;
                padding-left: 0 !important; padding-right: 0 !important;
            }
            /* Tablet expanded: user clicked hamburger */
            .tablet-sidebar-expanded .customer-sidebar {
                width: 256px !important;
                position: fixed !important;
                top: 0; bottom: 0; left: 0;
                z-index: 200 !important;
                box-shadow: 4px 0 32px rgba(0,0,0,0.18) !important;
            }
            [dir="rtl"].tablet-sidebar-expanded .customer-sidebar {
                left: auto !important; right: 0;
            }
            .tablet-sidebar-expanded .customer-sidebar .sidebar-text { display: inline !important; }
            .tablet-sidebar-expanded .customer-sidebar .nav-item {
                justify-content: flex-start !important;
                padding-left: 16px !important; padding-right: 16px !important;
                margin-left: 0 !important; margin-right: 0 !important;
            }
            .tablet-sidebar-expanded .customer-sidebar .logout-btn {
                justify-content: flex-start !important;
                padding-left: 16px !important; padding-right: 16px !important;
            }
        }

        .nav-item { transition: all 0.2s ease; }
    </style>

    <script>
        // Customer-specific cookie prefix — never shared with admin
        window.dakknCookiePrefix = 'dakkn_customer_';

        (function() {
            function getCookieValue(name) {
                var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
                return match ? decodeURIComponent(match[2]) : null;
            }
            // Priority: Use customer-specific localStorage, fall back to server value
            var savedTheme = localStorage.getItem('dakkn_customer_theme');
            @if (User.Identity?.IsAuthenticated == true)
            {
                <text>
            var serverIsDark = @(isDarkMode.ToString().ToLower());
            var serverTheme = serverIsDark ? 'dark' : 'light';
            var effectiveTheme = savedTheme || serverTheme || 'light';
            localStorage.setItem('dakkn_customer_theme', effectiveTheme);
            if (effectiveTheme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
                </text>
            }
            else
            {
                <text>
            var effectiveTheme = savedTheme || 'light';
            localStorage.setItem('dakkn_customer_theme', effectiveTheme);
            if (effectiveTheme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
                </text>
            }

            // Customer language — redirect to sync if cookie differs from current
            var customerLang = getCookieValue('dakkn_customer_lang');
            var culture = "@culture";
            localStorage.setItem('dakkn_customer_lang', customerLang || culture);
            if (customerLang && customerLang !== culture) {
                window.location.href = '/Translation/SetLanguage?culture=' + customerLang + '&returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
            }

            // Initialize Sidebar State
            // Only collapse via JS on desktop; tablet uses CSS media query for icon-only mode
            var isCollapsed = localStorage.getItem('dakkn_customer_sidebar_collapsed') === 'true';
            if (isCollapsed && window.innerWidth >= 1280) {
                document.documentElement.classList.add('sidebar-is-collapsed');
            }
        })();

        document.addEventListener('DOMContentLoaded', function() {
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenInput) {
                window.csrfToken = tokenInput.value;
            }
        });

        // Uses cookie-based auth; no JWT silent refresh needed here.

        // Failsafe: Ensure preloader is hidden
        setTimeout(function() {
            var preloader = document.getElementById('dakkn-preloader');
            if (preloader) {
                preloader.style.opacity = '0';
                setTimeout(function() {
                    preloader.remove();
                    document.documentElement.removeAttribute('data-dakkn-loading');
                }, 400);
            }
        }, 1500);
    </script>
</head>
<body class="text-text-primary dark:text-white bg-background dark:bg-[#0F172A] transition-colors duration-300 h-screen overflow-hidden flex font-sans">
    
    <!-- Preloader Overlay -->
    @await Html.PartialAsync("Partials/_Preloader")

    <!-- Sidebar Overlay for Mobile -->
    <div id="sidebar-overlay" class="sidebar-overlay md:hidden" onclick="toggleCustomerSidebar()"></div>

    <!-- Tablet Sidebar Overlay (shown when sidebar expanded on tablet) -->
    <div id="tablet-sidebar-overlay" class="hidden md:block xl:hidden fixed inset-0 z-[199] bg-slate-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300" onclick="collapseCustomerSidebarTablet()"></div>

    <!-- Sidebar -->
    <aside id="customer-sidebar" class="hidden md:flex flex-col customer-sidebar h-screen w-64 shadow-medium z-40 relative flex-shrink-0 transition-all duration-300 bg-surface dark:bg-[#1E293B] border-r border-border dark:border-white/5">
        <div class="p-lg border-b border-border dark:border-white/5 flex flex-col items-center justify-center gap-sm group cursor-pointer overflow-hidden">
        </div>

        <nav class="flex-1 overflow-y-auto no-scrollbar py-md px-sm flex flex-col gap-sm">
            <a asp-controller="Customer" asp-action="Index" class="nav-item flex items-center gap-md @(currentAction == "Index" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["Dashboard_Welcome"]">
                <span class="material-symbols-outlined @(currentAction == "Index" ? "filled-icon" : "")">grid_view</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["Dashboard_Welcome"]</span>
            </a>
            <a asp-controller="Customer" asp-action="Products" class="nav-item flex items-center gap-md @(currentAction == "Products" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["nav_shop"]">
                <span class="material-symbols-outlined @(currentAction == "Products" ? "filled-icon" : "")">shopping_bag</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["nav_shop"]</span>
            </a>
            <a asp-controller="Customer" asp-action="Favorites" class="nav-item flex items-center gap-md @(currentAction == "Favorites" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["nav_favorites"]">
                <span class="material-symbols-outlined @(currentAction == "Favorites" ? "filled-icon" : "")">favorite</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["nav_favorites"]</span>
            </a>
            <a asp-controller="StickerSuggestion" asp-action="Submit" class="nav-item flex items-center gap-md @(currentAction == "Submit" || currentAction == "MySuggestions" || currentAction == "Details" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["nav_sticker_suggestion"]">
                <span class="material-symbols-outlined @(currentAction == "Submit" || currentAction == "MySuggestions" || currentAction == "Details" ? "filled-icon" : "")">lightbulb</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["nav_sticker_suggestion"]</span>
            </a>
            <a asp-controller="Customer" asp-action="Orders" class="nav-item flex items-center gap-md @(currentAction == "Orders" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["admin_orders"]">
                <span class="material-symbols-outlined @(currentAction == "Orders" ? "filled-icon" : "")">receipt_long</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["admin_orders"]</span>
            </a>
            <a asp-controller="Customer" asp-action="Support" class="nav-item flex items-center gap-md @(currentAction == "Support" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["nav_support"]">
                <span class="material-symbols-outlined @(currentAction == "Support" ? "filled-icon" : "")">support_agent</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["nav_support"]</span>
            </a>
            <a asp-controller="Customer" asp-action="BrandReviews" class="nav-item flex items-center gap-md @(currentAction == "BrandReviews" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["brand_reviews_my_reviews"]">
                <span class="material-symbols-outlined @(currentAction == "BrandReviews" ? "filled-icon" : "")">rate_review</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["brand_reviews_my_reviews"]</span>
            </a>
            <a asp-controller="Customer" asp-action="Profile" class="nav-item flex items-center gap-md @(currentAction == "Profile" ? "bg-primary text-on-primary shadow-lg" : "text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5") rounded-2xl px-4 py-3.5 transition-all duration-200 mt-auto" title="@Localizer["nav_profile"]">
                <span class="material-symbols-outlined @(currentAction == "Profile" ? "filled-icon" : "")">person</span>
                <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["nav_profile"]</span>
            </a>
        </nav>

        <div class="p-md border-t border-border dark:border-white/5">
            <form id="logout-form" asp-controller="Auth" asp-action="Logout" method="post">
                <input type="hidden" name="refreshToken" id="logout-refresh-token" />
                <button type="button" onclick="submitLogout()" class="logout-btn w-full flex items-center gap-md text-text-secondary dark:text-outline-variant hover:text-error dark:hover:text-error-light hover:bg-error/5 rounded-2xl px-4 py-3.5 transition-all duration-200" title="@Localizer["f_logout"]">
                    <span class="material-symbols-outlined flex-shrink-0">logout</span>
                    <span class="font-bold sidebar-text whitespace-nowrap">@Localizer["f_logout"]</span>
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden bg-background dark:bg-[#0F172A] transition-colors duration-300">
        <!-- Top Appbar -->
        <header class="flex justify-between items-center w-full px-lg h-20 z-30 bg-surface/80 dark:bg-[#1E293B]/80 backdrop-blur-md flex-shrink-0 border-b border-border dark:border-white/5">
            <div class="flex items-center gap-md">
                <button onclick="toggleCustomerSidebar()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light hover:bg-primary/5 transition-all">
                    <span class="material-symbols-outlined rtl:rotate-180" id="sidebar-toggle-icon">menu_open</span>
                </button>
                <h2 class="hidden md:block font-h3 text-h3 font-bold text-text-primary dark:text-white">@ViewData["Title"]</h2>
            </div>

            <div class="flex items-center gap-lg">
                <form method="get" action="@Url.Action("Products", "Customer")" class="relative hidden sm:block">
                    <input name="searchTerm" class="bg-surface-container dark:bg-white/5 rounded-full py-2.5 px-5 ltr:pl-11 rtl:pr-11 text-sm font-medium border border-transparent dark:border-white/5 focus:ring-2 focus:ring-primary focus:bg-surface dark:focus:bg-white/10 outline-none w-64 lg:w-80 transition-all text-text-primary dark:text-white placeholder:text-text-secondary dark:placeholder:text-outline" placeholder="@Localizer["search_placeholder"]" type="text">
                    <button type="submit" class="absolute ltr:left-4 rtl:right-4 top-1/2 -translate-y-1/2 text-text-secondary dark:text-outline text-lg">
                        <span class="material-symbols-outlined">search</span>
                    </button>
                </form>

                <div class="flex items-center gap-sm">
                    @await Html.PartialAsync("Partials/_LanguageToggle")
                    @await Html.PartialAsync("Partials/_ThemeToggle")
                    <a asp-controller="Customer" asp-action="Cart" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary dark:text-outline-variant hover:text-primary dark:hover:text-primary-light transition-colors relative hover:bg-primary/5 dark:hover:bg-white/5" title="@Localizer["nav_cart"]">
                        <span class="material-symbols-outlined">shopping_cart</span>
                        <span class="absolute -top-0.5 -end-0.5 min-w-[16px] h-4 bg-primary text-on-primary text-[8px] font-bold rounded-full flex items-center justify-center shadow-sm border-2 border-white dark:border-[#0F172A] leading-none px-[2px]" id="cart-badge">0</span>
                    </a>
                    
                    <div class="h-10 w-[1px] bg-border dark:bg-white/10 mx-2 hidden sm:block"></div>

                    <a asp-action="Profile" class="flex items-center gap-md p-1.5 ltr:pr-4 rtl:pl-4 rounded-full bg-surface-container dark:bg-white/5 border border-border dark:border-white/10 hover:border-primary/30 transition-all">
                        <div class="w-8 h-8 rounded-full overflow-hidden shadow-small">
                            <img src="@(ResolveProfileUrl(profilePictureUrl, fullName))" class="w-full h-full object-cover" alt='@Localizer["profile_avatar_alt"]'>
                        </div>
                        <span class="hidden sm:block font-bold text-sm text-text-primary dark:text-white">@(fullName.Split(' ')[0])</span>
                    </a>
                </div>
            </div>
        </header>

        <!-- Scrollable Content -->
        <div class="flex-1 overflow-y-auto custom-scrollbar">
            @RenderBody()

        </div>
    </main>

    <!-- Mobile Bottom Navigation -->
    <nav class="mobile-bottom-nav md:hidden">
        <a asp-controller="Customer" asp-action="Index" class="mob-nav-item @(currentAction == "Index" ? "active" : "")">
            <span class="material-symbols-outlined">grid_view</span>
            <span>@Localizer["admin_overview"]</span>
        </a>
        <a asp-controller="Customer" asp-action="Products" class="mob-nav-item @(currentAction == "Products" ? "active" : "")">
            <span class="material-symbols-outlined">shopping_bag</span>
            <span>@Localizer["nav_shop"]</span>
        </a>
        <a asp-controller="Customer" asp-action="Orders" class="mob-nav-item @(currentAction == "Orders" ? "active" : "")">
            <span class="material-symbols-outlined">receipt_long</span>
            <span>@Localizer["admin_orders"]</span>
        </a>
        <a asp-controller="Customer" asp-action="Profile" class="mob-nav-item @(currentAction == "Profile" ? "active" : "")">
            <span class="material-symbols-outlined">person</span>
            <span>@Localizer["nav_profile"]</span>
        </a>
        <button type="button" onclick="submitLogout()" class="mob-nav-item mob-nav-logout">
            <span class="material-symbols-outlined">logout</span>
            <span>@Localizer["f_logout"]</span>
        </button>
    </nav>

    <!-- Back to Top -->
    <button id="back-to-top" class="opacity-0 pointer-events-none" aria-label="@Localizer["back_to_top"]">
        <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script src="~/js/landing.js" asp-append-version="true" defer></script>
    <script src="~/js/site-animations.js" asp-append-version="true" defer></script>

    <script>
        function toggleCustomerSidebar() {
            if (window.innerWidth < 768) {
                // Mobile: toggle slide-over drawer
                document.documentElement.classList.toggle('mobile-sidebar-open');
            } else if (window.innerWidth < 1280) {
                // Tablet: toggle full expanded overlay sidebar
                const isExpanded = document.documentElement.classList.toggle('tablet-sidebar-expanded');
                updateSidebarIcon(!isExpanded);
                setTabletOverlay(isExpanded);
            } else {
                // Desktop: toggle icon-only collapse
                const isCollapsed = document.documentElement.classList.toggle('sidebar-is-collapsed');
                localStorage.setItem('dakkn_customer_sidebar_collapsed', isCollapsed);
                updateSidebarIcon(isCollapsed);
            }
        }

        function collapseCustomerSidebarTablet() {
            document.documentElement.classList.remove('tablet-sidebar-expanded');
            updateSidebarIcon(true);
            setTabletOverlay(false);
        }

        function setTabletOverlay(show) {
            const overlay = document.getElementById('tablet-sidebar-overlay');
            if (!overlay) return;
            overlay.style.opacity = show ? '1' : '0';
            overlay.style.pointerEvents = show ? 'auto' : 'none';
        }

        function updateSidebarIcon(isCollapsed) {
            const icon = document.getElementById('sidebar-toggle-icon');
            if (icon) icon.textContent = isCollapsed ? 'menu' : 'menu_open';
        }

        function submitLogout() {
            const form = document.getElementById('logout-form');
            const tokenInput = document.getElementById('logout-refresh-token');
            if (tokenInput) tokenInput.value = localStorage.getItem('dakkn_refresh_token') || '';
            form.submit();
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Set correct icon on load
            if (window.innerWidth >= 1280) {
                const savedCollapsed = localStorage.getItem('dakkn_customer_sidebar_collapsed') === 'true';
                if (savedCollapsed) {
                    document.documentElement.classList.add('sidebar-is-collapsed');
                    updateSidebarIcon(true);
                } else {
                    updateSidebarIcon(false);
                }
            } else {
                // Tablet/mobile: icon-only by default
                updateSidebarIcon(true);
            }
        });

        // Hover-based link prefetching for instant page transitions
        let prefetchTimer;
        document.addEventListener('mouseover', function(e) {
            const link = e.target.closest('a[href]');
            if (!link || !link.href.startsWith(location.origin) || link.href === location.href) return;
            clearTimeout(prefetchTimer);
            prefetchTimer = setTimeout(function() {
                const l = document.createElement('link');
                l.rel = 'prefetch';
                l.href = link.href;
                document.head.appendChild(l);
            }, 80);
        }, { passive: true });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
