@inject IStringLocalizer<Messages> Localizer
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @Localizer["brand"]</title>

    @* Fonts & Icons *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    @* Tailwind via CDN *@
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    @* Custom Landing Stylesheet *@
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

    <style>
        :root {
            --color-primary:       #0891B2;
            --color-primary-hover: #0E7490;
            --color-surface:       #FFFFFF;
            --color-bg-base:       #FFFCF8;
            --color-border:        #A8CDD6;
            --color-input-bg:      #EFF9FB;
            --color-text-primary:  #0A2030;
            --color-text-muted:    #3A5A62;
        }
        
        .dark {
            --color-surface:       #1A3840;
            --color-bg-base:       #0A2030;
            --color-border:        #5F8A96;
            --color-input-bg:      #1A3840;
            --color-text-primary:  #E4F3F7;
            --color-text-muted:    #A8CDD6;
        }

        /* Fix for Material Symbols font loading */
        .material-symbols-outlined {
            font-family: 'Material Symbols Outlined';
            font-weight: normal;
            font-style: normal;
            font-size: 24px;
            line-height: 1;
            letter-spacing: normal;
            text-transform: none;
            display: inline-block;
            white-space: nowrap;
            word-wrap: normal;
            direction: ltr;
            -webkit-font-feature-settings: 'liga';
            -webkit-font-smoothing: antialiased;
        }
    </style>
</head>
<body class="bg-[var(--color-bg-base)] text-[var(--color-text-primary)] min-h-screen flex flex-col antialiased overflow-x-hidden selection:bg-primary-container selection:text-on-primary-container">

    <div class="min-h-screen flex items-center justify-center px-4 py-12 relative overflow-hidden">
        @* Background Pattern Overlay *@
        <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--color-primary) 1px, transparent 1px); background-size: 32px 32px;"></div>
        
        @* Ambient decorative elements (reused from landing style) *@
        <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
            <div class="deco-blob animate-blob-1 bg-primary/20 w-[500px] h-[500px] -top-32 -left-32"></div>
            <div class="deco-blob animate-blob-2 bg-tertiary-container/25 w-[400px] h-[400px] -bottom-20 right-0"></div>
            <div class="absolute top-1/4 right-1/4 w-96 h-96 bg-secondary/10 rounded-full blur-[100px] animate-pulse"></div>
        </div>

        <div class="w-full max-w-md bg-[var(--color-surface)]/80 backdrop-blur-xl rounded-3xl p-8 shadow-2xl border border-[var(--color-border)]/20 relative z-10">

            <div class="mb-10 text-center">
                <a asp-action="Index" asp-controller="Home" class="inline-block logo-glow transition-transform hover:scale-105">
                    <img src="~/images/logo.png" alt="DAKKN" class="h-16 md:h-20 mx-auto" />
                </a>
            </div>

            @RenderBody()

        </div>
    </div>

    @* Custom Landing Script for i18n & transitions *@
    <script src="~/js/landing.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
