@using System.Text.Json
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" data-dakkn-loading="true">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @Localizer["brand"]</title>

    @* Fonts & Icons *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&family=Cairo:wght@400;500;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />

    @* Tailwind via CDN *@
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    @* Custom Styles *@
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
        }
        [dir="ltr"] body {
            font-family: 'Inter', sans-serif;
        }

        /* Prevent FOUC and show preloader */
        [data-dakkn-loading] body {
            visibility: hidden !important;
            overflow: hidden !important;
        }

        #dakkn-preloader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            visibility: visible !important;
        }

        .dark #dakkn-preloader {
            background: #0f172a;
        }

        .preloader-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(8, 145, 178, 0.1);
            border-top-color: #0891B2;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>

    <script>
        (function() {
            const savedTheme = localStorage.getItem('dakkn_theme');
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const isDark = savedTheme === 'dark' || (!savedTheme && systemPrefersDark);
            
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();

        // Inject current translations immediately to avoid flickering
        window.currentTranslations = @Html.Raw(JsonSerializer.Serialize(DAKKN.Application.Localization.JsonLocalizationProvider.GetTranslations(culture)));
    </script>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-800 dark:text-slate-100 min-h-screen antialiased selection:bg-primary/10">

    <!-- Preloader Overlay -->
    <div id="dakkn-preloader">
        <div class="preloader-spinner"></div>
    </div>

    <div class="flex flex-col lg:flex-row min-h-screen">
        
        <!-- Left Side: Illustration (Hidden on mobile) -->
        <div class="hidden lg:flex lg:w-[45%] bg-decorative relative overflow-hidden items-center justify-center p-12">
            <!-- Decorative Background Elements -->
            <div class="absolute inset-0 opacity-10 pointer-events-none">
                <div class="absolute top-10 left-10 w-32 h-32 border-4 border-white rounded-full"></div>
                <div class="absolute bottom-20 right-20 w-48 h-48 border-4 border-white rotate-45"></div>
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-white/20 rounded-full"></div>
            </div>

            <div class="relative z-10 flex flex-col items-center text-center">
                <div class="mb-12">
                    <a asp-action="Index" asp-controller="Home" class="logo-glow">
                        <img src="~/images/logo.png" alt="DAKKN" class="h-14 w-auto brightness-0 invert" />
                    </a>
                </div>
                
                <div class="relative max-w-lg">
                    @if (IsSectionDefined("Illustration"))
                    {
                        @RenderSection("Illustration")
                    }
                    else
                    {
                        <!-- Default Illustration if none provided -->
                        <div class="relative w-[400px] h-[400px] flex items-center justify-center">
                            <div class="absolute inset-0 bg-white/10 rounded-3xl blur-3xl animate-pulse"></div>
                            <span class="material-symbols-outlined text-[120px] text-white/50">rocket_launch</span>
                        </div>
                    }
                </div>

                <p class="mt-8 text-white text-2xl font-bold tracking-wide">
                    @Localizer["auth.layout.tagline"]
                </p>
            </div>
        </div>

        <!-- Right Side: Content Area -->
        <div class="w-full lg:w-[55%] flex flex-col relative px-6 md:px-12 lg:px-24 py-8">
            
            <!-- Top Actions: Lang & Brand (Mobile) -->
            <div class="flex justify-between items-center mb-12">
                <div class="lg:hidden">
                    <a asp-action="Index" asp-controller="Home">
                        <img src="~/images/logo.png" alt="DAKKN" class="h-8" />
                    </a>
                </div>
                <div class="flex-grow hidden lg:block"></div>
                
                <div class="flex items-center gap-4">
                    <!-- Language Switcher -->
                    <div class="flex items-center space-x-2 space-x-reverse text-sm font-bold">
                        <a href="javascript:void(0)" onclick="applyLang('ar', true)" 
                           class="@(culture == "ar" ? "text-primary border-b-2 border-primary" : "text-slate-400 hover:text-primary") pb-0.5 transition-all">AR</a>
                        <span class="text-slate-300 dark:text-slate-600">/</span>
                        <a href="javascript:void(0)" onclick="applyLang('en', true)" 
                           class="@(culture == "en" ? "text-primary border-b-2 border-primary" : "text-slate-400 hover:text-primary") pb-0.5 transition-all">EN</a>
                    </div>
                </div>
            </div>

            <!-- Form Body -->
            <div class="flex-grow flex flex-col justify-center max-w-md mx-auto w-full">
                @RenderBody()
            </div>

            <!-- Footer -->
            <div class="mt-auto pt-8 flex justify-center items-center text-xs text-slate-400 dark:text-slate-600">
                <p>© @DateTime.Now.Year Dakkn. @Localizer["footer_copy"]</p>
            </div>
        </div>
    </div>

    <!-- Dark Mode Toggle Floating -->
    <div class="fixed bottom-6 end-6 z-50">
        <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-full shadow-lg transition-all hover:scale-110 active:scale-95">
            @await Html.PartialAsync("Partials/_ThemeToggle")
        </div>
    </div>

    @* Custom Landing Script for i18n & transitions *@
    <script src="~/js/landing.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>