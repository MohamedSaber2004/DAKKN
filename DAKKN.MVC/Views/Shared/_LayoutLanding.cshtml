@using System.Text.Json
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" data-dakkn-loading="true" style="--primary-color: #0E908C; --primary-rgb: 14, 144, 140;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="KExNmmPDKOUIfyg_MDdUD5w0J3o8K2lRmYdiS2M9Pts" />
    <meta name="robots" content="index, follow" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | DAKKN" : Localizer["brand"])</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="192x192" href="~/favicon.png" />
    <link rel="apple-touch-icon" href="~/favicon.png" />
    <meta name="description" content="@(ViewData["Description"] ?? Localizer["seo_description"])" />

    @{
        var ogTitle = ViewData["Title"]?.ToString() ?? Localizer["brand"];
        var ogDesc  = ViewData["Description"]?.ToString() ?? Localizer["seo_description"].ToString();
        var ogImage = ViewData["OgImage"]?.ToString() ?? $"{baseUrl}/images/logo.png";
        var ogUrl   = $"{baseUrl}{Context.Request.Path}";
    }

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content="@ogUrl" />
    <meta property="og:title"       content="@ogTitle" />
    <meta property="og:description" content="@ogDesc" />
    <meta property="og:image"       content="@ogImage" />
    <meta property="og:site_name"   content="DAKKN" />
    <meta property="og:locale"      content="@(culture == "ar" ? "ar_SA" : "en_US")" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="@ogTitle" />
    <meta name="twitter:description" content="@ogDesc" />
    <meta name="twitter:image"       content="@ogImage" />

    <!-- Canonical URL -->
    <link rel="canonical" href="@ogUrl" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@graph": [
            {
                "@@type": "Organization",
                "@@id": "@baseUrl/#organization",
                "name": "DAKKN",
                "url": "@baseUrl",
                "logo": {
                    "@@type": "ImageObject",
                    "url": "@baseUrl/images/logo.png",
                    "width": 512,
                    "height": 341
                },
                "sameAs": [],
                "contactPoint": {
                    "@@type": "ContactPoint",
                    "telephone": "+20-XXX-XXXXXXX",
                    "contactType": "customer service",
                    "availableLanguage": ["Arabic", "English"]
                }
            },
            {
                "@@type": "WebSite",
                "@@id": "@baseUrl/#website",
                "url": "@baseUrl",
                "name": "DAKKN",
                "description": "@ogDesc",
                "publisher": { "@@id": "@baseUrl/#organization" },
                "potentialAction": {
                    "@@type": "SearchAction",
                    "target": {
                        "@@type": "EntryPoint",
                        "urlTemplate": "@baseUrl/shop/products?search={search_term_string}"
                    },
                    "query-input": "required name=search_term_string"
                },
                "inLanguage": "@(culture == "ar" ? "ar-SA" : "en-US")"
            }
        ]
    }
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Custom Landing Stylesheet -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
        }
        [dir="ltr"] body {
            font-family: 'Inter', sans-serif;
        }

        [data-dakkn-loading] body {
            visibility: hidden !important;
            overflow: hidden !important;
        }

        #dakkn-preloader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            visibility: visible !important;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        #dakkn-preloader.fade-out {
            opacity: 0;
            visibility: hidden !important;
        }
        .dark #dakkn-preloader { background: var(--dark-page, #0A2030); }

        .preloader-wrapper {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100px;
            height: 100px;
        }
        .preloader-spinner {
            position: absolute;
            width: 80px;
            height: 80px;
            border: 3px solid rgba(var(--primary-rgb, 14, 144, 140), 0.15);
            border-top-color: var(--primary-color, #0E908C);
            border-radius: 50%;
            animation: spin 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
        }
        .preloader-logo {
            position: absolute;
            height: 36px;
            width: auto;
            animation: pulse-logo 2s ease-in-out infinite;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
        @@keyframes pulse-logo {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; }
        }
    </style>

    <script>
        (function() {
            // Apply theme from localStorage
            const savedTheme = localStorage.getItem('dakkn_theme');
            const isDark = savedTheme === 'dark';
            
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // Sync language with localStorage
            const culture = "@culture";
            localStorage.setItem('dakkn_lang', culture);
        })();

        document.addEventListener('DOMContentLoaded', function() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenInput) {
                window.csrfToken = tokenInput.value;
            }
        });

        // Inject current translations immediately to avoid flickering
        window.currentTranslations = @Html.Raw(JsonSerializer.Serialize(DAKKN.Application.Localization.JsonLocalizationProvider.GetTranslations(culture)));
    </script>

    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body class="bg-background dark:bg-dark-page text-slate-900 dark:text-slate-100 min-h-screen flex flex-col antialiased overflow-x-hidden selection:bg-primary/10">

    <!-- Preloader Overlay -->
    @await Html.PartialAsync("Partials/_Preloader")

    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Back to Top -->
    <button id="back-to-top" class="opacity-0 pointer-events-none" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="@Localizer["back_to_top"]">
        <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <!-- Custom Landing Script for i18n & translations -->
    <script src="~/js/landing.js" asp-append-version="true"></script>
    <script src="~/js/site-animations.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
