@using System.Text.Json
@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var dir = culture == "ar" ? "rtl" : "ltr";
}
<!DOCTYPE html>
<html lang="@culture" dir="@dir" id="html-root" data-dakkn-loading="true" style="--primary-color: #0E908C; --primary-rgb: 14, 144, 140;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    @* <link rel="icon" type="image/png" sizes="32x32" href="~/favicon.png" />
    <link rel="apple-touch-icon" href="~/images/logo.png" /> *@
    <meta name="description" content="@(ViewData["Description"] ?? Localizer["hero_p"])" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans+Arabic:wght@400;500;600;700;800&family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <!-- Tailwind via CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <!-- Tailwind Custom Configuration -->
    <script src="~/js/tailwind.config.js" asp-append-version="true"></script>

    <!-- Custom Landing Stylesheet -->
    <link rel="stylesheet" href="~/css/landing.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'IBM Plex Sans Arabic', 'Cairo', sans-serif;
        }
        [dir="ltr"] body {
            font-family: 'Inter', sans-serif;
        }

        [data-dakkn-loading] body {
            visibility: hidden !important;
            overflow: hidden !important;
        }

        #dakkn-preloader {
            position: fixed;
            inset: 0;
            z-index: 9999;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            visibility: visible !important;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }
        #dakkn-preloader.fade-out {
            opacity: 0;
            visibility: hidden !important;
        }
        .dark #dakkn-preloader { background: var(--dark-page, #0A2030); }

        .preloader-spinner {
            width: 44px;
            height: 44px;
            border: 3px solid rgba(var(--primary-rgb, 14, 144, 140), 0.15);
            border-top-color: var(--primary-color, #0E908C);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        .preloader-logo {
            height: 48px;
            margin-bottom: 1.5rem;
            opacity: 0.8;
        }
        @@keyframes spin { to { transform: rotate(360deg); } }
    </style>

    <script>
        (function() {
            // Apply theme from localStorage
            const savedTheme = localStorage.getItem('dakkn_theme');
            const isDark = savedTheme === 'dark';
            
            if (isDark) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }

            // Sync language with localStorage
            const culture = "@culture";
            localStorage.setItem('dakkn_lang', culture);
        })();

        document.addEventListener('DOMContentLoaded', function() {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (tokenInput) {
                window.csrfToken = tokenInput.value;
            }
        });

        // Inject current translations immediately to avoid flickering
        window.currentTranslations = @Html.Raw(JsonSerializer.Serialize(DAKKN.Application.Localization.JsonLocalizationProvider.GetTranslations(culture)));
    </script>

    @await RenderSectionAsync("HeadStyles", required: false)
</head>
<body class="bg-background dark:bg-dark-page text-slate-900 dark:text-slate-100 min-h-screen flex flex-col antialiased overflow-x-hidden selection:bg-primary/10">

    <!-- Preloader Overlay -->
    <div id="dakkn-preloader">
        <img src="~/images/logo.png" alt="DAKKN" class="preloader-logo" />
        <div class="preloader-spinner"></div>
    </div>

    @RenderBody()

    <!-- Theme Toggle Floating -->
    <div class="fixed bottom-6 end-6 z-50">
        <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-full shadow-lg transition-all hover:scale-110 active:scale-95">
            @await Html.PartialAsync("Partials/_ThemeToggle")
        </div>
    </div>

    <!-- Back to Top -->
    <button id="back-to-top" class="opacity-0 pointer-events-none" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="@Localizer["back_to_top"]">
        <span class="material-symbols-outlined text-lg">arrow_upward</span>
    </button>

    <!-- Custom Landing Script for i18n & translations -->
    <script src="~/js/landing.js" asp-append-version="true"></script>
    <script src="~/js/site-animations.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
