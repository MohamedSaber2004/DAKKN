@model ErrorViewModel
@{
    Layout = "_LayoutLanding";
    ViewData["Title"] = "Error";
}

<section class="min-h-[60vh] flex items-center justify-center px-4 py-24 bg-cyan-50">
    <div class="max-w-2xl w-full text-center space-y-8 glass-panel p-12 rounded-3xl shadow-xl">
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-error/10 text-error mb-4">
            <span class="material-symbols-outlined text-[48px]">warning</span>
        </div>
        
        <h1 class="text-4xl font-black text-on-surface">Error.</h1>
        <h2 class="text-xl font-bold text-error">An error occurred while processing your request.</h2>

        @if (Model.ShowRequestId)
        {
            <div class="bg-surface-container-high p-4 rounded-2xl border border-outline-variant/30 inline-block">
                <p class="text-sm font-semibold text-on-surface-variant">
                    Request ID: <code class="text-primary font-mono bg-primary/5 px-2 py-1 rounded">@Model.RequestId</code>
                </p>
            </div>
        }

        <div class="space-y-4 pt-6 text-sm text-on-surface-variant leading-relaxed">
            <h3 class="font-bold text-on-surface uppercase tracking-widest text-xs">Development Mode</h3>
            <p>
                Swapping to <strong>Development</strong> environment will display more detailed information about the error that occurred.
            </p>
            <p>
                <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
                It can result in displaying sensitive information from exceptions to end users.
            </p>
        </div>

        <div class="pt-8">
            <a asp-controller="Home" asp-action="Index" class="bg-primary hover:bg-primary-container text-on-primary font-bold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-primary/20 inline-block">
                Back to Safety
            </a>
        </div>
    </div>
</section>
