@if (TempData["SuccessMessage"] is string successKey)
{
    <div class="flex items-center gap-3 bg-green-500/15 border border-green-500/40 text-green-600 dark:text-green-400 rounded-2xl px-4 py-3 mb-6 text-sm scroll-animate visible" role="alert">
        <span class="material-symbols-outlined text-xl flex-shrink-0">check_circle</span>
        <span data-i18n="alert.@successKey"></span>
    </div>
}

@{
    var errorKey = TempData["ErrorMessage"] as string;
    var hasModelErrors = !ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any());
}

@if (!string.IsNullOrEmpty(errorKey) || hasModelErrors)
{
    var displayKey = errorKey ?? ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage ?? "generic_error";

    <div class="flex items-center gap-3 bg-red-500/15 border border-red-500/40 text-red-600 dark:text-red-400 rounded-2xl px-4 py-3 mb-6 text-sm scroll-animate visible" role="alert">
        <span class="material-symbols-outlined text-xl flex-shrink-0">report</span>
        <span data-i18n="alert.@displayKey"></span>
    </div>
}
