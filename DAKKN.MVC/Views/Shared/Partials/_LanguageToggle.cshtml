@{
    var culture = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("en") ? "en" : "ar";
    var targetCulture = culture == "en" ? "ar" : "en";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<a asp-controller="Translation" asp-action="SetLanguage" asp-route-culture="@targetCulture" asp-route-returnUrl="@returnUrl" 
   class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline-variant dark:hover:text-primary-light transition-all hover:bg-primary/5 dark:hover:bg-white/5 font-bold text-sm border border-border dark:border-white/5"
                title="@(culture == "en" ? Localizer["lang_toggle_switch_to_ar"] : Localizer["lang_toggle_switch_to_en"])">
    @(culture == "en" ? Localizer["lang_ar"] : Localizer["lang_en"])
</a>
