<button onclick="toggleDarkMode()" class="w-10 h-10 rounded-full flex items-center justify-center text-text-secondary hover:text-primary dark:text-outline-variant dark:hover:text-primary-light transition-all hover:bg-primary/5 dark:hover:bg-white/5 group border border-transparent dark:border-white/5" title="Toggle Theme">
    <span class="material-symbols-outlined dark:hidden transition-transform group-hover:rotate-12">dark_mode</span>
    <span class="material-symbols-outlined hidden dark:block text-yellow-400 transition-transform group-hover:rotate-45">light_mode</span>
</button>
